    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هو يعلم ما سيقع، ويعلم الحدود التي لا يمكن أن يتجاوزوها، والصلاحية في مجال الشفاعة التي تعطى لهم فقط"""@ar ;
    hesin:actions """استحضار علم الله المحيط عند الشك في وعوده أو وعيده."""@ar ;
