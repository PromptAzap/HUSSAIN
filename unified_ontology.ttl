hesin:F5_C130 a hesin:Concept ;
    rdfs:label """الإمام علي عليه السلام"""@ar ;
    hesin:definition """الإمام الأول عند الزيدية، صاحب العلم الواسع الذي أشار إليه النبي، والذي أهملته الأمة بعد وفاة النبي."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """من كان يقول: ((إن هاهنا لعلماً جماً لو أجد له حملة)) من كان يقول: ((علمني رسول الله (صلوات الله عليه وعلى آله) ألف باب من العلم كل باب يفتح ألف باب )) من كان يقول: (( سلوني قبل أن تفقدوني))"""@ar ;
    hesin:actions """الرجوع إلى علم أهل البيت."""@ar ;
    hesin:hasSynonym """علي بن أبي طالب"""@ar ;
