hesin:F7_C282 a hesin:Concept ;
    rdfs:label """مسلسل ابن ماجة (نموذج تثقيف خاطئ)"""@ar ;
    hesin:definition """نقد لمسلسل "ابن ماجة" الذي يقدم صورة مشوهة للعلماء كخدام للسلاطين، مما يرسخ ثقافة التبعية."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """يعرض في تلفزيون صنعاء في هذه الأيام قصة [ابن ماجة]، وقال عن الحديث حول هذا الشخص أنه حديث مهم لأنه شخص عظيم. أليس يقال عنه أنه إمام ،ثم عندما يعظم هذا الشخص في نفسك تجده ـ كما يحكي الفيلم ـ إماماً يجنِّد نفسه لأميرة جميلة!!. هكذا يعرضه الفيلم هذا أن العلماء يجب أن يكونوا خداماً للسلاطين."""@ar ;
    hesin:actions """نقد: يُستخدم لفضح الإعلام الهابط."""@ar ;
    hesin:hasSynonym """العالم خادم للأمير"""@ar ;
    hesin:hasComponent """صورة مشوهة للعالم."""@ar ;
    hesin:hasComponent """خادم للأمير."""@ar ;
    hesin:hasComponent """ثقافة التبعية."""@ar ;
    hesin:belongsToGroup hesin:F7_Group_40 ;
    hesin:belongsToLesson hesin:F7_Lesson .
hesin:F7_C283 a hesin:Concept ;
    rdfs:label """الزيدية (المسؤولية)"""@ar ;
    hesin:definition """دعوة للزيدية (شيعة اليمن) لأن يكونوا أوعى الأمة، وأن يتحملوا مسؤوليتهم في مواجهة اليهود وأمريكا، والتمسك بمذهبهم."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أنا أرى وأعتقد أن الزيدية، أن الزيود ـ وإن كانوا قليلاً ـ إذا اتّحدت كلمتهم، إذا بنوا أنفسهم، إذا وعوا هم، وهم يجب أن يكونوا أوعى الأمة... الزيود هؤلاء الذين بدأ التأثير عليهم وترويضهم ليكونوا كالسُّـنَّية الآخرين... يجب على الزيود أن يكونوا واعين."""@ar ;
    hesin:actions """تحفيز: يُستخدم لتحفيز الزيدية."""@ar ;
    hesin:hasSynonym """يجب أن يكونوا أوعى الأمة"""@ar ;
    hesin:hasComponent """الزيدية أوعى الأمة."""@ar ;
    hesin:hasComponent """التمسك بالمذهب."""@ar ;
    hesin:hasComponent """تحمل المسؤولية."""@ar ;
    hesin:belongsToGroup hesin:F7_Group_40 ;
    hesin:belongsToLesson hesin:F7_Lesson .
