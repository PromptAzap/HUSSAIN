hesin:F5_C001 a hesin:Concept ;
    rdfs:label """أزمة الثقة بالله"""@ar ;
    hesin:definition """حالة يعيشها المسلمون تتمثل في عدم اعتمادهم على وعود الله وتوجيهاته في سلوكهم العملي، مما يؤدي إلى الخوف من غير الله والرغبة في غيره."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """المسلمون يعيشون أزمة ثقة بالله .. لماذا؟ أليس في القرآن الكريم ما يمكن أن يعزز ثقتنا بالله سبحانه وتعالى؟"""@ar ;
    hesin:actions """رصد حالة الضعف في الثقة من خلال تحليل السلوك العملي (الخوف من غير الله، التوجه إلى غير الله في الرغبات والمخاوف)."""@ar ;
    hesin:hasSynonym """ضعف الثقة بالله"""@ar ;
    hesin:hasSynonym """انعدام الثقة بالله"""@ar ;
    hesin:hasComponent """قلة معرفة بالله"""@ar ;
    hesin:hasComponent """ضعف الإيمان العملي"""@ar ;
    hesin:hasComponent """الخوف من غير الله"""@ar ;
    hesin:hasComponent """الرغبة في غير الله"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_1 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C002 a hesin:Concept ;
    rdfs:label """المعرفة بالله"""@ar ;
    hesin:definition """إدراك متكامل لصفات الله (ألوهيته، ملكه، عظمته، رحمته، علمه، قدرته) ينتج عنه تأثير عملي في سلوك العبد (خشية، رجاء، ثقة)."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """نعود إلى معرفة الله سبحانه وتعالى... وأهم مصدر لمعرفة الله سبحانه وتعالى هو القرآن الكريم"""@ar ;
    hesin:actions """استخراج وتصنيف الآيات التي تتحدث عن صفات الله وأفعاله، وربطها بالسلوك العملي المطلوب."""@ar ;
    hesin:hasSynonym """معرفة الله سبحانه وتعالى"""@ar ;
    hesin:hasSynonym """العلم بالله"""@ar ;
    hesin:hasComponent """معرفة ألوهية الله"""@ar ;
    hesin:hasComponent """معرفة ملك الله وملكوته"""@ar ;
    hesin:hasComponent """معرفة أسمائه وصفاته (الرحمن، الرحيم، العزيز، الحكيم...)"""@ar ;
    hesin:hasComponent """معرفة نعمه على العباد"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_1 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C003 a hesin:Concept ;
    rdfs:label """خشوع القلب"""@ar ;
    hesin:definition """حالة انفعالية ووجدانية في القلب تجعله متأثرًا بذكر الله وآياته، متفاعلاً معها، لينًا منقادًا للحق."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """المطلوب من القلوب هو أن تخشع لذكر الله، هو أن تلين، هو أن تصدِّق، أن تثق، أن تمتلئ بالخشية من الله"""@ar ;
    hesin:actions """قياس التفاعل مع النصوص الدينية (الزيادة في الإيمان، التأثر البالغ)."""@ar ;
    hesin:hasSynonym """لين القلب"""@ar ;
    hesin:hasSynonym """رقة القلب"""@ar ;
    hesin:hasSynonym """الخشية"""@ar ;
    hesin:hasComponent """التأثر بذكر الله"""@ar ;
    hesin:hasComponent """التفاعل مع آيات القرآن"""@ar ;
    hesin:hasComponent """الإيمان الصادق"""@ar ;
    hesin:hasComponent """الثقة بالله"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_1 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C004 a hesin:Concept ;
    rdfs:label """قسوة القلب"""@ar ;
    hesin:definition """حالة من الجمود العاطفي والروحي تجعل القلب غير متأثر بالمواعظ وآيات القرآن، مما يؤدي إلى الغفلة والنسيان."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """ستقسو قلوبنا ـ ونعوذ بالله من قسوة القلوب ـ متى ما قست القلوب يصبح هذا القرآن الكريم الذي لو أنزله الله على الجبال من الصخرات الصماء لتصدعت من خشية الله، لكن القلب متى ما قسي يصبح أقسى من الحجارة، فلا يؤثر فيه شيء"""@ar ;
    hesin:actions """رصد الاستجابة للمواعظ عبر الزمن، قياس مدى التأثر بالتكرار."""@ar ;
    hesin:hasSynonym """قسوة القلوب"""@ar ;
    hesin:hasSynonym """صلابة القلب"""@ar ;
    hesin:hasComponent """عدم التأثر بالمواعظ"""@ar ;
    hesin:hasComponent """تكرار الاستماع دون تفاعل"""@ar ;
    hesin:hasComponent """الروتين في العبادات"""@ar ;
    hesin:hasComponent """طوال الأمد (مرور الزمن دون تجديد)"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_1 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C005 a hesin:Concept ;
    rdfs:label """الإيمان العملي"""@ar ;
    hesin:definition """إيمان يتجاوز مجرد التصديق النظري إلى سلوك عملي يظهر في: الخوف من الله، الرجاء فيه، التوكل عليه، واتباع هديه."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """الإيمان بالله الذي يجعلك تخاف غير الله أكثر مما تخاف من الله ليس إيمانا بالله، الإنسان المؤمن بالله هو من يكون خوفه من الله أعظم من خوفه من غيره، هو من يكون رجاؤه في الله أعظم من رجائه في غيره"""@ar ;
    hesin:actions """تحليل السلوك العملي للفرد (ممن يخاف، بمن يرجو) لتحديد درجة الإيمان."""@ar ;
    hesin:hasSynonym """الإيمان الصادق"""@ar ;
    hesin:hasSynonym """الإيمان الواعي"""@ar ;
    hesin:hasSynonym """التصديق العملي"""@ar ;
    hesin:hasComponent """الخوف من الله أعظم من خوف غيره"""@ar ;
    hesin:hasComponent """الرجاء في الله أعظم من رجاء غيره"""@ar ;
    hesin:hasComponent """العمل الصالح"""@ar ;
    hesin:hasComponent """التوكل على الله"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_1 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C006 a hesin:Concept ;
    rdfs:label """ألوهية الله"""@ar ;
    hesin:definition """الإقرار بأن الله وحده المستحق للعبادة، وهو وحده الذي يُرجى ويُخاف، وهو وحده الذي يُتولى ويُلتجأ إليه."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """متى ما آمنا بأنه وحده إلهنا ـ إيمانا واعيا وليس فقط مجرد كلام ـ سنتقيه، سنسلِّم أنفسنا له، سنثق به، سنتوكل عليه، نلتجئ إليه، نرغب فيه، نخاف منه"""@ar ;
    hesin:actions """اختبار السلوك العملي: هل الخوف والرجاء منصبان على الله وحده؟"""@ar ;
    hesin:hasSynonym """لا إله إلا الله"""@ar ;
    hesin:hasSynonym """وحدانية الله"""@ar ;
    hesin:hasSynonym """توحيد الألوهية"""@ar ;
    hesin:hasComponent """لا معبود بحق إلا الله"""@ar ;
    hesin:hasComponent """لا مرجوّ حقيقة إلا الله"""@ar ;
    hesin:hasComponent """لا مخوف حقيقة إلا الله"""@ar ;
    hesin:hasComponent """لا متولى حقيقة إلا الله"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_2 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C007 a hesin:Concept ;
    rdfs:label """عبادة الهوى"""@ar ;
    hesin:definition """جعل الهوى الشخصي أو الخوف من المخلوق أو حب الدنيا هو المحرك الأساسي للسلوك بدلاً من شرع الله."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """قد يبرز الهوى إلها لك، ويبرز الخوف إلها لك، ويبرز الطواغيت آلهة لك، وتبرز الدنيا إلها لك، وتبرز المطامع كلها آلهة لك"""@ar ;
    hesin:actions """تحليل دوافع السلوك: هل الدافع هو هوى النفس أم شرع الله؟"""@ar ;
    hesin:hasSynonym """اتخاذ الهوى إلهًا"""@ar ;
    hesin:hasComponent """طاعة النفس في معصية الله"""@ar ;
    hesin:hasComponent """الخوف من المخلوقين أكثر من الله"""@ar ;
    hesin:hasComponent """الرغبة في الدنيا وتقديمها على الآخرة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_2 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C008 a hesin:Concept ;
    rdfs:label """التوكل على الله"""@ar ;
    hesin:definition """الاعتماد على الله في جلب المنافع ودفع المضار، مع الأخذ بالأسباب المشروعة، وعدم الخوف من غيره."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """يتوكلون على الله من منطلق إيمانهم القوي بالله، وثقتهم القوية بالله"""@ar ;
    hesin:actions """قياس مدى اعتماد الفرد على الله في مواجهة التحديات."""@ar ;
    hesin:hasSynonym """الاعتماد على الله"""@ar ;
    hesin:hasSynonym """الثقة بالله"""@ar ;
    hesin:hasComponent """الاعتماد على الله في الرزق"""@ar ;
    hesin:hasComponent """الاعتماد على الله في النصر"""@ar ;
    hesin:hasComponent """عدم الخوف من المخلوقين"""@ar ;
    hesin:hasComponent """عدم الرجاء في المخلوقين"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_2 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C009 a hesin:Concept ;
    rdfs:label """التأمل في القرآن"""@ar ;
    hesin:definition """عملية التفكر والتدبر في آيات القرآن لفهم معانيها، واستخلاص الدروس والعبر، والوصول إلى معرفة الله."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """إذا تأمل الإنسان في واقع الناس... يجب أن نتأمل كثيراً في كتاب الله"""@ar ;
    hesin:actions """استخراج الآيات ذات الموضوع الواحد وجمعها لتكوين صورة متكاملة."""@ar ;
    hesin:hasSynonym """التدبر"""@ar ;
    hesin:hasSynonym """التفكر في آيات الله"""@ar ;
    hesin:hasComponent """جمع الآيات المتعلقة بموضوع واحد"""@ar ;
    hesin:hasComponent """تصور المعاني (مثل تصور الجنة والنار)"""@ar ;
    hesin:hasComponent """ربط الآيات بالواقع"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_3 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C010 a hesin:Concept ;
    rdfs:label """التذكير بالآخرة"""@ar ;
    hesin:definition """استحضار يوم القيامة وأهواله في النفس، مما يدفع إلى العمل الصالح والابتعاد عن المعاصي."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """تذكر القيامة له أثره العظيم جداً، جداً في المجالين: في مجال أن تنظر من الأعمال إلى ما فيه نجاتك يوم القيامة فتنطلق فيه، وتبتعد عن الأعمال أو عن التقصير الذي فيه هلاكك يوم القيامة"""@ar ;
    hesin:actions """جمع الآيات التي تصف القيامة والنار والجنة، وجعلها محورًا للتذكير."""@ar ;
    hesin:hasSynonym """تذكر يوم القيامة"""@ar ;
    hesin:hasSynonym """الخوف من الآخرة"""@ar ;
    hesin:hasComponent """تصور أهوال القيامة"""@ar ;
    hesin:hasComponent """تصور الحساب"""@ar ;
    hesin:hasComponent """تصور الجنة والنار"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_3 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C011 a hesin:Concept ;
    rdfs:label """التفاعل مع الآيات (الزيادة في الإيمان)"""@ar ;
    hesin:definition """الاستجابة الإيجابية لآيات القرآن بحيث تترك أثرًا في القلب، وتزيد من قوة الإيمان، وتدفع إلى العمل."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """نفرض على أنفسنا أن نزداد إيمانا من كل آية نسمعها من آيات الله تتلى علينا، من كل تذكير نسمعه بالله لنا، أن نزداد إيمانا"""@ar ;
    hesin:actions """رصد التغير في السلوك والإيمان بعد الاستماع للآيات."""@ar ;
    hesin:hasSynonym """ازدياد الإيمان"""@ar ;
    hesin:hasSynonym """التفاعل مع الذكر"""@ar ;
    hesin:hasComponent """الوجل عند ذكر الله"""@ar ;
    hesin:hasComponent """زيادة الإيمان عند تلاوة الآيات"""@ar ;
    hesin:hasComponent """العمل بمقتضى الآيات"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_3 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C012 a hesin:Concept ;
    rdfs:label """رحمة الله"""@ar ;
    hesin:definition """صفة إلهية تعني أن كل تشريعات الله وأوامره ونواهيه إنما تصدر عن رحمة بعباده، وهي أشد من رحمة الإنسان بنفسه."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """إذا كان هو رحمن إذاً فهو عندما ينزل القرآن الكريم ويهدينا بالقرآن الكريم فهو من منطلق أنه رحيم بنا، إذاً فكل ما في القرآن الكريم من توجيهات وإرشادات وهداية هي كلها رحمة بنا"""@ar ;
    hesin:actions """عند مواجهة أمر شاق، يُستحضر أن الله أرحم من النفس."""@ar ;
    hesin:hasSynonym """الرحمن"""@ar ;
    hesin:hasSynonym """الرحيم"""@ar ;
    hesin:hasComponent """التشريع رحمة"""@ar ;
    hesin:hasComponent """الهداية رحمة"""@ar ;
    hesin:hasComponent """الله أرحم بالإنسان من نفسه"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_4 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C013 a hesin:Concept ;
    rdfs:label """ملك الله"""@ar ;
    hesin:definition """ملكية الله التامة والنافذة للسماوات والأرض وما بينهما، ويوم القيامة لا يشاركه فيها أحد."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """إذا كان هو من له الملك وحده في يوم القيامة فهو وحده من يجب أن نلتجئ إليه، ونرغب إليه، ونرغب فيه، ونخاف منه"""@ar ;
    hesin:actions """استحضار ملكية الله عند الخوف من أي سلطة بشرية."""@ar ;
    hesin:hasSynonym """مالك السماوات والأرض"""@ar ;
    hesin:hasSynonym """مالك يوم الدين"""@ar ;
    hesin:hasComponent """ملكية السماوات والأرض"""@ar ;
    hesin:hasComponent """ملكية يوم القيامة (لا شفاعة إلا بإذنه)"""@ar ;
    hesin:hasComponent """لا مشاركة لأحد في ملكه"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_4 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C014 a hesin:Concept ;
    rdfs:label """عزة الله"""@ar ;
    hesin:definition """صفة إلهية تعني أن الله لا يُغلب، ولا يُقهر، وأن من يتولاه يعز به ولا يذل."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
