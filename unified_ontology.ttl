hesin:F4_C001 a hesin:Concept ;
    rdfs:label """القرآن كتاب هداية"""@ar ;
    hesin:definition """القرآن هو المصدر الأساسي والكامل للهداية في كل مجالات الحياة، ليس مجرد كتاب معلومات أو أحكام فقهية، بل هو دليل شامل لحركة الإنسان في كل شؤونه."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لاحظ كلمة هدى، هداية، النظرة هذه إلى القرآن الكريم غابت، وهي تترتب عليها فوارق كثيرة جداً، أنظر إليه ككتاب هداية، واعرف الهداية ما هي، كتاب هداية لمجالات واسعة جداً، لكل شيء."""@ar ;
    hesin:actions """عند تحليل أي نص قرآني، يجب اعتباره في المقام الأول كتاب هداية، واستخلاص البعد التوجيهي والتربوي أولاً."""@ar ;
    hesin:hasSynonym """كتاب هداية"""@ar ;
    hesin:hasSynonym """نور"""@ar ;
    hesin:hasSynonym """شفاء"""@ar ;
    hesin:hasSynonym """تبيان"""@ar ;
    hesin:hasSynonym """فرقان"""@ar ;
    hesin:hasSynonym """موعظة"""@ar ;
    hesin:hasComponent """نور يضيء ظلمات الحياة"""@ar ;
    hesin:hasComponent """شفاء للأمراض النفسية والروحية"""@ar ;
    hesin:hasComponent """تبيان لكل شيء يحتاجه الإنسان في مسيرته"""@ar ;
    hesin:hasComponent """فرقان يفصل بين الحق والباطل"""@ar ;
    hesin:hasComponent """موعظة للمتقين"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_1 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C002 a hesin:Concept ;
    rdfs:label """القرآن نور"""@ar ;
    hesin:definition """القرآن هو مصدر الإضاءة في ظلمات الحياة المادية والمعنوية، وهو أرقى أنواع النور الذي يهدي إلى الحق ويميزه عن الباطل."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """يتكرر كثيراً الحديث عن الهدى، عن هدى الله بأنه نور؛ لأن هنا تتصور معه بأنه تكون الحياة ظلمات كلها، تكون الحياة كلها ظلمات. فالإنسان بحاجة إلى هذا النور."""@ar ;
    hesin:actions """عند تحليل آيات الهداية، يجب فهمها في إطار النور الذي يزيل الظلمات، والبحث عن تطبيقات هذا النور في كل مجال."""@ar ;
    hesin:hasSynonym """نور الله"""@ar ;
    hesin:hasSynonym """نور السموات والأرض"""@ar ;
    hesin:hasSynonym """نور الهداية"""@ar ;
    hesin:hasComponent """النور في المشكاة (الكوة) - اجتماع النور في مكان واحد"""@ar ;
    hesin:hasComponent """المصباح في الزجاجة النقية - صفاء ونقاء الهدى"""@ar ;
    hesin:hasComponent """الزيت المبارك - استمرارية وعمق الهدى"""@ar ;
    hesin:hasComponent """نور على نور - تزايد الهدى وتراكمه"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_1 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C003 a hesin:Concept ;
    rdfs:label """القرآن تبيان لكل شيء"""@ar ;
    hesin:definition """القرآن يقدم بيانًا شاملاً وكاملاً لكل ما يحتاجه الإنسان في حياته، ليس بالقائمة التفصيلية المحدودة، بل بمنهج يهدي إلى كل شيء، بما في ذلك المجالات التي لا تظهر في النظرة القاصرة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """وَنَزَّلْنَا عَلَيْكَ الْكِتَابَ تِبْيَاناً لِّكُلِّ شَيْءٍ... فجعله سبحانه تبياناً... تبياناً: بيان واضح، القرآن استخدم أرقى، وأخر ما يمكن تملكه من تعبير عن الوضوح، النور، الهدى، الشفاء."""@ar ;
    hesin:actions """عند مواجهة أي قضية جديدة، يجب البحث عن هدايتها في القرآن من خلال منهجه لا من خلال النص الحرفي فقط."""@ar ;
    hesin:hasSynonym """تفصيل لكل شيء"""@ar ;
    hesin:hasSynonym """بيان للناس"""@ar ;
    hesin:hasComponent """تبيان لمعرفة الله"""@ar ;
    hesin:hasComponent """تبيان لعلاقة الإنسان بربه"""@ar ;
    hesin:hasComponent """تبيان لعلاقة الإنسان بالآخرين"""@ar ;
    hesin:hasComponent """تبيان لمواجهة الأعداء"""@ar ;
    hesin:hasComponent """تبيان للأمور المستجدة في الحياة"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_1 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C004 a hesin:Concept ;
    rdfs:label """القرآن فرقان وفصل"""@ar ;
    hesin:definition """القرآن هو المعيار الذي يفصل بين الحق والباطل، والهدى والضلال، والصواب والخطأ، وهو قول جاد وحكم رشيد ليس فيه هزل أو لعب."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """الفرقان فهو التفصيل من الله فيه لرشده... فرقان يفصل ما بين الحق والباطل، يبين الحق من الباطل، الخطأ من الصواب، الهدى من الضلال."""@ar ;
    hesin:actions """يجب استخدام القرآن كمعيار للحكم على الأفكار والمواقف، وليس كمصدر معلومات فقط."""@ar ;
    hesin:hasSynonym """قول فصل"""@ar ;
    hesin:hasSynonym """فرقان"""@ar ;
    hesin:hasSynonym """فصل بين الحق والباطل"""@ar ;
    hesin:hasComponent """حَكَم جد رشيد"""@ar ;
    hesin:hasComponent """ليس بالهزل أو اللعب"""@ar ;
    hesin:hasComponent """يفصل في كل قضية"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_1 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C005 a hesin:Concept ;
    rdfs:label """القرآن تأثير خارق"""@ar ;
    hesin:definition """للقُرآن قدرة تأثيرية هائلة تفوق ما يتصوره البشر، ولو نزل على أقسى المخلوقات (الجبل) لرأيته خاشعًا متصدعًا من خشية الله، فإذا لم يؤثر في الإنسان فالخلل في الإنسان لا في القرآن."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هنا يتحدث عن شيء له أثر خارق... يقول لك: هذا هو على أرقى ما يمكن من التأثير، وكله يقول لك في الأخير: ليس هناك تقصير من هذا الجانب على الإطلاق، الخلل عندك."""@ar ;
    hesin:actions """عند ملاحظة عدم تأثر النفس أو الآخرين بالقرآن، يجب البحث عن الخلل في طريقة التلقي أو التقديم، وليس في القرآن نفسه."""@ar ;
    hesin:hasSynonym """لو أنزل على جبل لتصدع"""@ar ;
    hesin:hasSynonym """تسيير الجبال"""@ar ;
    hesin:hasSynonym """تقطيع الأرض"""@ar ;
    hesin:hasSynonym """تكليم الموتى"""@ar ;
    hesin:hasComponent """تأثير يفوق صلابة الجبل"""@ar ;
    hesin:hasComponent """خشية وخضوع"""@ar ;
    hesin:hasComponent """تصدع وانكسار للهيبة"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_1 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C006 a hesin:Concept ;
    rdfs:label """الهداية العامة والإرشاد"""@ar ;
    hesin:definition """هي الهداية التي تشمل جميع الناس من خلال إرسال الرسل وإنزال الكتب، وهي تمهيد للإنسان ليتخذ قراره باتباع الهدى أو تركه."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """مسألة الهداية، تأتي الهداية العامة هذه التي تعني: الإرشاد، إرسال الرسل، إنزال الكتب. هذه التي يسمونها: الهداية العامة، الإرشاد."""@ar ;
    hesin:actions """عند الحديث عن الهداية، يجب التمييز بين المستوى العام (البيان والإرشاد) والمستوى الخاص (التوفيق والرعاية)."""@ar ;
    hesin:hasSynonym """الإرشاد"""@ar ;
    hesin:hasSynonym """إرسال الرسل"""@ar ;
    hesin:hasSynonym """إنزال الكتب"""@ar ;
    hesin:hasComponent """إرسال الرسل"""@ar ;
    hesin:hasComponent """إنزال الكتب"""@ar ;
    hesin:hasComponent """البيان والإرشاد العام"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_2 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C007 a hesin:Concept ;
    rdfs:label """الهداية الخاصة والرعاية"""@ar ;
    hesin:definition """هي الهداية الخاصة التي يحصل عليها الإنسان بعد استجابته للهداية العامة، وتتضمن رعاية الله له وتثبيته على الهدى وحفظه من الزيغ."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لكن يهدي لنوره قضية ثانية، مطلوب أن الإنسان نفسه هو يتسبب لهذه من جهة الله، يهتم، يصغي، يتفهم، يرجو الله، يدعو الله أن يهديه... تكون دائماً ترجو الهدى من الله، وتتخوف على الهدى الذي عندك أن لا تكون عرضة لأن يفلت من بين يديك، تطلب من الله بأنه يرعاك، يحفظك."""@ar ;
    hesin:actions """في بناء النظام، يجب مراعاة أن الهداية عملية تفاعلية بين الجهد البشري والرعاية الإلهية."""@ar ;
    hesin:hasSynonym """يهدي لنوره"""@ar ;
    hesin:hasSynonym """الهداية لمن يشاء"""@ar ;
    hesin:hasSynonym """رعاية الله"""@ar ;
    hesin:hasComponent """الاستجابة للهداية العامة"""@ar ;
    hesin:hasComponent """الاهتمام والإصغاء"""@ar ;
    hesin:hasComponent """الدعاء والتضرع إلى الله"""@ar ;
    hesin:hasComponent """طلب الثبات والرعاية"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_2 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C008 a hesin:Concept ;
    rdfs:label """الخشية من الله"""@ar ;
    hesin:definition """هي الحالة النفسية التي تنتج عن التأثر العميق بالقرآن، وتتجلى في الخضوع والتذلل لله، والحذر من مخالفة أمره، وهي الدافع الأساسي للتقوى والعمل الصالح."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """القرآن هذا هو بالشكل الذي لو أنزل على جبل لرأيته خاشعاً متصدعاً من خشية الله... فعندما نجد أنفسنا لم يحصل عندنا شيء من خشية الله فلا يوجد خلل في القرآن الكريم."""@ar ;
    hesin:actions """عند قياس مدى التأثر بالقرآن، يجب النظر إلى الخشية كأحد المؤشرات الرئيسية."""@ar ;
    hesin:hasSynonym """خشية الله"""@ar ;
    hesin:hasSynonym """خوف من الله"""@ar ;
    hesin:hasSynonym """تقوى"""@ar ;
    hesin:hasComponent """خضوع وتذلل"""@ar ;
    hesin:hasComponent """انكسار هيبة أمام عظمة الله"""@ar ;
    hesin:hasComponent """حذر من مخالفة الأوامر"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_2 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C009 a hesin:Concept ;
    rdfs:label """القرآن كمقياس"""@ar ;
    hesin:definition """القرآن هو المعيار الوحيد لمعرفة الحق من الباطل، وقياس مدى صحة الأفكار والمواقف، واختبار الانسجام مع الهدى الإلهي."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """القرآن هو المقياس. إذا رأيت نفسك أقرب ما تكون إلى القرآن الكريم، في حركته، في حيويته، وليس إلى القرآن الكريم برؤيتك التي تغطي على أكثره، وتحكِّم عليه أشياء أخرى... ترجع إلى القرآن الكريم على ما هو عليه، في حيويته، في حركته، في مقاصده تجد حركتك، وتوجهك منسجم معه، إذاً فلست من هذا النوع."""@ar ;
    hesin:actions """في أي عملية تحليل، يجب الرجوع إلى القرآن كمعيار للحكم على النتائج والاستنتاجات."""@ar ;
    hesin:hasSynonym """المقياس القرآني"""@ar ;
    hesin:hasSynonym """معيار الحق"""@ar ;
    hesin:hasSynonym """محك الإيمان"""@ar ;
    hesin:hasComponent """معيار للحق والباطل"""@ar ;
    hesin:hasComponent """مقياس للهدى والضلال"""@ar ;
    hesin:hasComponent """محك لصحة الحركة والتوجه"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_2 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C010 a hesin:Concept ;
    rdfs:label """الاستجابة للهدى"""@ar ;
    hesin:definition """هي العملية التي يقوم بها الإنسان تجاه الهدى الإلهي، وتتضمن: فتح الصدر، الإصغاء باهتمام، التفهم، والتطبيق الفوري دون تسويف."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لازم أن يكون عنده اهتمام بأن يفتح صدره، يصغي، يستمع باهتمام حتى يستفيد... كلما تسمع تهتم. لا تقل ما قد هو الآن."""@ar ;
    hesin:actions """في النظام الآلي، يجب رصد مدى الاستجابة للهدى كمؤشر رئيسي لاتجاه المسار."""@ar ;
    hesin:hasSynonym """قبول الهدى"""@ar ;
    hesin:hasSynonym """فهم الهدى"""@ar ;
    hesin:hasSynonym """الاهتمام بالهدى"""@ar ;
    hesin:hasComponent """فتح الصدر والاستعداد"""@ar ;
    hesin:hasComponent """الإصغاء والإنصات"""@ar ;
    hesin:hasComponent """التفهم والتدبر"""@ar ;
    hesin:hasComponent """التطبيق الفوري"""@ar ;
    hesin:hasComponent """عدم التسويف والتأجيل"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_3 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C011 a hesin:Concept ;
    rdfs:label """النفوس الميتة"""@ar ;
    hesin:definition """هي حالة الإنسان الذي لا يتأثر بالباطل ولا ينزعج منه، فلا يكون للهدى قيمة عنده، وهو ميت الروح والحس الأخلاقي."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هذه هي النفوس الميتة. الذي لا ينزعج للباطل، لا يؤلمه الباطل، لا يعتبر الباطل فضيعاً، والضلال فضيعاً، قبيحاً، سيئاً، فتأكد أنه لن يكون للهدى قيمة عنده، ولا للحق قيمة."""@ar ;
    hesin:actions """عند رصد ردود الفعل تجاه الباطل، يمكن استخدامها كمؤشر على حيوية الروح."""@ar ;
    hesin:hasSynonym """لا يستحي من الباطل"""@ar ;
    hesin:hasSynonym """لا ينزعج من الضلال"""@ar ;
    hesin:hasComponent """عدم الانزعاج من الباطل"""@ar ;
    hesin:hasComponent """عدم تألم من الضلال"""@ar ;
    hesin:hasComponent """عدم اعتبار الباطل قبيحًا"""@ar ;
    hesin:hasComponent """انعدام قيمة الحق والهدى"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_3 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C012 a hesin:Concept ;
    rdfs:label """الإنزعاج من الباطل"""@ar ;
    hesin:definition """هي الحساسية النفسية تجاه الباطل والضلال، وهي مقياس لمدى حياة القلب واستعداده لقبول الحق."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """قيمة الحق عندك هو بمقدار ماذا؟ كراهيتك للباطل، انزعاجك من الباطل، قبح الباطل في نفسك."""@ar ;
    hesin:actions """يمكن استخدام هذا المفهوم لقياس مدى التأثر بالقيم القرآنية."""@ar ;
    hesin:hasSynonym """كراهية الباطل"""@ar ;
    hesin:hasSynonym """قبح الباطل في النفس"""@ar ;
    hesin:hasComponent """كراهية الباطل"""@ar ;
    hesin:hasComponent """انزعاج عند رؤية الضلال"""@ar ;
    hesin:hasComponent """شعور بقبح الباطل"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_3 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C013 a hesin:Concept ;
    rdfs:label """الاهتمام بالهدى"""@ar ;
    hesin:definition """هو إعطاء الهدى أهميته الحقيقية، واعتباره حاجة ماسة كالحاجة إلى النور في الظلام، والتعامل معه بجدية وحذر."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """يجب أن يكون الناس حريصين؛ لأنه يتحدث يقول: هناك ظلام ونور، الحياة ظلام، الضلال ظلام، أنتم بحاجة إلى نور."""@ar ;
    hesin:actions """في التصميم التعليمي، يجب بناء أنظمة تزيد من مستوى الاهتمام بالهدى."""@ar ;
    hesin:hasSynonym """إعطاء قيمة للهدى"""@ar ;
    hesin:hasSynonym """الجدية في التلقي"""@ar ;
    hesin:hasComponent """إدراك حاجة النفس إلى الهدى"""@ar ;
    hesin:hasComponent """الجدية في التلقي"""@ar ;
    hesin:hasComponent """الحذر من الضلال"""@ar ;
    hesin:hasComponent """عدم التهاون"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_3 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C014 a hesin:Concept ;
    rdfs:label """الظلمات والضلال"""@ar ;
    hesin:definition """هي حالة الإنسان الذي لا يهتدي بالقرآن، فيعيش في حيرة وتخبط، لا يدري أين يذهب، ويتعثر في حياته."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """وهكذا يكون شكل الناس في ظلمات الضلال مثل شكلك وأنت في طريق متجه لأي مكان آخر في ظلمات الليل، في ظلام شديد."""@ar ;
    hesin:actions """يجب رصد مؤشرات الضلال والظلمات كعلامات تحذيرية."""@ar ;
    hesin:hasSynonym """ظلمات الضلال"""@ar ;
    hesin:hasSynonym """الحياة ظلمات"""@ar ;
    hesin:hasSynonym """الضلال"""@ar ;
    hesin:hasComponent """حيرة وتردد"""@ar ;
    hesin:hasComponent """تخبط في الواقع"""@ar ;
    hesin:hasComponent """عدم القدرة على التمييز"""@ar ;
    hesin:hasComponent """عواقب وخيمة"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_3 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C015 a hesin:Concept ;
    rdfs:label """المتقون"""@ar ;
    hesin:definition """هم الذين يتعاملون مع القرآن بجدية، ويسعون للعمل به في كل مجالات الحياة، وهم أصحاب حركة دائمة ونفوس يقظة، وليسوا فقط من يؤدون العبادات الظاهرية."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """المتقون هم من سيهتدون بهذا القرآن ويتعاملون مع هداه بكل جدية... المتقون عمليون، عمليون دائماً، متحركون بحركة الحياة، وفي مجالات الحياة كلها."""@ar ;
    hesin:actions """عند تعريف المتقين في النظام، يجب أن يشمل الجانب العملي والحركي وليس فقط الجانب العبادي."""@ar ;
    hesin:hasSynonym """أولو الألباب"""@ar ;
    hesin:hasSynonym """المؤمنون العاملون"""@ar ;
    hesin:hasComponent """جدية في التعامل مع الهدى"""@ar ;
    hesin:hasComponent """حركة دائمة في الحياة"""@ar ;
    hesin:hasComponent """نفوس يقظة"""@ar ;
    hesin:hasComponent """عمل في مجالات الحياة كلها"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_3 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C016 a hesin:Concept ;
    rdfs:label """آيات الله الكونية"""@ar ;
    hesin:definition """هي الأحداث والظواهر في الكون وفي النفس البشرية التي تدل على الحق، وهي مدرسة تربوية واسعة، ولكن لا يمكن فهمها والاهتداء بها إلا من خلال القرآن."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """القرآن الكريم هو يهدي بشكل واسع إلى ما يعتبر امتداداً لهدايته، إلى الآيات الكونية. هو يهدي إلى الآيات الكونية... فهي مدرسة، مدرسة واسعة، لكن مفتاحها من خلال القرآن، من خلال القرآن."""@ar ;
    hesin:actions """يجب ربط الأحداث المعاصرة بالرؤية القرآنية لفهمها والاستفادة منها."""@ar ;
    hesin:hasSynonym """آيات في الآفاق"""@ar ;
    hesin:hasSynonym """آيات في الأنفس"""@ar ;
    hesin:hasComponent """آفاقية (في الكون)"""@ar ;
    hesin:hasComponent """نفسية (في الذات البشرية)"""@ar ;
    hesin:hasComponent """متغيرة ومتجددة"""@ar ;
    hesin:hasComponent """تحتاج إلى مفتاح قرآني"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_3 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C017 a hesin:Concept ;
    rdfs:label """الإعراض عن الهدى"""@ar ;
    hesin:definition """هو عدم الاستجابة للهدى الإلهي، وعدم إعطائه الأهمية التي يستحقها، ويؤدي إلى عقوبات إلهية تتمثل في الضلال وقسوة القلب."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """يعرض عليك الهدى، ما تصغي، ما تهتم، ستقع في ضلال... عندما لا ترضى تفهم، بعدما تعرض، ما تبصر، وهو يقدم لك القرآن الكريم، هنا تستحق أنه يقيض شيطاناً."""@ar ;
    hesin:actions """رصد الإعراض كأول علامة خطر تستدعي التدخل."""@ar ;
    hesin:hasSynonym """عدم الاهتمام"""@ar ;
    hesin:hasSynonym """عدم القبول"""@ar ;
    hesin:hasSynonym """عدم التفهم"""@ar ;
    hesin:hasComponent """عدم الإصغاء"""@ar ;
    hesin:hasComponent """عدم الاهتمام"""@ar ;
    hesin:hasComponent """عدم التفهم"""@ar ;
    hesin:hasComponent """تسويف وتأجيل"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_3 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C018 a hesin:Concept ;
    rdfs:label """الزيغ وزيغ القلب"""@ar ;
    hesin:definition """هو ميل القلب عن طريق الحق والهدى بعد أن عرض عليه، ويكون نتيجة للإعراض المتعمد عن الهدى، وهو عقوبة إلهية تجعل القلب لا يعود يستجيب للهدى."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هذه حقيقة، حقيقة تزيغ، تحاول تتملص، ما تهتم، يزيغ الله قلبك، ثم يقسو، فلا يعد ينفع فيك شيء، إلا إذا حاولت تقحم نفسك، وترجع إلى الله هو، ترجع إليه هو، وتتوب إليه."""@ar ;
    hesin:actions """يجب التعامل مع الزيغ كمرحلة متقدمة من الضلال تتطلب تدخلاً خاصًا."""@ar ;
    hesin:hasSynonym """إزاغة القلب"""@ar ;
    hesin:hasSynonym """ميل القلب عن الحق"""@ar ;
    hesin:hasComponent """ميل عن الحق"""@ar ;
    hesin:hasComponent """عقوبة على الإعراض"""@ar ;
    hesin:hasComponent """فقدان القدرة على الاستجابة"""@ar ;
    hesin:hasComponent """الحل: التوبة والرجوع إلى الله"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_3 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C019 a hesin:Concept ;
    rdfs:label """قسوة القلب"""@ar ;
    hesin:definition """هي حالة يفقد فيها القلب القدرة على التأثر بالهدى والموعظة، فيصبح صاحبه جريئًا على الباطل، لا يستوحش من الضلال، ولا يتأثر بالحق."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """قلوبهم أصبحت قاسية، أصبحت عندهم جرأة على الباطل؛ لأنهم من البداية لم يقبلوا أن يهتدوا نهائياً... القلوب القاسية لا تعد تكترث من الوقوع في الباطل، لا يعد الباطل عندها شيء موحش."""@ar ;
    hesin:actions """رصد قسوة القلب كمؤشر خطر يتطلب تدخلاً جذريًا."""@ar ;
    hesin:hasSynonym """القلب القاسي"""@ar ;
    hesin:hasSynonym """عدم التأثر"""@ar ;
    hesin:hasComponent """فقدان القدرة على التأثر"""@ar ;
    hesin:hasComponent """جرأة على الباطل"""@ar ;
    hesin:hasComponent """عدم استيحاش من الضلال"""@ar ;
    hesin:hasComponent """تحريف الكلم عن مواضعه"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_3 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C020 a hesin:Concept ;
    rdfs:label """التقوى"""@ar ;
    hesin:definition """هي حالة من اليقظة والشعور بالمسؤولية تجاه الله، تدفع الإنسان إلى الحذر من كل ما يغضب الله، والعمل في كل المجالات لتحقيق مرضاته."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """التقوى هي حالة تخشى، تخاف، تخاف من الله، تخشاه؛ فأنت تحرص على أن تقي نفسك من كل ما يمكن أن يجلب عليك سخطه، أو غضبه، أو مقته، أو عقوبته في الدنيا، وفي الآخرة."""@ar ;
    hesin:actions """يجب ربط التقوى بالعمل والحركة في الحياة، وليس فقط بالعبادات."""@ar ;
    hesin:hasSynonym """خشية الله"""@ar ;
    hesin:hasSynonym """الورع"""@ar ;
    hesin:hasSynonym """العمل الصالح"""@ar ;
    hesin:hasComponent """خشية من الله"""@ar ;
    hesin:hasComponent """شعور بالمسؤولية"""@ar ;
    hesin:hasComponent """حرص على الوقاية من سخط الله"""@ar ;
    hesin:hasComponent """عمل في كل المجالات"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_3 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C021 a hesin:Concept ;
    rdfs:label """النسيان الإلهي"""@ar ;
    hesin:definition """هو تناسي الإنسان لأهمية الهدى الإلهي، وتجاهل التحذيرات من الشيطان، مما يجعله عرضة للإغواء والوقوع في المعصية."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """لكن آدم نسي، مثلنا، نسي ماذا؟ نسي أهمية ما قدم إليه، عندما كان يقول له: إن الشيطان عدو لهم ينتبهون له، لا يغويهم، لا يصغوا إليه."""@ar ;
    hesin:actions """يجب رصد النسيان كآلية دفاعية للهروب من الهدى."""@ar ;
    hesin:hasSynonym """نسيان ما ذكر به"""@ar ;
    hesin:hasSynonym """تناسي الهدى"""@ar ;
    hesin:hasComponent """تناسي أهمية الهدى"""@ar ;
    hesin:hasComponent """تجاهل التحذيرات"""@ar ;
    hesin:hasComponent """الانخداع بالشيطان"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_3 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C022 a hesin:Concept ;
    rdfs:label """دعاء الثبات"""@ar ;
    hesin:definition """هو الدعاء الذي يطلبه المؤمن من الله ليثبته على الهدى، ويحفظه من الزيغ، ويمنحه رحمته ورعايته."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """تكون دائماً ترجو الهدى من الله، وتتخوف على الهدى الذي عندك أن لا تكون عرضة لأن يفلت من بين يديك، تطلب من الله بأنه يرعاك، يحفظك {رَبَّنَا لاَ تُزِغْ قُلُوبَنَا بَعْدَ إِذْ هَدَيْتَنَا وَهَبْ لَنَا مِن لَّدُنكَ رَحْمَةً}."""@ar ;
    hesin:actions """يجب تضمين هذا الدعاء كجزء من أي برنامج تربية روحية."""@ar ;
    hesin:hasSynonym """ربنا لا تزغ قلوبنا"""@ar ;
    hesin:hasSynonym """طلب الرعاية الإلهية"""@ar ;
    hesin:hasComponent """طلب عدم إزاغة القلب"""@ar ;
    hesin:hasComponent """طلب الثبات على الهدى"""@ar ;
    hesin:hasComponent """طلب الرحمة الإلهية"""@ar ;
    hesin:hasComponent """الإقرار بأن الله هو الوهاب"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_3 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C023 a hesin:Concept ;
    rdfs:label """الخوف من الزيغ"""@ar ;
    hesin:definition """هو حالة من اليقظة والحذر، يشعر بها المؤمن تجاه خطر الانحراف عن الهدى، وهي دافع للاستمرار في طلب الثبات من الله."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """وتتخوف على الهدى الذي عندك أن لا تكون عرضة لأن يفلت من بين يديك، تطلب من الله بأنه يرعاك، يحفظك."""@ar ;
    hesin:actions """رصد مستوى الخوف من الزيغ كمؤشر على صحة المسار."""@ar ;
    hesin:hasSynonym """الخوف من الضلال"""@ar ;
    hesin:hasSynonym """الحذر من الانحراف"""@ar ;
    hesin:hasComponent """شعور بالخطر"""@ar ;
    hesin:hasComponent """حذر من الانحراف"""@ar ;
    hesin:hasComponent """دافع للدعاء والاستمرار"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_3 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C024 a hesin:Concept ;
    rdfs:label """النظرة القاصرة للقرآن"""@ar ;
    hesin:definition """هي النظرة التي تحصر دور القرآن في مجالات محدودة (كالعقائد والعبادات)، وتغفل عن شموليته وهدايته لكل مجالات الحياة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هذا هو خلط في المفهوم... النظرة القاصرة إلى الدين، والمجالات التي يتناولها... التي تنظر إلى القرآن الكريم ككتاب هداية لمجالات محدودة فقط."""@ar ;
    hesin:actions """يجب العمل على توسيع النظرة للقرآن لتشمل كل مجالات الحياة."""@ar ;
    hesin:hasSynonym """تضييق مجال القرآن"""@ar ;
    hesin:hasSynonym """فهم محدود للدين"""@ar ;
    hesin:hasComponent """حصر القرآن في العقائد والعبادات"""@ar ;
    hesin:hasComponent """عدم رؤية شمولية القرآن"""@ar ;
    hesin:hasComponent """اعتبار القرآن غير كافٍ"""@ar ;
    hesin:hasComponent """البحث عن مصادر بديلة"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_4 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C025 a hesin:Concept ;
    rdfs:label """التأويل التنزيهي"""@ar ;
    hesin:definition """هو محاولة تأويل الآيات التي تتحدث عن أفعال إلهية (كالإضلال والإزاغة) بطريقة تخرجها عن ظاهرها، بدعوى تنزيه الله، مما يؤدي إلى إغفال الجانب التربوي والتحذيري فيها."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """من يتحدثون عنهم بأنه هو يضلهم... مشغول بمسألة التأويل، كيف يتأول... طلعنا في الأخير من نسمي أنفسنا عدلية، طلعنا لا نقِّل سوءاً عن المجبرة حقيقة."""@ar ;
    hesin:actions """يجب التعامل مع الآيات كما هي، مع التركيز على البعد التربوي والتحذيري."""@ar ;
    hesin:hasSynonym """التأويل لنزاهة الله"""@ar ;
    hesin:hasSynonym """التبرير لآيات الصفات"""@ar ;
    hesin:hasComponent """صرف الآيات عن ظاهرها"""@ar ;
    hesin:hasComponent """التركيز على تنزيه الله"""@ar ;
    hesin:hasComponent """إغفال الجانب التربوي"""@ar ;
    hesin:hasComponent """التعامل مع الآيات كإشكالية"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_4 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C026 a hesin:Concept ;
    rdfs:label """تَقييض الشيطان"""@ar ;
    hesin:definition """هي عقوبة إلهية لمن يعرض عن ذكر الله، حيث يسلط عليه شيطانًا يكون قرينًا له، يضله ويصدّه عن سبيل الله، حتى يحسب أنه مهتدٍ."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """عندما لا ترضى تفهم، بعدما تعرض، ما تبصر، وهو يقدم لك القرآن الكريم، هنا تستحق أنه يقيض شيطاناً، يهيئ شيطاناً، لا يعد يبالي بك."""@ar ;
    hesin:actions """رصد علامات تَقييض الشيطان كمؤشر خطر متقدم."""@ar ;
    hesin:hasSynonym """تسليط الشيطان"""@ar ;
    hesin:hasSynonym """قرين من الشياطين"""@ar ;
    hesin:hasComponent """عقوبة على الإعراض"""@ar ;
    hesin:hasComponent """تسليط شيطان"""@ar ;
    hesin:hasComponent """صد عن السبيل"""@ar ;
    hesin:hasComponent """شعور بالاهتداء مع الضلال"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_4 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C027 a hesin:Concept ;
    rdfs:label """تحريف الكلم عن مواضعه"""@ar ;
    hesin:definition """هو تغيير معاني النصوص الإلهية عن مقاصدها الحقيقية، وهو نتيجة لقسوة القلب والزيغ، ويصل بصاحبه إلى درجة التجري على الباطل."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """ينطلقون يحرفون الكلم عن مواضعه... يتحولون إلى شيطان مريد... متى ما قسي قلب الإنسان، متى ما زاغ قلبه، في الأخير ينطلق في الباطل متجرئاً."""@ar ;
    hesin:actions """رصد تحريف الكلم كمؤشر على تقدم الضلال."""@ar ;
    hesin:hasSynonym """تحريف الكلام"""@ar ;
    hesin:hasSynonym """قلب الحقائق"""@ar ;
    hesin:hasComponent """تغيير المعاني عن مقاصدها"""@ar ;
    hesin:hasComponent """قلب الحقائق"""@ar ;
    hesin:hasComponent """تجرؤ على الباطل"""@ar ;
    hesin:hasComponent """نسيان ما ذكروا به"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_4 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C028 a hesin:Concept ;
    rdfs:label """الهدى من عند الله فقط"""@ar ;
    hesin:definition """لا يمكن للإنسان أن يهتدي إلى الحق من خلال ذكائه أو جهوده الفردية وحدها، بل لا بد من الرجوع إلى كتاب الله والله نفسه كمصدر للهداية."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """الهدى لا يكون إلا بكتاب الله وبالله، لا يكون إلا بهذا؛ ولهذا قال: [بل لن يبصر، ولن يرى للحق عيناً، ولا أثراً، ولا يزال ـ ما لم يراجعه ـ لا يزال متحيراً ضالاً]."""@ar ;
    hesin:actions """في بناء أنظمة المعرفة، يجب جعل القرآن المرجع الأساسي."""@ar ;
    hesin:hasSynonym """مصدرية الهدى"""@ar ;
    hesin:hasSynonym """استقلالية الهدى الإلهي"""@ar ;
    hesin:hasComponent """عدم الاكتفاء بالذكاء الفردي"""@ar ;
    hesin:hasComponent """الحاجة إلى هدى الله"""@ar ;
    hesin:hasComponent """القرآن كمصدر أساسي"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_4 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C029 a hesin:Concept ;
    rdfs:label """اعتبار الضلال هدى"""@ar ;
    hesin:definition """هي المرحلة التي يصل إليها الإنسان عندما يتلبس بالضلال ويصبح مقتنعًا به، لدرجة أنه يحسب نفسه مهتديًا وهو في أشد حالات الضلال."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """وهذه من أخطر المراحل التي يصل إليها الإنسان: أن يصبح في ضلال، في باطل، وما زال يعتبر أنه مهتدي! {وَيَحْسَبُونَ أَنَّهُم مُّهْتَدُونَ}."""@ar ;
    hesin:actions """رصد هذه المرحلة كمؤشر خطر شديد يتطلب تدخلًا خاصًا."""@ar ;
    hesin:hasSynonym """يحسبون أنهم مهتدون"""@ar ;
    hesin:hasSynonym """الانقلاب في التصور"""@ar ;
    hesin:hasComponent """الضلال مع الشعور بالاهتداء"""@ar ;
    hesin:hasComponent """الانقلاب في التصورات"""@ar ;
    hesin:hasComponent """الجنودية للباطل"""@ar ;
    hesin:hasComponent """الإيمان بالباطل"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_4 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C030 a hesin:Concept ;
    rdfs:label """الانقلاب (المقلوب)"""@ar ;
    hesin:definition """هي حالة يختل فيها التصور لدى الإنسان، فيرى الضار نافعًا، والباطل حقًا، والغش نصحًا، والهلاك نجاة."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """قد صار مقلوباً، قد صار يسير بالمقلوب [يعد نفعا له ما يضره، وثقة عنده أبداً من يغره، مرحاً لهلكته فرحاً]... يرى غشه له براً ونصحاً."""@ar ;
    hesin:actions """رصد علامات الانقلاب كإنذار نهائي."""@ar ;
    hesin:hasSynonym """يعد نفعًا له ما يضره"""@ar ;
    hesin:hasSynonym """رؤية الغش نصحًا"""@ar ;
    hesin:hasComponent """قلب الموازين"""@ar ;
    hesin:hasComponent """اعتبار الضار نافعًا"""@ar ;
    hesin:hasComponent """اعتبار الغش نصحًا"""@ar ;
    hesin:hasComponent """الفرح بالهلاك"""@ar ;
    hesin:hasComponent """الإفتراء والبهتان"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_4 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C031 a hesin:Concept ;
    rdfs:label """نقد التأويل العقلاني"""@ar ;
    hesin:definition """نقد لمنهج المعتزلة في تأويل آيات الصفات (كالعدلية)، وإعلان أن هذا المنهج لا يخدم تنزيه الله بشكل حقيقي، وأنه يؤدي إلى إغفال الجانب التربوي المهم في النص."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """طلعنا في الأخير من نسمي أنفسنا عدلية، طلعنا لا نقِّل سوءاً عن المجبرة حقيقة، خاصة في الزمن هذا... لا يوجد تنزيه لله، ولا حتى الأسلوب الذي كانوا يسيرون عليه الذي يسمونه: التأويل، ما هو أسلوب تنزيهي نهائياً."""@ar ;
    hesin:actions """عند مواجهة آيات الصفات، يجب التركيز على البعد التربوي وعدم الانشغال بالتأويلات العقلانية."""@ar ;
    hesin:hasSynonym """نقد المعتزلة"""@ar ;
    hesin:hasSynonym """نقع سوء المجبرة"""@ar ;
    hesin:hasComponent """رفض التأويلات التي تخرج النص عن ظاهره"""@ar ;
    hesin:hasComponent """نقد منهج المعتزلة في التعامل مع آيات الإضلال"""@ar ;
    hesin:hasComponent """التأكيد على الجانب التربوي للنص"""@ar ;
    hesin:hasComponent """اعتبار أن تنزيه الله لا يحتاج إلى تأويل"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_5 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C032 a hesin:Concept ;
    rdfs:label """الإكتفاء بغير القرآن"""@ar ;
    hesin:definition """هو الاعتماد على مصادر أخرى غير القرآن في الهداية والتوجيه، معتقدًا أن القرآن غير كافٍ، وهذا يؤدي إلى الضلال لأن القرآن هو المصدر الكامل للهداية."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """الويل كل الويل لمن لم يكتف في أموره، وأمور غيره بتنزيل رب العالمين... يريد يوعظ الآخرين، يبحث له عن كتب أخرى في الترغيب والترهيب، تلك التي تكون مليئة أخطاء رهيبة."""@ar ;
    hesin:actions """في أي نظام معرفي، يجب أن يكون القرآن هو المرجع الأول والأخير."""@ar ;
    hesin:hasSynonym """البحث عن كتب أخرى"""@ar ;
    hesin:hasSynonym """عدم الاكتفاء بالقرآن"""@ar ;
    hesin:hasComponent """عدم الاكتفاء بالقرآن"""@ar ;
    hesin:hasComponent """البحث عن مصادر بديلة"""@ar ;
    hesin:hasComponent """الاعتقاد بأن القرآن غير كافٍ"""@ar ;
    hesin:hasComponent """الوقوع في الأخطاء"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_5 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C033 a hesin:Concept ;
    rdfs:label """الإشكالية في الإنسان لا في القرآن"""@ar ;
    hesin:definition """إذا لم يؤثر القرآن في الإنسان أو لم يهتد به، فالخلل ليس في القرآن (الذي لو أنزل على جبل لتصدع)، بل الخلل في الإنسان نفسه أو في طريقة تقديم القرآن له."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لا، إفهم بأن القرآن لا يوجد فيه إشكالية، الإشكالية توجد عند الناس، ترجع لمعالجة الإشكالية عند الناس من القرآن نفسه."""@ar ;
    hesin:actions """عند مواجهة عدم التأثر، يجب البحث عن أسباب الخلل في الإنسان أو الطريقة."""@ar ;
    hesin:hasSynonym """الخلل عندك"""@ar ;
    hesin:hasSynonym """قصور الإنسان"""@ar ;
    hesin:hasComponent """القرآن كامل التأثير"""@ar ;
    hesin:hasComponent """الجبل يتأثر بالقرآن"""@ar ;
    hesin:hasComponent """عدم التأثر يعود للإنسان"""@ar ;
    hesin:hasComponent """المعالجة من القرآن نفسه"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_5 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C034 a hesin:Concept ;
    rdfs:label """شمولية القرآن للحياة"""@ar ;
    hesin:definition """القرآن لا يقتصر على الجانب الروحي والعبادي، بل يشمل كل مجالات الحياة: السياسة، الاقتصاد، الاجتماع، الثقافة، الصناعة، الزراعة، وغيرها."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """الدين هو يملئ الحياة، يملئ الحياة بكلها، والتبيين لا يعني أن يعمل لك قائمة تفصيلية بأسماء الأشياء بالتحديد، هو يبين لك كيف تكون، يهديك إلى كيف تكون هذه الأمة."""@ar ;
    hesin:actions """في التطبيقات العملية، يجب البحث عن هداية القرآن في كل مجال."""@ar ;
    hesin:hasSynonym """الدين يملأ الحياة"""@ar ;
    hesin:hasSynonym """القرآن يهدي لكل شيء"""@ar ;
    hesin:hasComponent """السياسة والحكم"""@ar ;
    hesin:hasComponent """الاقتصاد والإنفاق"""@ar ;
    hesin:hasComponent """الصناعة والزراعة"""@ar ;
    hesin:hasComponent """التربية والتعليم"""@ar ;
    hesin:hasComponent """العلاقات الاجتماعية"""@ar ;
    hesin:hasComponent """التصميم المعماري"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_6 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C035 a hesin:Concept ;
    rdfs:label """البشرى في الدنيا"""@ar ;
    hesin:definition """المؤمنون الذين يتبعون هدى الله يحصلون على بشارات في الدنيا قبل الآخرة، تشمل: الطمأنينة، النجاح في الأعمال، الثبات، والتأييد الإلهي."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """بشرى في الحياة نفسها، والقرآن الكريم ذكر أمثلة للبشرى هذه... بشارات بنجاحات في أعمالهم، بشارات بأن مواقفهم صحيحة، بأن حركتهم ثابتة، بشارات بأن الله معهم."""@ar ;
    hesin:actions """رصد البشرى كمؤشر على صحة المسار وثباته."""@ar ;
    hesin:hasSynonym """بشرى للمؤمنين"""@ar ;
    hesin:hasSynonym """الطمأنينة"""@ar ;
    hesin:hasComponent """طمأنينة القلب"""@ar ;
    hesin:hasComponent """نجاح في الأعمال"""@ar ;
    hesin:hasComponent """ثبات في المواقف"""@ar ;
    hesin:hasComponent """تأييد إلهي"""@ar ;
    hesin:hasComponent """بركة في الحياة"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_6 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C036 a hesin:Concept ;
    rdfs:label """مشروع المتقين"""@ar ;
    hesin:definition """مشروع المتقين هو مشروع شامل يهدف إلى إظهار دين الله في الأرض، ويتطلب العمل في مجالات متعددة: الزراعة، الصناعة، التجارة، التثقيف، وغيرها."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """المتقين يرون أن من واجبهم أن يجاهدوا في سبيل الله، المتقين يرون أنه لا بد أن يكونوا مجاهدين في سبيل الله، يكافحون أعداء الله، يزيحون أعداء الله، يعملون على إظهار دين الله في الأرض كلها. هذا مشروع كبير."""@ar ;
    hesin:actions """في بناء الأنظمة، يجب ربط التقوى بالمشاريع العملية الكبرى."""@ar ;
    hesin:hasSynonym """الجهاد في سبيل الله"""@ar ;
    hesin:hasSynonym """إظهار الدين"""@ar ;
    hesin:hasSynonym """بناء الأمة"""@ar ;
    hesin:hasComponent """جهاد في سبيل الله"""@ar ;
    hesin:hasComponent """مكافحة أعداء الله"""@ar ;
    hesin:hasComponent """إظهار دين الله"""@ar ;
    hesin:hasComponent """بناء الأمة"""@ar ;
    hesin:hasComponent """العمل في مجالات متعددة"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_6 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C037 a hesin:Concept ;
    rdfs:label """آل البيت كوسيلة تبيان"""@ar ;
    hesin:definition """آل البيت (عليهم السلام) هم الوسيلة التي يهدي إليها القرآن لتبيين التطبيق العملي لهديه، فهم أعلم الناس بما كان عليه النبي (صلى الله عليه وآله) في جميع شؤون الدين."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """لو تمسكوا بالإمام علي مثلاً، والأمة سارت بمسيرة الإمام علي، أليس الإمام علي يعرف كيف كان يصلي رسول الله... فتكون الأمة تمشي على طريقة واحدة."""@ar ;
    hesin:actions """عند دراسة التطبيقات العملية، يجب الرجوع إلى منهج آل البيت كوسيلة لفهم التطبيق القرآني."""@ar ;
    hesin:hasSynonym """الإمام علي"""@ar ;
    hesin:hasSynonym """أئمة أهل البيت"""@ar ;
    hesin:hasSynonym """وسيلة التطبيق"""@ar ;
    hesin:hasComponent """معرفة التطبيق العملي"""@ar ;
    hesin:hasComponent """وحدة المنهج"""@ar ;
    hesin:hasComponent """الحفاظ على السنة النبوية"""@ar ;
    hesin:hasComponent """الهداية من خلال القرآن"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_6 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C038 a hesin:Concept ;
    rdfs:label """قصة آدم نموذجًا للهداية"""@ar ;
    hesin:definition """قصة آدم تقدم نموذجًا كاملاً للهداية الإلهية: البيان الواضح من الله، التحذير من الشيطان، النسيان البشري، والمعصية، ثم التوبة والرجوع إلى الله."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """هذه القصة العظيمة الرهيبة التي فيها عبر لأول رجل وامرأة من البشر، أب وأم البشر هؤلاء جميعاً، حول المعصية، وأثر المعصية، وكيف كان الهدى، يعني: فيها نموذج كامل."""@ar ;
    hesin:actions """عند تحليل قصص القرآن، يجب استخلاص العبر التربوية والمنهجية."""@ar ;
    hesin:hasSynonym """نموذج الهدى"""@ar ;
    hesin:hasSynonym """قصة الأبوين"""@ar ;
    hesin:hasComponent """البيان الإلهي الواضح"""@ar ;
    hesin:hasComponent """التحذير من الشيطان"""@ar ;
    hesin:hasComponent """النسيان البشري"""@ar ;
    hesin:hasComponent """الوقوع في المعصية"""@ar ;
    hesin:hasComponent """الشقاء في الدنيا نتيجة المعصية"""@ar ;
    hesin:hasComponent """التوبة والرجوع"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_7 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C039 a hesin:Concept ;
    rdfs:label """قصة بني إسرائيل نموذجًا للقسوة"""@ar ;
    hesin:definition """قصة بني إسرائيل تقدم نموذجًا لمآل الإعراض عن الهدى: نقض الميثاق، اللعن، قسوة القلب، تحريف الكلم، والنسيان لما ذكروا به."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """يتحدث عنهم، عن بني إسرائيل: {فَبِمَا نَقْضِهِم مِّيثَاقَهُمْ لَعنَّاهُمْ وَجَعَلْنَا قُلُوبَهُمْ قَاسِيَةً يُحَرِّفُونَ الْكَلِمَ عَن مَّوَاضِعِهِ}."""@ar ;
    hesin:actions """استخدام قصة بني إسرائيل كتحذير من عواقب الإعراض عن الهدى."""@ar ;
    hesin:hasSynonym """نقض الميثاق"""@ar ;
    hesin:hasSynonym """قسوة القلب"""@ar ;
    hesin:hasSynonym """تحريف الكلم"""@ar ;
    hesin:hasComponent """نقض الميثاق"""@ar ;
    hesin:hasComponent """استحقاق اللعن"""@ar ;
    hesin:hasComponent """قسوة القلب"""@ar ;
    hesin:hasComponent """تحريف الكلم"""@ar ;
    hesin:hasComponent """نسيان ما ذكروا به"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_7 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C040 a hesin:Concept ;
    rdfs:label """قصة الشيطان عبرة"""@ar ;
    hesin:definition """قصة الشيطان تبين كيف أن الإعراض عن أمر الله والعناد يؤدي إلى قسوة القلب، ثم التحول إلى شيطان مريد، حتى لو كان قبل ذلك عابدًا."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """الشيطان نفسه أولاً انصرف عن تنفيذ أمر إلهي، عاند... بسبب العناد قسي قلبه، وفي الأخير تحول إلى شيطان مريد، وكان قبل عبَّادة."""@ar ;
    hesin:actions """استخدام قصة الشيطان كتحذير من تطور الإعراض إلى عناد."""@ar ;
    hesin:hasSynonym """تحول الشيطان"""@ar ;
    hesin:hasSynonym """العناد وقسوة القلب"""@ar ;
    hesin:hasComponent """الانصراف عن الأمر الإلهي"""@ar ;
    hesin:hasComponent """العناد"""@ar ;
    hesin:hasComponent """قسوة القلب"""@ar ;
    hesin:hasComponent """التحول إلى شيطان مريد"""@ar ;
