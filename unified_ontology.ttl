    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C131 a hesin:Concept ;
    rdfs:label """ظلم الثقلين"""@ar ;
    hesin:definition """هجر الأمة للقرآن والعترة وعدم الرجوع إليهما كمصدرين رئيسيين للهداية، مما أدى إلى ضياعها."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """الأمة ظلمت الثقلين: يعني القرآن والعترة، ظلموهم من أول الزمان، من بعد رسول الله (صلوات الله عليه وعلى آله) وعلى طول التاريخ"""@ar ;
    hesin:actions """العودة إلى القرآن والعترة كمصدرين رئيسيين."""@ar ;
