hesin:F5_C123 a hesin:Concept ;
    rdfs:label """المعتزلة"""@ar ;
    hesin:definition """فرقة كلامية ظهرت في التاريخ الإسلامي، اشتهرت بالاشتغال بالعقل والجدل، وسخرت من أئمة أهل البيت، وتركت آثارًا سلبية على الأمة."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """المعتزلة هم من كانوا يرون أنفسهم علماء أجلاء إلى درجة أنهم ـ كما يحكي الشرفي في شرح الأساس ـ أنهم كان البعض منهم يسخرون بأئمة أهل البيت فينظرون نظرة بأنهم بسطاء وتفكيرهم بسيط ومتخلفين ثقافياً"""@ar ;
    hesin:actions """نقد منهج المعتزلة وتبيان أخطائه."""@ar ;
    hesin:hasSynonym """المعتزلة"""@ar ;
    hesin:hasComponent """الاشتغال بالعقل والجدل"""@ar ;
    hesin:hasComponent """التكبر على أهل البيت"""@ar ;
    hesin:hasComponent """التأثير السلبي على الثقافة الإسلامية"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_20 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C124 a hesin:Concept ;
    rdfs:label """الأشعرية"""@ar ;
    hesin:definition """فرقة كلامية ظهرت كرد فعل على المعتزلة، لكنها أيضًا ابتعدت عن المنهج القرآني وأسهمت في إضعاف الأمة."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """المعتزلة، الأشعرية، العقائد الباطلة من هنا وهناك"""@ar ;
    hesin:actions """نقد منهج الأشعرية."""@ar ;
    hesin:hasSynonym """الأشاعرة"""@ar ;
    hesin:hasComponent """الاشتغال بالكلام"""@ar ;
    hesin:hasComponent """الابتعاد عن القرآن"""@ar ;
    hesin:hasComponent """التأثير السلبي"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_20 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C125 a hesin:Concept ;
    rdfs:label """ابن تيمية"""@ar ;
    hesin:definition """عالم مسلم له غزارة علمية، لكنه كان يفتقد إلى الأسس القرآنية الصحيحة في منهجه، مما أدى إلى عقائد باطلة وأقوال غريبة."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """نحن نعرف أشخاصا كابن تيمية مثلاً من العلماء الذين عرفوا بغزارة العلم... لكنه كان يفتقد إلى أسس، إلى أسس ينطلق منها، أسس يرشد إليها القرآن الكريم"""@ar ;
    hesin:actions """نقد منهج ابن تيمية وبيان أخطائه."""@ar ;
    hesin:hasSynonym """شيخ الإسلام (كما يلقب)"""@ar ;
    hesin:hasComponent """غزارة في المقروءات"""@ar ;
    hesin:hasComponent """افتقاد الأسس القرآنية"""@ar ;
    hesin:hasComponent """عقائد باطلة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_20 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C126 a hesin:Concept ;
    rdfs:label """الإمام الخميني"""@ar ;
    hesin:definition """قائد الثورة الإسلامية في إيران، الذي أكد على أن الأمة ظلمت القرآن والعترة، ودعا إلى العودة إليهما."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """كان الإمام الخميني يقول: إن الثقلين ظلما، قال: الأمة ظلمت الثقلين: يعني القرآن والعترة"""@ar ;
    hesin:actions """الاستفادة من أقواله في نقد التراث."""@ar ;
    hesin:hasSynonym """الخميني"""@ar ;
    hesin:hasSynonym """قائد الثورة الإسلامية"""@ar ;
    hesin:hasComponent """التأكيد على ظلم الثقلين"""@ar ;
    hesin:hasComponent """الدعوة للعودة إلى القرآن والعترة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_20 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C127 a hesin:Concept ;
    rdfs:label """طاعة الحاكم الظالم"""@ar ;
    hesin:definition """حالة من التناقض يعيشها من يشتغل بعلم الكلام، حيث يخضع لحاكم ظالم رغم ادعائه المعرفة بالله."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """تراه في نفس الوقت يدين بالطاعة لحاكم ظالم.. هل هذا عرف الله؟"""@ar ;
    hesin:actions """قياس مدى انعكاس المعرفة على موقف الفرد من الظلم."""@ar ;
    hesin:hasSynonym """الخضوع للظالم"""@ar ;
    hesin:hasSynonym """طاعة الطاغوت"""@ar ;
