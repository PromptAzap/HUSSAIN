hesin:ConceptGroup a owl:Class .
hesin:Collection a owl:Class .

hesin:F1_Collection a hesin:Collection ;
    rdfs:label """من هدي القرآن الكريم"""@ar ;
    hesin:description """سلسلة دروس في تفسير القرآن الكريم، مع التركيز على استخلاص المنهجية القرآنية في الخطاب والدعوة والتربية والجهاد."""@ar .
