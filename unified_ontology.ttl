hesin:F5_C135 a hesin:Concept ;
    rdfs:label """الثقافة المغلوطة"""@ar ;
    hesin:definition """تقديم خاطئ للإسلام من قبل بعض العلماء، جعل الدين يبدو وكأنه عائق عن التقدم."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """نعرف من خلال هذا كيف يمكن أن يكون الأثر السيئ للأخطاء الثقافية، وقد تضرب أمة بأكملها وتجعلها تحت الأقدام"""@ar ;
    hesin:actions """نقد التراث وتصحيح التقديم."""@ar ;
