hesin:F6_C024 a hesin:Concept ;
    rdfs:label """حزب الله"""@ar ;
    hesin:definition """الفئة التي تتولى الله ورسوله والإمام علي، وهي الموعودة بالغلبة على الأعداء."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """وَمَنْ يَتَوَلَّ اللَّهَ وَرَسُولَهُ وَالَّذِينَ آمَنُوا فَإِنَّ حِزْبَ اللَّهِ هُمُ الْغَالِبُونَ"""@ar ;
    hesin:actions """مفهوم مركزي للتصنيف: من يقبل بهذه الشروط يُصنف ضمن "حزب الله"."""@ar ;
    hesin:hasSynonym """الغالبون"""@ar ;
