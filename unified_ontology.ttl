    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C031 a hesin:Concept ;
    rdfs:label """البخل"""@ar ;
    hesin:definition """الامتناع عن الإنفاق في سبيل الله وعن إطعام المسكين، ناتج عن ضعف الإيمان."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """وَكَانَ فِي الدُّنْيَا بَخِيلا، وَلا حَتَّى يَحُثُّ الآخَرِينَ عَلَى إِطْعَامِ الْمِسْكِينِ"""@ar ;
    hesin:actions """رصد سلوك الإنفاق في سبيل الله."""@ar ;
