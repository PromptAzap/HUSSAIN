    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C022 a hesin:Concept ;
    rdfs:label """القلب السليم"""@ar ;
    hesin:definition """القلب الذي امتلأ بولاية الله والرسول والإمام علي، مما يجعله محصنًا ضد مرض التولي للكافرين."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """القلب السليم الذي هو مملوء بتولي الله ورسوله والذين آمنوا لا يمكن أن يميل إليهم"""@ar ;
    hesin:actions """الهدف النهائي لأي عملية تربوية."""@ar ;
    hesin:hasSynonym """القلب المملوء بالإيمان"""@ar ;
    hesin:hasSynonym """القلب المحصن"""@ar ;
