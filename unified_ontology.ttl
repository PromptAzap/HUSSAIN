    hesin:definition """اليوم الذي يجمع الله فيه الأولين والآخرين للحساب والجزاء، وفيه يتجلى العدل الإلهي."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """يوم القيامة.. يجب أن نتأمل كثيراً في كتاب الله، فنرجع إلى القرآن كم ورد في شرح تفاصيل ذلك الموقف الرهيب"""@ar ;
    hesin:actions """جمع الآيات التي تصف القيامة لتكوين صورة متكاملة."""@ar ;
