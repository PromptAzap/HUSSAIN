    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C041 a hesin:Concept ;
    rdfs:label """الأسلوب التربوي في الآيات"""@ar ;
    hesin:definition """الآيات التي تتحدث عن أفعال الله (كالإضلال والإزاغة) يجب أن تُقرأ بمنهج تربوي تحذيري، وليس بمنهج تأويلي يغفل هذا البعد."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """الإمام القاسم يتحدث من منطلق هداية؛ لهذا قال في مكان آخر عبارة يوصي أولاده أن ينظروا إلى القرآن الكريم ككتاب هداية."""@ar ;
    hesin:actions """في تحليل النصوص، يجب التركيز على البعد التربوي والتحذيري."""@ar ;
    hesin:hasSynonym """الجانب التربوي"""@ar ;
    hesin:hasSynonym """التحذير والتخويف"""@ar ;
    hesin:hasComponent """التحذير من عواقب الإعراض"""@ar ;
    hesin:hasComponent """التخويف من قسوة القلب"""@ar ;
    hesin:hasComponent """الترغيب في الاستجابة"""@ar ;
    hesin:hasComponent """إبراز خطورة الزيغ"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_8 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C042 a hesin:Concept ;
    rdfs:label """منهج أهل البيت الأصلي"""@ar ;
    hesin:definition """منهج أهل البيت في التعامل مع القرآن هو منهج يركز على هداية القرآن، ويتعامل مع الآيات بكل صراحة ووضوح، دون تأويلات تغفل الجانب التربوي."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """كتابته بالطريقة التي تكشف كيف رؤية أهل البيت، وتوجه أهل البيت الأصلي، قبل تجي أشياء أخرى. هنا يعطي فعلاً رؤية أهل البيت."""@ar ;
    hesin:actions """اعتماد منهج أهل البيت كإطار لفهم القرآن."""@ar ;
    hesin:hasSynonym """رؤية أهل البيت"""@ar ;
    hesin:hasSynonym """منهج الإمام القاسم"""@ar ;
    hesin:hasComponent """التركيز على هداية القرآن"""@ar ;
    hesin:hasComponent """التعامل مع الآيات بصراحة"""@ar ;
    hesin:hasComponent """عدم الانشغال بالتأويلات"""@ar ;
    hesin:hasComponent """رؤية شمولية للدين"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_8 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C043 a hesin:Concept ;
    rdfs:label """ضرورة اليقظة والحذر"""@ar ;
    hesin:definition """المؤمن يجب أن يكون دائم اليقظة والحذر من الضلال والشيطان، وألا يغفل عن أهمية الهدى في كل لحظة من حياته."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """مطلوب من الإنسان أن تكون نفسيته نفسية يقظة، دائماً منتبهاً، حذراً، يقظاً، ما يكون عرضة لأن ينسى، ويأتي أحد من الناس يغويه فينسى الأصول."""@ar ;
    hesin:actions """رصد مستوى اليقظة والحذر كمؤشر على صحة المسار."""@ar ;
    hesin:hasSynonym """الانتباه"""@ar ;
    hesin:hasSynonym """عدم الغفلة"""@ar ;
    hesin:hasComponent """انتباه دائم"""@ar ;
    hesin:hasComponent """حذر من الضلال"""@ar ;
    hesin:hasComponent """عدم الغفلة عن الهدى"""@ar ;
    hesin:hasComponent """استعداد دائم للتذكر"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_8 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C044 a hesin:Concept ;
    rdfs:label """النظرة الموضوعية في التعامل مع الشبهات"""@ar ;
    hesin:definition """منهجية التعامل مع الشبهات المثارة حول القرآن تقوم على الإنصاف والموضوعية أولاً، فمنشأ الشبهة غالبًا هو التحامل وعدم الإنصاف."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """القرآن يريد منك نظرة موضوعية، نظرة موضوعية أولاً، إذا ما عندك نظرة موضوعية، إذا أنت متحامل فمنشأ الشبه هو كونك متحامل، أنك لا تنظر نظرة موضوعية، لا تنظر نظرة منصفة."""@ar ;
    hesin:actions """عند مواجهة أي شبهة، يجب أولاً تحليل موقف الطرف الآخر ومدى موضوعيته."""@ar ;
    hesin:hasSynonym """الإنصاف"""@ar ;
    hesin:hasSynonym """عدم التحامل"""@ar ;
    hesin:hasSynonym """النظرة المنصفة"""@ar ;
    hesin:hasComponent """عدم التحامل المسبق"""@ar ;
    hesin:hasComponent """النظر بموضوعية"""@ar ;
    hesin:hasComponent """الإنصاف في التقييم"""@ar ;
    hesin:hasComponent """فهم منشأ الشبهة"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_9 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C045 a hesin:Concept ;
    rdfs:label """تحليل منشأ الشبهة"""@ar ;
    hesin:definition """منهجية تقوم على تتبع أصل الشبهة ومصدرها، وفهم الدوافع النفسية والفكرية وراء ظهورها، قبل البدء في الرد عليها."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """أولاً كيف تنشأ الشبهة، وما منشأ الشبهة؟... إذا أنت متحامل فمنشأ الشبه هو كونك متحامل."""@ar ;
    hesin:actions """بناء قاعدة بيانات لأصول الشبهات ومصادرها لتسهيل الرد عليها."""@ar ;
    hesin:hasSynonym """معرفة مصدر الإشكال"""@ar ;
    hesin:hasSynonym """فهم أصل الشبهة"""@ar ;
    hesin:hasComponent """تتبع أصل الشبهة"""@ar ;
    hesin:hasComponent """فهم دوافع صاحبها"""@ar ;
    hesin:hasComponent """تحليل الخلفية الفكرية"""@ar ;
    hesin:hasComponent """كشف التحامل والهوى"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_9 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C046 a hesin:Concept ;
    rdfs:label """الدفاع النفسي العاطفي"""@ar ;
    hesin:definition """هو منهج دفاعي يقوم على المطالبة بالإيمان المسبق قبل التفكير والتحليل، وهو منهج غير منطقي وغير مقبول في الحوار الجاد."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هل القرآن كتاب يقول مثلما يأتي يقول لك أي منجم: [ما هو نافع لك إلا إذا قد بدأت أولاً تؤمن تماماً به أنه كذا كذا] فيكون هذا في الأخير تأثير نفسي؟"""@ar ;
    hesin:actions """رفض أي منهج يطلب الإيمان المسبق دون برهان."""@ar ;
    hesin:hasSynonym """التأثير النفسي"""@ar ;
    hesin:hasSynonym """الإيمان المسبق دون تفكير"""@ar ;
    hesin:hasComponent """الإيمان المسبق المطلوب"""@ar ;
    hesin:hasComponent """التأثير النفسي بدل البرهان"""@ar ;
    hesin:hasComponent """عدم احترام العقل والمنطق"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_9 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C047 a hesin:Concept ;
    rdfs:label """منهج المنجمين"""@ar ;
    hesin:definition """منهج يعتمد على طلب الإيمان المسبق دون دليل، وهو أسلوب المنجمين والمشعوذين، ولا يصح نسبته إلى القرآن."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هل القرآن كتاب يقول مثلما يأتي يقول لك أي منجم: [ما هو نافع لك إلا إذا قد بدأت أولاً تؤمن تماماً به أنه كذا كذا]"""@ar ;
    hesin:actions """التمييز بين الإيمان المبني على البصيرة والإيمان المبني على التأثير النفسي."""@ar ;
    hesin:hasSynonym """التأثير النفسي"""@ar ;
    hesin:hasSynonym """الإيحاء"""@ar ;
    hesin:hasComponent """طلب الإيمان قبل التفكير"""@ar ;
    hesin:hasComponent """الاعتماد على التأثير النفسي"""@ar ;
    hesin:hasComponent """غياب البرهان المنطقي"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_9 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C048 a hesin:Concept ;
    rdfs:label """الأدلة الجملية (ضرب الأصول)"""@ar ;
    hesin:definition """منهج في الحوار والمناظرة يقوم على التركيز على الأدلة الأساسية الجملية التي إذا ثبتت سقطت معها كل التفاصيل والتفريعات، بدل الانشغال بالتفاصيل الدقيقة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هناك أشياء تغنيك عن هذا كله، ممكن تضرب الأصل بكله، تضرب الأصل كله، فيتهاوى كل هذا... هذه هي الأدلة الجملية، الأدلة الجملية على أساسيات."""@ar ;
    hesin:actions """عند تصميم نظام للحوار، يجب إعطاء الأولوية للأدلة الجملية على التفاصيل."""@ar ;
    hesin:hasSynonym """ضرب الأصل"""@ar ;
    hesin:hasSynonym """الأدلة الإجمالية"""@ar ;
    hesin:hasSynonym """الأدلة الأساسية"""@ar ;
    hesin:hasComponent """التركيز على الأصول الكبرى"""@ar ;
    hesin:hasComponent """ضرب الأساس الذي تقوم عليه التفاصيل"""@ar ;
    hesin:hasComponent """تجنب الانشغال بالتفاصيل الدقيقة"""@ar ;
    hesin:hasComponent """الاقتصاد في الجهد والوقت"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_9 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C049 a hesin:Concept ;
    rdfs:label """منهجية الحوار القرآني"""@ar ;
    hesin:definition """المنهجية التي يرسّمها القرآن للحوار والمناظرة، والتي تقوم على الموضوعية والإنصاف، وضرب الأصول قبل التفاصيل."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """القرآن الكريم يرسم في هذا الجانب، يرسم منهجية للحوار مع الآخر للدخول في حوار مع طرف آخر."""@ar ;
    hesin:actions """بناء نظام حوار يعتمد على الأصول الجملية."""@ar ;
    hesin:hasSynonym """الحوار بالتي هي أحسن"""@ar ;
    hesin:hasSynonym """الجدل بالحسنى"""@ar ;
    hesin:hasComponent """الموضوعية والإنصاف"""@ar ;
    hesin:hasComponent """التركيز على الأصول"""@ar ;
    hesin:hasComponent """الحكمة والموعظة الحسنة"""@ar ;
    hesin:hasComponent """عدم الدخول في تفاصيل غير مجدية"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_9 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C050 a hesin:Concept ;
    rdfs:label """الانشغال بالتفاصيل الدقيقة"""@ar ;
    hesin:definition """منهج خاطئ في الحوار يتمثل في الانشغال بالتفاصيل الدقيقة والجزئيات قبل ترسيخ الأصول الكبرى، مما يؤدي إلى إطالة الحوار وعدم الوصول إلى نتيجة."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """تدخل في تفاصيل تغرق أنت والآخرين، وأخذ ورد طويل عريض، أيام طويلة ما تنتهوا إلى شيء."""@ar ;
    hesin:actions """تجنب الانشغال بالتفاصيل قبل إثبات الأصول."""@ar ;
    hesin:hasSynonym """الغرق في الجزئيات"""@ar ;
    hesin:hasSynonym """التفريعات غير المجدية"""@ar ;
    hesin:hasComponent """التركيز على الجزئيات"""@ar ;
    hesin:hasComponent """إهمال الأصول"""@ar ;
    hesin:hasComponent """إطالة الحوار دون فائدة"""@ar ;
    hesin:hasComponent """ضياع الوقت والجهد"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_9 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C051 a hesin:Concept ;
    rdfs:label """حفظ القرآن الإلهي"""@ar ;
    hesin:definition """الله سبحانه وتعالى تولى حفظ القرآن الكريم من التحريف والزيادة والنقصان، وهو محفوظ في اللوح المحفوظ، ولا يمكن لأي قوة أن تنال من نصه."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """القرآن الكريم يشهد على أنه كامل... تولى حفظه، ما يستطيع أحد من أعدائه أن يلعب فيه على الإطلاق، ولا ينقِّص منه ما يستطيع أحد."""@ar ;
    hesin:actions """اعتبار القرآن مصدرًا موثوقًا مطلقًا لا يحتاج إلى أسانيد."""@ar ;
    hesin:hasSynonym """الذكر المحفوظ"""@ar ;
    hesin:hasSynonym """اللوح المحفوظ"""@ar ;
    hesin:hasComponent """حفظ النص من التحريف"""@ar ;
    hesin:hasComponent """حفظ النص من الزيادة والنقصان"""@ar ;
    hesin:hasComponent """استمرارية الحفظ إلى آخر الزمان"""@ar ;
    hesin:hasComponent """وجود النسخة الأصلية في اللوح المحفوظ"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_10 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C052 a hesin:Concept ;
    rdfs:label """روايات ضياع القرآن"""@ar ;
    hesin:definition """روايات مكذوبة تزعم أن بعض آيات القرآن قد ضاعت أو أكلتها الجرذان، وهي روايات متناقشة مع القرآن ومع حفظ الله له."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """جاءت بها أحاديث من عند السنية، إن كان سورة كذا مثل سورة كذا، ولكن أكلها الجرذان! كانت تحت سرير عائشة أكلتها الجرذان!!"""@ar ;
    hesin:actions """رفض أي رواية تدعي نقصان أو تحريف القرآن بشكل مطلق."""@ar ;
    hesin:hasSynonym """حديث الجرذان"""@ar ;
    hesin:hasSynonym """أكلت الجرذان آيات"""@ar ;
    hesin:hasSynonym """نقص القرآن"""@ar ;
    hesin:hasComponent """روايات عن أكل الجرذان لآيات"""@ar ;
    hesin:hasComponent """روايات عن وجود سور طويلة ثم ضاع معظمها"""@ar ;
    hesin:hasComponent """روايات عن اختلاف في جمع القرآن"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_10 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C053 a hesin:Concept ;
    rdfs:label """تحريف القرآن"""@ar ;
    hesin:definition """ادعاء باطل بأن القرآن الكريم قد تعرض للتحريف (زيادة أو نقصان)، وهذا الادعاء يناقض النصوص القرآنية التي تؤكد حفظه وتمامه."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """افتروا الكذب فيه وهم لا يشعرون... كيف يصح أن يذهب منه شيء وهو صراط الله المستقيم، وتبيانه لكل شيء."""@ar ;
    hesin:actions """رفض أي ادعاء بالتحريف واعتبار القرآن كاملاً."""@ar ;
    hesin:hasSynonym """تغيير القرآن"""@ar ;
    hesin:hasSynonym """زيادة أو نقصان في القرآن"""@ar ;
    hesin:hasComponent """ادعاء النقصان"""@ar ;
    hesin:hasComponent """ادعاء الزيادة"""@ar ;
    hesin:hasComponent """الاعتماد على روايات ضعيفة"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_10 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C054 a hesin:Concept ;
    rdfs:label """القرآن كمصدر موثوق"""@ar ;
    hesin:definition """القرآن الكريم هو المصدر الأرفع من أن يحتاج إلى أسانيد وروايات لإثبات صحته، فهو كالشمس في وضوحه، والإعجاز هو الدليل الأكبر على أنه من عند الله."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """القرآن هو أرفع من مسألة الأسانيد، هل تحتاج الشمس حدثني فلان عن فلان،عن فلان أن هناك شمس تطلع كل يوم؟"""@ar ;
    hesin:actions """اعتبار القرآن المرجع الأول والأعلى الذي لا يحتاج إلى تثبيت بالروايات."""@ar ;
    hesin:hasSynonym """القرآن لا يحتاج إلى سند"""@ar ;
    hesin:hasSynonym """القرآن كالشمس"""@ar ;
    hesin:hasComponent """وضوح القرآن كالشمس"""@ar ;
    hesin:hasComponent """الإعجاز دليل على الصحة"""@ar ;
    hesin:hasComponent """عدم الحاجة إلى أسانيد"""@ar ;
    hesin:hasComponent """الاستغناء عن الروايات في إثبات النص"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_10 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C055 a hesin:Concept ;
    rdfs:label """نقد الرواة والمحدثين"""@ar ;
    hesin:definition """نقد منهج المحدثين الذين جمعوا الأحاديث دون تمحيص كاف، مما أدى إلى تدوين كذب وباطل وخلوده للأمة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """المحدثين هم مثل الصحفيين سواء، حدثنا، أخبرنا، وهكذا، قرقرة وجمَّاع أحاديث من أجل يطلع الحافظ فلان... سطَّروا الكذب، وبقي الكذب، خلدوا الكذب."""@ar ;
    hesin:actions """نقد الأحاديث بعرضها على القرآن، وعدم قبولها كمسلمات."""@ar ;
    hesin:hasSynonym """المحدثون كالصحفيين"""@ar ;
    hesin:hasSynonym """تدوين الكذب"""@ar ;
    hesin:hasSynonym """خلدوا الكذب"""@ar ;
    hesin:hasComponent """جمع الأحاديث دون تمحيص"""@ar ;
    hesin:hasComponent """تشبيه المحدثين بالصحفيين"""@ar ;
    hesin:hasComponent """خلق الكذب وخلوده"""@ar ;
    hesin:hasComponent """الاهتمام بالحفظ دون النقد"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_10 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C056 a hesin:Concept ;
    rdfs:label """نقد منهج أصول الفقه"""@ar ;
    hesin:definition """نقد لمنهج أصول الفقه الذي فصل القضايا اللغوية (الأمر والنهي، العام والخاص...) عن أصولها اللغوية الطبيعية، مما أدى إلى تعقيد الفهم وإبعاد الناس عن الفهم الطبيعي للقرآن."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """فعندما جاءوا يأخذون عناوين معينة، مثلاً عندما تلاحظ أصول الفقه، يوجد فيه عناوين هي عناوين أساساً هي من داخل أساليب اللغة... فصلوها، أعطوها اصطلاحات أخرى، تعريفات أخرى، بحثوها بشكل آخر."""@ar ;
    hesin:actions """الرجوع إلى الفهم الطبيعي للغة العربية في فهم القرآن."""@ar ;
    hesin:hasSynonym """أصول الفقه"""@ar ;
    hesin:hasSynonym """منهج الاستنباط الفردي"""@ar ;
    hesin:hasComponent """فصل القضايا عن أصولها اللغوية"""@ar ;
    hesin:hasComponent """وضع اصطلاحات معقدة"""@ar ;
    hesin:hasComponent """صعوبة الفهم الطبيعي"""@ar ;
    hesin:hasComponent """إبعاد الناس عن القرآن"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_10 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C057 a hesin:Concept ;
    rdfs:label """الفهم الطبيعي للقرآن"""@ar ;
    hesin:definition """فهم القرآن من خلال اللغة العربية وأساليبها الطبيعية، ومعايشة النصوص الأدبية العربية، لا من خلال الاصطلاحات المعقدة التي وضعها المتأخرون."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """لو تركت هي في موضوعها، لو تركت ضمن مباحث اللغة، ومن أساليب اللغة، ستقرأ اللغة أنت، تقرأ الشعر العربي، تقرأ النصوص العربية، تقرأ الأدب العربي، فتعرف أنت كيف كان العربي يخاطب الآخر."""@ar ;
    hesin:actions """تعلم اللغة العربية وأساليبها لفهم القرآن."""@ar ;
    hesin:hasSynonym """فهم اللغة العربية"""@ar ;
    hesin:hasSynonym """معايشة النصوص العربية"""@ar ;
    hesin:hasComponent """معايشة اللغة العربية"""@ar ;
    hesin:hasComponent """قراءة الشعر والأدب العربي"""@ar ;
    hesin:hasComponent """فهم أساليب التخاطب العربي"""@ar ;
    hesin:hasComponent """تجنب الاصطلاحات المعقدة"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_10 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C058 a hesin:Concept ;
    rdfs:label """القرآن حمال أوجه"""@ar ;
    hesin:definition """ادعاء باطل بأن القرآن يحتمل معاني متعددة متعارضة، ويمكن تأويله حسب الأهواء، وهذا يناقض كونه كتابًا محكمًا لا يأتيه الباطل."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لاحظ النظرة هذه! ما تركه المذيع أبداً يقرأ آية... القرآن حمّال أوجه... هذا ما هو صحيح، القرآن ما يتلون مع كل مزاج... وإلا لكان القرآن مداهن، مجامل، لا يوثق به."""@ar ;
    hesin:actions """رفض ادعاء تعدد المعاني المتعارضة، والبحث عن المعنى الواحد المتكامل."""@ar ;
    hesin:hasSynonym """احتمالية القرآن"""@ar ;
    hesin:hasSynonym """تعدد المعاني المتعارضة"""@ar ;
    hesin:hasComponent """ادعاء تعدد المعاني المتعارضة"""@ar ;
    hesin:hasComponent """إمكانية التأويل حسب الأهواء"""@ar ;
    hesin:hasComponent """فقدان الثقة بالقرآن"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_10 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C059 a hesin:Concept ;
    rdfs:label """بعثرة الناس وتشتتهم"""@ar ;
    hesin:definition """نتيجة منهج الاستنباط الفردي والاجتهاد الشخصي، الذي يؤدي إلى تعدد الآراء والمواقف، مما يشتت الأمة ويضعفها."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """الطريقة الأخرى تؤدي إلى بعثرة الناس، وتعدد الرؤى تتعدد الأقوال، تعدد المواقف، تشتت الناس، يغرقون هم في صراع فيما بينهم."""@ar ;
    hesin:actions """العمل على توحيد المنهج لتحقيق الوحدة."""@ar ;
    hesin:hasSynonym """تعدد الآراء"""@ar ;
    hesin:hasSynonym """اختلاف العلماء"""@ar ;
    hesin:hasComponent """تعدد الآراء والمواقف"""@ar ;
    hesin:hasComponent """الاختلاف والصراع الداخلي"""@ar ;
    hesin:hasComponent """ضعف الأمة وتفرقها"""@ar ;
    hesin:hasComponent """فقدان الوحدة"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_10 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C060 a hesin:Concept ;
    rdfs:label """وحدة الأمة والمنهج"""@ar ;
    hesin:definition """النتيجة الطبيعية للمنهج القرآني الصحيح هي بناء أمة واحدة ذات منهج واحد وقيادة واحدة، وليس تعدد الآراء والمواقف."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """الطريقة هذه التي يحكي لك عنها تجدها هي الطريقة التي يقدم على أساسها بناء كيان واحد، أمة واحدة بكل ما تعنيه الكلمة، منهج واحد، قيادة واحدة."""@ar ;
    hesin:actions """العمل على توحيد الأمة وفق المنهج القرآني."""@ar ;
    hesin:hasSynonym """كيان واحد"""@ar ;
    hesin:hasSynonym """أمة واحدة"""@ar ;
    hesin:hasSynonym """منهج واحد"""@ar ;
    hesin:hasComponent """كيان واحد"""@ar ;
    hesin:hasComponent """منهج واحد"""@ar ;
    hesin:hasComponent """قيادة واحدة"""@ar ;
    hesin:hasComponent """مواقف واحدة"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_10 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C061 a hesin:Concept ;
    rdfs:label """القراءات القرآنية"""@ar ;
    hesin:definition """الاختلافات في تلاوة القرآن (كمالك/ملك، تعقلون/يعقلون) والتي لا تؤثر على النص القرآني الجوهري، وهي غالبًا من صنع الافتراضات المتأخرة."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """القراءات هي من الخبصة التي عملوها، هي من الإفتراضات التي عملوها، لكن القراءات ما كانت بالشكل الذي يؤثر على النص القرآني نهائياً."""@ar ;
    hesin:actions """عدم إبراز القراءات للناس بطريقة تثير الشك، والتركيز على النص الواحد."""@ar ;
    hesin:hasSynonym """القراءات السبع"""@ar ;
    hesin:hasSynonym """اختلاف القراءات"""@ar ;
    hesin:hasComponent """اختلافات في الضبط (الحركات)"""@ar ;
    hesin:hasComponent """اختلافات في الحروف أحيانًا"""@ar ;
    hesin:hasComponent """عدم التأثير على المعنى الجوهري"""@ar ;
    hesin:hasComponent """محدودية نطاق الاختلاف"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_11 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C062 a hesin:Concept ;
    rdfs:label """السنة النبوية"""@ar ;
    hesin:definition """كلام رسول الله (صلى الله عليه وآله) كان يدور حول القرآن ويقدم معانيه وتوجيهاته، وليس نصوصًا ملزمة بالحرف كما القرآن، ولم يُكتب في زمنه، وروي بالمعنى مما أدى إلى دخول التحريف."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """المسألة لو كانت بالشكل هذا: أن رسول الله عندما كان يتحدث مع الناس هو يعتبر كلامه نصوص كنصوص القرآن يجب أن تدون للأمة؛ لكان هو أول من يجب عليه أن يقوم بهذه المهمة."""@ar ;
    hesin:actions """عرض الأحاديث على القرآن، وقبول ما وافقه."""@ar ;
    hesin:hasSynonym """كلام رسول الله"""@ar ;
    hesin:hasSynonym """الأحاديث النبوية"""@ar ;
    hesin:hasComponent """كلام النبي حول القرآن"""@ar ;
    hesin:hasComponent """إيصال المعاني والمقاصد"""@ar ;
    hesin:hasComponent """عدم تدوين النص الحرفي"""@ar ;
    hesin:hasComponent """الرواية بالمعنى"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_11 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C063 a hesin:Concept ;
    rdfs:label """السنة عند السنية"""@ar ;
    hesin:definition """المفهوم السني للسنة الذي يعتبرها مصدرًا مستقلاً بذاته، ملزمًا كالقرآن، ويعتمد على كتب حديث مدونة بعد قرون من وفاة النبي."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """موضوع السنة، أن السنة هي هذه الأحاديث، هذه الروايات، هذه الكتب: البخاري، ومسلم، وكذا، وكذا.. هذه هي السنة!! وأنت ملزم بهذه كما أنت ملزم بالقرآن."""@ar ;
    hesin:actions """رفض اعتبار السنة مصدرًا مستقلاً، وعرضها على القرآن."""@ar ;
    hesin:hasSynonym """كتب الحديث"""@ar ;
    hesin:hasSynonym """البخاري ومسلم"""@ar ;
    hesin:hasSynonym """الأحاديث المدونة"""@ar ;
    hesin:hasComponent """السنة مصدر مستقل"""@ar ;
    hesin:hasComponent """الإلزام بها كالقرآن"""@ar ;
    hesin:hasComponent """الاعتماد على كتب متأخرة"""@ar ;
    hesin:hasComponent """تقديم السنة على القرآن أحيانًا"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_11 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C064 a hesin:Concept ;
    rdfs:label """السنة المصدر الثاني"""@ar ;
    hesin:definition """مفهوم خاطئ يرى أن السنة مصدر ثانٍ للتشريع، وأن القرآن محتاج إلى السنة لبيانه، مما يؤدي إلى تقديم الروايات على النص القرآني أحيانًا."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """جامعة الإيمان في صنعاء معها ملزمة في هذا الموضوع، كلام سيء يقول فيها: القرآن أحوج إلى السنة من السنة إلى القرآن!! بالعبارات هذه؛ ليشدك إلى الأحاديث، والروايات، ويخليك بمعزل عن النص القرآني."""@ar ;
    hesin:actions """عدم قبول أي رواية تخالف القرآن."""@ar ;
    hesin:hasSynonym """السنة مبينة للقرآن"""@ar ;
    hesin:hasSynonym """القرآن أحوج إلى السنة"""@ar ;
    hesin:hasComponent """السنة مصدر للتشريع"""@ar ;
    hesin:hasComponent """القرآن يحتاج إلى السنة"""@ar ;
    hesin:hasComponent """تقديم الروايات على القرآن"""@ar ;
    hesin:hasComponent """إبعاد الناس عن القرآن"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_11 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C065 a hesin:Concept ;
    rdfs:label """البيان لا يعارض المبين"""@ar ;
    hesin:definition """قاعدة منهجية أساسية تقول: إن البيان (السنة) لا يمكن أن يعارض المبين (القرآن)، فالسنة هي تفسير للقرآن، وأي رواية تخالف القرآن لا يمكن قبولها."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """البيان لا يجوز أن يكون معارضاً للمبيَّن، هذا ما يسمى تفسير، ولا يسمى بيان."""@ar ;
    hesin:actions """عرض كل رواية على القرآن، وقبول ما وافقه."""@ar ;
    hesin:hasSynonym """السنة لا تعارض القرآن"""@ar ;
    hesin:hasSynonym """التفسير لا يناقض المفسر"""@ar ;
    hesin:hasComponent """السنة تفسير للقرآن"""@ar ;
    hesin:hasComponent """عدم جواز المعارضة"""@ar ;
    hesin:hasComponent """عرض السنة على القرآن"""@ar ;
    hesin:hasComponent """رفض المخالف"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_11 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C066 a hesin:Concept ;
    rdfs:label """الوضعية المثالية للعمل الإسلامي"""@ar ;
    hesin:definition """هي الظروف المثالية التي تتيح للحركة الإسلامية العمل والتثقف والطرح بشكل متكامل، دون ضغوط الاحتلال أو التبعية التي تؤطر المنطق وتحد من الحرية."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """الوضعية التي نحن فيها الآن من أرقى، وأفضل الوضعيات على الإطلاق... شواهد من حولك، وكلها ليست بالشكل الذي تكون ضاغط عليك."""@ar ;
    hesin:actions """استثمار الظروف المثالية للتثقيف والتأهيل."""@ar ;
    hesin:hasSynonym """الوضعية غير المضغوطة"""@ar ;
    hesin:hasSynonym """الحرية في الطرح"""@ar ;
    hesin:hasComponent """غياب الضغط الخارجي"""@ar ;
    hesin:hasComponent """حرية الطرح المتكامل"""@ar ;
    hesin:hasComponent """تفرغ للتثقيف والتأهيل"""@ar ;
    hesin:hasComponent """وجود شواهد من الواقع"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_12 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C067 a hesin:Concept ;
    rdfs:label """الوضعية المضغوطة (الاحتلال)"""@ar ;
    hesin:definition """الظروف التي يفرض فيها الاحتلال أو الضغط الخارجي منطقًا محددًا على الحركات الإسلامية، فيؤطر تفكيرها وطرحها في إطار ضيق، ويحرمها من التكامل والشمولية."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لو أنك في وضعية محتل لكانت ذهنيتك ذهنية رفع محتل، تفكيرك تفكير رفع محتل، ربما تنسى تأهيل نفسك للرؤية العامة."""@ar ;
    hesin:actions """تجنب التأطير الضيق، والحفاظ على الرؤية العامة."""@ar ;
    hesin:hasSynonym """منطق الاحتلال"""@ar ;
    hesin:hasSynonym """التأطير بالواقع"""@ar ;
    hesin:hasComponent """التركيز على رفع الاحتلال فقط"""@ar ;
    hesin:hasComponent """نسيان الرؤية العامة"""@ar ;
    hesin:hasComponent """التأطير بالواقع المفروض"""@ar ;
    hesin:hasComponent """فقدان الشمولية"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_12 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C068 a hesin:Concept ;
    rdfs:label """التثقيف القرآني المتكامل"""@ar ;
    hesin:definition """بناء ثقافة قرآنية شاملة تمكن الإنسان من مواجهة الحرب الشاملة على الإسلام، وليس فقط التعامل مع القضايا الجزئية المحدودة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """نثقف أنفسنا ثقافة نستطيع أن نواجه الحرب التي هي حرب على الإسلام، الإسلام، ومسلمين، مسلمين، ليس فقط لبنان."""@ar ;
    hesin:actions """بناء برامج ثقافية شاملة تغطي كل المجالات."""@ar ;
    hesin:hasSynonym """ثقافة قرآنية"""@ar ;
    hesin:hasSynonym """طرح إسلامي عام"""@ar ;
    hesin:hasComponent """شمولية الرؤية"""@ar ;
    hesin:hasComponent """فهم حرب العدو الشاملة"""@ar ;
    hesin:hasComponent """الاستعداد لمواجهة شاملة"""@ar ;
    hesin:hasComponent """بناء قدرات ثقافية متكاملة"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_12 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C069 a hesin:Concept ;
    rdfs:label """الطرح الإسلامي العام"""@ar ;
    hesin:definition """هو الطرح الذي لا يقيد نفسه بإطار محلي أو ضيق، بل ينطلق من رؤية شاملة للإسلام كدين للعالمين، ويتحدى الشرعية التي يدعيها العدو لنفسه."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """أمامك مجال لتقدم طرحاً إسلامياً عاماً... لماذا لا تتذكر تقول للأمريكي... لنا شرعية أن نتحرك في مواجهة عدو الله أينما كان."""@ar ;
    hesin:actions """بناء خطاب إسلامي عالمي لا يقيد بحدود ضيقة."""@ar ;
    hesin:hasSynonym """طرح متكامل"""@ar ;
    hesin:hasSynonym """رؤية شاملة"""@ar ;
    hesin:hasComponent """شمولية الرؤية"""@ar ;
    hesin:hasComponent """عدم التقيد بالحدود الضيقة"""@ar ;
    hesin:hasComponent """منافسة العدو في شرعيته"""@ar ;
    hesin:hasComponent """الانطلاق من الإسلام دينًا للعالمين"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_12 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C070 a hesin:Concept ;
    rdfs:label """تأطير الحركات الإسلامية"""@ar ;
    hesin:definition """هو التحديد الذي يفرضه الواقع (كالاحتلال، التبعية، التحالفات) على الحركات الإسلامية، فيجعلها تقدم الإسلام بشكل جزئي غير شامل."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هذه الحركات نفسها هي قد تُفرض عليها وضعية تؤطر منطقها، وتؤطر أسلوب عملها؛ فتراها في الأخير ليست حركة، هي تؤمن هي بأنها حركة لا تقدم الإسلام بالشكل العام في الساحة."""@ar ;
    hesin:actions """تجنب التأطير الضيق والعمل على الرؤية الشاملة."""@ar ;
    hesin:hasSynonym """تحديد الإطار"""@ar ;
    hesin:hasSynonym """منطق المقاومة المحلية"""@ar ;
    hesin:hasComponent """منطق مقاومة الاحتلال فقط"""@ar ;
    hesin:hasComponent """فقدان الرؤية الشاملة"""@ar ;
    hesin:hasComponent """عدم تقديم الإسلام العام"""@ar ;
    hesin:hasComponent """التأثر بالتحالفات"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_12 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C071 a hesin:Concept ;
    rdfs:label """التبعية للداعمين"""@ar ;
    hesin:definition """حالة من التبعية للداعمين الماليين أو السياسيين تؤدي إلى تأطير الخطاب والمنطق، وفقدان حرية التعبير والتحرك."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أصبحت مشاريعك مفصلة على أساس دعمه ومساندته... لا يرون أنفسهم مدينين لأحد... لو كنت مثلاً مدين لمساندة طرف آخر لكان هذا سيحكم خطابك، يحكم منطقك."""@ar ;
    hesin:actions """العمل على الاستقلال المالي والفكري لتجنب التبعية."""@ar ;
    hesin:hasSynonym """المديونية"""@ar ;
    hesin:hasSynonym """التأثر بالداعمين"""@ar ;
    hesin:hasComponent """المديونية للداعمين"""@ar ;
    hesin:hasComponent """تأطير الخطاب حسب رغباتهم"""@ar ;
    hesin:hasComponent """فقدان حرية النقد"""@ar ;
    hesin:hasComponent """إضعاف الموقف"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_12 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C072 a hesin:Concept ;
    rdfs:label """التراجع والمساومة"""@ar ;
    hesin:definition """نتيجة التبعية والضغوط، حيث تضطر الحركات إلى التراجع عن مواقفها وشعاراتها الأساسية، والمساومة على مبادئها."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """شعار: [ الموت لأمريكا الموت لإسرائيل ] هل سمعناه في الخطاب الأخير في عيد النصر؟... جاء ضغط ربما من جانب إيران... الشعار ربما لم يعد يرفعه!"""@ar ;
    hesin:actions """الحفاظ على الثبات وعدم المساومة على المبادئ."""@ar ;
    hesin:hasSynonym """التفريط"""@ar ;
    hesin:hasSynonym """التخلي عن الشعارات"""@ar ;
    hesin:hasComponent """التراجع عن الشعارات"""@ar ;
    hesin:hasComponent """المساومة على المبادئ"""@ar ;
    hesin:hasComponent """الضعف أمام الضغوط"""@ar ;
    hesin:hasComponent """فقدان الثبات"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_12 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C073 a hesin:Concept ;
    rdfs:label """الاستقلال المالي والفكري"""@ar ;
    hesin:definition """حالة من عدم التبعية لأي طرف خارجي، تتيح للحركة الإسلامية حرية الطرح والتعبير والنقد، دون قيود أو محاذير."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """تجد عندما يكون الناس معتمدين على أنفسهم سيتمكنون أن يكون عملهم متكاملاً، يكون طرحهم متكاملاً، لا يرون أنفسهم مدينين لأحد."""@ar ;
    hesin:actions """العمل على تحقيق الاستقلال المالي والفكري."""@ar ;
    hesin:hasSynonym """عدم التبعية"""@ar ;
    hesin:hasSynonym """الاعتماد على النفس"""@ar ;
    hesin:hasComponent """الاعتماد على الذات ماليًا"""@ar ;
    hesin:hasComponent """الاستقلال الفكري"""@ar ;
    hesin:hasComponent """حرية النقد"""@ar ;
    hesin:hasComponent """سلامة الموقف"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_12 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C074 a hesin:Concept ;
    rdfs:label """الثبات والاستمرارية"""@ar ;
    hesin:definition """القدرة على الصمود والثبات على المبادئ في ظل الضغوط، وعدم التفريط في عناصر القوة."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """في الوقت الحرج ترى مساومة عليك من هذا النوع، هو يقول: يجب أن نفهم، أن نحتفظ بعناصر قوتنا."""@ar ;
    hesin:actions """بناء أنظمة تدعم الثبات والاستمرارية."""@ar ;
    hesin:hasSynonym """الصمود"""@ar ;
    hesin:hasSynonym """عدم المساومة"""@ar ;
    hesin:hasComponent """الصمود في وجه الضغوط"""@ar ;
    hesin:hasComponent """عدم التفريط في المبادئ"""@ar ;
    hesin:hasComponent """الحفاظ على عناصر القوة"""@ar ;
    hesin:hasComponent """الاستمرارية في المسار"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_12 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C075 a hesin:Concept ;
    rdfs:label """طبيعة الإنسان الأصلية"""@ar ;
    hesin:definition """الإنسان بطبيعته الأصلية قابل للهدى ومتأثر بالإحسان، لكن تراكم الضلال والهوى قد يجعله يصل إلى حالة من الظلم والكفر تصبح كأنها طبيعة ثانوية."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """الإنسان بطبيعته أليس هو يتأثر بالإحسان؟ يتأثر بالإحسان، لكن عندما يفهم الإحسان... ليس بطبيعته، غريزته التي خلق عليها، ظلوم كفار."""@ar ;
    hesin:actions """التركيز على قدرة الإنسان على التغيير والتطهر."""@ar ;
    hesin:hasSynonym """الفطرة"""@ar ;
    hesin:hasSynonym """قابلية الهدى"""@ar ;
    hesin:hasComponent """قابلية التأثر بالإحسان"""@ar ;
    hesin:hasComponent """الطبيعة الأصلية قابلة للهدى"""@ar ;
    hesin:hasComponent """تراكم الضلال يخلق طبيعة ثانوية"""@ar ;
    hesin:hasComponent """الهدى يزكي النفس"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_13 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C076 a hesin:Concept ;
    rdfs:label """الطبيعة المترسخة (الضلال)"""@ar ;
    hesin:definition """حالة ترسخ الضلال في النفس نتيجة الإعراض المستمر، فتصبح كأنها طبيعة ثانوية تغطي على الفطرة الأصلية."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """أحيانا قد يصل الناس تترسخ لديهم حالة فتبدو وكأنها غريزية، أو طبيعية، في فترة مثلاً الضلال الذي تراكم حتى رسخ لديهم أشياء فأصبحت وكأنها حالة."""@ar ;
    hesin:actions """العمل على إزالة الطبقات المتراكمة من الضلال."""@ar ;
    hesin:hasSynonym """ظلوم كفار"""@ar ;
    hesin:hasSynonym """النفس المطبعة على الضلال"""@ar ;
    hesin:hasComponent """تراكم الضلال"""@ar ;
    hesin:hasComponent """الرسوخ في النفس"""@ar ;
    hesin:hasComponent """الظهور كطبيعة"""@ar ;
    hesin:hasComponent """إمكانية التغيير بالهدى"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_13 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C077 a hesin:Concept ;
    rdfs:label """فاعلية الهدى"""@ar ;
    hesin:definition """الهدى الإلهي قادر على تزكية النفوس وتغييرها من حالة إلى حالة أفضل، وهو فاعل ومؤثر في واقع الإنسان."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """الهدى يزكي النفوس فتصبح نفوساً طاهرة، يصبح عنصر خير، ويأتي الخير على يديه، سواء فرد، أو مجتمع، نتيجة هدى الله."""@ar ;
    hesin:actions """الثقة في قدرة الهدى على التغيير."""@ar ;
    hesin:hasSynonym """تأثير الهدى"""@ar ;
    hesin:hasSynonym """قدرة القرآن على التغيير"""@ar ;
    hesin:hasComponent """تزكية النفوس"""@ar ;
    hesin:hasComponent """تغيير الواقع"""@ar ;
    hesin:hasComponent """جعل الإنسان عنصر خير"""@ar ;
    hesin:hasComponent """التأثير في الفرد والمجتمع"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_13 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C078 a hesin:Concept ;
    rdfs:label """الحق يدمغ الباطل"""@ar ;
    hesin:definition """الحق قوي بطبيعته، والباطل ضعيف لا يثبت أمام الحق. إذا انطلق أهل الحق بالحق، فإنه سيدمغ الباطل ويزهقه."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{بَلْ نَقْذِفُ بِالْحَقِّ عَلَى الْبَاطِلِ فَيَدْمَغُهُ فَإِذَا هُوَ زَاهِقٌ}... الحق هو القوي، والباطل هو الضعيف."""@ar ;
    hesin:actions """الثقة في قوة الحق وعدم اليأس."""@ar ;
    hesin:hasSynonym """الحق قوي"""@ar ;
    hesin:hasSynonym """الباطل زاهق"""@ar ;
    hesin:hasComponent """قوة الحق الذاتية"""@ar ;
    hesin:hasComponent """ضعف الباطل الذاتي"""@ar ;
    hesin:hasComponent """دمج الحق للباطل"""@ar ;
    hesin:hasComponent """زهوق الباطل"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_14 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C079 a hesin:Concept ;
    rdfs:label """منطق ضعف أهل الحق"""@ar ;
    hesin:definition """مفهوم خاطئ يروج أن أهل الحق دائمًا ضعفاء لا ينتصرون، وأن الباطل هو الراسخ في الدنيا، وهو منطق مخالف للقرآن."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """حتى تجد من يقول لك: أهل الحق دائماً يكونون ضعافاً، وأهل الحق ما يسبر لهم شيء... هذا منطق شيطاني هذا حقيقة."""@ar ;
    hesin:actions """رفض منطق ضعف الحق والثقة في النصر."""@ar ;
    hesin:hasSynonym """أهل الحق لا ينتصرون"""@ar ;
    hesin:hasSynonym """الحق ضعيف"""@ar ;
    hesin:hasComponent """تشاؤم من قدرة الحق"""@ar ;
    hesin:hasComponent """تعظيم الباطل"""@ar ;
    hesin:hasComponent """اليأس من النصر"""@ar ;
    hesin:hasComponent """الانسحاب من المواجهة"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_14 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C080 a hesin:Concept ;
    rdfs:label """استبانة سبيل المجرمين"""@ar ;
    hesin:definition """حركة المجرمين وأعداء الإسلام في الواقع تكشف طريقتهم ونواياهم، مما يساعد على تنبيه الناس وتوعيتهم."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """من خلال مواقفهم تستطيع أن توعي الناس: لاحظوا الباطل كيف يكون، لاحظوا أهل الباطل كيف يكونون؟ لاحظوا ماذا يريدون أن يصنعوا؟"""@ar ;
    hesin:actions """تحليل حركة الأعداء لاستخلاص الدروس والعبر."""@ar ;
    hesin:hasSynonym """تجلي الباطل"""@ar ;
    hesin:hasSynonym """كشف نوايا الأعداء"""@ar ;
    hesin:hasComponent """كشف نوايا الأعداء"""@ar ;
    hesin:hasComponent """توضيح طرقهم"""@ar ;
    hesin:hasComponent """تنبيه الناس"""@ar ;
    hesin:hasComponent """تعزيز موقف الحق"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_14 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C081 a hesin:Concept ;
    rdfs:label """النصر للحق"""@ar ;
    hesin:definition """النصر حليف الحق بطبيعته، وأهل الحق إذا تحركوا وفق منهج الله فإن النصر سيكون لهم."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """الحق المبين الغالب... يتحدث بالغلبة لجانب الحق، النصر بجانب الحق، القوة لجانب الحق."""@ar ;
    hesin:actions """الثقة في نصر الله وعدم اليأس."""@ar ;
    hesin:hasSynonym """غلبة الحق"""@ar ;
    hesin:hasSynonym """نصر الله"""@ar ;
    hesin:hasComponent """الحق غالب بطبيعته"""@ar ;
    hesin:hasComponent """النصر حليف الحق"""@ar ;
    hesin:hasComponent """القوة لجانب الحق"""@ar ;
    hesin:hasComponent """الغلبة لأهل الحق"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_14 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C082 a hesin:Concept ;
    rdfs:label """الاختصاص الإلهي بالعلم"""@ar ;
    hesin:definition """هناك علوم وحقائق في القرآن لا يطلع عليها إلا من اختصهم الله بها، وهذا الاختصاص ليس لتميز شخصي، بل لدورهم في هداية الناس."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """أخر باطنة خفية إلا عمن خصه الله بمستورها... من اختصه الله بعلمها... اختصاص لمن له دور يختص."""@ar ;
    hesin:actions """الرجوع إلى أهل الاختصاص في فهم القرآن."""@ar ;
    hesin:hasSynonym """من خصه الله"""@ar ;
    hesin:hasSynonym """علماء آل البيت"""@ar ;
    hesin:hasComponent """وجود علوم خفية"""@ar ;
    hesin:hasComponent """اختصاص الله بها من يشاء"""@ar ;
    hesin:hasComponent """الغاية هي هداية الناس"""@ar ;
    hesin:hasComponent """دور في قيادة الأمة"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_15 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C083 a hesin:Concept ;
    rdfs:label """فهم كل الناس للقرآن بالتساوي"""@ar ;
    hesin:definition """مفهوم خاطئ يفترض أن كل إنسان مكلف بفهم القرآن بالتساوي، وأن الاجتهاد الفردي هو السبيل لفهمه، وهو ما أدى إلى تعدد الآراء والاختلاف."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هكذا يقولون؛ على أساس أنه مكلف به، فكيف يكون مكلفاً به ولا يفهمه؟ بالنظرة الفردية... إن كنتم تفهمون القرآن فعلاً فإما أن يكون القرآن هو نفسه مختلف وهو الذي يجعلكم مختلفين، أو أنكم لا تفهمون القرآن."""@ar ;
    hesin:actions """الرجوع إلى أهل العلم المختصين لفهم القرآن."""@ar ;
    hesin:hasSynonym """الاجتهاد الفردي"""@ar ;
    hesin:hasSynonym """كل إنسان يفهم القرآن"""@ar ;
    hesin:hasComponent """مساواة الجميع في الفهم"""@ar ;
    hesin:hasComponent """الاجتهاد الفردي"""@ar ;
    hesin:hasComponent """تعدد الآراء"""@ar ;
    hesin:hasComponent """فقدان الوحدة"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_15 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C084 a hesin:Concept ;
    rdfs:label """العلم للهداية لا للتميز"""@ar ;
    hesin:definition """العلم والاختصاص الذي يمنحه الله لبعض عباده ليس لتميزهم الشخصي، بل لهداية الناس وخدمتهم."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """اختصاص هذا بكله أليس من اجل الناس؟ يعني: هو في إطار هداية الناس... هذا العالم هو حقي، أليس معناه في الأخير هكذا؟"""@ar ;
    hesin:actions """نشر العلم وعدم احتكاره."""@ar ;
    hesin:hasSynonym """العالم لهداية الناس"""@ar ;
    hesin:hasSynonym """العلم من أجل الناس"""@ar ;
    hesin:hasComponent """الغائية في العلم (هداية الناس)"""@ar ;
    hesin:hasComponent """عدم الاحتكار أو التميز الشخصي"""@ar ;
    hesin:hasComponent """العلم حق للناس"""@ar ;
    hesin:hasComponent """دور العالم في خدمة الأمة"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_15 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C085 a hesin:Concept ;
    rdfs:label """احتكار العلم والتميز"""@ar ;
    hesin:definition """منهج خاطئ يقدم العلم والاختصاص الإلهي كأنه تميز شخصي وحق خاص، مما يثير تساؤلات ويبعد الناس عن أهل العلم."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """تكون مشكلة لو أن المسالة فردية، وهذا متميز على هذا... بالشكل الذي يقدم القضية وكأنها اختصاص شخصي [أما احنا شفتوا أما أنتم لا ] مثل طريقة الأولاد الصغار."""@ar ;
    hesin:actions """تقديم العلم كوسيلة لخدمة الناس لا تميز."""@ar ;
    hesin:hasSynonym """نحن ونحن"""@ar ;
    hesin:hasSynonym """اختصاص شخصي"""@ar ;
    hesin:hasComponent """تقديم الاختصاص كحق شخصي"""@ar ;
    hesin:hasComponent """إثارة التساؤلات"""@ar ;
    hesin:hasComponent """إبعاد الناس"""@ar ;
    hesin:hasComponent """فهم خاطئ للاختصاص"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_15 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C086 a hesin:Concept ;
    rdfs:label """منهج الإمام القاسم في التعامل مع القرآن"""@ar ;
    hesin:definition """منهج الإمام القاسم في فهم القرآن يقوم على النظر إلى القرآن ككتاب هداية شامل، والتعامل مع آياته بصراحة دون تأويلات، والتركيز على البعد التربوي والعملي."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هذا الكتاب، [مديح القرآن] يعطي رؤية صحيحة عن القرآن، مفاهيم صحيحة عن القرآن... هو نظرة أهل البيت، ورؤية أهل البيت، وتوصيات، وتوجيهات أهل البيت."""@ar ;
    hesin:actions """اعتماد منهج الإمام القاسم كإطار لفهم القرآن."""@ar ;
    hesin:hasSynonym """رؤية أهل البيت"""@ar ;
    hesin:hasSynonym """الكتابة التي تكشف رؤية أهل البيت"""@ar ;
    hesin:hasComponent """القرآن كتاب هداية شامل"""@ar ;
    hesin:hasComponent """التعامل مع الآيات بصراحة"""@ar ;
    hesin:hasComponent """التركيز على البعد التربوي"""@ar ;
    hesin:hasComponent """رفض التأويلات المنحرفة"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_16 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C087 a hesin:Concept ;
    rdfs:label """بكاء الإمام القاسم على الأمة"""@ar ;
    hesin:definition """حالة من التألم العميق على حال الأمة التي تهجر القرآن ولا تعمل به، وهي تعبير عن شدة الحرص على هداية الناس."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """الإمام القاسم عندما كان يعرف القرآن على هذا الشكل، ويعرف الناس على هذا الشكل كان يبكي، كان معروف بأنه كان كثير البكاء لماذا؟ بِيِن يطَّم واحد على ما بين نقول."""@ar ;
    hesin:actions """استشعار المسؤولية والحزن على هجر القرآن."""@ar ;
    hesin:hasSynonym """تألم على حال الأمة"""@ar ;
    hesin:hasSynonym """البكاء من أجل القرآن"""@ar ;
    hesin:hasComponent """التألم على حال الأمة"""@ar ;
    hesin:hasComponent """الحرص على هداية الناس"""@ar ;
    hesin:hasComponent """الرغبة في رجوع الأمة إلى القرآن"""@ar ;
    hesin:hasComponent """الشعور بالمسؤولية"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_16 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C088 a hesin:Concept ;
    rdfs:label """الدين للحياة"""@ar ;
    hesin:definition """الدين الإسلامي ليس للآخرة فقط، بل هو للحياة الدنيا أيضًا، فهو منهج شامل يجلب الخير والبركة والسعادة في الدنيا قبل الآخرة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """الدين هو للحياة الدنيا وللحياة الأخرى، لسعادة الناس، لسعادة البشر في الحياة الدنيا وفي الحياة الأخرى."""@ar ;
    hesin:actions """تقديم الدين كمنهج شامل للحياة، لا كمجرد عبادات للآخرة."""@ar ;
    hesin:hasSynonym """الدين يصلح الدنيا والآخرة"""@ar ;
    hesin:hasSynonym """الدين يجلب الخير"""@ar ;
    hesin:hasComponent """الدين للحياة الدنيا والآخرة معًا"""@ar ;
    hesin:hasComponent """الدين يجلب الخير والبركة"""@ar ;
    hesin:hasComponent """الدين يصلح حياة الناس"""@ar ;
    hesin:hasComponent """السعادة في الدنيا من ثمار الدين"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_17 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C089 a hesin:Concept ;
    rdfs:label """الفصل بين الدين والدنيا"""@ar ;
    hesin:definition """مفهوم خاطئ يفصل الدين عن شؤون الحياة الدنيا، ويظن أن الاهتمام بالدين سيضيع المصالح الدنيوية، وهذا مخالف لحقيقة الدين الذي يصلح الدنيا والآخرة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """البعض يتصور أنها ستضيع مصالحهم في ظل الاهتمام بدينهم! هذا ما هو صحيح، إن أصل المسألة ما هو صحيح."""@ar ;
    hesin:actions """تصحيح مفهوم أن الدين يضيع الدنيا، وتأكيد أنه يصلحها."""@ar ;
    hesin:hasSynonym """الدين للآخرة فقط"""@ar ;
    hesin:hasSynonym """الدنيا بعيدًا عن الدين"""@ar ;
    hesin:hasComponent """الاعتقاد بأن الدين للآخرة فقط"""@ar ;
    hesin:hasComponent """الخوف من ضياع المصالح الدنيوية"""@ar ;
    hesin:hasComponent """الفصل بين العبادة والحياة"""@ar ;
    hesin:hasComponent """تضييق مجال الدين"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_17 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C090 a hesin:Concept ;
    rdfs:label """الدين للآخرة فقط"""@ar ;
    hesin:definition """مفهوم منحرف يصور الدين وكأنه لا علاقة له بالدنيا، وأن مهمته فقط إعداد الناس للآخرة، مما يؤدي إلى إهمال الحياة الدنيا والانشغال عنها."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """من جريمة من قدموا الدين وكأن ما له علاقة بالحياة هذه! جعلوا البشر ما يتطلعون إليه، وكأنه فقط ليوم القيامة!"""@ar ;
    hesin:actions """تقديم نماذج عملية من السيرة النبوية في العمل للدنيا والآخرة."""@ar ;
    hesin:hasSynonym """ترك الدنيا للدين"""@ar ;
    hesin:hasSynonym """الرهبانية"""@ar ;
    hesin:hasComponent """حصر الدين في العبادات"""@ar ;
    hesin:hasComponent """عدم ربط الدين بالحياة العملية"""@ar ;
    hesin:hasComponent """إهمال قضايا الدنيا"""@ar ;
    hesin:hasComponent """فقدان القدوة العملية"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_17 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C091 a hesin:Concept ;
    rdfs:label """عمارة الدنيا بالدين"""@ar ;
    hesin:definition """تشريعات الدين وأحكامه مصممة لدفع الناس إلى عمارة الدنيا وتطويرها، من خلال تحميلهم المسؤولية والعمل في كل المجالات."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """تجد كثيراً من تشريعاته وبعضها من الأسس الهامة هي بالشكل الذي يدفع الناس إلى أن يعمروا الدنيا. مثلاً قضية الجهاد... أن تحمل الناس مسئولية الدين، هذه النقطة لوحدها تتكفل بعمارة الدنيا كلها."""@ar ;
    hesin:actions """تقديم الدين كدافع للعمل والتقدم في الحياة."""@ar ;
    hesin:hasSynonym """الدين يعمر الحياة"""@ar ;
    hesin:hasSynonym """الدين سبب التقدم"""@ar ;
    hesin:hasComponent """الجهاد يدفع إلى العمل في كل المجالات"""@ar ;
    hesin:hasComponent """الميراث ينظم المال ويحفز العمل"""@ar ;
    hesin:hasComponent """العبادات تنظم الحياة وتنميها"""@ar ;
    hesin:hasComponent """الالتزام بالدين يدفع للتقدم"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_17 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C092 a hesin:Concept ;
    rdfs:label """التخلف والضعف"""@ar ;
    hesin:definition """التخلف والضعف الذي تعاني منه الأمة الإسلامية سببه الإعراض عن الدين، وليس الدين نفسه، فالدين هو الذي يدفع لعمارة الدنيا والتقدم."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """التخلف الذي نحن فيه سببه أن ما هناك اهتمام بالدين! لما لم تكن مثلاً الدول مهتمة بأمر الدين، أهملت الدنيا، وأهملت الأمة."""@ar ;
    hesin:actions """ربط التخلف بالإعراض عن الدين، وليس بالدين نفسه."""@ar ;
    hesin:hasSynonym """التأخر"""@ar ;
    hesin:hasSynonym """الضعف الحضاري"""@ar ;
    hesin:hasComponent """الإعراض عن الدين"""@ar ;
    hesin:hasComponent """إهمال الدنيا"""@ar ;
    hesin:hasComponent """ضعف الأمة"""@ar ;
    hesin:hasComponent """تراجع الحضارة"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_17 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C093 a hesin:Concept ;
    rdfs:label """البركة الإلهية"""@ar ;
    hesin:definition """البركة هي الخير الإلهي الذي يزيد في الأشياء ويجعلها تنمو وتؤثر، وهي نتيجة طبيعية للالتزام بالدين والاتجاه إلى الله."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """اتجه إلى الدين والدين تجده كله متعلق بالحياة... تحصل الأشياء تلقائياً، يحصل الخير من جهة الله سبحانه وتعالى، تستقيم الحياة بدون ما يغرقوا هم في الموضوع."""@ar ;
    hesin:actions """الثقة في البركة الإلهية مع العمل الجاد."""@ar ;
    hesin:hasSynonym """الخير الإلهي"""@ar ;
    hesin:hasSynonym """النماء من الله"""@ar ;
    hesin:hasComponent """زيادة في الخير"""@ar ;
    hesin:hasComponent """نماء في الأعمال"""@ar ;
    hesin:hasComponent """تأثير أكبر من الجهد الظاهر"""@ar ;
    hesin:hasComponent """استقامة الحياة"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_17 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C094 a hesin:Concept ;
    rdfs:label """مرض القلب"""@ar ;
    hesin:definition """حالة غير طبيعية تصيب القلب البشري، تتجلى في مفاهيم مغلوطة، ورؤى خاطئة، ونفاق، وجبن، وغيرها من الأمراض الروحية التي تحول دون الانتفاع بالهدى."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """عبارة مرض هذه ترد في القرآن عبارة عامة, أنواع المرض كثيرة جداً في الإنسان. عندما يقول: مرض، تشمل نفاق، تشمل جبن, تشمل أشياء كثيرة من أنواع المرض, مفاهيم غلط, رؤى خطأ."""@ar ;
    hesin:actions """تشخيص أمراض القلب وعلاجها بالقرآن."""@ar ;
    hesin:hasSynonym """أمراض القلوب"""@ar ;
    hesin:hasSynonym """النفاق"""@ar ;
    hesin:hasSynonym """الجبن"""@ar ;
    hesin:hasSynonym """المفاهيم المغلوطة"""@ar ;
    hesin:hasComponent """مفاهيم خاطئة عن الله والدنيا"""@ar ;
    hesin:hasComponent """نفاق ورياء"""@ar ;
    hesin:hasComponent """جبن وضعف"""@ar ;
    hesin:hasComponent """عدم الاهتمام بقضايا الدين"""@ar ;
    hesin:hasComponent """غياب الشعور بالمسؤولية"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_18 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C095 a hesin:Concept ;
    rdfs:label """عدم زيادة الإيمان"""@ar ;
    hesin:definition """حالة من الجمود الروحي لا يزداد فيها الإيمان عند نزول الآيات القرآنية، بسبب غياب الاهتمام والشعور بالمسؤولية والروح العملية."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """كلنا نعرف أننا ما بين نزداد إيمان، لا نزداد إيمان بآيات هي هامة جداً؛ لأن عندنا مرض, ما هو المرض؟ ما عندنا اهتمام, ولا شعور بمسؤولية, ولا عنده روح عملية."""@ar ;
    hesin:actions """تنمية الاهتمام والشعور بالمسؤولية لزيادة الإيمان."""@ar ;
    hesin:hasSynonym """الإيمان لا يزيد"""@ar ;
    hesin:hasSynonym """الجمود الإيماني"""@ar ;
    hesin:hasComponent """عدم التأثر بالآيات"""@ar ;
    hesin:hasComponent """غياب الاهتمام"""@ar ;
    hesin:hasComponent """عدم الشعور بالمسؤولية"""@ar ;
    hesin:hasComponent """فقدان الروح العملية"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_18 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C096 a hesin:Concept ;
    rdfs:label """زيادة الرجس"""@ar ;
    hesin:definition """عندما يمر الإنسان المريض القلب على آيات القرآن دون أن يتأثر بها، فإن ذلك يزيده رجسًا وضلالًا، لأن عدم الاستفادة من الهدى يعني التخلف أكثر."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """فَأَمَّا الَّذِينَ فِي قُلُوبِهِم مَّرَضٌ فَزَادَتْهُمْ رِجْسًا إِلَى رِجْسِهِمْ... هذا المرض هو كثير فينا، هذا النوع من المرض، لا يعد واحد يلمس أهمية الآية، أهميتها."""@ar ;
    hesin:actions """تحذير الناس من خطورة المرور على الآيات دون استفادة."""@ar ;
    hesin:hasSynonym """زيادة الضلال"""@ar ;
    hesin:hasSynonym """تراكم الرجس"""@ar ;
    hesin:hasComponent """عدم الاستفادة من الآيات"""@ar ;
    hesin:hasComponent """تراكم الضلال"""@ar ;
    hesin:hasComponent """فقدان القدرة على التمييز"""@ar ;
    hesin:hasComponent """الانحدار الأخلاقي"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_18 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C097 a hesin:Concept ;
    rdfs:label """سلامة القلب"""@ar ;
    hesin:definition """حالة القلب السليم التي تتجلى في الاهتمام بالمسؤولية الدينية، والروح العملية، والتأثر بالآيات القرآنية، وزيادة الإيمان والمعرفة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """إذا عندك اهتمام بمسؤولية دينية, عندك روح عملية, من ترى الآية هامة جداً، هامة جداً, ولذيذة وتزداد إيماناً, وتزداد معرفة."""@ar ;
    hesin:actions """العمل على تحقيق سلامة القلب بالاهتمام والمسؤولية."""@ar ;
    hesin:hasSynonym """قلب سليم"""@ar ;
    hesin:hasSynonym """قلب يقظ"""@ar ;
    hesin:hasComponent """الاهتمام بالمسؤولية الدينية"""@ar ;
    hesin:hasComponent """الروح العملية"""@ar ;
    hesin:hasComponent """التأثر بالآيات"""@ar ;
    hesin:hasComponent """زيادة الإيمان والمعرفة"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_18 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C098 a hesin:Concept ;
    rdfs:label """زيادة الإيمان"""@ar ;
    hesin:definition """عندما يكون الإنسان صاحب اهتمام ومسؤولية وروح عملية، فإن آيات القرآن تزيده إيمانًا ومعرفة، وترفعه إلى مستويات أعلى من اليقين."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """عندك اهتمام بمسؤولية دينية, عندك روح عملية, من ترى الآية هامة جداً، هامة جداً, ولذيذة وتزداد إيماناً, وتزداد معرفة."""@ar ;
    hesin:actions """ربط الإيمان بالعمل والمسؤولية."""@ar ;
    hesin:hasSynonym """نمو الإيمان"""@ar ;
    hesin:hasSynonym """ازدياد اليقين"""@ar ;
    hesin:hasComponent """الاهتمام بالمسؤولية"""@ar ;
    hesin:hasComponent """الروح العملية"""@ar ;
    hesin:hasComponent """التأثر بالآيات"""@ar ;
    hesin:hasComponent """ازدياد اليقين والمعرفة"""@ar ;
    hesin:hasComponent """الاستبشار والفرح"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_18 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C099 a hesin:Concept ;
    rdfs:label """تحميل الله المسؤولية"""@ar ;
    hesin:definition """مفهوم منحرف يحمل الله سبحانه وتعالى مسؤولية ضعف الإنسان وانتشار الباطل، كأنه هو الذي طبع الحياة بطابع يغلب فيه الباطل، وهذا يتنافى مع عدل الله وحكمته."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """من أسوء الرجس انك في الأخير تحمل الباري المسؤولية، فكأنه هو الذي طبع الحياة بهذا الطابع السيئ، وهو الذي خلق الإنسان على هذه الحالة السيئة."""@ar ;
    hesin:actions """نقد المفاهيم التي تحمل الله مسؤولية الضعف البشري."""@ar ;
    hesin:hasSynonym """نسبة الضعف إلى الله"""@ar ;
    hesin:hasSynonym """الظلم في حق الله"""@ar ;
    hesin:hasComponent """نسبة ضعف الحق إلى الله"""@ar ;
    hesin:hasComponent """القول بأن الله طبع الدنيا للباطل"""@ar ;
    hesin:hasComponent """نفي حكمة الله عن خلقه"""@ar ;
    hesin:hasComponent """التبرير بالجبر والقدر"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_19 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C100 a hesin:Concept ;
    rdfs:label """تنزيه الله عن الظلم"""@ar ;
    hesin:definition """الاعتقاد بأن الله منزه عن الظلم، وأنه لا يخلق الشر لأجل الشر، ولا يطبع الحياة بطابع يغلب فيه الباطل، بل هو الحكيم العادل."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """هذا يتنافى مع قدسية الله, مع جلاله, مع حكمته, مع رحمته, مع ألوهيته, مع كل صفات الكمال, يتنافى تماماً."""@ar ;
    hesin:actions """الدفاع عن عدل الله وحكمته."""@ar ;
    hesin:hasSynonym """عدل الله"""@ar ;
    hesin:hasSynonym """حكمة الله"""@ar ;
    hesin:hasComponent """نفي الظلم عن الله"""@ar ;
    hesin:hasComponent """الإيمان بحكمة الله"""@ar ;
    hesin:hasComponent """الإيمان بعدل الله"""@ar ;
    hesin:hasComponent """رفض نسب الشر إلى الله"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_19 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C101 a hesin:Concept ;
    rdfs:label """طبيعة الإنسان القابلة للحق"""@ar ;
    hesin:definition """الإنسان بطبيعته الفطرية قابل للحق ويميل إليه، وما يظهر من ميل إلى الباطل هو نتيجة تربية خاطئة وتثقيف منحرف، وليس نتيجة طبيعة أصلية."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """غير صحيح، غير صحيح أن الإنسان بفطرته ما يعجبه إلا الباطل, الإنسان مظلوم, الإنسان كمجتمع ظلم على أيدي علماء السوء."""@ar ;
    hesin:actions """الثقة في قابلية الإنسان للحق مع العمل على إزالة العوائق."""@ar ;
    hesin:hasSynonym """فطرة الله"""@ar ;
    hesin:hasSynonym """قابلية الهدى"""@ar ;
    hesin:hasComponent """قابلية الإنسان للحق فطريًا"""@ar ;
    hesin:hasComponent """انحراف الإنسان نتيجة التربية"""@ar ;
    hesin:hasComponent """دور علماء السوء في الإضلال"""@ar ;
    hesin:hasComponent """إمكانية العودة إلى الحق"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_19 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C102 a hesin:Concept ;
    rdfs:label """الإنسان لا يقبل الحق"""@ar ;
    hesin:definition """مفهوم منحرف يزعم أن الإنسان بطبيعته لا يقبل الحق ويميل إلى الباطل، وهذا يؤدي إلى اليأس من هداية الناس وتحميل الله مسؤولية ضلالهم."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """عندما يقول لك: [الناس هكذا ما بيعجبهم إلا الباطل] أليس هذا رجس؟ يعني هذا هو مفهوم, وفي الأخير نرى هذا المفهوم: الناس ما يعجبهم إلا الباطل!"""@ar ;
    hesin:actions """رفض اليأس من هداية الناس والثقة في فطرة الإنسان."""@ar ;
    hesin:hasSynonym """الناس ما يعجبهم إلا الباطل"""@ar ;
    hesin:hasSynonym """طبيعة الإنسان سيئة"""@ar ;
    hesin:hasComponent """التشاؤم من قدرة الإنسان على الهدى"""@ar ;
    hesin:hasComponent """تبرير انتشار الباطل"""@ar ;
    hesin:hasComponent """تحميل الله المسؤولية"""@ar ;
    hesin:hasComponent """اليأس من هداية الناس"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_19 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C103 a hesin:Concept ;
    rdfs:label """الإسلام سلاح للناس"""@ar ;
    hesin:definition """الإسلام هو سلاح وقوة للمسلمين، يبني الأمة ويمنحها القوة والقدرة، وليس العكس (أن المسلمين يدافعون عن الإسلام)."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """الإمام علي قال في الإسلام أنه سلاح, لأنه هو يبني الأمة, يجعلها أمة قوية, يجعلها أمة تمتلك قدرات رهيبة, واقعها بالشكل الذي يكون الله معها."""@ar ;
    hesin:actions """تقديم الإسلام كقوة وسلاح، وليس كعبء."""@ar ;
    hesin:hasSynonym """الدين قوة"""@ar ;
    hesin:hasSynonym """القرآن سلاح"""@ar ;
    hesin:hasComponent """الإسلام يبني الأمة"""@ar ;
    hesin:hasComponent """الإسلام يمنح القوة"""@ar ;
    hesin:hasComponent """الإسلام سلاح للمسلمين"""@ar ;
    hesin:hasComponent """المسلمين بحاجة للإسلام أكثر من حاجته إليهم"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_19 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C104 a hesin:Concept ;
    rdfs:label """الدفاع عن الدين"""@ar ;
    hesin:definition """مفهوم قاصر يصور المسلمين وكأنهم يدافعون عن الإسلام، بينما الحقيقة أن الإسلام هو الذي يدافع عنهم ويقويهم ويمنحهم القوة."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """عبارة نكررها لقصورنا وإلا فأصل الموضوع هو أن الدين دفاع عنا, القرآن سلاح لنا, الدين سلاح لنا."""@ar ;
    hesin:actions """تصحيح المفهوم بأن الإسلام هو القوة والسلاح."""@ar ;
    hesin:hasSynonym """ندافع عن ديننا"""@ar ;
    hesin:hasSynonym """حماية الإسلام"""@ar ;
    hesin:hasComponent """تصوير الإسلام كعبء"""@ar ;
    hesin:hasComponent """نسيان قوة الإسلام الذاتية"""@ar ;
    hesin:hasComponent """الشعور بالضعف"""@ar ;
    hesin:hasComponent """فقدان الثقة"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_19 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C105 a hesin:Concept ;
    rdfs:label """القرآن شفاء ورحمة"""@ar ;
    hesin:definition """القرآن يشفي الأمراض القلبية والمفاهيم الخاطئة، وهو رحمة للمؤمنين تزيدهم إيمانًا ويقينًا وترفعهم إلى مستويات أعلى."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """القرآن عندما يقول فيه: {وَنُنَزِّلُ مِنَ الْقُرْآنِ مَا هُوَ شِفَاء} شفاء يوجد أشياء كثيرة من الأمراض, من المفاهيم الخاطئة."""@ar ;
    hesin:actions """استخدام القرآن كعلاج للأمراض القلبية والفكرية."""@ar ;
    hesin:hasSynonym """شفاء لما في الصدور"""@ar ;
    hesin:hasSynonym """رحمة للمؤمنين"""@ar ;
    hesin:hasComponent """شفاء للأمراض القلبية"""@ar ;
    hesin:hasComponent """تصحيح المفاهيم الخاطئة"""@ar ;
    hesin:hasComponent """رحمة للمؤمنين"""@ar ;
    hesin:hasComponent """زيادة الإيمان والمعرفة"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_20 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C106 a hesin:Concept ;
    rdfs:label """القرآن لا يأتيه الباطل"""@ar ;
    hesin:definition """القرآن محفوظ من أن يتطرق إليه الباطل، سواء في نصه أو في معانيه، ولا يمكن لأي باطل أن ينفذ إليه أو يلصق به."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لَا يَأْتِيهِ الْبَاطِلُ مِن بَيْنِ يَدَيْهِ وَلَا مِنْ خَلْفِهِ... لا يوجد فيه منفذ للباطل على الإطلاق, لا يتطرق إليه الباطل."""@ar ;
    hesin:actions """الثقة في أن القرآن لا يمكن أن يؤول إلى باطل."""@ar ;
    hesin:hasSynonym """منعة القرآن"""@ar ;
    hesin:hasSynonym """حصانة القرآن"""@ar ;
    hesin:hasComponent """حصانة النص من التحريف"""@ar ;
    hesin:hasComponent """حصانة المعاني من التأويل الباطل"""@ar ;
    hesin:hasComponent """عدم إمكانية إلصاق الباطل به"""@ar ;
    hesin:hasComponent """منعة القرآن"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_20 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C107 a hesin:Concept ;
    rdfs:label """حصانة المؤمن بالقرآن"""@ar ;
    hesin:definition """من تثقف بثقافة القرآن ورأى الحياة برؤيته، فإن الباطل لا يستطيع أن ينال منه، بل كل باطل يصبح شاهدًا على أنه على حق."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """إذا أنت تتثقف بثقافة القرآن, ومعرفتك معرفة القرآن, ورؤيتك رؤية القرآن, ما كل ما حولك باطل؟ أي باطل في حينه ما عاد يمكن ينال منك."""@ar ;
    hesin:actions """بناء ثقافة ورؤية قرآنية لتحصين الناس."""@ar ;
    hesin:hasSynonym """الباطل لا ينال من المؤمن"""@ar ;
    hesin:hasSynonym """القرآن يحمي صاحبه"""@ar ;
    hesin:hasComponent """ثقافة قرآنية"""@ar ;
    hesin:hasComponent """رؤية قرآنية للحياة"""@ar ;
    hesin:hasComponent """منعة من الباطل"""@ar ;
    hesin:hasComponent """تحول الباطل إلى شاهد للحق"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_20 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C108 a hesin:Concept ;
    rdfs:label """ضعف المؤمنين"""@ar ;
    hesin:definition """ضعف المؤمنين وتمكن الباطل منهم هو نتيجة لابتعادهم عن القرآن وعدم تثقفهم بثقافته، وليس نتيجة طبيعة الحق."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """نحن في الواقع الذين ما تركنا الحق أن يبقى له مكان لا في نفوسنا ولا في واقع الحياة."""@ar ;
    hesin:actions """العودة إلى القرآن لاستعادة القوة والثبات."""@ar ;
    hesin:hasSynonym """عدم الثبات"""@ar ;
    hesin:hasSynonym """التأثر بالباطل"""@ar ;
    hesin:hasComponent """البعد عن القرآن"""@ar ;
    hesin:hasComponent """ضعف الثقافة القرآنية"""@ar ;
    hesin:hasComponent """تمكن الباطل في النفوس"""@ar ;
    hesin:hasComponent """فقدان الثبات"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_20 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C109 a hesin:Concept ;
    rdfs:label """القرآن يرفع المعنويات"""@ar ;
    hesin:definition """قراءة القرآن وتأمله ترفع المعنويات، وتقضي على مشاعر الضعف، وتجعل الإنسان قويًا في مواجهة التحديات."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """القرآن هو يرفع المعنويات بشكل رهيب, يخصم نفسك, يخصم الضعف الذي في نفسك بكله, وتخصم به أي طرف آخر."""@ar ;
    hesin:actions """توجيه الناس للرجوع إلى القرآن في أوقات الضعف."""@ar ;
    hesin:hasSynonym """تقوية النفس"""@ar ;
    hesin:hasSynonym """رفع الروح المعنوية"""@ar ;
    hesin:hasComponent """رفع المعنويات"""@ar ;
    hesin:hasComponent """قتل الضعف في النفس"""@ar ;
    hesin:hasComponent """القوة في المواجهة"""@ar ;
    hesin:hasComponent """الثبات في الأزمات"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_20 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C110 a hesin:Concept ;
    rdfs:label """القرآن يهدي للأمور المعدة"""@ar ;
    hesin:definition """القرآن يهدي إلى قضايا واقعية وكأنها معدة مسبقًا، ويكشف عن حقائق ونتائج حتمية تجعل من يسير عليها في منأى عن الشقاء والضلال."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """ويقصدان به الأمور المُعَدة... تجد ما يهدي إليه القرآن هو يهدي إلى قضايا واقعية, فيبدو ما يهدي إليه وكأنه قد أعد من قبل أن يكون على النحو الفلاني."""@ar ;
    hesin:actions """الاعتماد على هداية القرآن في مواجهة القضايا الواقعية."""@ar ;
    hesin:hasSynonym """الواقعية القرآنية"""@ar ;
    hesin:hasSynonym """القرآن يكشف الحقائق"""@ar ;
    hesin:hasComponent """الهداية إلى قضايا واقعية"""@ar ;
    hesin:hasComponent """كشف الحقائق والنتائج الحتمية"""@ar ;
    hesin:hasComponent """الحماية من الشقاء والضلال"""@ar ;
    hesin:hasComponent """التنبؤ بالنتائج"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_20 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C111 a hesin:Concept ;
    rdfs:label """الترتيب الإلهي في التاريخ"""@ar ;
    hesin:definition """الله سبحانه وتعالى يدير الأحداث التاريخية بما يخدم دينه ورسله، فيرتب الصراعات بين الأمم الأخرى ليفسح المجال لحركة الدعوة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """هذا درس للمسلمين أنهم إذا كانوا بهذا الشكل لن يبقى أمامك عائق على الإطلاق, تقول: أمامك كذا, ممكن الباري يفتح مشكلة لهؤلاء مع هؤلاء."""@ar ;
    hesin:actions """تحليل الأحداث التاريخية من منظور قرآني."""@ar ;
    hesin:hasSynonym """تدبير الله"""@ar ;
    hesin:hasSynonym """سنة الله في الأمم"""@ar ;
    hesin:hasComponent """تدبير الأحداث لخدمة الدين"""@ar ;
    hesin:hasComponent """ترتيب الصراعات بين الأمم"""@ar ;
    hesin:hasComponent """إفساح المجال لحركة الدعوة"""@ar ;
    hesin:hasComponent """تحقيق النصر للمؤمنين"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_21 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C112 a hesin:Concept ;
    rdfs:label """درس الروم والفرس"""@ar ;
    hesin:definition """قصة غلبة الروم ثم غلبتهم للفرس هي نموذج على الترتيب الإلهي الدقيق في التاريخ، حيث ضرب الروم أولاً لتأمين حركة الدعوة في مكة، ثم ضرب الفرس بعد ظهور الدولة الإسلامية في المدينة."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """تجد أن الصراع الذي قام بين الفرس والروم كان بالشكل الذي يخدم حركة رسول الله... ترتيب إلهي على مستوى العالم في ذلك الزمن!"""@ar ;
    hesin:actions """استخلاص الدروس من قصة الروم والفرس في مواجهة التحديات."""@ar ;
    hesin:hasSynonym """قصة غلبت الروم"""@ar ;
    hesin:hasSynonym """التكتيك الإلهي"""@ar ;
    hesin:hasComponent """ضرب الروم أولاً لخدمة الدعوة في مكة"""@ar ;
    hesin:hasComponent """ضرب الفرس بعد ظهور الدولة الإسلامية"""@ar ;
    hesin:hasComponent """موقف الروم كدولة دينية يختلف عن الفرس"""@ar ;
    hesin:hasComponent """التكتيك الإلهي الدقيق"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_21 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C113 a hesin:Concept ;
    rdfs:label """إزالة العقد بالقرآن"""@ar ;
    hesin:definition """القرآن يزيل كل العقد والمشكلات التي تواجه الإنسان، ويرفع الحيرة والضعف، ويفتح آفاقًا واسعة من الحلول التي لا تخطر على بال البشر."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """القرآن هو بهذا الشكل, ما يترك عقدة على الإطلاق أمام من يسيرون عليه مهما كانت, عندما ترى العقدة أنت باعتبار طاقاتك, قدراتك... ارتفع أنت بكلك إلى الله."""@ar ;
    hesin:actions """الرجوع إلى القرآن لحل المشكلات وإزالة العقد."""@ar ;
    hesin:hasSynonym """حل المشكلات"""@ar ;
    hesin:hasSynonym """رفع الحيرة"""@ar ;
    hesin:hasComponent """إزالة العقد النفسية والفكرية"""@ar ;
    hesin:hasComponent """تقديم حلول غير متوقعة"""@ar ;
    hesin:hasComponent """رفع الحيرة والضعف"""@ar ;
    hesin:hasComponent """فتح آفاق جديدة"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_21 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C114 a hesin:Concept ;
    rdfs:label """الأمل والثقة بنصر الله"""@ar ;
    hesin:definition """القرآن يزرع الأمل والثقة في قلوب المؤمنين، ويؤكد لهم أن النصر حليف الحق وأن الله سيتِم نوره ولو كره الكافرون."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هذه الآية هي من الآيات التي تعطي المسلمين أمل, الآية هذه هي من الآيات التي تعطي المسلمين أملاً بأن هذا الدين هو بالشكل الذي يمكن أن يظهر على الأديان."""@ar ;
    hesin:actions """زرع الأمل والثقة مع الحث على العمل."""@ar ;
    hesin:hasSynonym """التفاؤل"""@ar ;
    hesin:hasSynonym """الثقة بالنصر"""@ar ;
    hesin:hasComponent """الأمل في نصر الله"""@ar ;
    hesin:hasComponent """الثقة بأن الحق سينتصر"""@ar ;
    hesin:hasComponent """اليقين بأن نور الله سيتِم"""@ar ;
    hesin:hasComponent """رفع اليأس والقنوط"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_21 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C115 a hesin:Concept ;
    rdfs:label """نقد المنهج الفلسفي"""@ar ;
    hesin:definition """المنهج الفلسفي القائم على الجدل العقلي المجرد والمقدمات المنطقية هو منهج قاصر لا يصلح لهداية البشر، لأنه يغفل الجانب الوجداني والعاطفي، بينما المنهج القرآني يأتي للإنسان من كل جهاته."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """القرآن كشف بأن أسلوبه هو الأسلوب الذي يصلح للإنسان، وأن الأسلوب الآخر كان أسلوباً قاصراً... هم يقيمون الحوار، والمناظرات على أساس مقدمات منطقية، حوار عقلي... ما هناك لحظ للموضوع الآخر، الجانب الوجداني لدى الإنسان."""@ar ;
    hesin:actions """تجنب الانشغال بالجدل العقلي المجرد، والتركيز على المنهج القرآني المتكامل."""@ar ;
    hesin:hasSynonym """نقد الفلاسفة"""@ar ;
    hesin:hasSynonym """نقد المنطق العقلي المجرد"""@ar ;
    hesin:hasComponent """الاعتماد على المقدمات المنطقية فقط"""@ar ;
    hesin:hasComponent """إغفال الجانب الوجداني"""@ar ;
    hesin:hasComponent """عدم قدرته على إحداث الإيمان العميق"""@ar ;
    hesin:hasComponent """فشله في الوصول إلى الناس"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_22 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C116 a hesin:Concept ;
    rdfs:label """المنهج القرآني الشامل"""@ar ;
    hesin:definition """المنهج القرآني في الدعوة والحوار يعتمد على مخاطبة الإنسان من كل جوانبه: العقل، الوجدان، العاطفة، الخوف، الرجاء، وذلك من خلال الترغيب والترهيب، والقصص، والأمثال، والوعظ."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """جاء الأسلوب في القرآن الكريم بطريقة أنه يأتي للإنسان من كل جهة، منطق بشكل مقنع، وترغيب, وترهيب، واستعطاف, بكل الوسائل؛ ولهذا نجح، وانتشر الإسلام بشكل كبير في فترة قصيرة."""@ar ;
    hesin:actions """اعتماد المنهج القرآني الشامل في الدعوة والحوار."""@ar ;
    hesin:hasSynonym """أسلوب القرآن"""@ar ;
    hesin:hasSynonym """منهج الأنبياء"""@ar ;
    hesin:hasComponent """مخاطبة العقل بالمنطق المقنع"""@ar ;
    hesin:hasComponent """مخاطبة الوجدان بالترغيب والترهيب"""@ar ;
    hesin:hasComponent """استخدام القصص والأمثال"""@ar ;
    hesin:hasComponent """التذكير بالنعم والآلاء"""@ar ;
    hesin:hasComponent """التحذير من عواقب الإعراض"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_22 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C117 a hesin:Concept ;
    rdfs:label """فشل المتكلمين"""@ar ;
    hesin:definition """المتكلمون (المعتزلة والأشاعرة) الذين اعتمدوا على المنهج العقلي والجدلي في تقديم الدين فشلوا في إقناع الناس وإدخالهم في الإسلام، وانحسر تأثيرهم مع الزمن."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """نفس الشيء فشلوا، بل ضاعوا هم المعتزلة انقرضوا هم, والأشاعرة... ذابوا هم! هل استطاعوا أن يدخلوا أحداً إلى الإسلام؟ لا، بل حنبوا هم."""@ar ;
    hesin:actions """تجنب المنهج الكلامي الجدلي في تقديم الدين."""@ar ;
    hesin:hasSynonym """انقراض المعتزلة"""@ar ;
    hesin:hasSynonym """ضعف الأشاعرة"""@ar ;
    hesin:hasComponent """فشل في الدعوة إلى الإسلام"""@ar ;
    hesin:hasComponent """انقراض المذاهب الكلامية"""@ar ;
    hesin:hasComponent """ظهور إشكالات وشبهات من منهجهم"""@ar ;
    hesin:hasComponent """غلبة المنهج الحديثي عليهم"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_22 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C118 a hesin:Concept ;
    rdfs:label """نقد المعتزلة والأشاعرة"""@ar ;
    hesin:definition """نقد منهج المعتزلة والأشاعرة في تقديم الدين، حيث اعتمدوا على الجدل العقلي والأدلة المنطقية المجردة، وأغفلوا الجانب الوجداني والتربوي في القرآن."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """تجد نفس الشيء مشى أسلوب الفلاسفة إلى المتكلمين من الأشاعرة، والمعتزلة، مشى نفس الأسلوب حقهم: الحوار العقلي، الجدل العقلي، الأدلة العقلية، مناظرات عقلية... ما يلحظوا الأشياء الأخرى."""@ar ;
    hesin:actions """العودة إلى المنهج القرآني في العقيدة والدعوة."""@ar ;
    hesin:hasSynonym """نقد علم الكلام"""@ar ;
    hesin:hasSynonym """نقد المنهج العقلي في الدين"""@ar ;
    hesin:hasComponent """الاعتماد على الجدل العقلي"""@ar ;
    hesin:hasComponent """إهمال الجانب الوجداني"""@ar ;
    hesin:hasComponent """الانشغال بالمناظرات الداخلية"""@ar ;
    hesin:hasComponent """فشلهم في مواجهة الملحدين"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_22 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C119 a hesin:Concept ;
    rdfs:label """منهجية الدعوة القرآنية"""@ar ;
    hesin:definition """منهج الدعوة الذي سلكه الأنبياء هو التركيز على الدعوة إلى الله لا إلى الشخص، وإذابة الشخصية، وجعل القضية قضية هداية إلى الله، وليست مناظرة شخصية أو مباراة فكرية."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """الأسلوب الذي ظهر من سيرة الأنبياء (صلوات الله عليه وعلى آله) والأنبياء طريقتهم من أرقى الطرق في مجال الدعوة... تجدهم لا يقدم نفسه شخصياً، هو شخصياً, يدعوهم إلى الله, إلى الله, إلى الله."""@ar ;
    hesin:actions """اعتماد أسلوب الدعوة إلى الله مع إذابة الشخصية."""@ar ;
    hesin:hasSynonym """أسلوب الأنبياء"""@ar ;
    hesin:hasSynonym """الدعوة إلى الله"""@ar ;
    hesin:hasComponent """الدعوة إلى الله لا إلى الشخص"""@ar ;
    hesin:hasComponent """إذابة الشخصية وعدم تقديم الذات"""@ar ;
    hesin:hasComponent """التركيز على الترغيب والترهيب"""@ar ;
    hesin:hasComponent """استخدام الأسلوب الوجداني والعقلي معًا"""@ar ;
    hesin:hasComponent """الحرص على هداية الناس لا الانتصار الشخصي"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_23 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C120 a hesin:Concept ;
    rdfs:label """نقد منهج المتكلمين"""@ar ;
    hesin:definition """نقد منهج المتكلمين الذين انصرفوا عن الطريقة القرآنية في الحوار والدعوة إلى الجدل العقلي المجرد، مما أدى إلى غلبتهم وضعفهم وفشلهم في الدعوة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """نفس الشيء مشى أسلوب الفلاسفة إلى المتكلمين من الأشاعرة، والمعتزلة... ما يلحظوا الأشياء الأخرى... لما أنصرف المسلمون عن الطريقة هذه غُلبوا."""@ar ;
    hesin:actions """تجنب الجدل العقلي المجرد والعودة إلى المنهج القرآني."""@ar ;
    hesin:hasSynonym """نقد علم الكلام"""@ar ;
    hesin:hasSynonym """نقد الجدل العقلي"""@ar ;
    hesin:hasComponent """الانصراف عن المنهج القرآني"""@ar ;
    hesin:hasComponent """الانشغال بالجدل العقلي"""@ar ;
    hesin:hasComponent """ضعف التأثير في الناس"""@ar ;
    hesin:hasComponent """ظهور شبهات من منهجهم"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_22 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C121 a hesin:Concept ;
    rdfs:label """أثر المعتزلة على الزيدية"""@ar ;
    hesin:definition """تأثر الزيدية بمنهج المعتزلة في العقيدة والمنهج، مما أدى إلى ضياعهم وضعفهم، وانصرافهم عن المنهج القرآني الأصلي لأهل البيت."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """الزيدية عندما كان يوجد إتفاق معهم هكذا، أو مثل ما تقل ارتياح لجانبهم؛ لأنهم يتحدثون عن جانب العدل والتوحيد، طغى أسلوبهم علينا، ضيعونا نحن، طغى أسلوبهم علينا وإذا بنا ضعنا."""@ar ;
    hesin:actions """العودة إلى منهج أهل البيت الأصلي في فهم القرآن."""@ar ;
    hesin:hasSynonym """تأثر الزيدية بالمعتزلة"""@ar ;
    hesin:hasSynonym """خلل في المنهج"""@ar ;
    hesin:hasComponent """تأثر الزيدية بالمعتزلة"""@ar ;
    hesin:hasComponent """طغيان الأسلوب الكلامي"""@ar ;
    hesin:hasComponent """الابتعاد عن المنهج القرآني الأصلي"""@ar ;
    hesin:hasComponent """ضعف التأثير والدعوة"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_22 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C122 a hesin:Concept ;
    rdfs:label """الجدل الشخصي والمباراة"""@ar ;
    hesin:definition """منهج خاطئ في الحوار يقوم على أساس التناظر لمجرد إثبات الذات والانتصار الشخصي، وليس بهدف هداية الطرف الآخر، وهذا الأسلوب فاشل ولا يؤدي إلى نتائج."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أسلوب خاطئ... تنطلق بروح جدلية هكذا، تنطلق بروح دعوة، إصلاح، حرص على هدى، حرص على هدى للطرف الآخر... لا تكن هنا تؤهل نفسك على أساس أنك تسير تناظر الناس، ومناظرة لمجرد المناظرة، وجدل لمجرد الجدل."""@ar ;
    hesin:actions """تجنب الجدل الشخصي والتركيز على الدعوة إلى الله."""@ar ;
    hesin:hasSynonym """مناظرة لمجرد المناظرة"""@ar ;
    hesin:hasSynonym """مباراة فكرية"""@ar ;
    hesin:hasComponent """التناظر لمجرد الانتصار"""@ar ;
    hesin:hasComponent """إثبات الذات والشخصنة"""@ar ;
    hesin:hasComponent """غياب حرص الهداية"""@ar ;
    hesin:hasComponent """فشل في التأثير"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_23 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C123 a hesin:Concept ;
    rdfs:label """إذابة الشخصية في الحوار"""@ar ;
    hesin:definition """منهج في الحوار والدعوة يقوم على إذابة الشخصية وعدم تقديم الذات، بحيث يشعر الطرف الآخر أن القضية هي قضية هداية إلى الله، وليست قضية شخصية أو مذهبية."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لازم أنك تذيب شخصيتك نهائياً, تشده إلى الله, والموضوع إلى الله {إِن نَّحْنُ إِلاَّ بَشَرٌ مِّثْلُكُمْ وَلَـكِنَّ اللّهَ} هذا النبي بكله يقول له: نحن بشر مثلك يا أخي, فقط القضية كذا."""@ar ;
    hesin:actions """التركيز على الدعوة إلى الله مع إذابة الشخصية."""@ar ;
    hesin:hasSynonym """إزالة الأنا"""@ar ;
    hesin:hasSynonym """عدم تقديم الذات"""@ar ;
    hesin:hasComponent """عدم تقديم الذات"""@ar ;
    hesin:hasComponent """التركيز على الدعوة إلى الله"""@ar ;
    hesin:hasComponent """تجنب الشخصنة"""@ar ;
    hesin:hasComponent """جعل القضية قضية هدى للجميع"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_23 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C124 a hesin:Concept ;
    rdfs:label """فشل الحوارات المذهبية"""@ar ;
    hesin:definition """الحوارات والمناظرات بين المذاهب الإسلامية التي جرت بالمنهج الجدلي الشخصي فشلت في إقناع الطرف الآخر، ولم تؤد إلى تغيير أو هداية، بل زادت في التفرق."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لاحظ عندما أضاع المسلمون هذه الطريقة أصبح المعتزلي يناظر الأشعري, وأصبح الزيدي يناظر كذا, طوائف... وجلسوا يتناظرون, يتناظرون لمَّا انتهوا, لا احد جر هذا إليه, ولا أحد دخل في هذا المذهب."""@ar ;
    hesin:actions """تجنب الحوارات الجدلية العقيمة والعودة إلى منهج الدعوة."""@ar ;
    hesin:hasSynonym """جدل الشيعة والسنة"""@ar ;
    hesin:hasSynonym """مناظرات المذاهب"""@ar ;
    hesin:hasComponent """المناظرات بين المذاهب"""@ar ;
    hesin:hasComponent """غياب منهج الدعوة"""@ar ;
    hesin:hasComponent """فشل في التأثير والهداية"""@ar ;
    hesin:hasComponent """زيادة التفرق والخلاف"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_23 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C125 a hesin:Concept ;
    rdfs:label """نجاح الدعوة"""@ar ;
    hesin:definition """نجاح الدعوة وانتشار الإسلام كان نتيجة اتباع المنهج القرآني في الدعوة (إذابة الشخصية، الدعوة إلى الله، الترغيب والترهيب)، وليس بسبب الجدل العقلي المجرد."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """الأسلوب الذي ظهر من سيرة الأنبياء (صلوات الله عليه وعلى آله) والأنبياء طريقتهم من أرقى الطرق في مجال الدعوة... ولهذا نجح رسول الله (صلوات الله عليه وعلى آله)."""@ar ;
    hesin:actions """اعتماد المنهج القرآني في الدعوة لتحقيق النجاح."""@ar ;
    hesin:hasSynonym """انتشار الإسلام"""@ar ;
    hesin:hasSynonym """قبول الهدى"""@ar ;
    hesin:hasComponent """اتباع المنهج القرآني"""@ar ;
    hesin:hasComponent """إذابة الشخصية"""@ar ;
    hesin:hasComponent """التركيز على الدعوة إلى الله"""@ar ;
    hesin:hasComponent """استخدام الترغيب والترهيب"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_23 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C126 a hesin:Concept ;
    rdfs:label """اللغة العربية من خلال النصوص"""@ar ;
    hesin:definition """فهم اللغة العربية لا يكون من خلال دراسة القواعد النحوية والصرفية المجردة فقط، بل من خلال معايشة النصوص الأدبية (الشعر والنثر) لفهم أساليب العرب في التعبير والتخاطب."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """المطلوب أن تتعرف على اللغة نفسها، وأن تمارس قراءتها، والإطلاع على نصوصها, من شعر ونثر, حتى تعرف أنت تلقائياً أساليبها."""@ar ;
    hesin:actions """تعليم اللغة العربية من خلال النصوص لا القواعد فقط."""@ar ;
    hesin:hasSynonym """معايشة اللغة"""@ar ;
    hesin:hasSynonym """قراءة الشعر والنثر"""@ar ;
    hesin:hasComponent """قراءة الشعر العربي"""@ar ;
    hesin:hasComponent """قراءة النثر العربي البليغ"""@ar ;
    hesin:hasComponent """معايشة أساليب العرب"""@ar ;
    hesin:hasComponent """فهم روح اللغة ونفسها"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_24 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C127 a hesin:Concept ;
    rdfs:label """الاقتصار على قواعد النحو"""@ar ;
    hesin:definition """مفهوم خاطئ يختزل اللغة العربية في قواعد النحو والصرف، مما يجعلها ثقيلة ومعقدة على الطلاب، ويحول دون فهمهم لروح اللغة وأساليبها الحقيقية."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """اللغة العربية مربوطة عندنا بالنحو، النحو عندنا من أعقد الأشياء على الطلاب, يتصور اللغة العربية يعني النحو، والنحو قد بدا ثقيل."""@ar ;
    hesin:actions """عدم الاقتصار على النحو في تعليم اللغة العربية."""@ar ;
    hesin:hasSynonym """النحو المجرد"""@ar ;
    hesin:hasSynonym """اللغة العربية = النحو"""@ar ;
    hesin:hasComponent """حصر اللغة في النحو"""@ar ;
    hesin:hasComponent """تعقيد دراسة اللغة"""@ar ;
    hesin:hasComponent """صعوبة الفهم على الطلاب"""@ar ;
    hesin:hasComponent """الابتعاد عن روح اللغة"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_24 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C128 a hesin:Concept ;
    rdfs:label """القرآن مرجع لغوي"""@ar ;
    hesin:definition """القرآن الكريم هو مرجع أساسي من مراجع اللغة العربية، بل إن بعض المفردات لا يمكن فهم معناها الحقيقي إلا من خلال استعمالها القرآني، وهو يوثق النص العربي."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """القرآن، أعتقد أن القرآن نفسه هو من أهم المراجع اللغوية, من أهم مراجع اللغة العربية... فيه توثيق أيضاً للنص العربية."""@ar ;
    hesin:actions """الاعتماد على القرآن في فهم اللغة العربية."""@ar ;
    hesin:hasSynonym """القرآن أهم مراجع اللغة"""@ar ;
    hesin:hasSynonym """توثيق اللغة"""@ar ;
    hesin:hasComponent """القرآن مرجع لغوي"""@ar ;
    hesin:hasComponent """توثيق النص العربي"""@ar ;
    hesin:hasComponent """كشف معاني المفردات"""@ar ;
    hesin:hasComponent """ضبط الأساليب اللغوية"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_24 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C129 a hesin:Concept ;
    rdfs:label """ضعف الفهم القرآني"""@ar ;
    hesin:definition """ضعف فهم القرآن وعدم القدرة على استيعاب معانيه العميقة ناتج عن الابتعاد عن معايشة اللغة العربية من خلال نصوصها، والاقتصار على القواعد المجردة."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """النحوي ما يجلس نحوي يلتزم بعمل استقراء أنه لماذا نصبوا هذه ولماذا رفعوا هذه... لكن هو أيضاً يتطرق إلى المعاني, يتحدث عن المعاني."""@ar ;
    hesin:actions """العودة إلى معايشة اللغة العربية من خلال النصوص."""@ar ;
    hesin:hasSynonym """عدم فهم القرآن"""@ar ;
    hesin:hasSynonym """الابتعاد عن روح اللغة"""@ar ;
    hesin:hasComponent """عدم معايشة اللغة"""@ar ;
    hesin:hasComponent """الاقتصار على القواعد"""@ar ;
    hesin:hasComponent """صعوبة فهم الأساليب"""@ar ;
    hesin:hasComponent """الابتعاد عن روح القرآن"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_24 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C130 a hesin:Concept ;
    rdfs:label """محاربة اللغة العربية"""@ar ;
    hesin:definition """هناك حملة منظمة لمحاربة اللغة العربية والشعر العربي، تحت شعارات الحرية، بهدف إبعاد الناس عن فهم القرآن الكريم."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """تجد اللغة العربية محاربة جداً من اليهود, حتى الشعر العربي يحاربونه, يحاربونه بطرق كثيرة تحت عنوان الحرية حتى في اللغة, الحرية من القيود هذه, قيود القافية, وقيود البحور والوزن, مثل الشعر العمودي الذي يسمونه الشعر الحر."""@ar ;
    hesin:actions """الحفاظ على اللغة العربية والشعر العربي كوسيلة لفهم القرآن."""@ar ;
    hesin:hasSynonym """هجمة على العربية"""@ar ;
    hesin:hasSynonym """الشعر الحر"""@ar ;
    hesin:hasComponent """محاربة الشعر العربي"""@ar ;
    hesin:hasComponent """الدعوة إلى الشعر الحر (تحرر من القافية والوزن)"""@ar ;
    hesin:hasComponent """إبعاد الناس عن فهم القرآن"""@ar ;
    hesin:hasComponent """استهداف اللغة كوسيلة للفهم"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_24 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C131 a hesin:Concept ;
    rdfs:label """الاختلاف في الدين"""@ar ;
    hesin:definition """الاختلاف في الدين وتفرق الأمة هو ظاهرة غير طبيعية في المنظور القرآني، وهو نتيجة لخروج الناس عن هدى الله، وليس أمرًا طبيعيًا أو مشروعًا."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """قضية حصلت لا يوجد أي مجال لسدها لا تحصل, بحيث نعمل على أن لا تحصل... الإختلاف هو طبيعي... هذه قضية فيها شاهد من الحياة بالنسبة لنا."""@ar ;
    hesin:actions """العمل على إزالة الاختلاف والعودة إلى المنهج الموحد."""@ar ;
    hesin:hasSynonym """تفرق الأمة"""@ar ;
    hesin:hasSynonym """تعدد الآراء"""@ar ;
    hesin:hasComponent """تفرق الأمة"""@ar ;
    hesin:hasComponent """تعدد الآراء في الدين"""@ar ;
    hesin:hasComponent """الاختلاف في الفهم"""@ar ;
    hesin:hasComponent """ضعف الأمة نتيجة الاختلاف"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_25 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C132 a hesin:Concept ;
    rdfs:label """ضعف الأمة وتفرقها"""@ar ;
    hesin:definition """تفرق الأمة وضعفها نتيجة مباشرة لاختلاف العلماء وتعدد الآراء في الدين، مما يجعل الأمة مشتتة غير قادرة على مواجهة التحديات."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """ما الأمة ستضطرب عندما يضطرب من يوجهوها؟ ما العلماء أساسا هم المعنيين بتوجيه الأمة؟ فإذا اختلف العلماء اختلف توجيههم للأمة, فتباينت مواقفها, فضعفت."""@ar ;
    hesin:actions """العمل على توحيد العلماء والمنهج لتقوية الأمة."""@ar ;
    hesin:hasSynonym """التمزق"""@ar ;
    hesin:hasSynonym """الهوان"""@ar ;
    hesin:hasComponent """اختلاف العلماء"""@ar ;
    hesin:hasComponent """تباين التوجيه"""@ar ;
    hesin:hasComponent """تشتت الأمة"""@ar ;
    hesin:hasComponent """الضعف والهوان"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_25 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C133 a hesin:Concept ;
    rdfs:label """أن الاختلاف من الدين"""@ar ;
    hesin:definition """مفهوم منحرف يزعم أن الاختلاف في الدين أمر مشروع، وأن كل مجتهد مصيب، وهذا يؤدي إلى تفتيت الدين وشرعنة التناقضات."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """قالوا: خلاص مادام المسألة بهذا الشكل فكلنا مصيبين! صلح, نتصالح أنه نكون كلنا مصيبين!... عندما نقول: مصيب طلع نفس الشيء, أن الدين يتفرق, ونجعل كل قضية في نفس الوقت, نجعلها حق, ونجعلها صواب!"""@ar ;
    hesin:actions """رفض فكرة شرعية الاختلاف في الدين."""@ar ;
    hesin:hasSynonym """شرعية الاختلاف"""@ar ;
    hesin:hasSynonym """الاختلاف رحمة"""@ar ;
    hesin:hasComponent """الادعاء بأن كل مجتهد مصيب"""@ar ;
    hesin:hasComponent """شرعنة الاختلاف"""@ar ;
    hesin:hasComponent """إضفاء الشرعية على التناقضات"""@ar ;
    hesin:hasComponent """تفتيت الأمة"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_25 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C134 a hesin:Concept ;
    rdfs:label """شرعية الاختلاف"""@ar ;
    hesin:definition """محاولة إضفاء الشرعية على الاختلاف في الدين تحت مبررات (كقول "كل مجتهد مصيب")، مما يؤدي إلى نسبة التناقض إلى الله وتبرير تفرق الأمة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """كيف نحاول في المشكلة هذه نحلها, نضفي عليها شرعية, ونقول: يجوز الإختلاف! ألسنا من صلحناه يجوز؟... فنكون قد أضفينا عليه شرعية, والشرع منسوب إلى من؟ منسوب إلى الله, طلع لك ماذا؟ أن الله يجوِّز الإختلاف في دينه!"""@ar ;
    hesin:actions """نقد فكرة شرعية الاختلاف وبيان بطلانها."""@ar ;
    hesin:hasSynonym """الاختلاف رحمة"""@ar ;
    hesin:hasSynonym """كل مجتهد مصيب"""@ar ;
    hesin:hasComponent """إضفاء الشرعية على الاختلاف"""@ar ;
    hesin:hasComponent """نسبة التناقض إلى الله"""@ar ;
    hesin:hasComponent """تبرير التفرق"""@ar ;
    hesin:hasComponent """مشكلة عقدية كبرى"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_25 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C135 a hesin:Concept ;
    rdfs:label """نقد شرعية الاختلاف"""@ar ;
    hesin:definition """نقد ومناقشة فكرة شرعية الاختلاف في الدين، وبيان أن الدين نزل لحسم الخلاف وجعل الناس أمة واحدة، وليس لشرعنة الاختلاف والتفرق."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """فكيف تنهى, وتتوعد المختلفين وتأتي تقدم لهم بينات تفرق بينهم؟! ما من صح هذا... فما نختلف فيه نحن من شئون الحياة هذه، في حركتنا في الحياة, وتعاملنا مع بعضنا بعض, جاء الدين ليحسم الخلاف هو, ليجعل الناس أمة واحدة."""@ar ;
    hesin:actions """بيان أن الدين نزل لحسم الخلاف لا لشرعنته."""@ar ;
    hesin:hasSynonym """رفض تبرير الاختلاف"""@ar ;
    hesin:hasSynonym """نقد مفهوم "كل مجتهد مصيب""""@ar ;
    hesin:hasComponent """رفض تبرير الاختلاف"""@ar ;
    hesin:hasComponent """التأكيد على أن الدين نزل لحسم الخلاف"""@ar ;
    hesin:hasComponent """نقد مفهوم "كل مجتهد مصيب""""@ar ;
    hesin:hasComponent """بيان أن الاختلاف من البشر لا من الدين"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_25 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C136 a hesin:Concept ;
    rdfs:label """تنزيه الله كغاية"""@ar ;
    hesin:definition """تنزيه الله وتقديسه والشهادة بكماله هي الغاية الكبرى التي يجب أن تكون مقياسًا لكل عمل وفكر، وأي مفهوم يمس بكمال الله أو يلحق به نقصًا هو جريمة كبرى."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """أن يكون عملك بالشكل الذي يكون دائماً تجعل تنزيه الله مقياس؛ لأنها هي الغاية الكبرى هو تنزيه الله, وتقديسه, والشهادة على كماله."""@ar ;
    hesin:actions """جعل تنزيه الله مقياسًا لكل فكرة وعمل."""@ar ;
    hesin:hasSynonym """قدسية الله"""@ar ;
    hesin:hasSynonym """الشهادة بكمال الله"""@ar ;
    hesin:hasComponent """تنزيه الله عن النقص"""@ar ;
    hesin:hasComponent """تقديس الله وجلاله"""@ar ;
    hesin:hasComponent """الشهادة بكمال الله"""@ar ;
    hesin:hasComponent """جعل التنزيه مقياسًا"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_26 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C137 a hesin:Concept ;
    rdfs:label """عدم جواز نسبة النقص إلى الله"""@ar ;
    hesin:definition """لا يجوز نسب أي نقص أو ظلم إلى الله، ومن ذلك القول بأن الله ترك الأمة بلا حل لمشكلاتها، أو أنه طبع الحياة بطابع يغلب فيه الباطل."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أي قضية طلعها إلى عند الله... أي أن الوضعية التي الأمة فيها الآن بالتأكيد أن هناك حل لها, إذاً الأمة هي انصرفت عنه... ما من صح أن تجيز على الله أن يترك عباده هكذا."""@ar ;
    hesin:actions """رفض أي فكرة تمس كمال الله أو تنسب إليه نقصًا."""@ar ;
    hesin:hasSynonym """نفي الظلم عن الله"""@ar ;
    hesin:hasSynonym """نفي الجور"""@ar ;
    hesin:hasComponent """نفي الظلم عن الله"""@ar ;
    hesin:hasComponent """نفي الجور عن الله"""@ar ;
    hesin:hasComponent """نفي التقصير عن الله"""@ar ;
    hesin:hasComponent """التأكيد على أن الحل موجود"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_26 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C138 a hesin:Concept ;
    rdfs:label """طبيعة الدنيا للباطل"""@ar ;
    hesin:definition """مفهوم منحرف يزعم أن الدنيا خلقت للباطل، وأن أهل الحق لا ينتصرون فيها، وهذا مفهوم يمس بكمال الله وحكمته وعدله."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """عندما تسمع حديث عن صراع الحق والباطل, وقوة أهل الباطل, وغلبة أهل الباطل وإمكانياتهم الهائلة يقولون: هكذا حال الدنيا, الباري أراد أن تكون الدنيا هكذا!"""@ar ;
    hesin:actions """رفض فكرة أن الدنيا للباطل والثقة في نصر الحق."""@ar ;
    hesin:hasSynonym """الدنيا دار الباطل"""@ar ;
    hesin:hasSynonym """الحق لا ينتصر"""@ar ;
    hesin:hasComponent """القول بأن الدنيا للباطل"""@ar ;
    hesin:hasComponent """نفي إمكانية انتصار الحق"""@ar ;
    hesin:hasComponent """تحميل الله المسؤولية"""@ar ;
    hesin:hasComponent """اليأس والقنوط"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_26 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C139 a hesin:Concept ;
    rdfs:label """زهوق الباطل"""@ar ;
    hesin:definition """الباطل بطبيعته زاهق لا يثبت، وهو الحالة الشاذة في الدنيا، وليس هو الأصل. إذا جاء الحق يدمغ الباطل ويزهقه."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """يتحدث عن الباطل بقوله: {وَقُلْ جَاء الْحَقُّ وَزَهَقَ الْبَاطِلُ إِنَّ الْبَاطِلَ كَانَ زَهُوقاً} هو الحالة الشاذة, هو الذي لا مكان له في الواقع."""@ar ;
    hesin:actions """الثقة في أن الباطل زاهق لا محالة."""@ar ;
    hesin:hasSynonym """الباطل زاهق"""@ar ;
    hesin:hasSynonym """الحق يدْمغ الباطل"""@ar ;
    hesin:hasComponent """الباطل حالة شاذة"""@ar ;
    hesin:hasComponent """الباطل لا يثبت"""@ar ;
    hesin:hasComponent """الحق يدْمغ الباطل"""@ar ;
    hesin:hasComponent """زهوق الباطل طبيعي"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_26 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C140 a hesin:Concept ;
    rdfs:label """الفساد من كسب الناس"""@ar ;
    hesin:definition """الفساد والظلم في الدنيا ليس من خلق الله، بل هو نتيجة كسب الناس وأعمالهم، والدنيا في أصل خلقها كنز ثمين صالح للحق والخير."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{ظَهَرَ الْفَسَادُ فِي الْبَرِّ وَالْبَحْرِ بِمَا كَسَبَتْ أَيْدِي النَّاسِ} هم الذين طبعوها بالفساد, هو خلقها عندما تأتي تشوف خلقها تجدها وكأنها كنز."""@ar ;
    hesin:actions """تحميل الإنسان مسؤولية الفساد، والعمل على إصلاحه."""@ar ;
    hesin:hasSynonym """مسؤولية الإنسان"""@ar ;
    hesin:hasSynonym """البشر يطبعون الحياة بالفساد"""@ar ;
    hesin:hasComponent """الدنيا في أصلها كنز ثمين"""@ar ;
    hesin:hasComponent """الفساد من كسب الناس"""@ar ;
    hesin:hasComponent """الإنسان يطبع الحياة بالفساد"""@ar ;
    hesin:hasComponent """إمكانية إصلاحها بالعودة إلى الله"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_26 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C141 a hesin:Concept ;
    rdfs:label """منهجية مواجهة العدو"""@ar ;
    hesin:definition """منهجية القرآن في مواجهة العدو تقوم على الإعداد لكل قوة ممكنة، مع الثقة بالله، وفهم نقاط ضعف العدو، واستخدام وسائل متاحة (كالمقاطعة الاقتصادية) قبل الانشغال بالتفوق العسكري."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """المسلمون ملزمون إلى أن يطوروا أنفسهم على أرقى مستوى, أن يعدو كل القوة, لكن وقوة واحدة يجب أن تكون لديهم دائماً, ومسيطرة على مشاعرهم."""@ar ;
    hesin:actions """الإعداد لكل قوة مع الثقة بالله وفهم نقاط ضعف العدو."""@ar ;
    hesin:hasSynonym """مقاومة الاحتلال"""@ar ;
    hesin:hasSynonym """مواجهة أمريكا"""@ar ;
    hesin:hasComponent """الإعداد لكل قوة ممكنة"""@ar ;
    hesin:hasComponent """الثقة بالله والتوكل عليه"""@ar ;
    hesin:hasComponent """فهم نقاط ضعف العدو"""@ar ;
    hesin:hasComponent """استخدام الوسائل المتاحة"""@ar ;
    hesin:hasComponent """عدم الانشغال بالتفوق العسكري فقط"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_27 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C142 a hesin:Concept ;
    rdfs:label """التكافؤ الحقيقي"""@ar ;
    hesin:definition """التكافؤ الحقيقي ليس مجرد مقارنة بالأسلحة والعتاد، بل هو فهم نقاط ضعف العدو (كاعتماده على النفط، هشاشة اقتصاده) واستخدامها في المواجهة."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """يوجد فهم مغلوط لمسألة التكافؤ, يعني يتصور أن القضية هي قضية مثلاً حديد... ما تحتاج لها ربما خبرات نهائياً؛ لأن هذه سنة إلهية, لا يسمح للعدو أن يكبر دون أن يكون فيه نقاط ضعف كبيرة."""@ar ;
    hesin:actions """فهم نقاط ضعف العدو واستغلالها."""@ar ;
    hesin:hasSynonym """التوازن"""@ar ;
    hesin:hasSynonym """موازين القوى"""@ar ;
    hesin:hasComponent """فهم نقاط ضعف العدو"""@ar ;
    hesin:hasComponent """استخدام الوسائل المتاحة"""@ar ;
    hesin:hasComponent """عدم الانشغال بالتفوق العسكري"""@ar ;
    hesin:hasComponent """الثقة في سنن الله"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_27 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C143 a hesin:Concept ;
    rdfs:label """التفكير بالتفوق العسكري فقط"""@ar ;
    hesin:definition """مفهوم خاطئ يختزل القوة في التفوق العسكري فقط (الطائرات والدبابات)، ويتجاهل وسائل القوة الأخرى (الاقتصادية، الثقافية، السياسية) وضعف العدو."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """ما عندي إلا بندق, أو عندي حاجة بسيطة والآخر عنده طائرة, وعنده كذا, فتقول متى ما قد عندي طائرات ودبابات, وعندي كذا, وعندي كذا ... الخ, فسأعمل كذا."""@ar ;
    hesin:actions """توسيع مفهوم القوة ليشمل كل المجالات."""@ar ;
    hesin:hasSynonym """العسكرية"""@ar ;
    hesin:hasSynonym """النظر إلى القوة المادية فقط"""@ar ;
    hesin:hasComponent """حصر القوة في العتاد العسكري"""@ar ;
    hesin:hasComponent """إغفال الوسائل الأخرى"""@ar ;
    hesin:hasComponent """اليأس من المواجهة"""@ar ;
    hesin:hasComponent """عدم فهم سنن الله"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_27 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C144 a hesin:Concept ;
    rdfs:label """التدخل الإلهي"""@ar ;
    hesin:definition """التدخل الإلهي هو نصر وتأييد من الله للمؤمنين، وقد يجعل تأثيرهم أكبر من إمكانياتهم المادية، ويرعب العدو ويجعله يتخذ قرارات خاطئة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """التدخل الإلهي قد يجعل الشيء من جانبك له تأثير بالنسبة للعدو, يجعل وجودك إشكالية ترعب العدو ولو كيان صغير, ترعب العدو, يصبح العدو نفسه تكون قراراته بالشكل الذي لا يرى بأن من مصلحته أن يضربك."""@ar ;
    hesin:actions """الثقة في التدخل الإلهي مع الأخذ بالأسباب."""@ar ;
    hesin:hasSynonym """نصر الله"""@ar ;
    hesin:hasSynonym """تأييد الله"""@ar ;
    hesin:hasComponent """نصر الله وتأييده"""@ar ;
    hesin:hasComponent """تأثير أكبر من الإمكانيات"""@ar ;
    hesin:hasComponent """إرهاب العدو"""@ar ;
    hesin:hasComponent """إرباك قرارات العدو"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_27 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C145 a hesin:Concept ;
    rdfs:label """القراءة بنية كذا"""@ar ;
    hesin:definition """تقديم القرآن على أنه مجرد أوراد تقرأ بنيات معينة (كدعاء أو تعويذة) هو تقديم غير صحيح، يؤدي إلى الإحباط عندما لا تتحقق النتائج، ويصرف الناس عن العمل الحقيقي به."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """قالوا: إقرؤوا { قُلْ هُوَ اللهُ أحَد} ألف مرة و{ألم تَر} خمس مائة مرة, يقرؤونها بنية أن الله يدمر أمريكا وإسرائيل!... هذه تقديم للقرآن بالنسبة للعامة بشكل غير صحيح, سيأتي من بعدك إحباط."""@ar ;
    hesin:actions """تقديم القرآن كمنهج للعمل لا كتعويذة."""@ar ;
    hesin:hasSynonym """تقديم القرآن كتعويذة"""@ar ;
    hesin:hasSynonym """قراءة الأوراد"""@ar ;
    hesin:hasComponent """تقديم القرآن كتعويذة"""@ar ;
    hesin:hasComponent """القراءة بنيات معينة"""@ar ;
    hesin:hasComponent """إهمال العمل به"""@ar ;
    hesin:hasComponent """الإحباط عند عدم النتيجة"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_27 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C146 a hesin:Concept ;
    rdfs:label """العمل بالقرآن"""@ar ;
    hesin:definition """العمل بالقرآن هو السير على هديه وتطبيقه في الواقع، وليس مجرد قراءته بنيات معينة، وهو الذي يحقق النتائج الملموسة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """يُقدم القرآن بالشكل الصحيح في التعامل معه, هو يهدي عملياً تنطلق {وَأَعِدُّواْ لَهُم مَّا اسْتَطَعْتُم مِّن قُوَّةٍ}... أليس هو يتحدث؟ يهدي عملياً؛ لأنه أنزله كتاباً لنقرأه ونسير على هديه."""@ar ;
    hesin:actions """التركيز على العمل بالقرآن لا القراءة فقط."""@ar ;
    hesin:hasSynonym """تطبيق القرآن"""@ar ;
    hesin:hasSynonym """السير على هداه"""@ar ;
    hesin:hasComponent """السير على هدى القرآن"""@ar ;
    hesin:hasComponent """تطبيق القرآن في الواقع"""@ar ;
    hesin:hasComponent """العمل العملي لا القراءة فقط"""@ar ;
    hesin:hasComponent """تحقيق النتائج"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_27 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C147 a hesin:Concept ;
    rdfs:label """إحباط وهبوط قيمة القرآن"""@ar ;
    hesin:definition """تقديم القرآن بشكل غير صحيح (كقراءة أوراد بنيات معينة) يؤدي إلى الإحباط وهبوط قيمة القرآن في النفوس عندما لا تتحقق النتائج المتوقعة."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """ماذا سيقول الناس بعد, من يقرؤون القرآن بالشكل هذا؟ سيقول واحد: ما نفع، هي نفس هذه, يعني هو ليس فيه حلاً للمشكلة هذه, ما عمل شيء, ما له أثر! ما هنا ستهبط قيمة القرآن في النفس."""@ar ;
    hesin:actions """تقديم القرآن كمنهج للعمل لا كتعويذة."""@ar ;
    hesin:hasSynonym """فقدان الثقة بالقرآن"""@ar ;
    hesin:hasSynonym """انخفاض القيمة"""@ar ;
    hesin:hasComponent """فقدان الثقة بالقرآن"""@ar ;
    hesin:hasComponent """هبوط قيمة القرآن"""@ar ;
    hesin:hasComponent """اليأس من فعاليته"""@ar ;
    hesin:hasComponent """الانصراف عنه"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_27 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C148 a hesin:Concept ;
    rdfs:label """تحقيق النصر"""@ar ;
    hesin:definition """النصر الحقيقي يتحقق بالعمل بالقرآن والسير على هديه، وليس بالتمني أو القراءة بنيات معينة، وهو وعد إلهي لمن يسيرون على هداه."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """أليس الناس سيموتون رغماً عنهم؟ إذا اتركها, وقد نحن في آخر الدنيا... خلنا نجرب القرآن, ننطلق على هديه بثقة وأينما وصلنا نوصل."""@ar ;
    hesin:actions """الثقة في نصر الله مع العمل الجاد."""@ar ;
    hesin:hasSynonym """غلبة الحق"""@ar ;
    hesin:hasSynonym """نصر الله"""@ar ;
    hesin:hasComponent """العمل بالقرآن"""@ar ;
    hesin:hasComponent """الثقة بهدى الله"""@ar ;
    hesin:hasComponent """السير على المنهج"""@ar ;
    hesin:hasComponent """وعد الله بالنصر"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_27 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C149 a hesin:Concept ;
    rdfs:label """الإعجاز القرآني الشامل"""@ar ;
    hesin:definition """إعجاز القرآن لا يقتصر على الجانب البلاغي والفني فقط، بل يشمل كل مجالات الحياة: النظام والتشريع والتربية والاقتصاد والسياسة وغيرها. القرآن فوق أي نظرية أو منهج بشري في أي زمان."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """موضوع أن القرآن معجز ليس الموضوع مرتبطاً بالنص اللغوي فقط... سيعرف أي إنسان لديه اهتمام في مجال من المجالات أن القرآن فوقه... هو معجز في أي زمان, الإنس والجن في أي زمان."""@ar ;
    hesin:actions """تقديم القرآن كمعجزة شاملة في كل المجالات، لا كمعجزة لغوية فقط."""@ar ;
    hesin:hasSynonym """إعجاز القرآن"""@ar ;
    hesin:hasSynonym """تحدي الإنس والجن"""@ar ;
    hesin:hasComponent """الإعجاز البلاغي والفني"""@ar ;
    hesin:hasComponent """الإعجاز التشريعي والنظامي"""@ar ;
    hesin:hasComponent """الإعجاز التربوي والنفسي"""@ar ;
    hesin:hasComponent """الإعجاز الاقتصادي والسياسي"""@ar ;
    hesin:hasComponent """الإعجاز في سعة المعنى وعمقه"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_28 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C150 a hesin:Concept ;
    rdfs:label """شمولية التحدي القرآني"""@ar ;
    hesin:definition """تحدّي القرآن للإنس والجن ليس مقيدًا بزمان أو مكان، بل هو مستمر إلى آخر الزمان. كلما تطورت قدرات البشر زادت قدرتهم على إدراك عظمة القرآن وإعجازه."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أليس الإنس حق الزمان هذا قد عندهم خبرات أكثر؟... هو معجز في أي زمان, الإنس والجن في أي زمان."""@ar ;
    hesin:actions """تقديم التحدي القرآني كحقيقة مستمرة في كل زمان."""@ar ;
    hesin:hasSynonym """التحدي في كل زمان"""@ar ;
    hesin:hasSynonym """تحدي الإنس والجن"""@ar ;
    hesin:hasComponent """التحدي مستمر في كل زمان"""@ar ;
    hesin:hasComponent """التحدي للإنس والجن جميعًا"""@ar ;
    hesin:hasComponent """عدم تقييد التحدي بزمان النزول"""@ar ;
    hesin:hasComponent """تجدد الإعجاز مع تطور الزمن"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_28 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C151 a hesin:Concept ;
    rdfs:label """حصر الإعجاز في البلاغة"""@ar ;
    hesin:definition """مفهوم قاصر يحصر إعجاز القرآن في الجانب البلاغي والفني فقط، ويتجاهل الأبعاد الأخرى من الإعجاز التشريعي والتربوي والنظامي."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """موضوع أن القرآن معجز ليس الموضوع مرتبطاً بالنص اللغوي فقط... عندما يفهم واحد بأن معنى:{لاَ يَأْتُونَ بِمِثْلِهِ} في جانب الفصاحة مثلاً, الفصاحة! الموضوع أوسع من هذا بكثير."""@ar ;
    hesin:actions """توسيع مفهوم الإعجاز ليشمل كل المجالات."""@ar ;
    hesin:hasSynonym """الإعجاز البلاغي فقط"""@ar ;
    hesin:hasSynonym """الجانب الفني"""@ar ;
    hesin:hasComponent """التركيز على الفصاحة والبلاغة فقط"""@ar ;
    hesin:hasComponent """تجاهل الجوانب الأخرى للإعجاز"""@ar ;
    hesin:hasComponent """ضعف الحجة في مواجهة غير العرب"""@ar ;
    hesin:hasComponent """عدم استيعاب سعة القرآن"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_28 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C152 a hesin:Concept ;
    rdfs:label """تجدد الإعجاز مع الزمن"""@ar ;
    hesin:definition """القرآن ليس كتابًا يُفهم مرة واحدة، بل كلما تقدم الزمن وتطورت المعارف البشرية، تتجلى عظمة القرآن من جديد، ويكون متقدمًا على كل النظريات البشرية."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """تفسر أنت في القرن الثالث, ما يأتي القرن الخامس إلا وقد أنت هناك وراء... وهو تجده يستوعب الحياة, يستوعب الحياة, كلما تأتي من أشياء هي تشهد له."""@ar ;
    hesin:actions """تقديم القرآن ككتاب متجدد في هدايته لكل عصر."""@ar ;
    hesin:hasSynonym """القرآن يتجاوز الزمن"""@ar ;
    hesin:hasSynonym """يستوعب كل العصور"""@ar ;
    hesin:hasComponent """القرآن يتجاوز التفاسير القديمة"""@ar ;
    hesin:hasComponent """يستوعب التطورات الحضارية"""@ar ;
    hesin:hasComponent """يتقدم على النظريات البشرية"""@ar ;
    hesin:hasComponent """يظل شاهدًا على الحق في كل عصر"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_28 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C153 a hesin:Concept ;
    rdfs:label """ضعف الحجة في مواجهة الآخرين"""@ar ;
    hesin:definition """ضعف المسلمين في مواجهة الآخرين وشبهاتهم ناتج عن ضعف فهمهم للقرآن واقتصارهم على الجوانب السطحية من إعجازه، وتركهم لمنهج القرآن في الحوار."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """تجد الأغلبية سيبرز وما هو فاهم للقرآن, أولاً ما هو فاهم منهجية القرآن, ولا فاهم لطريقة القرآن... يترتب على هذه هز للقرآن في النفوس."""@ar ;
    hesin:actions """العودة إلى الفهم الشامل للإعجاز القرآني."""@ar ;
    hesin:hasSynonym """العجز عن الإقناع"""@ar ;
    hesin:hasSynonym """ضعف الموقف"""@ar ;
    hesin:hasComponent """ضعف الفهم للقرآن"""@ar ;
    hesin:hasComponent """حصر الإعجاز في البلاغة"""@ar ;
    hesin:hasComponent """ترك منهج القرآن في الحوار"""@ar ;
    hesin:hasComponent """هزيمة نفسية أمام الآخرين"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_28 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C154 a hesin:Concept ;
    rdfs:label """القرآن سلاح"""@ar ;
    hesin:definition """القرآن هو السلاح الحقيقي للمسلمين في مواجهة أعدائهم، وليس العكس (أن المسلمين يدافعون عن القرآن). القرآن يكمم أفواه المعاندين ويلجمهم بالتحدي والإعجاز."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """القرآن هو سلاح يحمي الرسول نفسه... القرآن هو نفسه يكمم أفواهكم, ويلجمكم... افهم بأنه هو الذي يدافع عنك أنت, ما أنت الذي تأتي تتصدق عليه تدافع عنه."""@ar ;
    hesin:actions """استخدام القرآن كسلاح في الحوار من خلال التحدي والاستشهاد به."""@ar ;
    hesin:hasSynonym """الإسلام سلاح"""@ar ;
    hesin:hasSynonym """القرآن يدافع عن أهله"""@ar ;
    hesin:hasComponent """القرآن سلاح دفاعي وهجومي"""@ar ;
    hesin:hasComponent """القرآن يكمم أفواه المعاندين"""@ar ;
    hesin:hasComponent """القرآن هو المدافع عن أهله"""@ar ;
    hesin:hasComponent """استخدام التحدي كسلاح"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_29 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C155 a hesin:Concept ;
    rdfs:label """منهج التحدي القرآني"""@ar ;
    hesin:definition """منهج قرآني في الحوار مع المعاندين يقوم على التحدي المباشر: أن يأتوا بمثل القرآن أو بسورة من مثله، مع الاستشهاد بعجز البشر عن ذلك في كل زمان."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هنا يقول له: قل, يقدم القرآن سلاحاً... القرآن هو نفسه يكمم أفواهكم, ويلجمكم, وأنتم أعجز من أن تأتوا بشيء من مثله."""@ar ;
    hesin:actions """استخدام التحدي القرآني كأداة في الحوار مع المعاندين."""@ar ;
    hesin:hasSynonym """قل لهم"""@ar ;
    hesin:hasSynonym """التحدي بالقرآن"""@ar ;
    hesin:hasComponent """التحدي المباشر للمعاندين"""@ar ;
    hesin:hasComponent """الاستشهاد بالإعجاز القرآني"""@ar ;
    hesin:hasComponent """عدم الانشغال بالجدل العقلي"""@ar ;
    hesin:hasComponent """إلجام الخصم وكم أفواهه"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_29 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C156 a hesin:Concept ;
    rdfs:label """الدفاع عن القرآن"""@ar ;
    hesin:definition """مفهوم قاصر يصور المسلمين وكأنهم يدافعون عن القرآن، بينما الحقيقة أن القرآن هو الذي يدافع عنهم ويقويهم ويمنحهم القوة في مواجهة الخصوم."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """قد تترسخ القضية لدينا: [أن القرآن مسكين الله, والدين هذا مسكين الله عوينه ندافع عنه احنا]... لا..., القضية أرفع من هذا, أنك أنت, أنت الذي بحاجة إليه."""@ar ;
    hesin:actions """تقديم القرآن كقوة وسلاح لا كشيء يحتاج للدفاع."""@ar ;
    hesin:hasSynonym """ندافع عن ديننا"""@ar ;
    hesin:hasSynonym """حماية الإسلام"""@ar ;
    hesin:hasComponent """تصوير القرآن كضعيف يحتاج للدفاع"""@ar ;
    hesin:hasComponent """نسيان قوة القرآن الذاتية"""@ar ;
    hesin:hasComponent """ضعف الموقف النفسي"""@ar ;
    hesin:hasComponent """فقدان الثقة في القرآن"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_29 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C157 a hesin:Concept ;
    rdfs:label """الاستشهاد بالواقع لتجليات العجز"""@ar ;
    hesin:definition """منهج في الحوار يعتمد على الاستشهاد بالواقع والتجارب التاريخية لإظهار عجز النظريات البشرية وفشلها، قبل الدخول في مناقشة القرآن."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """مهم جداً أن يكون عند الناس آلية للإحصائيات... عندما طرحت الإشتراكية كنظرية, وحصل لها دولة... كيف كانت نتائجها في الحياة؟"""@ar ;
    hesin:actions """جمع وتحليل نتائج النظريات البشرية لاستخدامها في الحوار."""@ar ;
    hesin:hasSynonym """إحصائيات"""@ar ;
    hesin:hasSynonym """شواهد واقعية"""@ar ;
    hesin:hasComponent """جمع الإحصائيات والمعلومات"""@ar ;
    hesin:hasComponent """عرض نتائج النظريات الأخرى"""@ar ;
    hesin:hasComponent """إظهار فشلها في الواقع"""@ar ;
    hesin:hasComponent """تهيئة الطرف الآخر لتقبل القرآن"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_29 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C158 a hesin:Concept ;
    rdfs:label """تفنيد الآخر من واقعه"""@ar ;
    hesin:definition """منهج في الحوار يقوم على إبطال آراء الخصم من خلال عرض نتائجها السلبية في الواقع، وإظهار التناقضات في نظرياته، قبل الدخول في عرض الحق."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """تستطيع قبل أن تصل إلى موضوعك أنت تفنده هو من واقعه, وتبطل ما عنده مما عنده, تبطل ما عنده مما تجلى في واقع حياته هو."""@ar ;
    hesin:actions """دراسة واقع الخصم ونظرياته لاستخدامها في الرد عليه."""@ar ;
    hesin:hasSynonym """هزيمة الخصم بواقعه"""@ar ;
    hesin:hasSynonym """إبطال ما لديه بما لديه"""@ar ;
    hesin:hasComponent """عرض نتائج نظريات الخصم في الواقع"""@ar ;
    hesin:hasComponent """إظهار التناقضات في منهجه"""@ar ;
    hesin:hasComponent """إبطال ما لديه من خلال ما لديه"""@ar ;
    hesin:hasComponent """تهيئته لقبول الحق"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_29 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C159 a hesin:Concept ;
    rdfs:label """القرآن يفسر نفسه"""@ar ;
    hesin:definition """القرآن نفسه هو المرجع الأساسي لفهمه، من خلال التدبر والتأمل، وليس من خلال التفاسير البشرية التي قد تقصر أو تخطئ. القرآن يفتح أبواب علومه لمن يتدبره بإنصاف."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """القرآن هو نفسه يعتبر هنا هو الذي يفسر نفسه له, هو الذي يقدم نفسه له, هو الذي يفتح أبواب علومه له.. تدبر, تأمل, والقرآن هو يقدم نفسه لك."""@ar ;
    hesin:actions """التركيز على التدبر والتأمل في القرآن نفسه."""@ar ;
    hesin:hasSynonym """تدبر القرآن"""@ar ;
    hesin:hasSynonym """القرآن يهدي إلى نفسه"""@ar ;
    hesin:hasComponent """التدبر والتأمل في الآيات"""@ar ;
    hesin:hasComponent """القرآن يفسر نفسه بنفسه"""@ar ;
    hesin:hasComponent """عدم الاعتماد على التفاسير البشرية فقط"""@ar ;
    hesin:hasComponent """الانفتاح على هداية القرآن المباشرة"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_30 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C160 a hesin:Concept ;
    rdfs:label """الاعتماد على التفاسير البشرية فقط"""@ar ;
    hesin:definition """مفهوم خاطئ يقتصر على التفاسير البشرية في فهم القرآن، ويتجاهل أن القرآن نفسه يهدي ويفتح أبواب علومه لمن يتدبره، وأن التفاسير البشرية قاصرة ومتجاوزة."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """لاحظ كيف يفتضح المفسر, المفسر للقرآن نفسه, الذي فسر لك قبل ألف سنة, تجد الآن بأن الكثير من تفسيراته ليست معقولة, ولاهي مقبولة."""@ar ;
    hesin:actions """عدم الاقتصار على التفاسير والانطلاق إلى التدبر المباشر."""@ar ;
    hesin:hasSynonym """التفسير بالمأثور"""@ar ;
    hesin:hasSynonym """تفسير السلف"""@ar ;
    hesin:hasComponent """الاعتماد الكلي على التفاسير القديمة"""@ar ;
    hesin:hasComponent """تجاهل التدبر المباشر للقرآن"""@ar ;
    hesin:hasComponent """جمود الفهم وعدم تجدده"""@ar ;
    hesin:hasComponent """تقييد القرآن بفهم السابقين"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_30 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C161 a hesin:Concept ;
    rdfs:label """البيان الإلهي للقرآن"""@ar ;
    hesin:definition """بيان القرآن لا يقتصر على التفاسير اللفظية، بل يتمثل في حركة رسول الله (صلى الله عليه وآله) في الحياة، وتجسيده لهدي القرآن في مواقفه وأفعاله."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """البيان في حركته في الحياة, هو قرآن يتحرك, حركته كلها هي ماذا؟ تجسيد للقرآن, لما يهدي إليه القرآن."""@ar ;
    hesin:actions """فهم البيان القرآني من خلال حركة الرسول وأهل بيته في الحياة."""@ar ;
    hesin:hasSynonym """علينا بيانه"""@ar ;
    hesin:hasSynonym """البيان بالحركة"""@ar ;
    hesin:hasComponent """البيان بالحركة والتطبيق"""@ar ;
    hesin:hasComponent """تجسيد هدي القرآن في الحياة"""@ar ;
    hesin:hasComponent """مواقف الرسول (صلى الله عليه وآله) كبيان"""@ar ;
    hesin:hasComponent """عدم حصر البيان في التفاسير اللفظية"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_30 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C162 a hesin:Concept ;
    rdfs:label """حصر البيان في التفاسير اللفظية"""@ar ;
    hesin:definition """مفهوم خاطئ يحصر بيان القرآن في التفاسير اللفظية والروايات، ويتجاهل أن البيان الإلهي يتمثل في حركة الرسول (صلى الله عليه وآله) وتجسيده للقرآن في الحياة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أين هي الشروح حق القرآن؟ لمن يفهم القضية بهذا الشكل, مسألة شروح, وروايات, وأشياء من هذه... {ثُمَّ إِنَّ عَلَيْنَا بَيَانَهُ} الم يكن بالإمكان أن يرفق به{بيانه} فيعمل مجلدين آخرين؟ شرح بيان القرآن."""@ar ;
    hesin:actions """فهم البيان القرآني من خلال التطبيق العملي لا من خلال التفاسير فقط."""@ar ;
    hesin:hasSynonym """التفسير بالمأثور فقط"""@ar ;
    hesin:hasSynonym """البيان هو القول"""@ar ;
    hesin:hasComponent """حصر البيان في الكلام والروايات"""@ar ;
    hesin:hasComponent """تجاهل البيان بالحركة والتطبيق"""@ar ;
    hesin:hasComponent """إضاعة الجانب العملي من السنة"""@ar ;
    hesin:hasComponent """البحث عن تفاسير لفظية غير موجودة"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_30 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C163 a hesin:Concept ;
    rdfs:label """ضياع السنة الحقيقية"""@ar ;
    hesin:definition """ضياع الجانب العملي من سنة رسول الله (صلى الله عليه وآله) بسبب الانشغال بالروايات والأحاديث اللفظية، بينما السنة الحقيقية تتمثل في حركته وتجسيده للقرآن."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """هذا هو الجانب الذي لا يوجد فيه روايات, لا يوجد فيه أحاديث... هذا هو الجانب المهم, والجانب الكبير, وهذا هو البيان, أين هو هذا؟ عند الإمام علي."""@ar ;
    hesin:actions """العودة إلى فهم حركة الرسول (صلى الله عليه وآله) من خلال من حفظها (آل البيت)."""@ar ;
    hesin:hasSynonym """فقدان سنة الرسول العملية"""@ar ;
    hesin:hasSynonym """الانشغال بالروايات"""@ar ;
    hesin:hasComponent """الانشغال بالروايات اللفظية"""@ar ;
    hesin:hasComponent """إهمال الجانب العملي من السنة"""@ar ;
    hesin:hasComponent """فقدان فهم حركة الرسول في الحياة"""@ar ;
    hesin:hasComponent """الحاجة إلى من يحفظ السنة (الإمام علي)"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_30 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C164 a hesin:Concept ;
    rdfs:label """أسرار القرآن والاختصاص الإلهي"""@ar ;
    hesin:definition """هناك علوم وأسرار في القرآن يختص الله بها من يشاء من عباده، وهذه الاختصاصات ليست لتميز شخصي، بل لقيادة الأمة وأداء المهام الهامة في الحياة."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """قد يكون فيه أشياء هي اختصاصات... الشخص الذي له مهمة, وكل المهام هي مرتبطة بمن؟ بالحياة, بالبشر جميعاً... سيفهمه صاحب الدور المنوط به مهمة معينة."""@ar ;
    hesin:actions """التسليم بوجود اختصاصات إلهية في فهم القرآن مع عدم الغلو."""@ar ;
    hesin:hasSynonym """خفايا القرآن"""@ar ;
    hesin:hasSynonym """مكنون القرآن"""@ar ;
    hesin:hasComponent """وجود أسرار وعلوم خفية في القرآن"""@ar ;
    hesin:hasComponent """اختصاص الله بها من يشاء"""@ar ;
    hesin:hasComponent """الاختصاص مرتبط بالمهام والمسؤوليات"""@ar ;
    hesin:hasComponent """النتيجة تعود على الأمة جميعًا"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_30 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C165 a hesin:Concept ;
    rdfs:label """الدعوة إلى الله لا إلى الشخص"""@ar ;
    hesin:definition """منهج الدعوة الإسلامية يقوم على الدعوة إلى الله وشد الناس إلى الله، لا إلى الشخص الداعية. أولياء الله لا يوقفون الناس عند شخصهم، بل يمررونهم إلى الله."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أولياء الله فيمشوا الناس مطلع كلها, كلهم رجال مرور, مطلع إلى الله... لا يوقفك عنده إلا من؟ إلا أولياء الشيطان, يربطك عنده وفقط."""@ar ;
    hesin:actions """التركيز في الدعوة على شد الناس إلى الله، لا إلى الشخص."""@ar ;
    hesin:hasSynonym """إذابة الشخصية"""@ar ;
    hesin:hasSynonym """الشد إلى الله"""@ar ;
    hesin:hasComponent """الدعوة إلى الله لا إلى الشخص"""@ar ;
    hesin:hasComponent """إذابة الشخصية في الدعوة"""@ar ;
    hesin:hasComponent """تمرير الناس إلى الله"""@ar ;
    hesin:hasComponent """تجنب التبعية الشخصية"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_31 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C166 a hesin:Concept ;
    rdfs:label """التبعية الشخصية"""@ar ;
    hesin:definition """منهج منحرف في الدعوة يقوم على ربط الناس بشخص الداعية وإيقافهم عنده، بدلاً من شدهم إلى الله. هذا المنهج هو منهج أولياء الشيطان."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أولياء الشيطان, يربطك عنده وفقط, ويريد هو, هو, ويوقف الناس عند شخصيته هو!... فقط إلى عنده!"""@ar ;
    hesin:actions """تجنب ربط الناس بالشخص والتركيز على شدهم إلى الله."""@ar ;
    hesin:hasSynonym """الربط بالشخص"""@ar ;
    hesin:hasSynonym """أولياء الشيطان"""@ar ;
    hesin:hasComponent """ربط الناس بشخص الداعية"""@ar ;
    hesin:hasComponent """إيقاف الناس عند الشخص"""@ar ;
    hesin:hasComponent """عدم تمريرهم إلى الله"""@ar ;
    hesin:hasComponent """تكوين تبعية شخصية"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_31 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C167 a hesin:Concept ;
    rdfs:label """نموذج الجن في الدعوة"""@ar ;
    hesin:definition """نموذج الجن في تعاملهم مع القرآن هو نموذج مثالي: استمعوا فآمنوا، ثم ذهبوا إلى قومهم منذرين، داعين إلى الله لا إلى أنفسهم، قائلين "أجيبوا داعي الله"."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هؤلاء الجن عندما حضروا القرآن واستمعوه ماذا قالوا بعد هذه؟ {يَهْدِي إِلَى الرُّشْدِ فَآمَنَّا بِهِ وَلَن نُّشْرِكَ بِرَبِّنَا أَحَداً}... {ولَّوْا} رجعوا {إلى قومهم منذرين}."""@ar ;
    hesin:actions """تقديم نموذج الجن كنموذج مثالي في الاستجابة والدعوة."""@ar ;
    hesin:hasSynonym """استماع الجن"""@ar ;
    hesin:hasSynonym """تعامل الجن مع القرآن"""@ar ;
    hesin:hasComponent """الاستماع بإصغاء وتدبر"""@ar ;
    hesin:hasComponent """الإيمان السريع والقاطع"""@ar ;
    hesin:hasComponent """الذهاب للإنذار والدعوة"""@ar ;
    hesin:hasComponent """الدعوة إلى الله لا إلى الشخص"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_31 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C168 a hesin:Concept ;
    rdfs:label """الله يفيض على من يطيعه"""@ar ;
    hesin:definition """من أطاع الله وشكره، يفيض الله عليه من كرمه وعزته وعلمه وحكمته. بينما الدعاة الذين يربطون الناس بشخصهم ليس لديهم شيء يفيضونه على الناس."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """الله ما بيربط عنده هو, في الأخير يرد على الناس هم, فيفيض عليهم من كرمه... {لَئِن شَكَرْتُمْ لأَزِيدَنَّكُمْ}... أنت ماذا لديك من شيء؟ لا شيء."""@ar ;
    hesin:actions """التركيز على شكر الله وطاعته لتحقيق الفيض الإلهي."""@ar ;
    hesin:hasSynonym """شكر الله يزيد"""@ar ;
    hesin:hasSynonym """من أطاع الله أفاض عليه"""@ar ;
    hesin:hasComponent """الله يفيض على من يطيعه"""@ar ;
    hesin:hasComponent """الشكر يؤدي إلى الزيادة"""@ar ;
    hesin:hasComponent """الدعاة الحقيقيون يمررون الناس إلى الله"""@ar ;
    hesin:hasComponent """التبعية الشخصية لا تجلب خيرًا"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_31 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C169 a hesin:Concept ;
    rdfs:label """القرآن هدى ورحمة ونقمة"""@ar ;
    hesin:definition """القرآن الكريم هو كتاب واحد، لكنه يكون هدى ورحمة للمتقين، ويكون ضلالًا ونقمة لمن أعرض عنه. ليس لأن القرآن يختلف، بل لأن الناس يختلفون في استجابتهم."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """وهو أمر من أمور الله واحد، يضل به الضال ويرشد عنه الراشد، فهو ضلال لمن ضل عنه، وهدى لمن قبل منه، ونجاة لمن اتقى ورحمة وبركة، وخزي على من تعدى ونقمة وهلكة."""@ar ;
    hesin:actions """التأكيد على أن القرآن واحد، والاختلاف في النفوس."""@ar ;
    hesin:hasSynonym """ضلال لمن ضل عنه"""@ar ;
    hesin:hasSynonym """هدى لمن اهتدى"""@ar ;
    hesin:hasComponent """القرآن واحد لا يتغير"""@ar ;
    hesin:hasComponent """هدى ورحمة للمتقين"""@ar ;
    hesin:hasComponent """ضلال ونقمة للمعرضين"""@ar ;
    hesin:hasComponent """الاختلاف في الاستجابة لا في النص"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_32 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C170 a hesin:Concept ;
    rdfs:label """لا تغيير للنعمة إلا بتغيير النفس"""@ar ;
    hesin:definition """سنة الله في تغيير النعم والنقم أن التغيير يبدأ من داخل الإنسان نفسه. الله لا يغير ما بقوم حتى يغيروا ما بأنفسهم، فلا يلومن الإنسان إلا نفسه."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """إنما هو في الأخير يقدم لهم: {إِنَّ اللّهَ لاَ يُغَيِّرُ مَا بِقَوْمٍ حَتَّى يُغَيِّرُواْ مَا بِأَنْفُسِهِمْ}... وهذا يعطينا شاهد آخر."""@ar ;
    hesin:actions """تحميل الإنسان مسؤولية تغيير واقعه."""@ar ;
    hesin:hasSynonym """التغيير من عند النفس"""@ar ;
    hesin:hasSynonym """سنة التغيير الإلهي"""@ar ;
    hesin:hasComponent """التغيير يبدأ من النفس"""@ar ;
    hesin:hasComponent """لا تغيير للنعمة إلا بتغيير النفس"""@ar ;
    hesin:hasComponent """مسؤولية الإنسان عن واقعه"""@ar ;
    hesin:hasComponent """عدم تحميل الله مسؤولية الضعف"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_32 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C171 a hesin:Concept ;
    rdfs:label """القرآن كتاب حركة وحياة"""@ar ;
    hesin:definition """القرآن ليس كتاب معلومات يُقرأ مرة واحدة ويُفهم، بل هو كتاب حياة وحركة. الإنسان في حركة دائمة في الحياة، ويحتاج إلى هداية متجددة باستمرار."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """ليس كتاباً يمكن تقراه, تقراه, وتكمله, وتفهمه ثم تقوم تنطلق! أبداً, أبداً, هو كتاب حياة, كتاب حركة."""@ar ;
    hesin:actions """تقديم القرآن ككتاب للحركة والحياة لا للمعلومات فقط."""@ar ;
    hesin:hasSynonym """القرآن للحركة"""@ar ;
    hesin:hasSynonym """الحياة تحتاج هداية دائمة"""@ar ;
    hesin:hasComponent """القرآن للحياة والحركة"""@ar ;
    hesin:hasComponent """الهداية متجددة باستمرار"""@ar ;
    hesin:hasComponent """الإنسان في حركة دائمة"""@ar ;
    hesin:hasComponent """الحاجة إلى الإرشاد المستمر"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_32 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C172 a hesin:Concept ;
    rdfs:label """لا يعلم أسرار القرآن إلا المخصوصون"""@ar ;
    hesin:definition """لا يمكن لأي كان أن يحيط بكل أسرار القرآن، بل لا يعلمها إلا المخصوصون من الله (أهل البيت)، وهم الذين أؤتمنوا عليها لهداية الأمة."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """لا يحيط بعلمها المكنون، إلا كل مخصوص به مأمون... فَسِرُّ ما نزل الله سبحانه من الكتاب، فخفِيٌّ على كل مستهزئ لعَّاب."""@ar ;
    hesin:actions """الرجوع إلى أهل الاختصاص (آل البيت) في فهم أسرار القرآن."""@ar ;
    hesin:hasSynonym """المخصوصون بالعلم"""@ar ;
    hesin:hasSynonym """أهل البيت"""@ar ;
    hesin:hasComponent """وجود أسرار مكنونة في القرآن"""@ar ;
    hesin:hasComponent """لا يعلمها إلا المخصوصون"""@ar ;
    hesin:hasComponent """المخصوصون مؤتمنون عليها"""@ar ;
    hesin:hasComponent """خفاء الأسرار عن المستهزئين"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_32 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C173 a hesin:Concept ;
    rdfs:label """القلب آلية التعقل والفقه"""@ar ;
    hesin:definition """القلب (وليس العقل كمخلوق مستقل) هو الآلية التي يعقل بها الإنسان ويفقه. عملية التعقل (العقل) هي فعل الإنسان نفسه بواسطة القلب، وليس هناك مخلوق اسمه "العقل" منفصل عن الإنسان."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """القلب هو الآلية للتعقل, والفقه. القلب هو الآلية, وهي صريحة في القرآن مثل:{أَفَلَمْ يَسِيرُوا فِي الْأَرْضِ فَتَكُونَ لَهُمْ قُلُوبٌ يَعْقِلُونَ بِهَا}(الحج46) في آية أخرى:{لَهُمْ قُلُوبٌ لاَّ يَفْقَهُونَ بِهَا}(الأعراف179)."""@ar ;
    hesin:actions """في أي نظام معرفي، يجب اعتبار القلب (المدرك الإنساني) هو الآلية الأساسية، وليس "العقل" كمفهوم مجرد."""@ar ;
    hesin:hasSynonym """الفؤاد"""@ar ;
    hesin:hasSynonym """الآلية الإدراكية"""@ar ;
    hesin:hasComponent """القلب هو وعاء التعقل والفقه"""@ar ;
    hesin:hasComponent """الإنسان هو الذي يعقل ويفقه (الفاعل الحقيقي)"""@ar ;
    hesin:hasComponent """لا وجود لـ "عقل" كمخلوق مستقل"""@ar ;
    hesin:hasComponent """القلب قابل للتغير والتأثر"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_33 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C174 a hesin:Concept ;
    rdfs:label """العقل كمخلوق مستقل"""@ar ;
    hesin:definition """مفهوم منحرف يفترض وجود "عقل" كمخلوق مستقل له وجود ذاتي، وأنه يحل في القلب، وهذا المفهوم ليس له أصل في القرآن ويؤدي إلى أخطاء كبيرة في فهم الهداية."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أخطاء كبيرة جداً عندما حصل تصور أن هناك مخلوق آخر, مخلوق آخر, له وجوده ذاتياً وله كيانه, وهو العقل, يسمونه العقل, والقلب إنما هو عبارة عن محل والعقل هو في داخل القلب, وحالّ في القلب."""@ar ;
    hesin:actions """رفض مفهوم العقل كمخلوق مستقل والعودة إلى المفهوم القرآني للقلب."""@ar ;
    hesin:hasSynonym """العقل جوهر"""@ar ;
    hesin:hasSynonym """العقل عرض في القلب"""@ar ;
    hesin:hasComponent """العقل كمخلوق منفصل عن الإنسان"""@ar ;
    hesin:hasComponent """القلب مجرد محل للعقل"""@ar ;
    hesin:hasComponent """الإدراكات من العقل لا من الإنسان"""@ar ;
    hesin:hasComponent """استقلال الإنسان عن الله في المعرفة"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_33 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C175 a hesin:Concept ;
    rdfs:label """فقر الإنسان إلى الله في الهدى"""@ar ;
    hesin:definition """الإنسان في حالة فقر مطلق وحاجة دائمة إلى الله في كل شيء، وخاصة في الهدى. لا يمكن للإنسان أن يهتدي أو يعرف الحق والباطل من ذاته أو من "عقل" مستقل، بل لا بد من ارتباطه بالله."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """إذا عندك فهم بأن عندك آلية معينة هي تفرز حق وباطل, وخطأ وصواب, فستكون مفصول عن الله... التأكيد على أن يبقى الإنسان دائماً مسيطر على شعوره حاجته المطلقة إلى الله{يَا أَيُّهَا النَّاسُ أَنتُمُ الْفُقَرَاء إِلَى اللَّه}(فاطر15) فقراء في كل مجال, في كل شيء."""@ar ;
    hesin:actions """التأكيد على حاجة الإنسان لله في كل مجال، وخاصة في الهدى."""@ar ;
    hesin:hasSynonym """الحاجة المطلقة لله"""@ar ;
    hesin:hasSynonym """لا استقلال عن الله"""@ar ;
    hesin:hasComponent """الفقر المطلق إلى الله"""@ar ;
    hesin:hasComponent """الحاجة الدائمة للهداية الإلهية"""@ar ;
    hesin:hasComponent """عدم الاستقلال عن الله في المعرفة"""@ar ;
    hesin:hasComponent """الاستعانة بالله في كل شيء"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_33 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C176 a hesin:Concept ;
    rdfs:label """إشكالية استقلال العقل"""@ar ;
    hesin:definition """الاعتقاد بأن الإنسان يمكنه بمفرده (بعقله) أن يميز الحق من الباطل دون حاجة إلى هدى الله هو اعتقاد خاطئ ومضل، وهو سبب ضلال كثير من الناس."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """ما غرق الناس إلا عندما انفصلوا عن الله, غرقوا في الضلال؛ لأنه سار هناك لوحده, كل شخص[بيطنن لوحده]؛ لأن عنده أنه هو يستطيع... هذه العبارات هي من أضل الضلال, العبارات هذه."""@ar ;
    hesin:actions """نقد فكرة الاكتفاء بالعقل والرجوع إلى هدى الله."""@ar ;
    hesin:hasSynonym """الاكتفاء بالعقل"""@ar ;
    hesin:hasSynonym """الاستغناء عن الوحي"""@ar ;
    hesin:hasComponent """الاعتماد على العقل فقط"""@ar ;
    hesin:hasComponent """الاستغناء عن هدى الله"""@ar ;
    hesin:hasComponent """الثقة الزائدة في النفس"""@ar ;
    hesin:hasComponent """الانفصال عن الله"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_33 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C177 a hesin:Concept ;
    rdfs:label """مفهوم التكليف الفردي"""@ar ;
    hesin:definition """مفهوم خاطئ يفترض أن كل إنسان مكلف بفهم القرآن بنفسه، وأنه قادر على ذلك، مما أدى إلى تعدد الآراء والضلال، بدلاً من الرجوع إلى من اختصهم الله بالعلم."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """قاموا كل واحد قال: با نفهمه جا يربض عليه وعنده أنه سيفهمه! طلعنا صفر! حقيقة, وفهمناه قلب, وامتلأت نفوسنا ضلال."""@ar ;
    hesin:actions """رفض مفهوم التكليف الفردي المطلق والرجوع إلى أهل الاختصاص."""@ar ;
    hesin:hasSynonym """كل مكلف يفهم"""@ar ;
    hesin:hasSynonym """الاستقلالية في الفهم"""@ar ;
    hesin:hasComponent """افتراض القدرة الذاتية على الفهم"""@ar ;
    hesin:hasComponent """إهمال الحاجة إلى أعلام الهدى"""@ar ;
    hesin:hasComponent """تعدد الآراء والاختلاف"""@ar ;
    hesin:hasComponent """الانزلاق إلى الضلال"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_33 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C178 a hesin:Concept ;
    rdfs:label """القرآن هدى ونور وحياة"""@ar ;
    hesin:definition """القرآن هو النور الذي يبصر القلوب، والحياة التي تحيي النفوس، والسكن الذي تطمئن إليه النفوس الكريمة، واليقين الذي يزيل الشكوك والحيرة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """نور أعين القلوب المبصرة، وحياة ألباب النفوس المطهرة، إلف فكر كل حكيم، وسكن نفس كل كريم، وقصص الأنباء الصادقة، ونبأ الأمثال المتحققة، ويقين شكوك حيرة أولي الألباب."""@ar ;
    hesin:actions """تقديم القرآن كحياة ونور لا كمعلومات فقط."""@ar ;
    hesin:hasSynonym """كتاب هداية"""@ar ;
    hesin:hasSynonym """نور مبين"""@ar ;
    hesin:hasSynonym """حياة القلوب"""@ar ;
    hesin:hasComponent """نور للقلوب والأبصار"""@ar ;
    hesin:hasComponent """حياة للنفوس والأرواح"""@ar ;
    hesin:hasComponent """إلف وسكن للفكر والنفس"""@ar ;
    hesin:hasComponent """يقين يزيل الشكوك"""@ar ;
    hesin:hasComponent """قصص وأمثال واقعية"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_34 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C179 a hesin:Concept ;
    rdfs:label """القرآن كلام الله"""@ar ;
    hesin:definition """القرآن هو كلام الله، ليس مجرد نص مكتوب، بل هو وحي من الله، خالق السماوات والأرض. قراءة القرآن وتدبره يجب أن تكون في إطار استشعار هذا المعنى العظيم."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """القرآن هو قول الله, هو كلام الله... تأمل ممن هو هذا القرآن الكريم, هو كلام الله, هو من الله, نزله الله, هو وحي الله, الله الذي خلقنا وخلق السماوات والأرض وما فيهما."""@ar ;
    hesin:actions """استشعار عظمة القرآن باعتباره كلام الله."""@ar ;
    hesin:hasSynonym """قول الله"""@ar ;
    hesin:hasSynonym """وحي الله"""@ar ;
    hesin:hasComponent """القرآن كلام الله"""@ar ;
    hesin:hasComponent """وحي من الله"""@ar ;
    hesin:hasComponent """صادر عن خالق الكون"""@ar ;
    hesin:hasComponent """يستشعر القارئ عظمته"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_34 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C180 a hesin:Concept ;
    rdfs:label """تعظيم القرآن"""@ar ;
    hesin:definition """استشعار عظمة القرآن باعتباره كلام الله يؤدي إلى تعظيمه وتقديره، والانتفاع بهداه، وعدم التعامل معه ككتاب عادي."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """إذاً ترى أنه شيء كبير جداً, ونعمة كبيرة جداً أن تكون أنت تقرأ كلام الله, وتسمع كلام الله, ويكون لهداه أثر في نفسك."""@ar ;
    hesin:actions """تعظيم القرآن في النفوس من خلال استشعار أنه كلام الله."""@ar ;
    hesin:hasSynonym """تقدير القرآن"""@ar ;
    hesin:hasSynonym """إجلال القرآن"""@ar ;
    hesin:hasComponent """تقدير نعمة القرآن"""@ar ;
    hesin:hasComponent """استشعار عظمة المتكلم"""@ar ;
    hesin:hasComponent """الاهتمام بهداه"""@ar ;
    hesin:hasComponent """عدم الاستهانة به"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_34 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C181 a hesin:Concept ;
    rdfs:label """الاستثقال والاستهانة"""@ar ;
    hesin:definition """النظر إلى القرآن كتكليف شاق وأحمال ثقيلة يؤدي إلى استثقاله وعدم حبه، وهذا يمنع الانتفاع بهداه."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """قدم الدين بهذا الشكل؛ لهذا الناس هم في واقعهم الكثير منهم يستثقلون القرآن, يستثقلونه... الإنسان ما يستثقل حبيب له."""@ar ;
    hesin:actions """تقديم القرآن كنعمة ومنة، لا كتكليف شاق."""@ar ;
    hesin:hasSynonym """النظر إلى القرآن كتكليف شاق"""@ar ;
    hesin:hasSynonym """الاستخفاف"""@ar ;
    hesin:hasComponent """الشعور بالثقل والأحمال"""@ar ;
    hesin:hasComponent """عدم الحب للقرآن"""@ar ;
    hesin:hasComponent """الاستهانة به"""@ar ;
    hesin:hasComponent """فقدان الانتفاع"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_34 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C182 a hesin:Concept ;
    rdfs:label """القرآن يهدي ويضل"""@ar ;
    hesin:definition """القرآن كتاب واحد، لكنه يهدي المتقين ويزيدهم إيمانًا، ويضل المعرضين ويزيدهم ضلالًا. هذا ليس لأن القرآن يتغير، بل لأن الناس يختلفون في استجابتهم."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """فهو الهادي المضل، وهو المدبر المقبل، وهو المسمع المصم، وهو المهين المُكرِم، وهو المعطي المانع... نور هدىً على نور، وفرقان بين البِرِّ والفجور."""@ar ;
    hesin:actions """فهم أن الهداية والضلال نتيجة استجابة الإنسان، لا تغير في القرآن."""@ar ;
    hesin:hasSynonym """هدى للمتقين"""@ar ;
    hesin:hasSynonym """ضلال للمعرضين"""@ar ;
    hesin:hasComponent """القرآن يهدي من أقبل عليه"""@ar ;
    hesin:hasComponent """القرآن يضل من أعرض عنه"""@ar ;
    hesin:hasComponent """الهداية والضلال نتيجة الاستجابة"""@ar ;
    hesin:hasComponent """صفات متضادة في المفعول لا في الذات"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_35 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C183 a hesin:Concept ;
    rdfs:label """القرآن يقبل ويدبر"""@ar ;
    hesin:definition """القرآن يقبل على من أقبل عليه، ويدبر عن من أعرض عنه. هذه المقابلة هي سنة إلهية في التعامل مع الناس حسب استجابتهم."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """إن أُدبِر عنه أَدبر، أو أُقبِل عليه بصَّر. جعله الله يتلوّن في ذلك بألوان، ويتفنن فيه على أفنان... فمرّةً يُقبل على من أقبل إليه، ومرة يدبر عن من التوى في الهدى عليه."""@ar ;
    hesin:actions """إدراك أن القرآن يستجيب لاستجابة الإنسان."""@ar ;
    hesin:hasSynonym """يدبر عن المعرض"""@ar ;
    hesin:hasSynonym """يقبل على المقبل"""@ar ;
    hesin:hasComponent """القبول لمن أقبل"""@ar ;
    hesin:hasComponent """الإدبار لمن أدبر"""@ar ;
    hesin:hasComponent """الاستجابة للاستجابة"""@ar ;
    hesin:hasComponent """عدم الجمود"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_35 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C184 a hesin:Concept ;
    rdfs:label """القرآن حركة لا وقوف"""@ar ;
    hesin:definition """القرآن ليس كتابًا جامدًا يمكن التوقف فيه، بل هو حركة مستمرة. من لا يركب مع هذه الحركة يغرق كما غرق ابن نوح. لا مجال للتردد أو التسويف."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """القرآن في حركة عندما يقول: اركب معنا وإلا فستكون مع الكافرين أشبه شيء بما حصل, ما حصل لنبي الله نوح مع ابنه... {ارْكَب مَّعَنَا وَلاَ تَكُن مَّعَ الْكَافِرِينَ}(هود42)."""@ar ;
    hesin:actions """التأكيد على أن الانطلاق مع القرآن لا يقبل التوقف أو التسويف."""@ar ;
    hesin:hasSynonym """مسيرة متحركة"""@ar ;
    hesin:hasSynonym """لا توقف"""@ar ;
    hesin:hasComponent """القرآن حركة مستمرة"""@ar ;
    hesin:hasComponent """لا وقوف أو توقف"""@ar ;
    hesin:hasComponent """التسويف يؤدي إلى الهلاك"""@ar ;
    hesin:hasComponent """مثال ابن نوح وموج البحر"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_35 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C185 a hesin:Concept ;
    rdfs:label """القرآن لا يُفهم بمعزل عن أعلامه"""@ar ;
    hesin:definition """لا يمكن فهم القرآن والاهتداء به بمعزل عن أعلامه (أهل البيت). من يحاول فهم القرآن بمفرده يضل، كما ضل المفسرون الذين لم يرجعوا إلى ورثة القرآن."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لا تتصور بأنك حالة نادرة عندما ترجع أنت إلى الطريقة هذه... لا تتصور بأن ما هناك أحداً يحاول يرجع للقرآن وهو هكذا يقرؤه.. لكن بروحية أنه أنا, أنا أهتدي بالقرآن, وأعرف القرآن أنا... لا تتصور بأنك حالة نادرة."""@ar ;
    hesin:actions """الرجوع إلى أعلام الهدى (أهل البيت) لفهم القرآن."""@ar ;
    hesin:hasSynonym """الحاجة إلى ورثة القرآن"""@ar ;
    hesin:hasSynonym """القرناء"""@ar ;
    hesin:hasComponent """القرآن يحتاج إلى من يفسره"""@ar ;
    hesin:hasComponent """أعلام الهدى (أهل البيت) هم القرناء"""@ar ;
    hesin:hasComponent """الاستقلالية في الفهم تؤدي إلى الضلال"""@ar ;
    hesin:hasComponent """المفسرون مثال على ذلك"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_36 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C186 a hesin:Concept ;
    rdfs:label """ضمانة الدين (الأعلام)"""@ar ;
    hesin:definition """وجود أعلام (أهل البيت) هو الضمانة الإلهية لسلامة الدين من التحريف والتزييف. بدون هذه الضمانة، يمكن أن يتحول كل شيء (المساجد، الحج، الكتب) إلى وسائل إضلال."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """قضية ضرورية, لا بد أن يكون هناك ضمانة قائمة, وإلا فسيقدم كل شيء باطلاً... الأعلام لكتبها هي تمثل ضمانة لكل ما هو مطروح في الساحة."""@ar ;
    hesin:actions """التأكيد على ضرورة وجود أعلام هدى كضمانة لسلامة الدين."""@ar ;
    hesin:hasSynonym """ورثة القرآن"""@ar ;
    hesin:hasSynonym """الضمانة الإلهية"""@ar ;
    hesin:hasComponent """ضرورة وجود ضمانة للدين"""@ar ;
    hesin:hasComponent """الأعلام هم الضمانة"""@ar ;
    hesin:hasComponent """بدونهم يُستغل الدين"""@ar ;
    hesin:hasComponent """تحول المؤسسات الدينية إلى أدوات للظلم"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_36 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C187 a hesin:Concept ;
    rdfs:label """انحراف المؤسسات الدينية"""@ar ;
    hesin:definition """غياب الأعلام الحقيقيين للدين يؤدي إلى انحراف المؤسسات الدينية (المساجد، الحج، التعليم) لتصبح أدوات في يد السلاطين الجائرين لخدمة أغراضهم."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """فإذا لم يكن هناك علَم هو هو الذي يتحكم في المسجد, هو الذي يوجه كيف يكون المسجد, فسيكون المسجد منبر ضلال وإضلال, منبر يدجن الأمة للظالم, بل يدجن الأمة لليهود حقيقة."""@ar ;
    hesin:actions """نقد انحراف المؤسسات الدينية عند غياب الأعلام الحقيقيين."""@ar ;
    hesin:hasSynonym """استغلال الدين"""@ar ;
    hesin:hasSynonym """تزييف الدين"""@ar ;
    hesin:hasComponent """المسجد يصبح منبرًا للظالم"""@ar ;
    hesin:hasComponent """الحج يُستغل سياسيًا"""@ar ;
    hesin:hasComponent """التعليم يُوجه وفق أهواء السلطان"""@ar ;
    hesin:hasComponent """الدين يُستخدم لتبرير الظلم"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_36 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C188 a hesin:Concept ;
    rdfs:label """تلبيس الجبابرة وعلماء السوء"""@ar ;
    hesin:definition """سلاطين الجور وعلماء السوء المتعاونون معهم يتعاونون على تلبيس الدين وتحريفه، فيقدمون الباطل على أنه الحق، والضلال على أنه هدى."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """على ما بُلي به قديماً من تلبيس ملوك الجبابرة، وأتباعها من علماء العوام المتحيِّرة... في توجيهها له على أهوائها وتصريفه، وتأويلها له بخطئها على تحريفه."""@ar ;
    hesin:actions """كشف تلبيس الجبابرة وعلماء السوء."""@ar ;
    hesin:hasSynonym """تحريف الدين"""@ar ;
    hesin:hasSynonym """التزييف باسم الدين"""@ar ;
    hesin:hasComponent """تلبيس الحق بالباطل"""@ar ;
    hesin:hasComponent """تحريف النصوص"""@ar ;
    hesin:hasComponent """تقديم الإساءة إحسانًا"""@ar ;
    hesin:hasComponent """تسمية الكفر إيمانًا"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_36 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C189 a hesin:Concept ;
    rdfs:label """الإمام علي نموذج الحاكم القرآني"""@ar ;
    hesin:definition """الإمام علي (عليه السلام) نموذج للحاكم القرآني الذي لا يسعى لتأقلم الأمة مع شخصه، بل يسعى لهدايتها إلى الله، ويرفض استخدام القمع والإكراه لفرض الطاعة."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """تلاحظ في حركة الإمام علي لو كان عنده التفكير هذا لكان يستطيع هو أيضاً... يستطيع أن يؤقلم الأمة معه, ويكون سلطانه... ولكن لا, القضية أنه هو يريد للناس أن يسيروا في هدي الله."""@ar ;
    hesin:actions """تقديم الإمام علي كنموذج للحاكم القرآني."""@ar ;
    hesin:hasSynonym """ولاية الأمر"""@ar ;
    hesin:hasSynonym """الحكم بالقرآن"""@ar ;
    hesin:hasComponent """لا يسعى لتأقلم الأمة مع شخصه"""@ar ;
    hesin:hasComponent """يريد هداية الناس إلى الله"""@ar ;
    hesin:hasComponent """يرفض القمع والإكراه"""@ar ;
    hesin:hasComponent """يوعظ ويذكر ويرغب"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_36 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C190 a hesin:Concept ;
    rdfs:label """الحاكم المستبد"""@ar ;
    hesin:definition """الحاكم المستبد هو الذي يستخدم وسائل القمع والإكراه والتأقلم الثقافي لفرض سلطته، ويوظف المؤسسات الدينية والتعليمية لخدمة أغراضه."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """من أسهل الوسائل لأي شخص يحكم: أن تؤقلم الناس عليك وتخضعهم... جهاز مخابرات, وجهاز قمع, تخضعهم وبس, وخطباء في المساجد, ومدرسين في المدارس, وفي الجامعات."""@ar ;
    hesin:actions """نقد الحكم المستبد وأساليبه."""@ar ;
    hesin:hasSynonym """السلطان الجائر"""@ar ;
    hesin:hasSynonym """الطاغية"""@ar ;
    hesin:hasComponent """جهاز قمع ومخابرات"""@ar ;
    hesin:hasComponent """توظيف المساجد والتعليم"""@ar ;
    hesin:hasComponent """تأقلم الأمة مع شخصه"""@ar ;
    hesin:hasComponent """لا يبالي بهدى الله"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_36 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C191 a hesin:Concept ;
    rdfs:label """الحياة كلها مدرسة"""@ar ;
    hesin:definition """القرآن لا يقتصر المعرفة فيه على الكتب والمدونات، بل يجعل الحياة كلها (أحداثها، متغيراتها، حركة الناس فيها) مدرسة يتعلم منها الإنسان ويتزود بالمعارف."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """القرآن في رؤيته بالنسبة للجانب المعرفي, المعرفة... أنه يجعل الحركة في سبيله مدرسة يحول الحياة بكلها إلى مدرسة, كلها, يرى الدنيا عبارة عن فصل دراسي."""@ar ;
    hesin:actions """الانفتاح على الحياة كمنبع للمعرفة في إطار القرآن."""@ar ;
    hesin:hasSynonym """التعلم من الحياة"""@ar ;
    hesin:hasSynonym """الآيات الكونية"""@ar ;
    hesin:hasComponent """الحياة كلها فصل دراسي"""@ar ;
    hesin:hasComponent """الأحداث تعطي معارف"""@ar ;
    hesin:hasComponent """معرفة الباطل معرفة إيجابية"""@ar ;
    hesin:hasComponent """الانفتاح على كل شيء"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_37 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C192 a hesin:Concept ;
    rdfs:label """الاكتفاء بالقرآن"""@ar ;
    hesin:definition """القرآن كافٍ للهداية والمعرفة، وليس بحاجة إلى كم هائل من الكتب والمدونات. المعرفة الحقيقية تأتي من العمل بالقرآن والحركة في الحياة، وليس من تكديس الكتب."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """يبدو أمامنا أنه حتى يستكمل الموضوع أنه لازم رصات كتب! أقرأ حتى لو قالوا فيها, المهم أريد أقرأ, أريد أقرأ, أريد أحسي رصات... القرآن في رؤيته للجانب المعرفي, المعرفة... أنه يجعل الحركة في سبيله مدرسة."""@ar ;
    hesin:actions """التركيز على العمل بالقرآن والحركة في الحياة، لا على تكديس الكتب."""@ar ;
    hesin:hasSynonym """القرآن كافٍ"""@ar ;
    hesin:hasSynonym """لا حاجة لغيره"""@ar ;
    hesin:hasComponent """القرآن كافٍ"""@ar ;
    hesin:hasComponent """لا حاجة لرصات الكتب"""@ar ;
    hesin:hasComponent """المعرفة في الحركة لا في الكتب فقط"""@ar ;
    hesin:hasComponent """الحياة مدرسة"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_37 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C193 a hesin:Concept ;
    rdfs:label """الحاجة إلى رصات الكتب"""@ar ;
    hesin:definition """مفهوم خاطئ يرى أن كثرة الكتب والمقروءات هي سبيل المعرفة، متجاهلاً أن القرآن نفسه والحركة في الحياة هما المصدران الأساسيان للمعرفة النافعة."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """نأتي نقرأ الأول والثاني والثالث والرابع والخامس والسادس, وهكذا. تقول: هذه فيها خلل, لكن عندما نبعدها ماذا بقي؟"""@ar ;
    hesin:actions """تصحيح مفهوم المعرفة ليشمل العمل والحركة، لا الكتب فقط."""@ar ;
    hesin:hasSynonym """التكديس المعرفي"""@ar ;
    hesin:hasSynonym """كثرة المقروءات"""@ar ;
    hesin:hasComponent """الاعتقاد بأن العلم في الكتب فقط"""@ar ;
    hesin:hasComponent """التكديس المعرفي"""@ar ;
    hesin:hasComponent """إهمال العمل والحركة"""@ar ;
    hesin:hasComponent """الشعور بالعلم مع الجهل"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_37 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C194 a hesin:Concept ;
    rdfs:label """الغرق في الذاتية"""@ar ;
    hesin:definition """الانشغال بالذات والتمركز حولها هو أخطر ما يهدد الإنسان، وهو ما أدى إلى سقوط إبليس رغم عبادته الطويلة. الإنسان بحاجة إلى أن يكون منشغلاً بقضية أكبر من ذاته."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أخطر شيء على الإنسان هو عندما يكون غارقاً في ذاتيته, في نفسيته, هذه هي المشكلة الكبيرة, مثلما إبليس... كل سنة, كل سنتين, وكل قرن وهو يلتفت إلى نفسه, وهذه هي التي جعلته في الأخير يسقط."""@ar ;
    hesin:actions """تحذير الناس من خطر الغرق في الذاتية."""@ar ;
    hesin:hasSynonym """التمركز حول الذات"""@ar ;
    hesin:hasSynonym """الكبر"""@ar ;
    hesin:hasComponent """الانشغال بالذات"""@ar ;
    hesin:hasComponent """التمركز حول النفس"""@ar ;
    hesin:hasComponent """عدم الانشغال بقضية أكبر"""@ar ;
    hesin:hasComponent """السقوط رغم العبادة"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_38 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C195 a hesin:Concept ;
    rdfs:label """الانشغال بقضية أكبر"""@ar ;
    hesin:definition """الانشغال بقضية أكبر من الذات (الله، الدين، الأمة) هو الذي يملأ وجدان الإنسان ويحميه من الغرق في الذاتية والضلال."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """إذا ما عند الناس حمل مسئولية في الأخير يعيش في حالة فراغ, يرجع كل واحد إلى نفسه يريد نفسه هو... موضوع الله سبحانه وتعالى قضية كبيرة إذا هناك جهل في معرفة الله... ما هناك شيء يملأ وجدانك."""@ar ;
    hesin:actions """تشجيع الناس على الانشغال بقضايا أكبر من ذواتهم."""@ar ;
    hesin:hasSynonym """حمل المسؤولية"""@ar ;
    hesin:hasSynonym """الانشغال بالله والدين"""@ar ;
    hesin:hasComponent """حمل المسؤولية"""@ar ;
    hesin:hasComponent """الانشغال بالله والدين"""@ar ;
    hesin:hasComponent """ملء الوجدان بقضية أكبر"""@ar ;
    hesin:hasComponent """الحماية من الذاتية"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_38 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C196 a hesin:Concept ;
    rdfs:label """لا تثبيت للمؤمن إلا مع الخلل"""@ar ;
    hesin:definition """الله يثبت المؤمنين الذين يسيرون على الطريق الصحيح ولا يتركهم يسقطون في النهاية. التثبيت الإلهي مستمر، والسقوط لا يكون إلا إذا كان هناك خلل في البداية."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """إذا أنت تسير على طريقة صحيحة عشرات السنين بحيث أنه لم يبق بينك وبين الجنة؛[إلا شبراً أو ذراعاً] مثلما في ذاك الحديث, وفي الأخير يمكر لك , ويخلطف لك ليدخلك جهنم هذا غير صحيح!... يأتي تثبيت إلهي, تثبيت متواصل."""@ar ;
    hesin:actions """الثقة في تثبيت الله للمؤمنين مع الاستمرار في الطريق."""@ar ;
    hesin:hasSynonym """استمرار التثبيت"""@ar ;
    hesin:hasSynonym """رعاية الله"""@ar ;
    hesin:hasComponent """تثبيت إلهي مستمر"""@ar ;
    hesin:hasComponent """عدم السقوط في النهاية"""@ar ;
    hesin:hasComponent """الخلل في البداية هو الذي يكبر"""@ar ;
    hesin:hasComponent """رعاية الله لأوليائه"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_38 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C197 a hesin:Concept ;
    rdfs:label """سقوط المؤمن في النهاية"""@ar ;
    hesin:definition """مفهوم خاطئ يظن أن الله قد يضل المؤمن في آخر عمره رغم صلاحه السابق. هذا غير صحيح، فالله لا يخدع أولياءه، والسقوط يكون نتيجة خلل سابق."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """يفهم واحد بأن الباري لا يأتي [يخلطفٍ] لأوليائه أبداً... في الأخير يمكر لك , ويخلطف لك ليدخلك جهنم هذا غير صحيح!"""@ar ;
    hesin:actions """نفي فكرة خداع الله لأوليائه."""@ar ;
    hesin:hasSynonym """الخطف في آخر العمر"""@ar ;
    hesin:hasSynonym """الإضلال بعد الصلاح"""@ar ;
    hesin:hasComponent """الخوف من الخطف في النهاية"""@ar ;
    hesin:hasComponent """تصور أن الله يمكر بأوليائه"""@ar ;
    hesin:hasComponent """نفي هذه الفكرة"""@ar ;
    hesin:hasComponent """السقوط نتيجة خلل سابق"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_38 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C198 a hesin:Concept ;
    rdfs:label """القرآن أنيس وحبيب"""@ar ;
    hesin:definition """القرآن أنيس لمن آنسه، وحبيب لمن أحبه. معرفة حاجة الإنسان الماسة إلى القرآن تولد محبته، ويصبح أنيسًا في الشدائد، ومواسيًا في المصائب."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """أنيساً لمن آنسه لا يوحش، وحبيباً لمن حابه لا يبغض... عندما تعرف بأنك في أمس الحاجة إليه, وبأمس الحاجة إلى هدايته, بأمس الحاجة إلى نوره... ستكون محباً للقرآن."""@ar ;
    hesin:actions """تقديم القرآن كأنيس وحبيب، لا ككتاب جاف."""@ar ;
    hesin:hasSynonym """الأنس بالقرآن"""@ar ;
    hesin:hasSynonym """محبة القرآن"""@ar ;
    hesin:hasComponent """أنيس لا يوحش"""@ar ;
    hesin:hasComponent """حبيب لا يبغض"""@ar ;
    hesin:hasComponent """مواسي في الشدائد"""@ar ;
    hesin:hasComponent """محبة ناتجة عن معرفة الحاجة"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_38 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C199 a hesin:Concept ;
    rdfs:label """منهج ضرب الأسس"""@ar ;
    hesin:definition """منهج قرآني في الحوار يركز على ضرب الأسس الفاسدة التي يقوم عليها الباطل، بدلاً من الانشغال بالتفاصيل. إذا انهارت الأسس، تهاوت التفاصيل."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """ما تأتي تستغرق مع الآخرين في التفاصيل, في التفاصيل... عد إلى الأسس في حوارك, ارجع إلى الله, أبدأ من الله, واربط كل قضية بالله, ولاحظ عندما يتهاوى الباطل, ويضعف صاحبه."""@ar ;
    hesin:actions """التركيز على ضرب الأسس الفاسدة في الحوار."""@ar ;
    hesin:hasSynonym """التركيز على الأصول"""@ar ;
    hesin:hasSynonym """تفنيد القواعد"""@ar ;
    hesin:hasComponent """التركيز على الأسس"""@ar ;
    hesin:hasComponent """تجنب الانشغال بالتفاصيل"""@ar ;
    hesin:hasComponent """ربط كل قضية بالله"""@ar ;
    hesin:hasComponent """إضعاف الخصم من أساسه"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_39 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C200 a hesin:Concept ;
    rdfs:label """الدعوة بالترغيب لا القهر"""@ar ;
    hesin:definition """منهج الدعوة القرآني يقوم على الترغيب والإرشاد والحرص على هداية الناس، وليس على القهر وإظهار ضعف الخصم والانتصار الشخصي."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """يكون عندك روح أن تهدي, أن ترشد, لا أن تقهر الآخر, لا أن تغلبه, لا أن تبين ضعفه أمام الناس, لا تكن هذه عندك على الإطلاق. يكون عندك هدى, أن تهدي, أن ترشد."""@ar ;
    hesin:actions """الدعوة بالترغيب والحرص على الهداية، لا بالقهر."""@ar ;
    hesin:hasSynonym """الدعوة بالرحمة"""@ar ;
    hesin:hasSynonym """عدم الإكراه"""@ar ;
    hesin:hasComponent """حرص على الهداية"""@ar ;
    hesin:hasComponent """ترغيب وترهيب"""@ar ;
    hesin:hasComponent """عدم القهر والإكراه"""@ar ;
    hesin:hasComponent """عدم إظهار ضعف الخصم"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_39 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C201 a hesin:Concept ;
    rdfs:label """العلم بقدر القرآن وعظمته"""@ar ;
    hesin:definition """أساس التعامل مع القرآن هو معرفة قدره وعظمته عند الله، واستشعار أن القرآن كلام الله العظيم، وليس كتابًا عاديًا. هذا الاستشعار يغير كيفية التلقي والاستفادة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أن أول علم الكتاب وتعليمه، العلم بقدره عند الله وعِظَمِه... عندما تفتح المصحف, وتبدأ تقرأ تكون مستشعراً لأهمية هذا الكلام, أهمية القرآن الكريم, أولاً: أنه كلام الله, وفي نفس الوقت أن هذا الكلام هو عظيم القدر عند الله سبحانه وتعالى."""@ar ;
    hesin:actions """عند بدء أي دراسة للقرآن، يجب التأكيد على قدره وعظمته واستشعار ذلك."""@ar ;
    hesin:hasSynonym """معرفة قدر القرآن"""@ar ;
    hesin:hasSynonym """تقدير عظمة القرآن"""@ar ;
    hesin:hasComponent """استشعار أن القرآن كلام الله"""@ar ;
    hesin:hasComponent """إدراك عظمته عند الله"""@ar ;
    hesin:hasComponent """عدم التعامل معه ككتاب عادي"""@ar ;
    hesin:hasComponent """الاستعداد للانتفاع بهداه"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_40 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C202 a hesin:Concept ;
    rdfs:label """غرض القرآن وقصده"""@ar ;
    hesin:definition """لا بد من معرفة غرض القرآن وقصده (وهو الهداية والإرشاد) قبل البدء في قراءته وتعلمه. من لا يعرف الغرض لن يستفيد وسيخرج صفرًا."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """فليكن أول ما تخطرون في الكتاب ببالكم... ما ذكرت من غرضه ووصفت، ووقَّفت عليه من قصده وعرَّفت، فمن لم يعرف غرض ما يريد وقصده، لم يبذل في الطلب له جهده، ولم يعلم منه أبداً، هداية ولا رشداً."""@ar ;
    hesin:actions """قبل دراسة أي نص قرآني، تحديد غرضه ومقصده في سياق الهداية الشاملة."""@ar ;
    hesin:hasSynonym """مقاصد القرآن"""@ar ;
    hesin:hasSynonym """هدف القرآن"""@ar ;
    hesin:hasComponent """الهداية والإرشاد هما الغرض الأساسي"""@ar ;
    hesin:hasComponent """الإرشاد لكل شئون الحياة"""@ar ;
    hesin:hasComponent """تزكية النفس وبناء الأمة"""@ar ;
    hesin:hasComponent """لا يمكن الفهم دون معرفة الغرض"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_40 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C203 a hesin:Concept ;
    rdfs:label """القرآن كتاب هداية"""@ar ;
    hesin:definition """القرآن في المقام الأول هو كتاب هداية وإرشاد، وليس مجرد كتاب تشريع أو أحكام. الهداية تشمل كل مجالات الحياة وشئونها، وتستمر إلى يوم الدين."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """فرضُ كتاب الله يا بني وقصدُه، فهو هداية الله به ورشده... وهذا الشيء المهم في القرآن, وهذه مهمة القرآن الكريم: هداية من الله لعباده, إرشاد من الله لعباده. ويجب أن ننظر إلى القرآن بهذا المعنى."""@ar ;
    hesin:actions """تقديم القرآن ككتاب هداية شاملة قبل أي تصنيف آخر."""@ar ;
    hesin:hasSynonym """كتاب هدى"""@ar ;
    hesin:hasSynonym """نور"""@ar ;
    hesin:hasSynonym """إرشاد"""@ar ;
    hesin:hasComponent """هداية للناس جميعًا"""@ar ;
    hesin:hasComponent """إرشاد في كل شئون الحياة"""@ar ;
    hesin:hasComponent """مستمر إلى يوم الدين"""@ar ;
    hesin:hasComponent """أوسع من مجرد الأحكام التشريعية"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_40 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C204 a hesin:Concept ;
    rdfs:label """حصر القرآن في آيات الأحكام"""@ar ;
    hesin:definition """مفهوم خاطئ يحصر القرآن في آيات الأحكام (التي يزعم أنها خمسمائة آية)، ويتجاهل آلاف الآيات الأخرى التي تتناول الهداية والإرشاد في كل مجالات الحياة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """القرآن هو كتاب هداية, يهدي الناس إلى صراط مستقيم, إرشاد لهم, إرشاد واسع بسعة الحياة كلها... لا تأت تؤطره في ذهنك بخمسمائة آية, مثلما يعملون! يعني العلم كله, والدين كله في إطار خمسمائة آية!! وآلاف الآيات ماذا ستعملون بها؟!"""@ar ;
    hesin:actions """رفض حصر القرآن في آيات الأحكام وتوسيع النظر إلى كل آياته."""@ar ;
    hesin:hasSynonym """القرآن خمسمائة آية"""@ar ;
    hesin:hasSynonym """تضييق القرآن"""@ar ;
    hesin:hasComponent """حصر الدين في الأحكام الفقهية"""@ar ;
    hesin:hasComponent """تجاهل آلاف الآيات الأخرى"""@ar ;
    hesin:hasComponent """تضييق مجال القرآن"""@ar ;
    hesin:hasComponent """فقدان الغرض الأكبر من الهداية"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_40 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C205 a hesin:Concept ;
    rdfs:label """فقدان الهداية الشاملة"""@ar ;
    hesin:definition """عدم النظر إلى القرآن ككتاب هداية شامل يؤدي إلى فقدان الهداية في كل مجالات الحياة، والاقتصار على جوانب محدودة، وضياع الغرض الأساسي."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """لم ننظر إليه ككتاب هداية، ثم نعرف ما هي الهداية؟ الهداية في الحياة كلها, كل شئونها, كل أمورها, كل مجالاتها... مسألة الهداية يعني: هداية في الحياة كلها، كلما أمامك, كل مجالات الحياة."""@ar ;
    hesin:actions """التأكيد على شمولية هداية القرآن لكل مجالات الحياة."""@ar ;
    hesin:hasSynonym """ضياع الغرض"""@ar ;
    hesin:hasSynonym """الإعراض عن الهدى"""@ar ;
    hesin:hasComponent """عدم الاستفادة من القرآن"""@ar ;
    hesin:hasComponent """الاقتصار على جوانب محدودة"""@ar ;
    hesin:hasComponent """ضياع الغرض الأساسي"""@ar ;
    hesin:hasComponent """عدم فهم الهداية الشاملة"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_41 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C206 a hesin:Concept ;
    rdfs:label """الإعراض عن القرآن"""@ar ;
    hesin:definition """من لا يعرف قدر القرآن وغرضه يعرض عنه ويهجره، فيخسر ولا يستفيد، بل يزداد رجسًا وخسارًا."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """وإن كان من لم يعلم قدره وغرضه، أعرض عنه وهجره ورفضه، فقلَّ به هداه وإتباعه، ولم ينفعه مع الجهل استماعه، بل خسر به ورجس."""@ar ;
    hesin:actions """التحذير من الإعراض عن القرآن وبيان عواقبه."""@ar ;
    hesin:hasSynonym """عدم الاهتمام"""@ar ;
    hesin:hasSynonym """الترك"""@ar ;
    hesin:hasSynonym """الجفاء"""@ar ;
    hesin:hasComponent """عدم معرفة القدر والغرض"""@ar ;
    hesin:hasComponent """الهجر والإعراض"""@ar ;
    hesin:hasComponent """الخسارة والرجس"""@ar ;
    hesin:hasComponent """عدم الانتفاع"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_41 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C207 a hesin:Concept ;
    rdfs:label """الرجس والخسارة"""@ar ;
    hesin:definition """من يعرض عن القرآن أو لا يعرف غرضه يزداد رجسًا وخسارًا، ولا يستفيد منه شيئًا، بل يخرج صفرًا."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """فجعله كما تسمعون للمؤمنين شفاء ورحمة، وللظالمين عمى وخسارا ونقمة... ففرضُ كتاب الله يا بني وقصدُه، فهو هداية الله به ورشده... فمن لم يعرف غرض ما يريد وقصده... خرج من علمه كله صفرا."""@ar ;
    hesin:actions """بيان عواقب الإعراض عن القرآن."""@ar ;
    hesin:hasSynonym """الضلال"""@ar ;
    hesin:hasSynonym """الخسران المبين"""@ar ;
    hesin:hasComponent """زيادة الرجس والضلال"""@ar ;
    hesin:hasComponent """الخسارة في الدنيا والآخرة"""@ar ;
    hesin:hasComponent """عدم الانتفاع بالهدى"""@ar ;
    hesin:hasComponent """العمى عن الحق"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_41 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C208 a hesin:Concept ;
    rdfs:label """الهداية حركة مستمرة"""@ar ;
    hesin:definition """الهداية ليست حدثًا لمرة واحدة، بل هي حركة مستمرة تتواكب مع حركة الحياة. الإنسان في حركة دائمة، ويحتاج إلى هداية متجددة باستمرار."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """لاحظوا كلمة هداية هي توحي بأن الإنسان والحياة في حركة مستمرة... لا يوجد أحد جالس، لا يوجد أحد جالس أبداً، باعتبار حركة الحياة أبداً. وكلمة هدى، يعني: أنتم سائرون، أنتم ماشين، أن هذا ليهديكم كيف تكونون في مسيرتكم في الحياة."""@ar ;
    hesin:actions """التأكيد على أن الهداية عملية مستمرة، لا حدث لمرة واحدة."""@ar ;
    hesin:hasSynonym """الحياة حركة"""@ar ;
    hesin:hasSynonym """الحاجة المستمرة للهدى"""@ar ;
    hesin:hasComponent """الحياة حركة مستمرة"""@ar ;
    hesin:hasComponent """الحاجة إلى هداية متجددة"""@ar ;
    hesin:hasComponent """الإنسان لا يتوقف عن الحركة"""@ar ;
    hesin:hasComponent """الهداية مواكبة للحركة"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_41 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C209 a hesin:Concept ;
    rdfs:label """الهداية تشمل كل المجالات"""@ar ;
    hesin:definition """هداية القرآن لا تقتصر على الجانب الروحي فقط، بل تشمل كل مجالات الحياة: السياسة، الاقتصاد، التربية، النفس، الاجتماع، وغيرها."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """أليس الناس يحاولون أن يرسموا طريقة تهديهم فيكون أداؤهم أفضل؟ أليست هذه فكرة عند البشر جميعاً؟ إذاً البشر تراهم أنفسهم يتناولون المجالات كلها، لكن ما زالوا متخبطين. فهداية الله هي تبيان لكل شيء، في كل الأشياء التي يراها الناس."""@ar ;
    hesin:actions """تطبيق هداية القرآن على كل مجالات الحياة."""@ar ;
    hesin:hasSynonym """شمولية الهدى"""@ar ;
    hesin:hasSynonym """هدى للحياة كلها"""@ar ;
    hesin:hasComponent """الجانب السياسي"""@ar ;
    hesin:hasComponent """الجانب الاقتصادي"""@ar ;
    hesin:hasComponent """الجانب التربوي"""@ar ;
    hesin:hasComponent """الجانب النفسي"""@ar ;
    hesin:hasComponent """الجانب الاجتماعي"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_41 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C210 a hesin:Concept ;
    rdfs:label """حصر الهداية في الجانب الروحي"""@ar ;
    hesin:definition """مفهوم خاطئ يحصر هداية القرآن في الجانب الروحي والعبادي فقط، ويتجاهل أن القرآن هداية للحياة كلها بكل مجالاتها."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """لا تتصور هداية، يعني أنا في الجانب الذي نسميه الجانب الروحي، كيف أكون طيب, ومن أولياء الله، وهذه المفاهيم, لا, القرآن هو للدنيا، هو للحياة. والحياة هي أوسع منك."""@ar ;
    hesin:actions """رفض حصر الهداية في الجانب الروحي وتوسيعها لكل المجالات."""@ar ;
    hesin:hasSynonym """الهداية للآخرة فقط"""@ar ;
    hesin:hasSynonym """إهمال الدنيا"""@ar ;
    hesin:hasComponent """حصر الدين في الروحانيات"""@ar ;
    hesin:hasComponent """إهمال الحياة الدنيا"""@ar ;
    hesin:hasComponent """تضييق مجال الهداية"""@ar ;
    hesin:hasComponent """الانفصال عن الواقع"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_41 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C211 a hesin:Concept ;
    rdfs:label """الجد في الدين كالجد في التجارة"""@ar ;
    hesin:definition """يجب أن يكون المسلم أجد في طلب الهدى من القرآن من الجاد في تجارته وصناعته. لأن ما يطلب (الهدى) يدوم أبدًا ولا يفنى، بينما التجارة والصناعة تفنى وتزول."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """فلا يكونن أحد منهم فيما يزول عنه ويفنى، أجدّ منكم فيما يدوم أبدا ويبقى... فأن تقصروا في ذلك تكونوا أخسر فيما تعدونه من التجارة والصناعة خسرانا منهم."""@ar ;
    hesin:actions """تشبيه الجد في الدين بالجد في التجارة لتحفيز الناس."""@ar ;
    hesin:hasSynonym """الاجتهاد"""@ar ;
    hesin:hasSynonym """المثابرة"""@ar ;
    hesin:hasComponent """الجد والمثابرة في طلب الهدى"""@ar ;
    hesin:hasComponent """مقارنة بأهل التجارة والصناعة"""@ar ;
    hesin:hasComponent """الهدى يدوم أبدًا"""@ar ;
    hesin:hasComponent """الخسارة أعظم من خسارة التاجر"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_42 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C212 a hesin:Concept ;
    rdfs:label """التكاسل عن طلب الهدى"""@ar ;
    hesin:definition """التقصير في طلب الهدى والعمل به هو خسران مبين، أعظم من خسارة التاجر الذي أفلس. المسلم لا يجب أن يكون أقل جدًا من التاجر في طلب ما هو أنفع."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """فإن تُقَصِّروا في ذلك تكونوا أخسر فيما تعدونه من التجارة والصناعة خسرانا منهم... فأعوذ بالله لي ولكم من الخسران المبين، فإنه عند الله هو الخسران في الدين."""@ar ;
    hesin:actions """التحذير من التكاسل عن طلب الهدى."""@ar ;
    hesin:hasSynonym """الفتور"""@ar ;
    hesin:hasSynonym """الإهمال"""@ar ;
    hesin:hasComponent """الفتور والكسل"""@ar ;
    hesin:hasComponent """الإهمال لطلب الهدى"""@ar ;
    hesin:hasComponent """الخسارة العظمى"""@ar ;
    hesin:hasComponent """المقارنة بخسارة التجارة"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_42 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C213 a hesin:Concept ;
    rdfs:label """لا خسارة في الدين"""@ar ;
    hesin:definition """في التعامل مع الله لا خسارة على الإطلاق. كل إنفاق يخلف، كل تضحية تكافأ، كل عمل صالح يضاعف. الدين كله تجارة رابحة لا تبور."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أنه في الدين, التعامل مع الله لا يوجد خسارة على الإطلاق، لا يوجد خسارة نهائياً. عندما تنفق هو يعدك بأن يخلف عليك أكثر مما أعطيت... عندما تضحي بنفسك... أيضاً ما يخليك خاسر معه."""@ar ;
    hesin:actions """التأكيد على أن الدين تجارة رابحة لا خسارة فيها."""@ar ;
    hesin:hasSynonym """التجارة الرابحة"""@ar ;
    hesin:hasSynonym """الفوز مع الله"""@ar ;
    hesin:hasComponent """لا خسارة مع الله"""@ar ;
    hesin:hasComponent """الإخلاف على الإنفاق"""@ar ;
    hesin:hasComponent """مضاعفة الأجر"""@ar ;
    hesin:hasComponent """الحياة الحقيقية للشهداء"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_42 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C214 a hesin:Concept ;
    rdfs:label """الخسارة في الدين"""@ar ;
    hesin:definition """مفهوم خاطئ يعتبر العمل للدين خسارة، بينما العمل للدنيا يعتبر طبيعيًا. هذا المفهوم ناتج عن ضعف الإيمان وعدم الثقة في وعد الله."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """أن الخسارة هي كل عمل للدين، نحن نعتبرها خسارة! الأشياء الأخرى ما نبالي بها، لا نحسبها خسارة, ولا هي شيء!"""@ar ;
    hesin:actions """تصحيح مفهوم أن العمل للدين خسارة."""@ar ;
    hesin:hasSynonym """ظن الخسارة"""@ar ;
    hesin:hasSynonym """عدم الثقة بالله"""@ar ;
    hesin:hasComponent """اعتبار عمل الدين خسارة"""@ar ;
    hesin:hasComponent """عدم الثقة في وعد الله"""@ar ;
    hesin:hasComponent """المبالاة بالعمل الدنيوي"""@ar ;
    hesin:hasComponent """الخوف من التضحية"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_42 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C215 a hesin:Concept ;
    rdfs:label """تعظيم القرآن وإجلاله"""@ar ;
    hesin:definition """يجب على المسلم أن يصنع للقرآن قدسية وإجلالًا في نفسه، وفي أسرته، وفي المجتمع. تعظيم القرآن يشمل احترامه في التعامل والكتابة والقراءة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """يجب على الإنسان أنه يحاول أن يصنع للقرآن في نفسيته قدسية وإجلال، وفي أسرته عند أولاده، وفي أهل بيته، ولطلابه، وللمجتمع، أن يعمل الناس على ترسيخ، وإجلال للقرآن، وتقديس للقرآن عند المسلمين."""@ar ;
    hesin:actions """ترسيخ قدسية القرآن في النفوس والمجتمع."""@ar ;
    hesin:hasSynonym """تقديس القرآن"""@ar ;
    hesin:hasSynonym """إكرام القرآن"""@ar ;
    hesin:hasComponent """قدسية القرآن في النفس"""@ar ;
    hesin:hasComponent """إجلاله في الأسرة"""@ar ;
    hesin:hasComponent """تعظيمه في المجتمع"""@ar ;
    hesin:hasComponent """احترامه في التعامل"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_43 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C216 a hesin:Concept ;
    rdfs:label """احترام النص القرآني"""@ar ;
    hesin:definition """احترام النص القرآني يقتضي عدم امتهانه أو إلقائه في الطرقات، وجمع الأوراق التي تحتوي على نصوص قرآنية ودفنها أو وضعها في مكان لائق."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """يجب أن يلاحظوا دائماً عندما يكون الطلاب يكتبوا في دفاتر، يكتبوا {بسم الله الرحمن الرحيم} ويكتبوا نصوصاً قرآنية، ثم تراها مبعثرة... يجب على واحد أنه يحاول دائماً يحسس الطلاب بأنها طريقة خطأ هذه، يجمعوها ويدفنوها."""@ar ;
    hesin:actions """تعليم الطلاب احترام النص القرآني وعدم امتهانه."""@ar ;
    hesin:hasSynonym """عدم امتهان القرآن"""@ar ;
    hesin:hasSynonym """تجميع الأوراق القرآنية"""@ar ;
    hesin:hasComponent """جمع الأوراق القرآنية"""@ar ;
    hesin:hasComponent """عدم إلقائها في الطرقات"""@ar ;
    hesin:hasComponent """تعليم الطلاب احترام القرآن"""@ar ;
    hesin:hasComponent """دفن الأوراق أو حفظها"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_43 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C217 a hesin:Concept ;
    rdfs:label """امتهان القرآن"""@ar ;
    hesin:definition """ترك الأوراق القرآنية مبعثرة في الطرقات أو في الفصول هو امتهان للقرآن وعدم اكتراث به، وينبغي محاربته وتوعية الناس بخطورته."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """مظهر من مظاهر عدم الاكتراث بالقرآن الكريم، وكأنه كأي كلام آخر يداس ليست مشكلة!"""@ar ;
    hesin:actions """محاربة ظاهرة امتهان القرآن وتوعية الناس."""@ar ;
    hesin:hasSynonym """عدم الاكتراث"""@ar ;
    hesin:hasSynonym """الاستهانة"""@ar ;
    hesin:hasComponent """إلقاء الأوراق القرآنية"""@ar ;
    hesin:hasComponent """عدم جمعها"""@ar ;
    hesin:hasComponent """عدم الاكتراث بقيمتها"""@ar ;
    hesin:hasComponent """الاستهانة بالنص القرآني"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_43 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C218 a hesin:Concept ;
    rdfs:label """التلاوة مع التدبر"""@ar ;
    hesin:definition """قراءة القرآن لا ينبغي أن تكون مجرد تلاوة سريعة (نثر الدقل)، بل يجب أن تكون مع تدبر وتأمل وفهم. الترتيل هو التأني والتدبر."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لا تكتفوا بتلاوة الكتاب مِن تدبُّره، ولا ترضوا من قراءته بِهَذِّه ونثره، فإنه ذُكر أن رسول الله صلى الله عليه وآله وسلم قال: (لا تنثروا القرآن نثر الدقل)."""@ar ;
    hesin:actions """تشجيع التلاوة مع التدبر وعدم الاقتصار على القراءة السريعة."""@ar ;
    hesin:hasSynonym """قراءة بتأمل"""@ar ;
    hesin:hasSynonym """تدبر الآيات"""@ar ;
    hesin:hasComponent """التأني في القراءة"""@ar ;
    hesin:hasComponent """التدبر والفهم"""@ar ;
    hesin:hasComponent """عدم القراءة السريعة"""@ar ;
    hesin:hasComponent """الاستفادة من المعاني"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_44 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C219 a hesin:Concept ;
    rdfs:label """التنزيل والترتيل"""@ar ;
    hesin:definition """التنزيل والترتيل في قراءة القرآن يعني التأني والتمهل وعدم العجلة، مع التدبر والفهم، والإطالة في القراءة للاستفادة أكثر."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """فاقرأوه يا بني إذا قرأتموه بالتنزيل والترتيل... وتفهموا بالإطالة له والترتل والترسل... الإطالة له، ليس معناها المدودات، وأشياء من هذه، معناها التأني."""@ar ;
    hesin:actions """تشجيع الترتيل والتأني في قراءة القرآن."""@ar ;
    hesin:hasSynonym """التأني"""@ar ;
    hesin:hasSynonym """التمهل"""@ar ;
    hesin:hasComponent """التأني والتمهل"""@ar ;
    hesin:hasComponent """عدم العجلة"""@ar ;
    hesin:hasComponent """الإطالة في القراءة"""@ar ;
    hesin:hasComponent """التدبر المصاحب"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_44 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C220 a hesin:Concept ;
    rdfs:label """نثر القرآن"""@ar ;
    hesin:definition """نثر القرآن هو قراءته بسرعة دون تدبر، مثل نثر التمر الجاف (الدقل) الذي يسقط بسرعة. هذا النوع من القراءة لا يحقق الهدف من تلاوة القرآن."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لا ترضوا من قراءته بِهَذِّه ونثره، فإنه ذُكر أن رسول الله صلى الله عليه وآله وسلم قال: (لا تنثروا القرآن نثر الدقل)."""@ar ;
    hesin:actions """التحذير من نثر القرآن وتشجيع الترتيل والتدبر."""@ar ;
    hesin:hasSynonym """القراءة السريعة"""@ar ;
    hesin:hasSynonym """هذرمة"""@ar ;
    hesin:hasComponent """القراءة السريعة"""@ar ;
    hesin:hasComponent """عدم التدبر"""@ar ;
    hesin:hasComponent """عدم الفهم"""@ar ;
    hesin:hasComponent """خسارة المعاني"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_44 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C221 a hesin:Concept ;
    rdfs:label """أصل الحلال والحرام في القرآن"""@ar ;
    hesin:definition """كل حلال وحرام في الإسلام له أصل في القرآن الكريم، ولا يحل لأحد أن يحلل أو يحرم إلا به. من ينكر ذلك فهو جاهل بربه."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أن في كتاب الله جل جلاله، حرام الله كله وحلاله، فليس لأحد تحليل ولا تحريم إلا به، فمن أبى ذلك فهو من الجاهلين بربه."""@ar ;
    hesin:actions """التأكيد على أن أصل الحلال والحرام في القرآن."""@ar ;
    hesin:hasSynonym """المصدرية"""@ar ;
    hesin:hasSynonym """الهداية للحلال والحرام"""@ar ;
    hesin:hasComponent """القرآن مصدر الحلال والحرام"""@ar ;
    hesin:hasComponent """لا تحليل ولا تحريم إلا به"""@ar ;
    hesin:hasComponent """الأصل موجود في القرآن (مباشرة أو غير مباشرة)"""@ar ;
    hesin:hasComponent """منكري ذلك جهال"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_45 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C222 a hesin:Concept ;
    rdfs:label """مصادر تشريعية خارج القرآن"""@ar ;
    hesin:definition """الاعتقاد بوجود مصادر تشريعية مستقلة عن القرآن للحلال والحرام هو جهل بالله. كل تحليل وتحريم لا بد أن يكون مستندًا إلى القرآن."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """فمن أبى ذلك فهو من الجاهلين بربه... فليس لأحد تحليل ولا تحريم إلا به."""@ar ;
    hesin:actions """رفض مصادر التشريع المستقلة عن القرآن."""@ar ;
    hesin:hasSynonym """الاستقلال عن القرآن"""@ar ;
    hesin:hasSynonym """مصادر أخرى"""@ar ;
    hesin:hasComponent """الاعتقاد بمصادر أخرى"""@ar ;
    hesin:hasComponent """الاستقلال عن القرآن"""@ar ;
    hesin:hasComponent """الجهل بالله"""@ar ;
    hesin:hasComponent """الابتداع في الدين"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_45 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C223 a hesin:Concept ;
    rdfs:label """استخراج الأحكام من القرآن"""@ar ;
    hesin:definition """الأحكام التي ليست مذكورة صراحة في القرآن (كعدد ركعات الصلاة) يمكن استخراجها من خلال هداية القرآن إلى اتباع الرسول (صلى الله عليه وآله)، الذي هو امتداد لهداية القرآن."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """إذا قلنا مثلاً عدد الركعات في الصلاة ليست مذكورة في القرآن مثلاً عددها... أليس القرآن يهدي إلى إتباع رسوله (صلوات الله عليه وعلى آله)؟ ورسوله هو جاء بالصلاة على هذا النحو، هو نفسه امتداد لهداية القرآن."""@ar ;
    hesin:actions """استنباط الأحكام من القرآن من خلال هدايته إلى اتباع الرسول."""@ar ;
    hesin:hasSynonym """الاستنباط"""@ar ;
    hesin:hasSynonym """الاجتهاد في إطار القرآن"""@ar ;
    hesin:hasComponent """القرآن يهدي إلى اتباع الرسول"""@ar ;
    hesin:hasComponent """الرسول امتداد لهداية القرآن"""@ar ;
    hesin:hasComponent """الأحكام مستنبطة من القرآن"""@ar ;
    hesin:hasComponent """لا فصل بين القرآن والسنة"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_45 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C224 a hesin:Concept ;
    rdfs:label """أفضل الذكر بالقرآن"""@ar ;
    hesin:definition """أفضل ذكر لله هو تلاوة القرآن الكريم بتدبر، وكذلك الأذكار المأخوذة من القرآن (سبحان الله، الحمد لله، لا إله إلا الله، الله أكبر) هي من أفضل الأذكار."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """وأفضل الذكر كما يقول: هو القرآن الكريم، ومما ذكر الله به نفسه في القرآن الكريم، ومن الأذكار الجميلة: (سبحان الله والحمد لله ولا إله إلا الله والله أكبر) هذه من أحسن الأذكار، وهي كلها مأخوذة من القرآن الكريم."""@ar ;
    hesin:actions """تشجيع ذكر الله بتلاوة القرآن والأذكار القرآنية."""@ar ;
    hesin:hasSynonym """ذكر الله بالقرآن"""@ar ;
    hesin:hasSynonym """تلاوة القرآن"""@ar ;
    hesin:hasComponent """تلاوة القرآن أفضل الذكر"""@ar ;
    hesin:hasComponent """الأذكار القرآنية أفضل الأذكار"""@ar ;
    hesin:hasComponent """ذكر الله بالقرآن"""@ar ;
    hesin:hasComponent """استحضار معاني الذكر"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_46 ;
    hesin:belongsToLesson hesin:F4_Lesson .
hesin:F4_C225 a hesin:Concept ;
    rdfs:label """الأذكار المخالفة للقرآن"""@ar ;
    hesin:definition """بعض الأدعية والأذكار التي يستعملها الناس تتنافى مع روح القرآن وتعاليمه، خاصة في حالات الصراع والجهاد، وتختلف عن الأدعية القرآنية."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """بعض الناس يأتي يصلح له أدعية وتكون متنافية في الواقع مع ما قدم في القرآن، تكون متنافية تماماً. لاحظ كيف الأدعية في القرآن فيما يتعلق بحالات الصراع، بحالات الجهاد، تختلف عما يحصل من أدعية من عندنا."""@ar ;
    hesin:actions """تصحيح الأدعية والأذكار المخالفة للقرآن."""@ar ;
    hesin:hasSynonym """أدعية منحرفة"""@ar ;
    hesin:hasSynonym """أذكار لا أصل لها"""@ar ;
    hesin:hasComponent """تنافي روح القرآن"""@ar ;
    hesin:hasComponent """الاختلاف عن الأدعية القرآنية"""@ar ;
    hesin:hasComponent """ضعف الروح الجهادية"""@ar ;
    hesin:hasComponent """الانحراف عن المنهج القرآني"""@ar ;
    hesin:belongsToGroup hesin:F4_Group_46 ;
    hesin:belongsToLesson hesin:F4_Lesson .
