hesin:F3_Collection a hesin:Collection ;
    rdfs:label """سلسلة متفرقات"""@ar ;
    hesin:description """مجموعة من الدروس المتنوعة في هدي القرآن الكريم، تغطي مواضيع متعددة منها: شرح أدعية مكارم الأخلاق، الوحدة الإيمانية، آيات من سور متعددة، وغيرها من الموضوعات العقائدية والتربوية والسياسية."""@ar .
hesin:F3_Lesson a hesin:Lesson ;
    rdfs:label """مجموعة دروس متفرقة"""@ar ;
    hesin:belongsToCollection hesin:F3_Collection .
hesin:F3_Group_1 a hesin:ConceptGroup ;
    rdfs:label """مفاهيم الكمال الإيماني واليقين (دعاء مكارم الأخلاق - الدرس الأول)"""@ar ;
