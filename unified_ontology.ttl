hesin:F6_C001 a hesin:Concept ;
    rdfs:label """التولي (الولاء)"""@ar ;
    hesin:definition """عملية قلبية تبدأ بمشاعر الميل والتعاطف، ثم تتحول إلى تأييد عملي للمواقف، مما يؤدي إلى انتماء الفرد إلى الجماعة المتولى إليها."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """التولي يبدأ بميل، ثم ينعكس بشكل تأييد فتكون معهم موقفك موقفهم، تؤيد مواقفهم ولو موقفاً واحداً، تصبح في ذلك الموقف ولياً من أوليائهم ومتولياً لهم"""@ar ;
    hesin:actions """رصد أي موقف تأييدي للجماعات المستهدفة (اليهود والنصارى)، وتصنيفه كسلوك ولائي."""@ar ;
    hesin:hasSynonym """الاتخاذ أولياء"""@ar ;
    hesin:hasSynonym """الموالاة"""@ar ;
    hesin:hasSynonym """الانتماء القلبي"""@ar ;
    hesin:hasComponent """ميل قلبي أولي"""@ar ;
    hesin:hasComponent """تأييد مواقف عملي"""@ar ;
    hesin:hasComponent """انتماء حكمي"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_1 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C002 a hesin:Concept ;
    rdfs:label """مرض القلب"""@ar ;
    hesin:definition """حالة قلبية تنحرف عن السلامة الإيمانية، وتتجلى في تفضيل المصالح الشخصية أو الدنيوية على الدين، وتجعل صاحبها عرضة للتولي والمسارعة نحو أعداء الله."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """القلب المريض لا يمكن أن يحمل اهتماماً بمصالح الآخرين... مرض القلوب يتجلى بعناوين متعددة قد يصبح نفاقاً، شكاً، ارتياباً، إيثاراً لمصالح خاصة على الدين"""@ar ;
    hesin:actions """رصد المبررات المتكررة للتقاعس أو الموالاة كمؤشرات على وجود مرض قلبي."""@ar ;
    hesin:hasSynonym """القلوب المريضة"""@ar ;
    hesin:hasSynonym """النفاق"""@ar ;
    hesin:hasSynonym """الشك"""@ar ;
    hesin:hasSynonym """الريبة"""@ar ;
    hesin:hasComponent """ضعف الوازع الإيماني"""@ar ;
    hesin:hasComponent """عدم اكتمال ملء القلب بولاية الله"""@ar ;
    hesin:hasComponent """قابلية للتأثر بالوساوس والمؤثرات الخارجية"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_1 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C003 a hesin:Concept ;
    rdfs:label """المسارعة فيهم"""@ar ;
    hesin:definition """الإسراع في تقديم الخدمات والطاعة لليهود والنصارى (أو عملائهم) دون تردد، نتيجة مرض قلبي."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """يُسَارِعُونَ فِيهِمْ... يسارعون نحو توليهم نحو خدمة ضمائرهم، نحو تنفيذ خططهم مسارعة"""@ar ;
    hesin:actions """رصد التصريحات والأفعال التي تسبق الآخرين في تأييد مواقف القوى المعادية."""@ar ;
    hesin:hasSynonym """الإسراع نحوهم"""@ar ;
    hesin:hasSynonym """التبكير في الخدمة"""@ar ;
    hesin:hasComponent """سرعة الاستجابة"""@ar ;
    hesin:hasComponent """بذل الجهد في خدمتهم"""@ar ;
    hesin:hasComponent """عدم التثبت أو التأني"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_1 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C004 a hesin:Concept ;
    rdfs:label """التبرير بالخوف (نخشى أن تصيبنا دائرة)"""@ar ;
    hesin:definition """استعمال الخوف (الوهمي غالبًا) كذريعة لتبرير التقاعس أو الموالاة، مع أن السبب الحقيقي هو مرض القلب."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """يقولون نخشى أن تصيبنا دائرة... إنما هي تغطية فقط، وإلا فواقعه أن في قلبه مرض، فهو يسارع فيهم"""@ar ;
    hesin:actions """عند رصد عبارات خوف متكررة في سياقات تمنع العمل الإسلامي، تعامل كمؤشر على احتمالية مرض قلبي."""@ar ;
    hesin:hasSynonym """التغطية"""@ar ;
    hesin:hasSynonym """الادعاء بالخوف على المصلحة العامة"""@ar ;
    hesin:hasComponent """ادعاء الخوف (على النفس أو الأمة)"""@ar ;
    hesin:hasComponent """استخدام خطاب "الحرص" و"الحكمة""""@ar ;
    hesin:hasComponent """غطاء لموقف ولائي حقيقي"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_1 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C005 a hesin:Concept ;
    rdfs:label """ولاية الله والرسول والذين آمنوا"""@ar ;
    hesin:definition """ملء القلب بالارتباط الروحي والعملي بالله ورسوله وبالإمام علي بن أبي طالب (بوصفه المصداق الوحيد للآية)، وهو ما يحصن القلب من مرض التولي للكافرين."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """املئوا قلوبكم بالولاء لله ولرسوله وللذين آمنوا... من هم الذين آمنوا؟ الذين يقيمون الصلاة ويؤتون الزكاة وهم راكعون... الإمام علي بن أبي طالب"""@ar ;
    hesin:actions """في النظام: مفهوم مركب يُستخدم للتصنيف: من يقبل بهذا المفهوم يُصنف ضمن "حزب الله" المحتمل."""@ar ;
    hesin:hasSynonym """حزب الله"""@ar ;
    hesin:hasSynonym """الولاء المطلق"""@ar ;
    hesin:hasComponent """محبة الله والرسول"""@ar ;
    hesin:hasComponent """التولي للإمام علي عليه السلام"""@ar ;
    hesin:hasComponent """العمل بطاعة الله"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_1 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C006 a hesin:Concept ;
    rdfs:label """الارتداد"""@ar ;
    hesin:definition """نتيجة خطيرة للتولي والمرض القلبي، يتحول فيها المسلم ظاهرًا إلى الكفر عمليًا وإن بقي اسمه مسلمًا."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """مَنْ يَرْتَدَّ مِنْكُمْ عَنْ دِينِهِ... يصبح كافراً يصبح يهودياً، يصبح نصرانياً"""@ar ;
    hesin:actions """في التحليل الآلي: أي موقف يتضمن ترك العمل الإسلامي أو التخلي عن المواجهة تحت ضغط الخوف يُصنف ضمن مؤشرات الارتداد."""@ar ;
    hesin:hasSynonym """الرجوع عن الدين"""@ar ;
    hesin:hasSynonym """التحول إلى الكفر"""@ar ;
    hesin:hasComponent """طاعة اليهود والنصارى"""@ar ;
    hesin:hasComponent """التخلي عن مواجهتهم"""@ar ;
    hesin:hasComponent """التثبيط عن الجهاد"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_2 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C007 a hesin:Concept ;
    rdfs:label """الاستبدال (يأت الله بقوم)"""@ar ;
    hesin:definition """عقوبة إلهية للمتقاعسين والمرتدين، باستبدالهم بأمة أخرى أكثر إيمانًا وجدارة بحمل رسالة الإسلام."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """فَسَوْفَ يَأْتِي اللَّهُ بِقَوْمٍ يُحِبُّهُمْ وَيُحِبُّونَهُ... معناه أنتم سيضربكم، سيذلكم، وتنالون بسبب ارتدادكم الخسارة والذل"""@ar ;
    hesin:actions """مفهوم تنبؤي: عدم تحقق النصر رغم الإمكانات قد يكون مؤشرًا على أن الفئة غير مستحقة للتمكين."""@ar ;
    hesin:hasSynonym """التبديل"""@ar ;
    hesin:hasSynonym """الرفض الإلهي"""@ar ;
    hesin:hasComponent """رفض الله للفئة المتقاعسة"""@ar ;
    hesin:hasComponent """ظهور فئة جديدة أكثر التزامًا"""@ar ;
    hesin:hasComponent """ذل الفئة المرفوضة"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_2 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C008 a hesin:Concept ;
    rdfs:label """الندم"""@ar ;
    hesin:definition """الشعور بالخسارة والتحسر الذي يصيب المتولين والمرتدين بعد انكشاف الحقائق وتحقق وعد الله بالنصر لأوليائه."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """فَيُصْبِحُوا عَلَى مَا أَسَرُّوا فِي أَنْفُسِهِمْ نَادِمِينَ... على ما كان في واقع قلوبهم، تلك القلوب المريضة"""@ar ;
    hesin:actions """يستخدم كمتغير تابع في تحليل نتائج المواقف التاريخية."""@ar ;
    hesin:hasSynonym """التحسر"""@ar ;
    hesin:hasSynonym """الخسارة"""@ar ;
    hesin:hasComponent """انكشاف الأسرار"""@ar ;
    hesin:hasComponent """تبين الخيانة"""@ar ;
    hesin:hasComponent """الشعور بالخسارة"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_2 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C009 a hesin:Concept ;
    rdfs:label """حبوط الأعمال"""@ar ;
    hesin:definition """فقدان قيمة الأعمال الصالحة الظاهرة بسبب فساد الباطن (الولاء للكافرين) وانكشافه."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """حَبِطَتْ أَعْمَالُهُمْ فَأَصْبَحُوا خَاسِرِينَ... أصبح إنساناً مرفوضاً عالمياً... مات كمداً وغيظاً"""@ar ;
    hesin:actions """يُستخدم كتحذير من الفصل بين الظاهر والباطن."""@ar ;
    hesin:hasSynonym """بطلان العمل"""@ar ;
    hesin:hasSynonym """الخسارة"""@ar ;
    hesin:hasComponent """أعمال صالحة ظاهريًا"""@ar ;
    hesin:hasComponent """باطن فاسد (مرض، تولي)"""@ar ;
    hesin:hasComponent """خسارة دنيوية وأخروية"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_2 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C010 a hesin:Concept ;
    rdfs:label """القوم المحبوبون"""@ar ;
    hesin:definition """الفئة التي استحقت محبة الله لصدقها ووعيها، وهي البديل عن المتقاعسين والمرتدين."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """قوم نوعية أخرى عمليين، وبنفوس قوية... يحبونه فينطلقون في السعي فيما يحصلون به على رضاه"""@ar ;
    hesin:actions """مفهوم مرجعي للتصنيف: الفئة التي تستحق التمكين الإلهي."""@ar ;
    hesin:hasSynonym """حزب الله"""@ar ;
    hesin:hasSynonym """المؤمنون الواعون"""@ar ;
    hesin:hasComponent """محبة الله والرسول"""@ar ;
    hesin:hasComponent """الوعي والفهم"""@ar ;
    hesin:hasComponent """العمل بلا تردد"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_3 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C011 a hesin:Concept ;
    rdfs:label """الأذلة على المؤمنين"""@ar ;
    hesin:definition """صفة القوم المحبوبين في تعاملهم الداخلي: التواضع، كظم الغيظ، العفو، الصبر، والحفاظ على الوحدة."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أَذِلَّةٍ عَلَى الْمُؤْمِنِينَ... متواضعين يبدون أذلة؛ لأنهم جداً حريصون على وحدتهم"""@ar ;
    hesin:actions """رصد السلوك الداخلي: الانقسامات والخلافات تُصنف ضد هذه الصفة."""@ar ;
    hesin:hasSynonym """التواضع"""@ar ;
    hesin:hasSynonym """الرحمة"""@ar ;
    hesin:hasSynonym """اللين"""@ar ;
    hesin:hasComponent """التواضع"""@ar ;
    hesin:hasComponent """الحرص على الوحدة"""@ar ;
    hesin:hasComponent """التسامح والعفو"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_3 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C012 a hesin:Concept ;
    rdfs:label """الأعزة على الكافرين"""@ar ;
    hesin:definition """صفة القوم المحبوبين في مواجهة الأعداء: القوة، الشجاعة، وعدم الخوف من لومة لائم."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أَعِزَّةٍ عَلَى الْكَافِرِينَ... أقوياء ينطلقون بنفوس قوية، وليسوا ممن يحتاجون إلى تحريض ودفع"""@ar ;
    hesin:actions """رصد المواقف: التأخر عن الجهاد أو التبرير بالخوف يُصنف ضد هذه الصفة."""@ar ;
    hesin:hasSynonym """القوة"""@ar ;
    hesin:hasSynonym """الشجاعة"""@ar ;
    hesin:hasSynonym """العزة"""@ar ;
    hesin:hasComponent """قوة النفس"""@ar ;
    hesin:hasComponent """عدم التردد"""@ar ;
    hesin:hasComponent """الاستعداد للتضحية"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_3 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C013 a hesin:Concept ;
    rdfs:label """عدم الخوف من لومة لائم"""@ar ;
    hesin:definition """تجاوز تأثير النقد والإحباط الاجتماعي، والثبات على الموقف الحق مهما كانت الضغوط."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """وَلا يَخَافُونَ لَوْمَةَ لائِمٍ... ليسوا ممن يخافون لومة لائم... أن تخوفه بالقتل ستخوفه بماذا؟"""@ar ;
    hesin:actions """رصد الحساسية للنقد: كلما قل التأثر بالنقد زادت درجة هذا المفهوم."""@ar ;
    hesin:hasSynonym """الثبات"""@ar ;
    hesin:hasSynonym """الاستقرار النفسي"""@ar ;
    hesin:hasComponent """ثبات الموقف"""@ar ;
    hesin:hasComponent """عدم التأثر بالضغوط الاجتماعية"""@ar ;
    hesin:hasComponent """البحث عن رضا الله لا الناس"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_3 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C014 a hesin:Concept ;
    rdfs:label """الفتح أو أمر من عنده"""@ar ;
    hesin:definition """وعد إلهي بحلول النصر (بأيدي المؤمنين) أو العقوبة (من عند الله مباشرة) على المتولين والمرتدين."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """فَعَسَى اللَّهُ أَنْ يَأْتِيَ بِالْفَتْحِ أَوْ أَمْرٍ مِنْ عِنْدِهِ... إما بفتح على أيدي أوليائه، وإما بأمرٍ من عنده"""@ar ;
    hesin:actions """يُستخدم كمتغير توقع: أي تحول مفاجئ في موازين القوى قد يُفسر ضمن هذا المفهوم."""@ar ;
    hesin:hasSynonym """النصر"""@ar ;
    hesin:hasSynonym """العقوبة الإلهية"""@ar ;
    hesin:hasComponent """الفتح: نصر المؤمنين"""@ar ;
    hesin:hasComponent """أمر من عنده: عقوبة مباشرة (زلازل، خسف، إلخ)"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_4 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C015 a hesin:Concept ;
    rdfs:label """المكر والخبث اليهودي"""@ar ;
    hesin:definition """وسائل اليهود في التأثير على المسلمين: الإفساد عبر الإعلام، النساء، الثقافة، لاستهداف القلوب أولاً."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لديهم خبرة شيطانية، لديهم خبث شيطاني، ومكر شيطاني رهيب، وهم يتجهون نحو الوسوسة ونحو القلوب"""@ar ;
    hesin:actions """رصد وسائل الإعلام والتثقيف التي تستهدف القيم الإسلامية."""@ar ;
    hesin:hasSynonym """الوسوسة"""@ar ;
    hesin:hasSynonym """الإفساد"""@ar ;
    hesin:hasComponent """الإعلام المفسد (تلفزيون، صحف)"""@ar ;
    hesin:hasComponent """التبرج والصور الخليعة"""@ar ;
    hesin:hasComponent """التضليل الثقافي"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_4 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C016 a hesin:Concept ;
    rdfs:label """الجهاد في سبيل الله"""@ar ;
    hesin:definition """العمل المتكامل لمواجهة أعداء الله بكل الوسائل المتاحة (عسكريًا، اقتصاديًا، سياسيًا، ثقافيًا، إعلاميًا)."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """يجاهدون في سبيل الله... يجاهدون بالكلمة، يجاهدون بالمال، يجاهدون بالقلم، يجاهدون بالسيف"""@ar ;
    hesin:actions """مفهوم مركب يشمل أنواعًا متعددة من المقاومة."""@ar ;
    hesin:hasSynonym """المواجهة"""@ar ;
    hesin:hasSynonym """العمل الإسلامي"""@ar ;
    hesin:hasComponent """الجهاد بالكلمة"""@ar ;
    hesin:hasComponent """الجهاد بالمال"""@ar ;
    hesin:hasComponent """الجهاد بالقلم"""@ar ;
    hesin:hasComponent """الجهاد بالسيف"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_4 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C017 a hesin:Concept ;
    rdfs:label """فلته أبي بكر"""@ar ;
    hesin:definition """مفهوم يصف بيعة أبي بكر بأنها غير شرعية أو غير متوقعة، تمت بسرعة وتلفيق، وليست نابعة من أهلية المبايع."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """إن بيعة أبي بكر كانت فلتة... يعني إنما لفَّقْناها تلفيقاً حتى مشت وقبلها الناس... لم يكن هو المؤمل فيه"""@ar ;
    hesin:actions """يُستخدم كأصل تاريخي لتفسير الانحراف."""@ar ;
    hesin:hasSynonym """الانقلاب"""@ar ;
    hesin:hasSynonym """التلفيق"""@ar ;
    hesin:hasComponent """عدم الأهلية المتوقعة"""@ar ;
    hesin:hasComponent """التلفيق والإسراع"""@ar ;
    hesin:hasComponent """نتائج سلبية مستمرة"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_5 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C018 a hesin:Concept ;
    rdfs:label """عمر مهندس العملية"""@ar ;
    hesin:definition """تصور لعمر بن الخطاب بوصفه المخطط الرئيسي لبيعة أبي بكر، ومسؤولًا عن الانحراف بعد النبي."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """عمر بالذات لأنه هو المهندس للعملية كلها، هو المرتب للعملية كلها فيما يتعلق بأبي بكر"""@ar ;
    hesin:actions """يستخدم في تحليل التاريخ من منظور النص."""@ar ;
    hesin:hasSynonym """المخطط"""@ar ;
    hesin:hasSynonym """المرتب"""@ar ;
    hesin:hasComponent """التخطيط لبيعة أبي بكر"""@ar ;
    hesin:hasComponent """التنسيق مع معاوية لاحقًا"""@ar ;
    hesin:hasComponent """المسؤولية عن سيئات الأمة"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_5 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C019 a hesin:Concept ;
    rdfs:label """سيئات عمر ومعاوية"""@ar ;
    hesin:definition """ربط كل الانحرافات التاريخية في الأمة بثلاثة خلفاء (أبو بكر، عمر، عثمان) وبخاصة عمر كمهندس."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """معاوية سيئة من سيئات عمر... كل ظلم وقع للأمة، وكل معاناة وقعت الأمة فيها المسئول عنها أبو بكر وعمر وعثمان"""@ar ;
    hesin:actions """مفهوم تفسيري لتحليل أسباب التخلف."""@ar ;
    hesin:hasSynonym """الانحرافات"""@ar ;
    hesin:hasSynonym """الظلم"""@ar ;
    hesin:hasComponent """ظلم الأمة"""@ar ;
    hesin:hasComponent """معاناة المسلمين"""@ar ;
    hesin:hasComponent """الانحراف عن ولاية علي"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_5 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C020 a hesin:Concept ;
    rdfs:label """العمى عن الحل"""@ar ;
    hesin:definition """حالة من العجز الفكري والروحي عن تشخيص أسباب مشاكل الأمة، ناتجة عن التمسك بمنهج أبي بكر وعمر."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هي سبب المشكلة وهي المُعَمِّي عن حل المشكلة... لا يوجد قضية مثلها"""@ar ;
    hesin:actions """يُستخدم كتحذير: أي فكر لا ينتقد أصوله التاريخية يقع في هذا المفهوم."""@ar ;
    hesin:hasSynonym """الجمود"""@ar ;
    hesin:hasSynonym """عدم القدرة على التشخيص"""@ar ;
    hesin:hasComponent """عدم الجلوس لمناقشة الأسباب"""@ar ;
    hesin:hasComponent """الجمود الفكري"""@ar ;
    hesin:hasComponent """التمسك بالشخصيات حتى مع الهزائم"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_5 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C021 a hesin:Concept ;
    rdfs:label """القلب هو المضغة"""@ar ;
    hesin:definition """القلب هو مركز التحكم في سلوك الإنسان، وهو الذي يحرك المواقف واللسان والمال والسلاح."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """القلب هو المضغة الذي إذا صلحت صلح الإنسان، وإذا فسدت فسد الإنسان"""@ar ;
    hesin:actions """في النظام: كل تحليل يبدأ من القلب كمصدر أولي."""@ar ;
    hesin:hasSynonym """مركز الإنسان"""@ar ;
    hesin:hasSynonym """مصدر الحركة"""@ar ;
    hesin:hasComponent """مركز التوجيه"""@ar ;
    hesin:hasComponent """مصدر المواقف"""@ar ;
    hesin:hasComponent """قابل للتأثر والفساد"""@ar ;
