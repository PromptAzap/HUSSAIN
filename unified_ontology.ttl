hesin:F6_Collection a hesin:Collection ;
    rdfs:label """سلسلة دروس من سورة المائدة"""@ar ;
    hesin:description """تفسير موضوعي لآيات سورة المائدة (51-59) مع تركيز على قضية الولاء والبراء، وموقف الأمة من اليهود والنصارى، وربط ذلك بولاية الإمام علي بن أبي طالب عليه السلام. تم استخلاص المفاهيم عبر أربعة دروس منهجية."""@ar .
hesin:F6_Lesson a hesin:Lesson ;
    rdfs:label """المفاهيم المنهجية المستخلصة من سلسلة سورة المائدة (الدروس 1-4)"""@ar ;
    hesin:belongsToCollection hesin:F6_Collection .
