    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C023 a hesin:Concept ;
    rdfs:label """القلب الفارغ"""@ar ;
    hesin:definition """القلب الذي لم يُملأ بالولاء الصحيح، مما يجعله عرضة للفساد والتولي للكافرين."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """القلب الفارغ من هدي الله ومما يرشد إليه الله سبحانه وتعالى هو من سيكون ضحية"""@ar ;
    hesin:actions """يُستخدم كتحذير من عدم الاهتمام بالبناء الإيماني."""@ar ;
    hesin:hasSynonym """القلب الخالي"""@ar ;
    hesin:hasSynonym """القلب غير المحصن"""@ar ;
