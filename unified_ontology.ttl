hesin:F5_C136 a hesin:Concept ;
    rdfs:label """الثورة الصناعية"""@ar ;
    hesin:definition """التحول الصناعي والتكنولوجي الذي حدث في الغرب، واستُغل من قبل اليهود لفرض هيمنتهم على العالم الإسلامي."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """جاء اليهود ليستخدموا الثورة الصناعية فاستغلوها في الجانب الثقافي أن يقدموا للمسلمين بأن عليكم أن تتخلوا عن دينكم حتى تكونوا كمثلنا"""@ar ;
    hesin:actions """اللحاق بالثورة الصناعية من منطلق إسلامي."""@ar ;
