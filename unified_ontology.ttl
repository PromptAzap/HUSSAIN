    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C022 a hesin:Concept ;
    rdfs:label """حزب الله"""@ar ;
    hesin:definition """الجماعة التي تتولى الله ورسوله والمؤمنين، وتثق بالله، وتعمل بنصرة دينه."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """فَإِنَّ حِزْبَ اللَّهِ هُمُ الْغَالِبُونَ... نتولى الله.. كيف نتولى الله؟ حتى نرى أنفسنا عظيمي الثقة بالله، ثم انطلق إلى رسوله، ثم انطلق إلى الذين آمنوا ثم ستصبح فعلا أنت وإخوانك حزب الله وستكونون أنتم غالبون"""@ar ;
    hesin:actions """تحليل الانتماءات: هل الانتماء لله أم لقوى أخرى."""@ar ;
