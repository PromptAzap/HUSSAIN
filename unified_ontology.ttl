hesin:F5_C033 a hesin:Concept ;
    rdfs:label """ترسيخ (لا إله إلا الله)"""@ar ;
    hesin:definition """عملية منهجية تهدف إلى جعل معنى "لا إله إلا الله" راسخًا في النفس من خلال التكرار والتأمل والتطبيق العملي."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """فلنعمل دائما على أن نرسخ في أنفسنا: لا إله إلا هو... حاول أن تأخذ ورقة في جيبك واكتب فيها: {فَاعْلَمْ أَنَّهُ لا إِلَهَ إِلَّا اللَّهُ} وشغِلها شهراً وانظر كيف ستكون أنت"""@ar ;
    hesin:actions """تطبيق تمرين يومي (كتابة الآية، ترديدها) لمدة شهر."""@ar ;
    hesin:hasSynonym """تثبيت التوحيد"""@ar ;
    hesin:hasComponent """التكرار"""@ar ;
    hesin:hasComponent """الكتابة والتذكير"""@ar ;
    hesin:hasComponent """الربط بالمواقف"""@ar ;
    hesin:hasComponent """الاستغراب (الاستفهام) أمام كل خوف أو رغبة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_9 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C034 a hesin:Concept ;
    rdfs:label """التفكر في واقع الناس"""@ar ;
    hesin:definition """ملاحظة وتحليل واقع الناس لاستخلاص الدروس والعبر، ورؤية أثر العقائد والثقافات على سلوكهم."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """إذا تأمل الإنسان في واقع الناس يجد أننا ضحية عقائد باطلة، وثقافة مغلوطة"""@ar ;
    hesin:actions """رصد واقع الناس لاستخلاص أسباب الضعف الإيماني."""@ar ;
    hesin:hasSynonym """النظر في أحوال الناس"""@ar ;
    hesin:hasSynonym """التأمل الاجتماعي"""@ar ;
    hesin:hasComponent """ملاحظة السلوكيات"""@ar ;
    hesin:hasComponent """تحليل الأسباب"""@ar ;
    hesin:hasComponent """استخلاص العبر"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_9 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C035 a hesin:Concept ;
    rdfs:label """التصور (تصور الجنة والنار)"""@ar ;
    hesin:definition """تكوين صورة ذهنية مفصلة عن الجنة والنار من خلال جمع آيات القرآن وترتيبها."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لو تأت أنت أو أي واحد منا يحاول أن يجمع ما ذكره القرآن الكريم من الآيات في جهنم، ثم ضعها في ورقة تكون أمامك ترى كيف تتصور جهنم وتراها صورة متكاملة"""@ar ;
    hesin:actions """تجميع الآيات في ملفات موضوعية لتصور المشاهد الأخروية."""@ar ;
    hesin:hasSynonym """التخيل"""@ar ;
    hesin:hasSynonym """الرسم الذهني"""@ar ;
    hesin:hasComponent """جمع الآيات"""@ar ;
    hesin:hasComponent """ترتيبها موضوعيًا"""@ar ;
    hesin:hasComponent """تكوين صورة متكاملة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_9 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C036 a hesin:Concept ;
    rdfs:label """الروتين في العبادة"""@ar ;
    hesin:definition """تكرار الأعمال والعبادات دون تفاعل قلبي أو تأثر، مما يؤدي إلى قسوة القلب."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أصبح تقريبا مجرد روتين استماع القرآن الكريم، واستماع المواعظ، وحضور المناسبات، لكن دون أن نرجع إلى أنفسنا فنجعلها تتعامل مع كل ما تسمع بجدية"""@ar ;
    hesin:actions """رصد مدى التفاعل مع العبادات المتكررة."""@ar ;
    hesin:hasSynonym """العادة"""@ar ;
    hesin:hasSynonym """التكرار بلا روح"""@ar ;
    hesin:hasComponent """تكرار الاستماع"""@ar ;
    hesin:hasComponent """عدم التفاعل"""@ar ;
    hesin:hasComponent """عدم التطبيق"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_9 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C037 a hesin:Concept ;
    rdfs:label """القرآن الكريم"""@ar ;
    hesin:definition """المصدر الأساسي والأهم لمعرفة الله، وهو كلام الله المنزل على نبيه محمد، وفيه كل ما يحتاجه الإنسان من هداية."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """وأهم مصدر لمعرفة الله سبحانه وتعالى هو القرآن الكريم، الذي يعطي معرفة واسعة، معرفة متكاملة"""@ar ;
    hesin:actions """جعل القرآن المصدر الأول في الاستدلال والتحليل."""@ar ;
    hesin:hasSynonym """كتاب الله"""@ar ;
    hesin:hasSynonym """الهدي القرآني"""@ar ;
    hesin:hasComponent """مصدر المعرفة بالله"""@ar ;
    hesin:hasComponent """هداية للناس"""@ar ;
    hesin:hasComponent """نذير للبشر"""@ar ;
    hesin:hasComponent """فيه تصوير كامل للجنة والنار"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_10 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C038 a hesin:Concept ;
    rdfs:label """العترة الطاهرة"""@ar ;
    hesin:definition """أهل بيت النبي محمد (عليهم السلام)، وهم أحد الثقلين اللذين أوصى النبي بالتمسك بهما."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """جاءتنا من خارج الثقلين: كتاب الله، وعترة رسوله (صلوات الله عليه وعلى آله)"""@ar ;
    hesin:actions """يُستفاد من النص أن العترة مصدر للعلم، لكن لم يُفصل منهجيًا في هذا الدرس."""@ar ;
    hesin:hasSynonym """آل البيت"""@ar ;
    hesin:hasSynonym """عترة الرسول"""@ar ;
    hesin:hasComponent """مصدر للعلم"""@ar ;
    hesin:hasComponent """معين لفهم القرآن"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_10 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C039 a hesin:Concept ;
    rdfs:label """الثقلان"""@ar ;
    hesin:definition """مصدرا الهداية الأساسيان للمسلمين: القرآن الكريم والعترة الطاهرة."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """جاءتنا من خارج الثقلين: كتاب الله، وعترة رسوله"""@ar ;
    hesin:actions """الرجوع إلى الثقلين في المعرفة والهداية."""@ar ;
    hesin:hasSynonym """القرآن والعترة"""@ar ;
    hesin:hasComponent """كتاب الله"""@ar ;
    hesin:hasComponent """عترة رسول الله"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_10 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C040 a hesin:Concept ;
    rdfs:label """بنو إسرائيل (بني إسرائيل)"""@ar ;
    hesin:definition """نموذج تاريخي لجماعة أوتيت الكتاب، لكنها قست قلوبها بعد طول الأمد وكثرة المواعظ."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """تخويف من أن يصير الناس إلى ما صار إليه بنوا إسرائيل، الذين طال عليهم الأمد يسمعون مواعظ، ويقرؤون كتبا، ولكن ببرودة لا يتفاعلون معها"""@ar ;
    hesin:actions """دراسة تاريخ الأمم السابقة لاستخلاص العبر."""@ar ;
    hesin:hasSynonym """اليهود"""@ar ;
    hesin:hasSynonym """الذين أوتوا الكتاب"""@ar ;
    hesin:hasComponent """طال عليهم الأمد"""@ar ;
    hesin:hasComponent """قست قلوبهم"""@ar ;
    hesin:hasComponent """لم يتفاعلوا مع المواعظ"""@ar ;
    hesin:hasComponent """نزع الله منهم النبوة والملك"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_11 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C041 a hesin:Concept ;
    rdfs:label """الجاهليون (المشركون)"""@ar ;
    hesin:definition """نموذج تاريخي لأناس كانوا يعترفون بوجود الله وخلقه وتدبيره، لكنهم أشركوا معه آلهة أخرى."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """كان الجاهليون يؤمنون بالله بمعنى أنهم عارفون بأن هناك إله اسمه: [الله]، هو الذي خلق السموات والأرض، وهو الذي يدبر شئون السماوات والأرض"""@ar ;
    hesin:actions """المقارنة بين إيمان الجاهليين وإيمان المسلمين المعاصرين."""@ar ;
    hesin:hasSynonym """عرب الجاهلية"""@ar ;
    hesin:hasComponent """الإقرار بوجود الله"""@ar ;
    hesin:hasComponent """الإقرار بخلقه وتدبيره"""@ar ;
    hesin:hasComponent """الشرك في العبادة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_11 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C042 a hesin:Concept ;
    rdfs:label """النبوة"""@ar ;
    hesin:definition """اصطفاء الله لبعض عباده ليبلغوا رسالته ويهدوا الناس إلى دينه."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """فَأَتَتْكَ آيَاتُنَا فَنَسِيتَهَا... كنا في الدنيا نقول لك تبرأ من المجرمين تبرأ من الظالمين تمشي على هدي الله، لا ترتبط بغير هدي الله والهداة إلى دين الله"""@ar ;
    hesin:actions """الاعتماد على هدي الأنبياء في المعرفة."""@ar ;
    hesin:hasSynonym """الرسالة"""@ar ;
    hesin:hasSynonym """الأنبياء"""@ar ;
    hesin:hasComponent """تلقي الوحي"""@ar ;
    hesin:hasComponent """البلاغ"""@ar ;
    hesin:hasComponent """الهداية"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_12 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C043 a hesin:Concept ;
    rdfs:label """الشفاعة"""@ar ;
    hesin:definition """وساطة بعض المخلوقات (الأنبياء، الملائكة، المؤمنين) يوم القيامة لمن ارتضى الله وبإذنه."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """في يوم القيامة لا تكون شفاعة إلا لمن ارتضى، ولا شفاعة إلا لمن يأذن"""@ar ;
    hesin:actions """عدم الاعتماد على الشفاعة مع ترك العمل."""@ar ;
    hesin:hasSynonym """الوساطة يوم القيامة"""@ar ;
    hesin:hasComponent """بإذن الله"""@ar ;
    hesin:hasComponent """لمن ارتضى"""@ar ;
    hesin:hasComponent """لا تشفع للكافرين"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_12 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C044 a hesin:Concept ;
    rdfs:label """النفس"""@ar ;
    hesin:definition """ذات الإنسان التي تتأثر بالأعمال، وتخبث بالمعاصي، وتصلح بالطاعات."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """كل معصية ترسخ نسبة من الخبث في نفسك، وهكذا واحدة بعد واحدة حتى تحيط بك خطيئاتك"""@ar ;
    hesin:actions """تحليل أثر الأعمال على النفس."""@ar ;
    hesin:hasSynonym """الإنسان"""@ar ;
    hesin:hasSynonym """الذات"""@ar ;
    hesin:hasComponent """قابلة للتأثر"""@ar ;
    hesin:hasComponent """تخبث بالمعاصي"""@ar ;
    hesin:hasComponent """تصلح بالطاعات"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_13 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C045 a hesin:Concept ;
    rdfs:label """نسيان النفس"""@ar ;
    hesin:definition """نتيجة لنسيان الله، يفقد الإنسان الوعي بحقيقة نفسه ومصيره، فيضل عن طريق الخير."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """إذا ما نسيت الله نسيت نفسك"""@ar ;
    hesin:actions """ربط الوعي بالله بالوعي بالذات."""@ar ;
    hesin:hasSynonym """فقدان الوعي الذاتي"""@ar ;
    hesin:hasComponent """نتيجة نسيان الله"""@ar ;
    hesin:hasComponent """فقدان البصيرة"""@ar ;
    hesin:hasComponent """الضلال"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_13 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C101 a hesin:Concept ;
    rdfs:label """علم الكلام"""@ar ;
    hesin:definition """منهج معرفي تقليدي يركز على قضايا محدودة (كالجبر والاختيار، أفعال الله، الصفات) بأسلوب جدلي متأثر بالمنطق الفلسفي، دون أن يترك أثرًا وجدانيًا في النفس."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """عندما نأتي إلى كتب علم الكلام نجدها تتحدث عن قضايا محدودة وبأسلوب محدود ومناقشات [طويلة عريضة] حول قضايا أفعال الإنسان هل هي منه أم هي من الله... سببها أن الجميع ابتعدوا عن القرآن الكريم فلم يكن لله في نفوسهم العظمة"""@ar ;
    hesin:actions """تحديد المناهج المعرفية التي تفصل بين النظرية والتطبيق، واستبعادها."""@ar ;
    hesin:hasSynonym """الكلام"""@ar ;
    hesin:hasSynonym """أصول الدين"""@ar ;
    hesin:hasComponent """الاشتغال بالجدليات العقلية"""@ar ;
    hesin:hasComponent """التأثر بالمنطق الفلسفي"""@ar ;
    hesin:hasComponent """التركيز على قضايا محدودة"""@ar ;
    hesin:hasComponent """إنتاج عقائد نظرية مجردة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_14 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C102 a hesin:Concept ;
    rdfs:label """المعرفة الكلامية المحدودة"""@ar ;
    hesin:definition """معرفة تقتصر على إصدار أحكام عقلية مجردة عن الله (كوجوده ووحدانيته)، دون أن تتجاوز إلى الأثر الوجداني أو السلوك العملي."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """معرفة الله تحت عنوان: هو تحصيل عقائد صحيحة فيما يتعلق بالأفعال بالذات والصفات ـ كما يقولون ـ فيما يتعلق بأفعال الله وأفعال العباد"""@ar ;
    hesin:actions """قياس مدى تحول المعرفة إلى سلوك عملي."""@ar ;
    hesin:hasSynonym """المعرفة النظرية المجردة"""@ar ;
    hesin:hasSynonym """العقائد الصورية"""@ar ;
    hesin:hasComponent """إصدار أحكام عقلية"""@ar ;
    hesin:hasComponent """غياب الأثر الوجداني"""@ar ;
    hesin:hasComponent """انفصال عن السلوك"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_14 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C103 a hesin:Concept ;
    rdfs:label """غياب الحديث عن النعم في علم الكلام"""@ar ;
    hesin:definition """غياب موضوع نعم الله عن كتب علم الكلام، رغم كونها منهجًا قرآنيًا أساسيًا لمعرفة الله."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لم يعرض المتكلمون مسألة النعم الكثيرة التي أسبغها الله على عباده كأسلوب من أساليب معرفته سبحانه وتعالى. لم يقدموا الحديث عن شدة بطشه، وعن سعة رحمته فيما يعِدُ به أولياءه"""@ar ;
    hesin:actions """إعادة إدراج نعم الله في المناهج المعرفية."""@ar ;
    hesin:hasSynonym """إهمال نعم الله في المنهج الكلامي"""@ar ;
    hesin:hasComponent """إغفال النعم الظاهرة والباطنة"""@ar ;
    hesin:hasComponent """إغفال الحديث عن الجنة والنار كأسلوب معرفي"""@ar ;
    hesin:hasComponent """تركيز فقط على القضايا الجدلية"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_14 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C104 a hesin:Concept ;
    rdfs:label """خشونة المتكلمين"""@ar ;
    hesin:definition """حالة قلبية يصل إليها المشتغلون بعلم الكلام نتيجة انشغالهم بالجدل العقلي وانفصالهم عن الخطاب القرآني العاطفي العملي."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """كان من المعروف أن المتكلمين هم من عرفوا بالخشونة حتى قال الإمام القاسم بن إبراهيم (صلوات الله عليه) ـ لا ادري حكاية عن غيره أو قالها عن نفسه ـ (أنه لم يُعْرَف أن متكلماً خشع)"""@ar ;
    hesin:actions """رصد العلاقة بين المنهج المعرفي والحالة النفسية."""@ar ;
    hesin:hasSynonym """قسوة القلب"""@ar ;
    hesin:hasSynonym """غياب الخشوع"""@ar ;
    hesin:hasComponent """عدم الخشوع في الصلاة"""@ar ;
    hesin:hasComponent """غياب التأثر بالقرآن"""@ar ;
    hesin:hasComponent """قسوة في التعامل"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_14 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C105 a hesin:Concept ;
    rdfs:label """فصل العقيدة عن السلوك"""@ar ;
    hesin:definition """حالة يفصل فيها الإنسان بين ما يعتقده نظريًا وبين سلوكه العملي، فلا تترك العقيدة أثرًا في تصرفاته."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """عالم.. عالم لمجرد العلم، وعقائد لمجرد العقائد، علم محدود عقائد أتعامل معها بشكل أحكام أصدرها، وليس هناك أثر لها في النفس"""@ar ;
    hesin:actions """قياس مدى انعكاس العقيدة على السلوك."""@ar ;
    hesin:hasSynonym """انفصال العلم عن العمل"""@ar ;
    hesin:hasComponent """معرفة نظرية"""@ar ;
    hesin:hasComponent """غياب التأثير السلوكي"""@ar ;
    hesin:hasComponent """انفصال بين الإيمان والعمل"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_14 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C106 a hesin:Concept ;
    rdfs:label """المعرفة العملية"""@ar ;
    hesin:definition """معرفة بالله تتجاوز مجرد التصديق النظري إلى التأثير الوجداني (الخشية، الحب، الثقة) والسلوك العملي (الطاعة، العمل الصالح، الإبداع الحضاري)."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أما القرآن الكريم فهو كتاب عملي، كتاب عملي، معرفة تترك أثراً في النفوس، تترك هذه النفوس أثراً في الحياة، معرفة تزكو بها النفوس، فينعكس أثر هذه النفوس صلاحاً في هذه الحياة"""@ar ;
    hesin:actions """قياس المعرفة من خلال آثارها السلوكية والوجدانية."""@ar ;
    hesin:hasSynonym """المعرفة الواسعة"""@ar ;
    hesin:hasSynonym """المعرفة القرآنية"""@ar ;
    hesin:hasComponent """أثر وجداني (خشية، حب، ثقة)"""@ar ;
    hesin:hasComponent """أثر سلوكي (طاعة، عمل)"""@ar ;
    hesin:hasComponent """انعكاس على الحياة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_15 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C107 a hesin:Concept ;
    rdfs:label """معرفة الله من خلال النعم"""@ar ;
    hesin:definition """منهج قرآني لمعرفة الله من خلال استحضار نعمه الظاهرة والباطنة، مما يخلق في النفس مشاعر الحب والإجلال والثقة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """الحديث عن نعم الله سبحانه وتعالى مهم جداً، في القرآن الكريم آيات كثيرة تناولت كرم الله سبحانه وتعالى وإحسانه العظيم إلى عباده... فدلائل على قدرته سبحانه وتعالى، على حكمته، على رعايته، على عظم إحسانه إلى عباده ليحبوه ليعظموه ليجلوه"""@ar ;
    hesin:actions """جمع آيات النعم واستحضارها في التأمل اليومي."""@ar ;
    hesin:hasSynonym """معرفة الله عبر استحضار نعمه"""@ar ;
    hesin:hasComponent """استحضار النعم المادية"""@ar ;
    hesin:hasComponent """استحضار النعم المعنوية (الهداية)"""@ar ;
    hesin:hasComponent """ربط النعم بصفات الله"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_15 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C108 a hesin:Concept ;
    rdfs:label """استعطاف الله لعباده"""@ar ;
    hesin:definition """أسلوب قرآني يخاطب المشاعر الإنسانية الفطرية (الامتنان، تقدير الجميل) لشد العبد نحو الله، بدلاً من التهديد المباشر فقط."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """استعطاف لعباده أو تعطف منه... أي يخاطب وجدانك، يخاطبك أنت كإنسان ترعى الجميل، وتقدر الإحسان، وتشكر النعمة، وتعترف بالفضل لمن أسدى إليك النعمة ليشدك نحوه"""@ar ;
    hesin:actions """استخدام أسلوب التذكير بالنعم في الخطاب الدعوي."""@ar ;
    hesin:hasSynonym """الخطاب العاطفي"""@ar ;
    hesin:hasSynonym """الاستعطاف القرآني"""@ar ;
    hesin:hasComponent """تذكير بالإحسان"""@ar ;
    hesin:hasComponent """استحضار الجميل"""@ar ;
    hesin:hasComponent """خطاب الوجدان"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_15 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C109 a hesin:Concept ;
    rdfs:label """الأثر الوجداني للمعرفة"""@ar ;
    hesin:definition """المشاعر والانفعالات الإيمانية التي تنشأ عن معرفة الله (كالحب، الخشية، الحياء، الثقة)، وهي المحرك الحقيقي للسلوك."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """تلك المشاعر التي تتركها هذه، نظرتك إليها، نظرتك إلى من أسداها إليك، تلك المشاعر مهمة جداً في ربطك بالله، في ثقتك بالله، في انطلاقك في طاعته"""@ar ;
    hesin:actions """قياس المشاعر الإيمانية كمدخل لتقييم المعرفة."""@ar ;
    hesin:hasSynonym """المشاعر الإيمانية"""@ar ;
    hesin:hasSynonym """التفاعل القلبي"""@ar ;
    hesin:hasComponent """الحب"""@ar ;
    hesin:hasComponent """الخشية"""@ar ;
    hesin:hasComponent """الحياء"""@ar ;
    hesin:hasComponent """الثقة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_15 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C110 a hesin:Concept ;
    rdfs:label """التفكر (بالمعنى القرآني)"""@ar ;
    hesin:definition """منهج قرآني يجمع بين: (1) استخلاص الدلالات على كمال الله، (2) الإبداع والاختراع والتصنيع، (3) زيادة الخشية والمعرفة، وكلها منطلقة من دافع عبادي."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لاحظ كيف تأتي هذه العبارات في هذه الآيات... {إِنَّ فِي ذَلِكَ لَآياتٍ لِقَوْمٍ يَتَفَكَّرُونَ} آيات لقوم يتفكرون فيعلمون من خلال تفكرهم عظم نعم الله... يتفكرون أيضاً في ما سخر لهم داخل هذا العالم؛ لتتوسع معرفتهم بالله سبحانه وتعالى؛ وليصلوا من خلال تفكرهم ودراستهم لكل ظواهر هذه الحياة... يبدعوا ويخترعوا ويصنعوا ويكتشفوا الأشياء الكثيرة"""@ar ;
    hesin:actions """توجيه التفكر نحو الإنتاج الحضاري، وربطه بالدافع العبادي."""@ar ;
    hesin:hasSynonym """النظر"""@ar ;
    hesin:hasSynonym """التدبر"""@ar ;
    hesin:hasSynonym """دراسة الكون"""@ar ;
    hesin:hasComponent """دراسة ظواهر الكون"""@ar ;
    hesin:hasComponent """اكتشاف ما في باطن الأرض والسماء"""@ar ;
    hesin:hasComponent """الإبداع والاختراع"""@ar ;
    hesin:hasComponent """ازدياد الخشية من الله"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_16 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C111 a hesin:Concept ;
    rdfs:label """تسخير الكون للإنسان"""@ar ;
    hesin:definition """جعل الله كل ما في السموات والأرض (ظاهرها وباطنها) في خدمة الإنسان، ليستفيد منها في حياته، ويكتشف ما فيها، ويعمر الأرض."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَسَخَّرَ لَكُمْ مَا فِي السَّمَاوَاتِ وَمَا فِي الْأَرْضِ جَمِيعاً مِنْهُ} (الجاثـية: من الآية 13) من أجل ماذا؟ أن ننظر لنعرف من خلالها كيف نصدر حكماً ونسميه عقائداً... أم ليتفكر؛ ليتفكر فيصل إليه وعندما يصل إليه ترى كيف سيصنع الحياة فيحرك ظاهر العالم"""@ar ;
    hesin:actions """اكتشاف ما في الكون واستغلاله للعمران الحضاري."""@ar ;
    hesin:hasSynonym """سخَّر لكم"""@ar ;
    hesin:hasSynonym """مسخرات الله"""@ar ;
    hesin:hasComponent """تسخير الظاهر (الشمس، القمر، البحر)"""@ar ;
    hesin:hasComponent """تسخير الباطن (البترول، المعادن)"""@ar ;
    hesin:hasComponent """الهدف: التفكر والإبداع والشكر"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_16 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C112 a hesin:Concept ;
    rdfs:label """التفكر الكلامي المحدود"""@ar ;
    hesin:definition """اختزال آيات الكون في مجرد إثبات وجود الله وصفاته، مع إهمال البعد الإبداعي الحضاري للتفكر."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """شجرة واحدة ممكن أن تقوم بهذه المهمة، شجرة واحدة محدثة أليس لها محدث؟ إذاً هذه الشجرة نراها ورقها وسيقانها وزهورها وثمارها محكمة، أليست تدل على أن هناك قادرا وحكيما؟ تقضي على أن فاعلها عالم، وتدل على أنه حي؟ شجرة واحدة أمكن أن تقوم بالمهمة التي انشغل حولها [المعتزلة]"""@ar ;
    hesin:actions """تجاوز هذا المستوى إلى التفكر الإبداعي."""@ar ;
    hesin:hasSynonym """النظر الكلامي"""@ar ;
    hesin:hasSynonym """إثبات الصانع"""@ar ;
    hesin:hasComponent """إثبات الحدوث"""@ar ;
    hesin:hasComponent """إثبات الصانع"""@ar ;
    hesin:hasComponent """إصدار أحكام عقلية"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_16 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C113 a hesin:Concept ;
    rdfs:label """الإبداع الحضاري كعبادة"""@ar ;
    hesin:definition """جعل الإبداع والتصنيع والاختراع في إطار العبادة، بدافع معرفة الله وتعمير الأرض وشكره."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أراد القرآن أن ننطلق في ما نفهم أن ننطلق باعتبار هذا عبادة، بدافع عبادي (تفكروا) (يتفكرون).. والتفكر ما هو؟ دراسة الأشياء، فهمها"""@ar ;
    hesin:actions """توجيه البحث العلمي بدافع عبادي."""@ar ;
    hesin:hasSynonym """التصنيع"""@ar ;
    hesin:hasSynonym """الاختراع"""@ar ;
    hesin:hasSynonym """الإنتاج"""@ar ;
    hesin:hasComponent """دراسة العلوم"""@ar ;
    hesin:hasComponent """التجارب والاختراعات"""@ar ;
    hesin:hasComponent """نية العبادة وشكر الله"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_16 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C114 a hesin:Concept ;
    rdfs:label """العلم الحقيقي (العلم المورث للخشية)"""@ar ;
    hesin:definition """العلم الذي يورث صاحبه خشية الله، ويترك أثرًا في سلوكه، وليس مجرد اطلاع على قواعد ومعلومات."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """من كان عالماً على هذا النحو وليس بالشكل الذي سمته به الآية الكريمة {إنَّمَا يَخْشَى اللَّهَ مِنْ عِبَادِهِ الْعُلَمَاءُ} فإنه ما يزال جاهلاً"""@ar ;
    hesin:actions """تقييم العلم من خلال أثره في الخشية والسلوك."""@ar ;
    hesin:hasSynonym """العلم النافع"""@ar ;
    hesin:hasSynonym """علم الخشية"""@ar ;
    hesin:hasComponent """خشية الله"""@ar ;
    hesin:hasComponent """الأثر السلوكي"""@ar ;
    hesin:hasComponent """المعرفة الواسعة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_17 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C115 a hesin:Concept ;
    rdfs:label """العلم المصطلحي المجرد"""@ar ;
    hesin:definition """المعرفة التي تقتصر على الجانب المصطلحي والقواعدي دون أن تترك أثرًا في النفس أو السلوك."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هو عالم باعتباره اطلاع على قواعد، العلم يطلق على العلم النفسي، ويطلق أيضاً على مجرد القواعد.. يقال: علم الفقه، علم الكلام، علم كذا. لا بأس هو عالم بهذا المسمى"""@ar ;
    hesin:actions """التمييز بين العلم النافع والعلم الصوري."""@ar ;
    hesin:hasSynonym """علم الفقه"""@ar ;
    hesin:hasSynonym """علم الكلام"""@ar ;
    hesin:hasSynonym """العلوم الشرعية التقليدية"""@ar ;
    hesin:hasComponent """معرفة القواعد"""@ar ;
    hesin:hasComponent """غياب الأثر النفسي"""@ar ;
    hesin:hasComponent """غياب الخشية"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_17 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C116 a hesin:Concept ;
    rdfs:label """التأثر بالثقافات المغلوطة"""@ar ;
    hesin:definition """تأثر العلوم الإسلامية (خاصة علم الكلام) بالمنطق الفلسفي اليوناني والثقافات الأخرى، مما أدى إلى انحراف المنهج عن القرآن."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """معظمها مصبوغة بمنطق الفلاسفة ومتأثرة بأساليب الفلاسفة من الإماميين وغيرهم"""@ar ;
    hesin:actions """نقد المناهج المتأثرة بغير القرآن."""@ar ;
    hesin:hasSynonym """الثقافة الوافدة"""@ar ;
    hesin:hasSynonym """التأثر بالفلاسفة"""@ar ;
    hesin:hasComponent """منطق الفلاسفة"""@ar ;
    hesin:hasComponent """أساليب جدلية"""@ar ;
    hesin:hasComponent """ابتعاد عن القرآن"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_17 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C117 a hesin:Concept ;
    rdfs:label """تهميش القرآن في المعرفة"""@ar ;
    hesin:definition """عدم جعل القرآن المصدر الأساسي في المعرفة والمنهج، والاعتماد على مصادر أخرى (كالتقاليد الكلامية أو الثقافات الوافدة)."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """سبب ذلك كله هو أنه لم يحصل اعتماد ـ بالشكل المطلوب ـ على القرآن الكريم، وأنه لم يحصل اعتماد بالشكل المطلوب على القرآن الكريم، سببه تأثر بثقافة معينة وضعف في تحقق معنى (لا إله إلا الله)"""@ar ;
    hesin:actions """إعادة الاعتماد على القرآن كمصدر أول للمعرفة."""@ar ;
    hesin:hasSynonym """الابتعاد عن القرآن"""@ar ;
    hesin:hasSynonym """عدم الاعتماد على القرآن"""@ar ;
    hesin:hasComponent """الاعتماد على الكتب البشرية"""@ar ;
    hesin:hasComponent """عدم الرجوع إلى القرآن"""@ar ;
    hesin:hasComponent """تقديم التراث على القرآن"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_17 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C118 a hesin:Concept ;
    rdfs:label """الزهد المعطل"""@ar ;
    hesin:definition """فهم خاطئ لمفهوم الزهد الإسلامي، يقضي بالانصراف عن الدنيا وعدم استغلال ما سخره الله فيها، مما أدى إلى تخلف الأمة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """نظرنا إلى الدنيا هذه بكلها... بأنها لا تساوي جناح بعوضة، وأنها ليست بشيء، وعلى الإنسان أن ينصرف عنها، وإذا كان سيطلبها فليطلب فقط القوت الضروري منها والكفاية فقط منها وينطلق، يتركها الناس، يرفضها الناس، هذا هو التدين"""@ar ;
    hesin:actions """تصحيح مفهوم الزهد وفق القرآن."""@ar ;
    hesin:hasSynonym """ترك الدنيا"""@ar ;
    hesin:hasSynonym """الانصراف عن الحياة"""@ar ;
    hesin:hasComponent """ترك الإنتاج"""@ar ;
    hesin:hasComponent """عدم استغلال المسخرات"""@ar ;
    hesin:hasComponent """اعتبار الدنيا بلا قيمة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_18 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C119 a hesin:Concept ;
    rdfs:label """قيمة الدنيا في القرآن"""@ar ;
    hesin:definition """الدنيا لها قيمة باعتبارها ميدانًا للعبادة والتفكر والشكر، وهي نعمة عظيمة من الله تستحق الامتنان."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """إذا كانت الدنيا لا تساوي عند الله جناح بعوضة إذاً فلا قيمة لما يتمنن به علينا، إذا كان يعطي ما لا قيمة له عنده... الحكيم ينظر إلى الأشياء المهمة ذات قيمة فيما تعطيه"""@ar ;
    hesin:actions """الموازنة بين الدنيا والآخرة."""@ar ;
    hesin:hasSynonym """دنيا"""@ar ;
    hesin:hasSynonym """الحياة الدنيا"""@ar ;
    hesin:hasComponent """ميدان للعبادة"""@ar ;
    hesin:hasComponent """وسيلة لمعرفة الله"""@ar ;
    hesin:hasComponent """نعمة تستحق الشكر"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_18 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C120 a hesin:Concept ;
    rdfs:label """هداية الله المباشرة"""@ar ;
    hesin:definition """أن الله يتولى هداية عباده مباشرة عبر القرآن، وهي هداية واسعة تفتح أبواب المعرفة، ولا يمكن تحصيلها بالاعتماد على البشر فقط."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """عندما يهديك هو يهديك للمعرفة الصحيحة الواسعة يهديك إلى أبواب من الهدى تفتح أمامك أبواباً ,وأبواباً"""@ar ;
    hesin:actions """الدعاء بالهداية والعلم من الله."""@ar ;
    hesin:hasSynonym """علم لدني"""@ar ;
    hesin:hasSynonym """تعليم من الله"""@ar ;
    hesin:hasComponent """هداية إلى المعرفة الصحيحة"""@ar ;
    hesin:hasComponent """فتح أبواب الهدى"""@ar ;
    hesin:hasComponent """علم واسع"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_19 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C121 a hesin:Concept ;
    rdfs:label """الدعاء بالعلم (رب زدني علماً)"""@ar ;
    hesin:definition """التوجه إلى الله بالدعاء لزيادة العلم، بدلاً من الاعتماد فقط على المصادر البشرية."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَقُلْ رَبِّ زِدْنِي عِلْماً} (طـه: من الآية114) رب زدني علماً.. لم يقل له تعلم، انظر الآخرين ما لديهم وتعلم.. لا.. ربِّ أنت، أنت زدني علماً"""@ar ;
    hesin:actions """جعل الدعاء جزءًا من منهج طلب العلم."""@ar ;
