hesin:F5_C201 a hesin:Concept ;
    rdfs:label """الحياء من الله"""@ar ;
    hesin:definition """شعور داخلي ينشأ عن استشعار عظم نعمة الله، يدفع الإنسان إلى الامتناع عن استخدام هذه النعمة في معصيته، وهو أرفع من مجرد الخوف."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """تذكَّر دائماً بأن بصرك نعمة عظيمة من الله عليك، إذاً فاستحِ من الله، استحِ من الله أن تعصي ربك بالنعمة نفسها التي تفضل بها عليك"""@ar ;
    hesin:actions """استحضار النعم قبل القيام بأي فعل لاختبار مدى استحقاق الفعل لهذه النعمة."""@ar ;
    hesin:hasSynonym """الاستحياء من الله"""@ar ;
    hesin:hasSynonym """الخجل من نعمته"""@ar ;
    hesin:hasComponent """استشعار النعمة"""@ar ;
    hesin:hasComponent """الشعور بالامتنان"""@ar ;
    hesin:hasComponent """الامتناع عن المعصية حياءً لا خوفًا فقط"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_24 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C202 a hesin:Concept ;
    rdfs:label """الحياء من استخدام النعمة في المعصية"""@ar ;
    hesin:definition """أن يدرك الإنسان أن استخدام النعمة التي أنعم الله بها عليه في معصيته هو نوع من الكفران والجحود، بل هو إساءة أدب مع الله."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """استحِ من الله أن تصرف ريالاً واحداً في معصية من معاصيه، هذا كفر بنعمة الله، كفر بالله"""@ar ;
    hesin:actions """عند كل معصية محتملة، استحضار النعمة التي ستُستخدم في هذه المعصية."""@ar ;
    hesin:hasSynonym """استحياء النعمة"""@ar ;
    hesin:hasSynonym """عدم التفريط بالنعمة"""@ar ;
    hesin:hasComponent """إدراك أن النعمة أمانة"""@ar ;
    hesin:hasComponent """الشعور بأن المعصية خيانة للأمانة"""@ar ;
    hesin:hasComponent """الامتناع عن المعصية حياءً"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_24 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C203 a hesin:Concept ;
    rdfs:label """استشعار قيمة النعم"""@ar ;
    hesin:definition """إدراك أن ما يمتلكه الإنسان من قدرات وأموال وصحة ليس أمورًا طبيعية أو بديهية، بل هي نعم تستحق التقدير والشكر."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """متى ما تذكرت أن كل ما أرى، كلما أستمتع به في مختلف شؤون حياتي هو نعمة من الله سبحانه وتعالى، وأرى من خلال آياته الكريمة أنه يريد مني أن أقدرها، أن تكون ذات قيمة لدي"""@ar ;
    hesin:actions """مقارنة حالة الفرد بمن حُرم من هذه النعمة لتقدير قيمتها."""@ar ;
    hesin:hasSynonym """تقدير النعم"""@ar ;
    hesin:hasSynonym """معرفة قيمة ما بين اليدين"""@ar ;
    hesin:hasComponent """إدراك أن النعم ليست بديهية"""@ar ;
    hesin:hasComponent """الشعور بقيمتها الذاتية"""@ar ;
    hesin:hasComponent """الربط بين النعمة والمنعم"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_24 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C204 a hesin:Concept ;
    rdfs:label """النعم كآليات للطاعة والمعصية"""@ar ;
    hesin:definition """أن النعم التي أنعم الله بها على الإنسان (كالبصر، السمع، المال، اللسان) هي الأدوات نفسها التي يمكن استخدامها في طاعة الله أو معصيته."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """نعمه تعالى هي نفسها الآليات التي بها تطيع، والتي بها ـ أيضاً ـ تعصي"""@ar ;
    hesin:actions """عند استخدام أي نعمة، استحضار أنها أمانة يمكن أن تستخدم في الخير أو الشر."""@ar ;
    hesin:hasSynonym """ازدواجية استخدام النعم"""@ar ;
    hesin:hasComponent """النعم وسائل"""@ar ;
    hesin:hasComponent """يمكن توظيفها في الخير أو الشر"""@ar ;
    hesin:hasComponent """استخدامها في الشر هو كفران"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_24 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C205 a hesin:Concept ;
    rdfs:label """تذكير الله بنعمه (المشروع)"""@ar ;
    hesin:definition """أسلوب قرآني يقوم على تذكير الإنسان بنعم الله عليه، ليشدّه إلى الله محبة وإجلالاً، وليخلق في نفسه الحياء والشكر."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """الله يتمنن علينا بنعمه، ويعددها علينا، ويذكِّرنا بها، ويطلب منا أن نتذكر ما أنعم علينا به"""@ar ;
    hesin:actions """استخدام تذكير النعم في الخطاب الدعوي، مع عدم الخلط بينه وبين المنّ."""@ar ;
    hesin:hasSynonym """استعطاف الله"""@ar ;
    hesin:hasSynonym """تمنن الله"""@ar ;
    hesin:hasComponent """تعداد النعم"""@ar ;
    hesin:hasComponent """طلب التذكر"""@ar ;
    hesin:hasComponent """الهدف: الشد إلى الله"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_25 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C206 a hesin:Concept ;
    rdfs:label """المنّ بين الناس (الممنوع)"""@ar ;
    hesin:definition """أن يذكر الإنسان غيره بما أسدى إليه من معروف، بقصد التأثير على مشاعره واستغلال عواطفه، وهو منهي عنه شرعًا."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """الإنسان الذي يعطي إنساناً آخر لا يجوز له أن يمنَّ عليه بما أعطى فيظل دائماً يذكره بأنني فعلت لك كذا، وأنا أعطيتك كذا"""@ar ;
    hesin:actions """منع استخدام المنّ في العلاقات الإنسانية، وتعزيز ثقافة العطاء بلا مقابل."""@ar ;
    hesin:hasSynonym """التذكير بالمعروف"""@ar ;
    hesin:hasSynonym """الامتنان"""@ar ;
    hesin:hasComponent """تذكير الآخر بالمعروف"""@ar ;
    hesin:hasComponent """قصد التأثير العاطفي"""@ar ;
    hesin:hasComponent """استغلال الموقف"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_25 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C207 a hesin:Concept ;
    rdfs:label """الفارق الجوهري بين تذكير الله والمنّ"""@ar ;
    hesin:definition """الفرق الأساسي أن تذكير الله ينشئ ارتباطًا بالكمال المطلق (تكريم)، بينما المنّ ينشئ ارتباطًا بشريًا قائمًا على الاستغلال (إذلال)."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """الفارق كبير جداًَ... أن يشدني الله سبحانه إليه من خلال تذكيري بما أنعم علي من النعم العظيمة هو شدي إلى الكامل المطلق إلى الكمال، إلى من يعتبر ارتباطي به وقربي منه تكريماً لي. لكن لاحظ كيف يكون بالعكس فيما يتعلق بالناس فيما بينهم"""@ar ;
    hesin:actions """التمييز في الخطاب بين أسلوب تذكير النعم (المشروع) وأسلوب المنّ (الممنوع)."""@ar ;
    hesin:hasSynonym """الفرق بين العلاقة مع الله والعلاقة مع الناس"""@ar ;
    hesin:hasComponent """تذكير الله: شد إلى الكمال (تكريم)"""@ar ;
    hesin:hasComponent """المنّ: شد إلى البشر (استغلال)"""@ar ;
    hesin:hasComponent """تذكير الله: لا يبطل الأجر"""@ar ;
    hesin:hasComponent """المنّ: يبطل الأجر"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_25 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C208 a hesin:Concept ;
    rdfs:label """المال كسلاح ذو حدين"""@ar ;
    hesin:definition """أن المال يمكن استخدامه في دعم الحق (باعتباره وسيلة للإنفاق في سبيل الله) أو في دعم الباطل (باعتباره وسيلة للتأثير على الناس واستغلال عواطفهم)."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """المال هو سلاح ذو حدين، له أثر كبير في الجانب الإيجابي، ولها أثر كبير في الجانب السلبي"""@ar ;
    hesin:actions """تحليل استخدام المال في المجتمع: هل هو في خدمة الحق أم الباطل؟"""@ar ;
    hesin:hasSynonym """ازدواجية المال"""@ar ;
    hesin:hasSynonym """المال وسيلة للحق والباطل"""@ar ;
    hesin:hasComponent """يستخدمه الحق في دعم قيمه"""@ar ;
    hesin:hasComponent """يستخدمه الباطل في إفساد الناس"""@ar ;
    hesin:hasComponent """له تأثير عاطفي قوي"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_25 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C209 a hesin:Concept ;
    rdfs:label """نعمة البصر"""@ar ;
    hesin:definition """نعمة الإبصار التي تمكن الإنسان من مشاهدة آيات الله والتقلب في الحياة، وهي من أعظم النعم التي تستوجب الحياء من استخدامها في الحرام."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """البصر مهم جداً جداً، إذا فقد الإنسان بصره عاش مسجوناً في هذه الدنيا كأنه سجين، تذكَّر دائماً بأن بصرك نعمة عظيمة من الله عليك"""@ar ;
    hesin:actions """استحضار نعمة البصر قبل النظر إلى أي شيء."""@ar ;
    hesin:hasSynonym """العين"""@ar ;
    hesin:hasSynonym """الإبصار"""@ar ;
    hesin:hasComponent """وسيلة لمشاهدة آيات الله"""@ar ;
    hesin:hasComponent """وسيلة للتنقل والعمل"""@ar ;
    hesin:hasComponent """فقدانها سجن"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_26 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C210 a hesin:Concept ;
    rdfs:label """نعمة اللسان والنطق"""@ar ;
    hesin:definition """نعمة التعبير والبيان التي تميز الإنسان، وتستوجب الحياء من استخدامها في الكذب والغيبة والنميمة وشهادة الزور."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لسانك الذي وهبك الله وأنت تستطيع أن تعبر عن ما في نفسك تتكلم وتنطق... هذه النعمة العظيمة استحِ من الله سبحانه وتعالى أن تستخدمها في القول بالباطل"""@ar ;
    hesin:actions """استحضار نعمة اللسان قبل النطق بأي كلمة."""@ar ;
    hesin:hasSynonym """البيان"""@ar ;
    hesin:hasSynonym """القدرة على الكلام"""@ar ;
    hesin:hasComponent """القدرة على التعبير"""@ar ;
    hesin:hasComponent """القدرة على البيان"""@ar ;
    hesin:hasComponent """وسيلة للتواصل"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_26 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C211 a hesin:Concept ;
    rdfs:label """نعمة المال"""@ar ;
    hesin:definition """نعمة المال التي تمكن الإنسان من تلبية حاجاته، وتستوجب الحياء من إنفاقه في الحرام أو البخل في إنفاقه في سبيل الله."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """استحِ من الله أن تصرف ريالاً واحداً في معصية من معاصيه، هذا كفر بنعمة الله، كفر بالله"""@ar ;
    hesin:actions """استحضار أن المال من الله قبل إنفاقه."""@ar ;
    hesin:hasSynonym """الرزق"""@ar ;
    hesin:hasSynonym """الثروة"""@ar ;
    hesin:hasComponent """وسيلة لتلبية الحاجات"""@ar ;
    hesin:hasComponent """وسيلة لدعم الحق"""@ar ;
    hesin:hasComponent """أمانة يجب حفظها"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_26 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C212 a hesin:Concept ;
    rdfs:label """اليمين الغموس"""@ar ;
    hesin:definition """الحلف بالله كذبًا بقصد إضفاء الشرعية على الباطل، وهي من أعظم المعاصي التي تستخدم فيها نعمة النطق في معصية الله."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أنت عندما تحلف يميناً فاجرة تلك اليمين البالغة الخطورة التي هي من أوقح ما يصدر من الإنسان مع ربه، لأنك تقسم بالله أن القضية الفلانية كذا وكذا، وأنت تعلم أنك كاذب"""@ar ;
    hesin:actions """استحضار عظمة اسم الله قبل الحلف."""@ar ;
    hesin:hasSynonym """اليمين الفاجرة"""@ar ;
    hesin:hasSynonym """الحلف الكاذب"""@ar ;
    hesin:hasComponent """الحلف بالله"""@ar ;
    hesin:hasComponent """العلم بالكذب"""@ar ;
    hesin:hasComponent """إضفاء الشرعية على الباطل"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_26 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C213 a hesin:Concept ;
    rdfs:label """شهادة الزور"""@ar ;
    hesin:definition """الإدلاء بشهادة كاذبة باستخدام اسم الله، وهي من كبائر الذنوب التي تستخدم فيها نعمة النطق في إضفاء الشرعية على الباطل."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أن تأتي لتشهد شهادة زور، شهادة الزور هي نفس الشيء تشبه اليمين الفاجرة؛ لأنك تقول: أشهد لله أن هذه القضية كذا وكذا"""@ar ;
    hesin:actions """استحضار مسؤولية الشهادة أمام الله."""@ar ;
    hesin:hasSynonym """الشهادة الكاذبة"""@ar ;
    hesin:hasComponent """الإدلاء بالشهادة"""@ar ;
    hesin:hasComponent """العلم بالكذب"""@ar ;
    hesin:hasComponent """استخدام اسم الله"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_26 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C214 a hesin:Concept ;
    rdfs:label """قياس الغائب على الشاهد"""@ar ;
    hesin:definition """منهج معرفي يقوم على قياس علاقة الإنسان بالله على علاقات البشر بعضهم ببعض، وهو منهج باطل عند المؤلِّف."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أول خطوة خطاها [المعتزلة] في مجال معرفة الله: أنهم اعتمدوا على قاعدة باطلة من أساسها، هو أنهم نظروا أولاً فيما يحصل بيننا نحن الناس، أن هذا عندما يعطي هذا يجب عليه أن يشكره، إذاً فهناك نعم ننطلق منها لنشكر الذي أسداها. ألم يسوغوا للمسألة؟"""@ar ;
    hesin:actions """نقد أي محاولة لقياس أفعال الله على أفعال البشر."""@ar ;
    hesin:hasSynonym """القياس المنطقي في أصول المعرفة"""@ar ;
    hesin:hasSynonym """القياس العقلي"""@ar ;
    hesin:hasComponent """الاعتماد على التجربة الإنسانية"""@ar ;
    hesin:hasComponent """تعميم أحكام العلاقات البشرية على الله"""@ar ;
    hesin:hasComponent """إنتاج أحكام عقلية مجردة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_27 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C215 a hesin:Concept ;
    rdfs:label """خلط الجانب العاطفي بين الله والناس"""@ar ;
    hesin:definition """الخطأ الذي وقع فيه المعتزلة حين ساووا بين الجانب العاطفي في العلاقة مع الله والعلاقة مع الناس، دون مراعاة الفروق الجوهرية."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """ما الخلل في هذه؟ هو ترسيخ حالة التسوية, مع أن القرآن بيَّن أن المسالة ليست سوياً، ليس هناك مجال للمقايسة إلا في ما يتعلق بالجانب العاطفي"""@ar ;
    hesin:actions """التمييز بين الجانب العاطفي المشترك والاختلافات الجوهرية."""@ar ;
    hesin:hasSynonym """التسوية الخاطئة"""@ar ;
    hesin:hasSynonym """تعميم الحكم العاطفي"""@ar ;
    hesin:hasComponent """الاعتراف بوجود جانب عاطفي مشترك"""@ar ;
    hesin:hasComponent """إغفال الفروق الجوهرية"""@ar ;
    hesin:hasComponent """تعميم الحكم"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_27 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C216 a hesin:Concept ;
    rdfs:label """نقد وجوب النظر عند المعتزلة"""@ar ;
    hesin:definition """نقد منهج المعتزلة الذي جعل النظر العقلي في العلاقات البشرية أساسًا لمعرفة الله، بدلاً من جعل القرآن المصدر الأول."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أول خطوة خطاها [المعتزلة] في مجال معرفة الله: أنهم اعتمدوا على قاعدة باطلة من أساسها، هو أنهم نظروا أولاً فيما يحصل بيننا نحن الناس"""@ar ;
    hesin:actions """جعل القرآن المصدر الأول للمعرفة، والعقل أداة ثانوية."""@ar ;
    hesin:hasSynonym """نقد النظر العقلي كأصل في المعرفة"""@ar ;
    hesin:hasComponent """جعل العلاقات البشرية أصلًا"""@ar ;
    hesin:hasComponent """إنتاج أحكام عقلية"""@ar ;
    hesin:hasComponent """إغفال النصوص القرآنية"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_27 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C217 a hesin:Concept ;
    rdfs:label """تحرير العواطف من التأثيرات المادية"""@ar ;
    hesin:definition """تربية الإنسان على ألا تتأثر عواطفه ومواقفه بالإحسانات المادية، بل تكون مقاييسه إلهية (الحق والعدل)."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """يجب على الإنسان أن ينظر إلى الأشياء معتمداً على مقاييس إلهية وليس من خلال الماديات"""@ar ;
    hesin:actions """تدريب النفس على اتخاذ المواقف بناءً على الحق لا على المصالح المادية."""@ar ;
    hesin:hasSynonym """عدم الخضوع للمادة"""@ar ;
    hesin:hasSynonym """استقلالية العاطفة الإيمانية"""@ar ;
    hesin:hasComponent """عدم الخضوع للمال"""@ar ;
    hesin:hasComponent """عدم التأثر بالمنّ"""@ar ;
    hesin:hasComponent """استقلالية الموقف"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_28 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C218 a hesin:Concept ;
    rdfs:label """المقاييس الإلهية"""@ar ;
    hesin:definition """المقاييس المستمدة من الدين (الحق، العدل، التقوى) التي تحكم علاقات الإنسان ومواقفه، بدلاً من المقاييس المادية (المال، المنصب، النسب)."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """كما قال الإمام الخميني رحمة الله عليه: معايير إلهية, هو قال: ( يجب علينا أن تكون معاييرنا إلهية) أي المقاييس التي من خلالها نتعامل مع الآخرين, أو نقف مع الآخرين إلهية وليست مادية"""@ar ;
    hesin:actions """تقييم المواقف والأشخاص بناءً على معايير إلهية."""@ar ;
    hesin:hasSynonym """المعايير الإلهية"""@ar ;
    hesin:hasSynonym """الميزان الحق"""@ar ;
    hesin:hasComponent """الحق أساس المواقف"""@ar ;
    hesin:hasComponent """العدل أساس التعامل"""@ar ;
    hesin:hasComponent """التقوى أساس التقييم"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_28 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C219 a hesin:Concept ;
    rdfs:label """استغلال العواطف بالمال"""@ar ;
    hesin:definition """استخدام المال والإحسانات للتأثير على عواطف الناس واستمالتهم لدعم الباطل."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أهل الباطل أليسوا يسيرون الباطل بأعمال من هذا النوع؟ إحسان وبذل مال وتسهيلات معينة، وبذل معروف؟"""@ar ;
    hesin:actions """التحذير من استغلال المال في التأثير على الناس."""@ar ;
    hesin:hasSynonym """شراء الولاء"""@ar ;
    hesin:hasSynonym """التأثير المادي"""@ar ;
    hesin:hasComponent """بذل المال"""@ar ;
    hesin:hasComponent """إسداء المعروف"""@ar ;
    hesin:hasComponent """التأثير على العواطف"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_28 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C220 a hesin:Concept ;
    rdfs:label """الدعاء بعدم الحاجة إلى شرار الخلق"""@ar ;
    hesin:definition """دعاء نبوي يعلم المسلم أن يطلب من الله ألا يحتاج إلى الفاسقين والكافرين، حتى لا تؤثر إحساناتهم على عواطفه ومواقفه الدينية."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """قال: ((اللهم لا تحوجني إلى شرار خلقك)) أن أحتاج إلى شرار خلق الله فيعطيني هو أو أقبل عطيته فيؤثر على عواطفي فيشكل ضغطاً علي في مواقفي الدينية"""@ar ;
    hesin:actions """تعليم هذا الدعاء كمنهج وقائي."""@ar ;
    hesin:hasSynonym """التحرر من الحاجة إلى الفاسقين"""@ar ;
    hesin:hasComponent """طلب الاستغناء عن شرار الخلق"""@ar ;
    hesin:hasComponent """تجنب التأثير العاطفي"""@ar ;
    hesin:hasComponent """الحفاظ على استقلالية الموقف الديني"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_28 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C221 a hesin:Concept ;
    rdfs:label """دعاء عدم جعل للفاسق نعمة"""@ar ;
    hesin:definition """دعاء يعلم المسلم أن يطلب من الله ألا تكون للفاسق أو الكافر نعمة عليه، لأن الإحسان يخلق مودة قد تؤثر على موقفه الديني."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """في دعاء الإمام زين العابدين: (( اللهم ولا تجعل لفاسق ولا لكافر علي نعمة ترزقه من قلبي بها مودة ))"""@ar ;
    hesin:actions """تعليم هذا الدعاء كمنهج وقائي."""@ar ;
    hesin:hasSynonym """التحرر من نعم الفاسقين"""@ar ;
    hesin:hasComponent """طلب عدم وجود نعمة للفاسق"""@ar ;
    hesin:hasComponent """تجنب المودة الناتجة عن الإحسان"""@ar ;
    hesin:hasComponent """الحفاظ على الولاء لله"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_28 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C222 a hesin:Concept ;
    rdfs:label """فرعون كنموذج لاستغلال المال"""@ar ;
    hesin:definition """نموذج تاريخي لطاغوت استخدم المال والنعم المادية لاستخفاف قومه وإبعادهم عن نبي الله موسى، مع أنهم عاينوا الآيات البينات."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """فرعون الذي ذكر الله سبحانه وتعالى قصته في القرآن من أول من استخدم هذا الأسلوب: {أَلَيْسَ لِي مُلْكُ مِصْرَ وَهَذِهِ الْأَنْهَارُ تَجْرِي مِنْ تَحْتِي}"""@ar ;
    hesin:actions """دراسة قصة فرعون للتحذير من استغلال المال في السياسة."""@ar ;
    hesin:hasSynonym """نموذج الطاغوت المستخدم للمال"""@ar ;
    hesin:hasComponent """استخدام المال والنعم للتأثير"""@ar ;
    hesin:hasComponent """استخفاف القوم"""@ar ;
    hesin:hasComponent """إطاعة القوم رغم الآيات"""@ar ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C223 a hesin:Concept ;
    rdfs:label """الكفران (كفر النعمة)"""@ar ;
    hesin:definition """استخدام نعم الله في معصيته، أو نسيان مصدر النعمة، وهو نوع من الكفر العملي دون الكفر الاعتقادي."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """استحِ من الله أن تصرف ريالاً واحداً في معصية من معاصيه، هذا كفر بنعمة الله, كفر بالله"""@ar ;
    hesin:actions """ربط المعصية بالكفران لتعظيم وزرها."""@ar ;
    hesin:hasSynonym """جحود النعمة"""@ar ;
    hesin:hasSynonym """عدم الشكر"""@ar ;
    hesin:hasComponent """استخدام النعمة في المعصية"""@ar ;
    hesin:hasComponent """نسيان المنعم"""@ar ;
    hesin:hasComponent """عدم الشكر"""@ar ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C224 a hesin:Concept ;
    rdfs:label """الغلو في الزهد كعامل تخلف"""@ar ;
    hesin:definition """الفهم المغالي في الزهد الذي يجعل الدنيا بلا قيمة، مما يدفع المسلمين إلى ترك التفكر والإبداع فيها، وهو من أسباب تخلفهم."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """هذا نفسه من إحدى العوامل التي ضربت المسلمين فجعلتهم بعيدين عن أن يستخدموا ما سخر الله لهم في السموات وفي الأرض، وأن يتفكروا فيها؛ لأنها أصبحت ليست ذات قيمة لديهم"""@ar ;
    hesin:actions """تصحيح مفهوم الزهد وفق القرآن."""@ar ;
    hesin:hasSynonym """المبالغة في ترك الدنيا"""@ar ;
    hesin:hasComponent """اعتبار الدنيا بلا قيمة"""@ar ;
    hesin:hasComponent """ترك التفكر في المسخرات"""@ar ;
    hesin:hasComponent """التخلف الحضاري"""@ar ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C225 a hesin:Concept ;
    rdfs:label """الانشداد إلى الكمال المطلق"""@ar ;
    hesin:definition """العلاقة التي ينشئها تذكير الله بنعمه، وهي علاقة شد إلى الكمال المطلق (الله)، مما يحقق للإنسان تكريمًا وسموًا."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """أن يشدني الله سبحانه إليه من خلال تذكيري بما أنعم علي من النعم العظيمة هو شدي إلى الكامل المطلق إلى الكمال"""@ar ;
    hesin:actions """تعزيز الشعور بأن الارتباط بالله تكريم."""@ar ;
    hesin:hasSynonym """الشد إلى الله"""@ar ;
    hesin:hasSynonym """الارتباط بالكمال"""@ar ;
    hesin:hasComponent """التوجه إلى الله"""@ar ;
    hesin:hasComponent """الشعور بالتكريم"""@ar ;
    hesin:hasComponent """الارتقاء الروحي"""@ar ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C226 a hesin:Concept ;
    rdfs:label """الانشداد إلى البشر (التبعية المادية)"""@ar ;
    hesin:definition """العلاقة التي ينشئها المنّ والإحسان البشري، وهي علاقة تبعية تخلق شعورًا بالضعة والثقل."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """لاحظ كيف يكون بالعكس فيما يتعلق بالناس فيما بينهم، كيف يشعر الإنسان بالضعة، يشعر بثقل، بوطأة معروف معين أسدي إليه على نفسه"""@ar ;
    hesin:actions """تجنب خلق علاقات تبعية عبر المنّ."""@ar ;
    hesin:hasSynonym """الخضوع للناس بسبب النعم"""@ar ;
    hesin:hasComponent """الشعور بالضعة"""@ar ;
    hesin:hasComponent """التبعية للمحسن"""@ar ;
    hesin:hasComponent """فقدان الاستقلالية"""@ar ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C301 a hesin:Concept ;
    rdfs:label """نعمة الهداية (أعظم النعم)"""@ar ;
    hesin:definition """أعظم نعمة أنعم الله بها على عباده، وهي الهداية إلى الإيمان ودين الإسلام، التي تفوق النعم المادية في الأهمية والأثر."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """نعمة الهداية التي هي أعظم النعم، الهداية إلى الإيمان، هذا الدين العظيم دين الإسلام"""@ar ;
    hesin:actions """ترسيخ الشعور بأن الإيمان نعمة تستحق الشكر الدائم."""@ar ;
    hesin:hasSynonym """الإيمان"""@ar ;
    hesin:hasSynonym """الإسلام"""@ar ;
    hesin:hasSynonym """الهدى"""@ar ;
    hesin:hasComponent """الإيمان بالله"""@ar ;
    hesin:hasComponent """الإيمان بالرسول"""@ar ;
    hesin:hasComponent """الإيمان بالقرآن"""@ar ;
    hesin:hasComponent """الهداية إلى الصراط المستقيم"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_29 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C302 a hesin:Concept ;
    rdfs:label """القرآن الكريم كأحسن الحديث"""@ar ;
    hesin:definition """القرآن هو أروع وأعظم كلام، متشابه في إحكامه وحكمته، مثاني في تكرار مواعظه، له تأثير عظيم على قلوب الخاشعين."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """سمى كتابه الكريم بأنه أحسن الحديث، متشابهاً في حكمته، في فوائده، في عظمة آياته"""@ar ;
    hesin:actions """استحضار عظمة القرآن عند تلاوته."""@ar ;
    hesin:hasSynonym """أحسن الحديث"""@ar ;
    hesin:hasSynonym """الكتاب المتشابه مثاني"""@ar ;
    hesin:hasComponent """أحسن الحديث"""@ar ;
    hesin:hasComponent """متشابه في الإحكام"""@ar ;
    hesin:hasComponent """مثاني (متكرر المواعظ)"""@ar ;
    hesin:hasComponent """يورث الخشية"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_29 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C303 a hesin:Concept ;
    rdfs:label """نعمة الرسالة المحمدية"""@ar ;
    hesin:definition """نعمة إرسال النبي محمد (صلى الله عليه وآله) ليتلو الآيات، ويزكي النفوس، ويعلم الكتاب والحكمة، وهو من أعظم مظاهر منة الله على المؤمنين."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لَقَدْ مَنَّ اللَّهُ عَلَى الْمُؤْمِنِينَ إِذْ بَعَثَ فِيهِمْ رَسُولاً مِنْ أَنْفُسِهِمْ يَتْلُو عَلَيْهِمْ آيَاتِهِ وَيُزَكِّيهِمْ وَيُعَلِّمُهُمُ الْكِتَابَ وَالْحِكْمَةَ"""@ar ;
    hesin:actions """شكر الله على نعمة الرسول بطاعته."""@ar ;
    hesin:hasSynonym """بعثة الرسول"""@ar ;
    hesin:hasSynonym """نعمة النبي"""@ar ;
    hesin:hasComponent """تلاوة الآيات"""@ar ;
    hesin:hasComponent """تزكية النفوس"""@ar ;
    hesin:hasComponent """تعليم الكتاب والحكمة"""@ar ;
    hesin:hasComponent """إخراج من الظلمات إلى النور"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_29 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C304 a hesin:Concept ;
    rdfs:label """امتنان الله بالهداية"""@ar ;
    hesin:definition """أن الله هو صاحب المنة الحقيقية على المؤمنين بأن هداهم للإيمان، وليس للإنسان فضل على الله بإيمانه."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """بَلِ اللَّهُ يَمُنُّ عَلَيْكُمْ أَنْ هَدَاكُمْ لِلْإِيمَانِ"""@ar ;
    hesin:actions """تذكير النفس بأن الإيمان نعمة من الله لا فضل ذاتي."""@ar ;
    hesin:hasSynonym """منة الله"""@ar ;
    hesin:hasSynonym """فضل الله"""@ar ;
    hesin:hasComponent """الله هو المنعم"""@ar ;
    hesin:hasComponent """الهداية فضل منه"""@ar ;
    hesin:hasComponent """لا منة للعبد على الله"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_29 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C305 a hesin:Concept ;
    rdfs:label """تذكر النعم كأمر إلهي"""@ar ;
    hesin:definition """أمر إلهي متكرر في القرآن بتذكر نعم الله، لما له من أهمية بالغة في بناء العلاقة مع الله وفي حياة الإنسان."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """القرآن الكريم متى ما كرر شيئاً، متى ما أكد على شيء فإنه فعلاً ليس كلام لمجرد الكلام... وإنما يكرر الشيء لأهميته"""@ar ;
    hesin:actions """إدراج تذكر النعم كروتين يومي."""@ar ;
    hesin:hasSynonym """ذكر النعم"""@ar ;
    hesin:hasSynonym """استحضار النعم"""@ar ;
    hesin:hasComponent """تذكر النعم المادية"""@ar ;
    hesin:hasComponent """تذكر النعم المعنوية"""@ar ;
    hesin:hasComponent """الاستفادة من التذكر في السلوك"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_30 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C306 a hesin:Concept ;
    rdfs:label """تذكر النعم على وسائل النقل"""@ar ;
    hesin:definition """أن يذكر الإنسان نعمة الله عليه عند ركوب وسائل النقل (الحيوانات، السيارات، السفن)، ويعترف بأن الله سخرها له."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لِتَسْتَوُوا عَلَى ظُهُورِهِ ثُمَّ تَذْكُرُوا نِعْمَةَ رَبِّكُمْ إِذَا اسْتَوَيْتُمْ عَلَيْهِ"""@ar ;
    hesin:actions """تعليم أذكار الركوب وتأمل معانيها."""@ar ;
    hesin:hasSynonym """ذكر النعم عند الركوب"""@ar ;
    hesin:hasComponent """ذكر الله عند الركوب"""@ar ;
    hesin:hasComponent """التسبيح: سبحان الذي سخر لنا هذا"""@ar ;
    hesin:hasComponent """الاعتراف بالعجز عن التسخير"""@ar ;
    hesin:hasComponent """التذكير بالرجوع إلى الله"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_30 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C307 a hesin:Concept ;
    rdfs:label """تذكر النعم في حالات الخطر والدفع"""@ar ;
    hesin:definition """تذكر نعم الله في دفع كيد الأعداء وحماية المؤمنين، والاعتراف بأن السلامة من المكائد هي نعمة من الله."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """يَا أَيُّهَا الَّذِينَ آمَنُوا اذْكُرُوا نِعْمَتَ اللَّهِ عَلَيْكُمْ إِذْ هَمَّ قَوْمٌ أَنْ يَبْسُطُوا إِلَيْكُمْ أَيْدِيَهُمْ فَكَفَّ أَيْدِيَهُمْ عَنْكُمْ"""@ar ;
    hesin:actions """استحضار نعم النجاة من المكائد."""@ar ;
    hesin:hasSynonym """ذكر نعم الدفع"""@ar ;
    hesin:hasSynonym """نعم الحماية"""@ar ;
    hesin:hasComponent """تذكر نعم الدفع"""@ar ;
    hesin:hasComponent """الاعتراف بتدخل الله"""@ar ;
    hesin:hasComponent """التوكل على الله"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_30 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C308 a hesin:Concept ;
    rdfs:label """نعمة التأليف بين القلوب"""@ar ;
    hesin:definition """نعمة عظيمة من الله تتمثل في تحويل القلوب من العداوة إلى الألفة والمحبة، وجعل المؤمنين إخوانًا."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """وَاذْكُرُوا نِعْمَتَ اللَّهِ عَلَيْكُمْ إِذْ كُنْتُمْ أَعْدَاءً فَأَلَّفَ بَيْنَ قُلُوبِكُمْ فَأَصْبَحْتُمْ بِنِعْمَتِهِ إِخْوَاناً"""@ar ;
    hesin:actions """تذكر نعمة الألفة كحافز للحفاظ عليها."""@ar ;
    hesin:hasSynonym """الألفة"""@ar ;
    hesin:hasSynonym """الوحدة"""@ar ;
    hesin:hasSynonym """الإخاء"""@ar ;
    hesin:hasComponent """تحويل العداوة إلى محبة"""@ar ;
    hesin:hasComponent """تأليف القلوب"""@ar ;
    hesin:hasComponent """الإخاء الإيماني"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_31 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C309 a hesin:Concept ;
    rdfs:label """الألفة كحالة سعادة"""@ar ;
    hesin:definition """حالة من الانسجام والمحبة بين الناس تجعل الحياة ذات مذاق خاص، وتزيل المشاكل والتباينات."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """القلوب تتآلف فتحب أن تجتمع... تصبح الحياة سعيدة بين الناس، وهم في قراهم، في مساجدهم، في تجمعاتهم، في أسواقهم، في طرقاتهم"""@ar ;
    hesin:actions """تعزيز الشعور بالألفة كقيمة إيمانية."""@ar ;
    hesin:hasSynonym """التآلف"""@ar ;
    hesin:hasSynonym """الانسجام"""@ar ;
    hesin:hasComponent """الراحة عند لقاء الإخوان"""@ar ;
    hesin:hasComponent """اختفاء المشاكل"""@ar ;
    hesin:hasComponent """الحياة ذات طعم خاص"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_31 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C310 a hesin:Concept ;
    rdfs:label """الأخلاق في خدمة الوحدة"""@ar ;
    hesin:definition """أن الأخلاق الكريمة (كالعفو، كظم الغيظ، الإخاء) ليست طاعات مفردة، بل هي في خدمة غاية أكبر: وحدة المؤمنين وتمكينهم لنصرة دين الله."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """يجب أن نفهم أيضاً أن من أبرز غاياتها هي أنها تخدم عملية وحدة المؤمنين فيما بينهم، تلك القضية التي لا بد منها في تحقيق المسئولية الكبيرة عليهم لدين الله"""@ar ;
    hesin:actions """ربط تعليم الأخلاق بغايتها الكبرى (نصرة الدين)."""@ar ;
    hesin:hasSynonym """حسن الخلق"""@ar ;
    hesin:hasSynonym """الأخوة الإيمانية"""@ar ;
    hesin:hasComponent """الأخلاق كوسيلة"""@ar ;
    hesin:hasComponent """الوحدة كغاية"""@ar ;
    hesin:hasComponent """نصر الدين كمسؤولية"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_31 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C311 a hesin:Concept ;
    rdfs:label """التأليف الإلهي مقابل العجز البشري"""@ar ;
    hesin:definition """أن التأليف بين القلوب أمر إلهي لا يستطيع الإنسان تحقيقه بجهوده المادية مهما بلغت، بل هو بتدخل إلهي خاص."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """وَأَلَّفَ بَيْنَ قُلُوبِهِمْ لَوْ أَنْفَقْتَ مَا فِي الْأَرْضِ جَمِيعاً مَا أَلَّفْتَ بَيْنَ قُلُوبِهِمْ وَلَكِنَّ اللَّهَ أَلَّفَ بَيْنَهُمْ"""@ar ;
    hesin:actions """الدعاء بتأليف القلوب، وعدم الاعتماد على المال وحده."""@ar ;
    hesin:hasSynonym """عجز الإنسان عن التأليف"""@ar ;
    hesin:hasComponent """عجز المال عن التأليف"""@ar ;
    hesin:hasComponent """التأليف بيد الله"""@ar ;
    hesin:hasComponent """شكر هذه النعمة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_31 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C312 a hesin:Concept ;
    rdfs:label """الشكر كهدف من أهداف التسخير"""@ar ;
    hesin:definition """أن من أهداف تسخير الكون للإنسان هو أن يشكر الله على هذه النعم، وأن يعترف بفضله."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """وَلِتَبْتَغُوا مِنْ فَضْلِهِ وَلَعَلَّكُمْ تَشْكُرُونَ"""@ar ;
    hesin:actions """ربط استغلال النعم بالشكر."""@ar ;
    hesin:hasSynonym """الشكر"""@ar ;
    hesin:hasSynonym """الامتنان"""@ar ;
    hesin:hasComponent """الشكر بالقلب (الاعتراف)"""@ar ;
    hesin:hasComponent """الشكر باللسان (الحمد)"""@ar ;
    hesin:hasComponent """الشكر بالجوارح (الطاعة)"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_32 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C313 a hesin:Concept ;
    rdfs:label """الشكر كصفة للأنبياء والأولياء"""@ar ;
    hesin:definition """أن الشكر صفة ملازمة للأنبياء والأولياء، وهو سبب لاجتباء الله وهدايته."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """إِنَّ إِبْرَاهِيمَ كَانَ أُمَّةً قَانِتاً لِلَّهِ حَنِيفاً وَلَمْ يَكُ مِنَ الْمُشْرِكِينَ شَاكِراً لَأَنْعُمِهِ"""@ar ;
    hesin:actions """الاقتداء بالأنبياء في شكر النعم."""@ar ;
    hesin:hasSynonym """الشاكرون"""@ar ;
    hesin:hasSynonym """العبد الشكور"""@ar ;
    hesin:hasComponent """إبراهيم شاكرًا"""@ar ;
    hesin:hasComponent """نوح عبدًا شكورًا"""@ar ;
    hesin:hasComponent """موسى شاكرًا بالنعمة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_32 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C314 a hesin:Concept ;
    rdfs:label """دعاء سليمان (أوزعني أن أشكر)"""@ar ;
    hesin:definition """دعاء نبوي يعلم المسلم أن يطلب من الله أن يلهمه شكر نعمه، وأن يعمل صالحًا، وأن يدخله في عداد الصالحين."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """رَبِّ أَوْزِعْنِي أَنْ أَشْكُرَ نِعْمَتَكَ الَّتِي أَنْعَمْتَ عَلَيَّ وَعَلَى وَالِدَيَّ وَأَنْ أَعْمَلَ صَالِحاً تَرْضَاهُ وَأَدْخِلْنِي بِرَحْمَتِكَ فِي عِبَادِكَ الصَّالِحِينَ"""@ar ;
    hesin:actions """تعليم هذا الدعاء وتأمل معانيه."""@ar ;
    hesin:hasSynonym """طلب التوفيق للشكر"""@ar ;
    hesin:hasComponent """طلب الإلهام للشكر"""@ar ;
    hesin:hasComponent """طلب العمل الصالح"""@ar ;
    hesin:hasComponent """طلب الدخول في عداد الصالحين"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_32 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C315 a hesin:Concept ;
    rdfs:label """دعاء موسى (رب بما أنعمت علي)"""@ar ;
    hesin:definition """دعاء موسى (عليه السلام) بعد توفيقه لقتل القبطي والنجاة، حيث قطع عهدًا على نفسه ألا يكون معينًا للمجرمين، شكرًا لنعمة الله."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """رَبِّ بِمَا أَنْعَمْتَ عَلَيَّ فَلَنْ أَكُونَ ظَهِيراً لِلْمُجْرِمِينَ"""@ar ;
    hesin:actions """ترجمة الشكر إلى التزامات عملية."""@ar ;
    hesin:hasSynonym """شكر النعمة بالعهد"""@ar ;
    hesin:hasComponent """استحضار النعمة"""@ar ;
    hesin:hasComponent """قطع العهد"""@ar ;
    hesin:hasComponent """عدم الظهور للمجرمين"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_32 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C316 a hesin:Concept ;
    rdfs:label """كفران النعم (تبديل النعمة)"""@ar ;
    hesin:definition """استبدال نعمة الهداية والاستقامة بضلال أو معصية، وهو من أعظم الذنوب، وعاقبته شديدة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """وَمَنْ يُبَدِّلْ نِعْمَةَ اللَّهِ مِنْ بَعْدِ مَا جَاءَتْهُ فَإِنَّ اللَّهَ شَدِيدُ الْعِقَابِ"""@ar ;
    hesin:actions """التحذير من تبديل النعم والاستبدال بها."""@ar ;
    hesin:hasSynonym """جحود النعمة"""@ar ;
    hesin:hasSynonym """استبدال النعمة"""@ar ;
    hesin:hasComponent """تبديل الهدى بالضلال"""@ar ;
    hesin:hasComponent """تبديل الطاعة بالمعصية"""@ar ;
    hesin:hasComponent """تبديل الشكر بالكفران"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_33 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C317 a hesin:Concept ;
    rdfs:label """القرية الآمنة المطمئنة"""@ar ;
    hesin:definition """نموذج قرآني لمجتمع أنعم الله عليه بنعم كثيرة (أمن، رغد، رزق) فكفر بها، فعوقب بالجوع والخوف."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """وَضَرَبَ اللَّهُ مَثَلاً قَرْيَةً كَانَتْ آمِنَةً مُطْمَئِنَّةً يَأْتِيهَا رِزْقُهَا رَغَداً مِنْ كُلِّ مَكَانٍ فَكَفَرَتْ بِأَنْعُمِ اللَّهِ فَأَذَاقَهَا اللَّهُ لِبَاسَ الْجُوعِ وَالْخَوْفِ"""@ar ;
    hesin:actions """استحضار هذا المثل للتحذير من كفران النعم الجماعي."""@ar ;
    hesin:hasSynonym """نموذج كفران النعم الجماعي"""@ar ;
    hesin:hasComponent """الأمن والاطمئنان"""@ar ;
    hesin:hasComponent """الرزق الرغد"""@ar ;
    hesin:hasComponent """كفران النعم"""@ar ;
    hesin:hasComponent """العقاب بالجوع والخوف"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_33 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C318 a hesin:Concept ;
    rdfs:label """الهجرة من الأرياف إلى المدن"""@ar ;
    hesin:definition """ظاهرة اجتماعية يستغلها الأعداء (اليهود) لتفريغ الأرياف من سكانها، ليهاجروا إلى المدن حيث يسهل إفسادهم وإبعادهم عن دينهم."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """اليهود يعرفون هذه القضية، فلهذا يعملون على أن تظل الأرياف في مختلف الشعوب الإسلامية أريافاً تفتقر إلى الكثير من خدمات الحياة... فيهاجرون إلى المدن، فيتجمعون هناك بأعداد كبيرة... فتؤدي بتلك المجاميع التي كانت تشكر الله... عندما كانت تحصل على رزقها مما بين أيديهم... إلى أن تنسى الله"""@ar ;
    hesin:actions """الاهتمام بالأرياف وتوفير الخدمات لمنع الهجرة القسرية."""@ar ;
    hesin:hasSynonym """التحضر"""@ar ;
    hesin:hasSynonym """التمدن"""@ar ;
    hesin:hasComponent """تهميش الأرياف"""@ar ;
    hesin:hasComponent """الهجرة إلى المدن"""@ar ;
    hesin:hasComponent """تفريغ الأرياف من المؤمنين"""@ar ;
    hesin:hasComponent """إفساد المهاجرين في المدن"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_33 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C319 a hesin:Concept ;
    rdfs:label """الدنيا نعمة لا لعنة"""@ar ;
    hesin:definition """تصحيح للمفهوم الخاطئ الذي يرى الدنيا لعنة أو خداعة بذاتها، مع التأكيد على أنها نعمة عظيمة من الله يجب استغلالها في طاعته."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لا يصح أن ننطلق نحذر الناس من الدنيا؛ لأنها خداعة مكارة! هي نعمة عظيمة"""@ar ;
    hesin:actions """تعليم الناس كيف يملكون الدنيا ولا تملكهم."""@ar ;
    hesin:hasSynonym """نعم الله في الدنيا"""@ar ;
    hesin:hasComponent """الدنيا نعمة"""@ar ;
    hesin:hasComponent """يجب استغلالها في الطاعة"""@ar ;
    hesin:hasComponent """التحذير من سوء الاستخدام لا من الذات"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_34 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C320 a hesin:Concept ;
    rdfs:label """ملك الدنيا بلا طغيان (نموذج سليمان)"""@ar ;
    hesin:definition """نموذج سليمان (عليه السلام) الذي ملك أعظم ملك في الدنيا، لكنه لم يطغَ، بل كان شاكرًا، يعلم أن الملك ابتلاء."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """سليمان الذي قال {هَذَا مِنْ فَضْلِ رَبِّي} وإشارة هذا إلى الملك العظيم الذي أوتيه {لِيَبْلُوَنِي أَأَشْكُرُ أَمْ أَكْفُرُ}"""@ar ;
    hesin:actions """الاقتداء بسليمان في الشكر وعدم الاغترار بالدنيا."""@ar ;
    hesin:hasSynonym """الاستغناء مع الخشوع"""@ar ;
    hesin:hasComponent """ملك عظيم"""@ar ;
    hesin:hasComponent """شكر واعتراف بالفضل"""@ar ;
    hesin:hasComponent """عدم الطغيان"""@ar ;
    hesin:hasComponent """الدعاء بالثبات"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_34 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C321 a hesin:Concept ;
    rdfs:label """طغيان الاستغناء"""@ar ;
    hesin:definition """ظاهرة بشرية حيث يطغى الإنسان ويسرف إذا شعر بالاستغناء والغنى، مما يجعله ينسى الله ومسؤوليته."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """كَلَّا إِنَّ الْأِنْسَانَ لَيَطْغَى أَنْ رَآهُ اسْتَغْنَى"""@ar ;
    hesin:actions """التحذير من طغيان المال."""@ar ;
    hesin:hasSynonym """الطغيان بالمال"""@ar ;
    hesin:hasSynonym """الكبر"""@ar ;
    hesin:hasComponent """الشعور بالاستغناء"""@ar ;
    hesin:hasComponent """الطغيان والتكبر"""@ar ;
    hesin:hasComponent """نسيان الله"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_34 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C322 a hesin:Concept ;
    rdfs:label """الهم الكبير لنصرة الدين"""@ar ;
    hesin:definition """أن تحقيق الألفة والوحدة والأخلاق يتطلب حمل همّ نصرة الدين والمسؤولية الكبيرة تجاهه، وليس مجرد وعظ أخلاقي."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """ما لم نحمل هذا الهم الكبير، ومتى ما شعرنا بالمسؤولية الكبيرة، فإن من المتوقع فعلاً أن يتدخل الله"""@ar ;
    hesin:actions """توجيه الجهود نحو همّ نصرة الدين."""@ar ;
    hesin:hasSynonym """المسؤولية الكبيرة"""@ar ;
    hesin:hasSynonym """حمل الهم"""@ar ;
    hesin:hasComponent """حمل هم الدين"""@ar ;
    hesin:hasComponent """الشعور بالمسؤولية"""@ar ;
    hesin:hasComponent """التدخل الإلهي عند الصدق"""@ar ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C323 a hesin:Concept ;
    rdfs:label """نعمة النجاة من آل فرعون"""@ar ;
    hesin:definition """نعمة الله على بني إسرائيل بإنقاذهم من عبودية فرعون وتعذيبه، وهي نموذج لتذكر النعم في مقارنة الماضي بالحاضر."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """اذْكُرُوا نِعْمَةَ اللَّهِ عَلَيْكُمْ إِذْ أَنْجَاكُمْ مِنْ آلِ فِرْعَوْنَ يَسُومُونَكُمْ سُوءَ الْعَذَابِ"""@ar ;
    hesin:actions """مقارنة الحاضر بالماضي السيئ لتعزيز الشكر."""@ar ;
    hesin:hasSynonym """نعمة الخلاص"""@ar ;
    hesin:hasSynonym """التحرر من الظلم"""@ar ;
    hesin:hasComponent """النجاة من العذاب"""@ar ;
    hesin:hasComponent """المقارنة بين الماضي والحاضر"""@ar ;
    hesin:hasComponent """الحفاظ على المنجزات"""@ar ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C324 a hesin:Concept ;
    rdfs:label """الحفاظ على الثورة والمنجزات"""@ar ;
    hesin:definition """أن تحقيق النصر أو الثورة ليس نهاية المطاف، بل الأهم هو الحفاظ على المنجزات وعدم تبديل النعم."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """الإمام الخميني كان يقول للإيرانيين بعد الثورة الإسلامية: إن الحفاظ على الثورة أهم من الثورة نفسها"""@ar ;
    hesin:actions """الاهتمام بالحفاظ على المنجزات."""@ar ;
    hesin:hasSynonym """رعاية المنجزات"""@ar ;
    hesin:hasSynonym """الاستمرارية"""@ar ;
    hesin:hasComponent """تحقيق النصر"""@ar ;
    hesin:hasComponent """الحفاظ على المنجزات"""@ar ;
    hesin:hasComponent """عدم تبديل النعم"""@ar ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C325 a hesin:Concept ;
    rdfs:label """اليهود وخبرتهم بالسنن"""@ar ;
    hesin:definition """أن اليهود يتمتعون بخبرة في التعامل مع السنن الإلهية والإنسانية، ويستغلونها لإضعاف الأمم وإفسادها."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هم اليهود الذين يمتلكون ـ كما قلنا أكثر من مرة ـ خبرة بالسنن الإلهية، وبالسنن الإنسانية"""@ar ;
    hesin:actions """كشف مخططات اليهود."""@ar ;
    hesin:hasSynonym """استغلال السنن الإلهية"""@ar ;
    hesin:hasComponent """معرفة السنن"""@ar ;
    hesin:hasComponent """استغلالها في الإفساد"""@ar ;
    hesin:hasComponent """إضعاف الأمم"""@ar ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C326 a hesin:Concept ;
    rdfs:label """الاعتدال في الدنيا (لا زهد ولا طغيان)"""@ar ;
    hesin:definition """منهج وسطي في التعامل مع الدنيا: لا زهد معطل يعطل الإنتاج، ولا انبهار مادي يؤدي إلى الطغيان، بل تحرك في الدنيا مع الاهتداء بهدي الله."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """انطلقوا فيها ابتغوا من فضل الله فيها ، تحركوا فيها، ولكن اهتدوا فيها وأنتم تتحركون فيها بهديي"""@ar ;
    hesin:actions """تعليم الاعتدال في التعامل مع الدنيا."""@ar ;
    hesin:hasSynonym """الوسطية"""@ar ;
    hesin:hasSynonym """الموازنة"""@ar ;
    hesin:hasComponent """الابتغاء من فضل الله"""@ar ;
    hesin:hasComponent """التحرك في الدنيا"""@ar ;
    hesin:hasComponent """الاهتداء بهدي الله"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_34 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C401 a hesin:Concept ;
    rdfs:label """أسلوب "أفرأيتم" في التذكير بالنعم"""@ar ;
    hesin:definition """أسلوب قرآني يعتمد على طرح أسئلة استفهامية على الإنسان ليجيب بنفسه، فيشهد على حقيقة أن الله هو المنعم الحقيقي، فيتذكر نعمه ويشكرها."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """ففي [سورة الواقعة] بأسلوب آخر يقول لأولئك الذين ينظرون هذه النظرة إلى ما بين أيديهم: {أَفَرَأَيْتُمْ مَا تَحْرُثُونَ} (الواقعة:63) هذه الأموال التي تحرثونها... {أَأَنْتُمْ تَزْرَعُونَهُ أَمْ نَحْنُ الزَّارِعُونَ}"""@ar ;
    hesin:actions """استخدام أسلوب الاستفهام في التذكير بالنعم بدلاً من التلقين المباشر."""@ar ;
    hesin:hasSynonym """الاستفهام القرآني"""@ar ;
    hesin:hasSynonym """التذكير بالاستفهام"""@ar ;
    hesin:hasComponent """طرح سؤال استفهامي"""@ar ;
    hesin:hasComponent """جعل الإنسان يشهد على نفسه"""@ar ;
    hesin:hasComponent """إقرار الإنسان بأن الله هو المنعم"""@ar ;
    hesin:hasComponent """دفع الإنسان إلى الشكر"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_35 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C402 a hesin:Concept ;
    rdfs:label """الإقرار بالمنعم (شهادة النفس)"""@ar ;
    hesin:definition """أن يشهد الإنسان على نفسه بأن الله هو المنعم الحقيقي بكل نعمة، بعد أن يستحضر الأسئلة القرآنية التي تدفعه إلى هذا الإقرار."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """فإذا كنت معترفاً بأن الله سبحانه وتعالى هو الذي زرع، هو الذي أنبت... فما هو الموقف الصحيح بالنسبة لي منه تعالى أمام ما أعطاني"""@ar ;
    hesin:actions """تدريب النفس على الإجابة الصادقة على أسئلة القرآن."""@ar ;
    hesin:hasSynonym """الاعتراف لله"""@ar ;
    hesin:hasSynonym """شهادة الإنسان على نفسه"""@ar ;
    hesin:hasComponent """استحضار الأسئلة"""@ar ;
    hesin:hasComponent """الإجابة الصادقة"""@ar ;
    hesin:hasComponent """الاعتراف بالفضل لله"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_35 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C403 a hesin:Concept ;
    rdfs:label """الاستفهام عن الزراعة (نعمة التربة)"""@ar ;
    hesin:definition """تذكير الإنسان بأن الله هو الذي ينبت الزرع ويخرجه من الأرض، وليس الإنسان بقدراته الذاتية."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{أَفَرَأَيْتُمْ مَا تَحْرُثُونَ أَأَنْتُمْ تَزْرَعُونَهُ أَمْ نَحْنُ الزَّارِعُونَ} داخلها أسئلة كثيرة جداً، بدءً من الأرض وانتهاء بالثمرة التي تجنيها"""@ar ;
    hesin:actions """تذكر نعمة الزراعة عند الحصاد."""@ar ;
    hesin:hasSynonym """نعمة الزرع"""@ar ;
    hesin:hasSynonym """نعمة الأرض"""@ar ;
    hesin:hasComponent """الأرض من الله"""@ar ;
    hesin:hasComponent """القدرة على الحراثة من الله"""@ar ;
    hesin:hasComponent """إنبات الزرع من الله"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_35 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C404 a hesin:Concept ;
    rdfs:label """الاستفهام عن الماء (نعمة الماء)"""@ar ;
    hesin:definition """تذكير الإنسان بأن الماء نعمة من الله ينزله من السماء، ولو شاء لجعله ملحًا لا يصلح للشرب أو الزراعة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{أَفَرَأَيْتُمُ الْمَاءَ الَّذِي تَشْرَبُونَ أَأَنْتُمْ أَنْزَلْتُمُوهُ مِنَ الْمُزْنِ أَمْ نَحْنُ الْمُنْزِلُونَ} (الواقعة:68-69) سؤال، كيف سيكون الجواب: أنت يا الله الذي تنـزله من المزن، من السحاب"""@ar ;
    hesin:actions """تذكر نعمة الماء عند الشرب والوضوء."""@ar ;
    hesin:hasSynonym """نعمة الشرب"""@ar ;
    hesin:hasSynonym """أساس الحياة"""@ar ;
    hesin:hasComponent """إنزال الماء من السماء"""@ar ;
    hesin:hasComponent """إمكانية جعله أجاجًا (مالحًا)"""@ar ;
    hesin:hasComponent """الماء أساس الحياة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_35 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C405 a hesin:Concept ;
    rdfs:label """الاستفهام عن النار (نعمة النار)"""@ar ;
    hesin:definition """تذكير الإنسان بأن الله هو من خلق مصادر النار (كالأشجار التي تقدح منها النار)، وهي نعمة تذكر بنار جهنم ومتاع للمسافرين."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{أَفَرَأَيْتُمُ النَّارَ الَّتِي تُورُونَ أَأَنْتُمْ أَنْشَأْتُمْ شَجَرَتَهَا أَمْ نَحْنُ الْمُنْشِئُونَ} (الواقعة:71-72) يوم كان العرب يقدحون زناداً في زناد بشجرتين فتنقدح النار فيشتعل العود"""@ar ;
    hesin:actions """تذكر نعمة النار والكهرباء عند استخدامها."""@ar ;
    hesin:hasSynonym """نعمة الطاقة"""@ar ;
    hesin:hasSynonym """النار كمنفعة"""@ar ;
    hesin:hasComponent """خلق مصادر النار"""@ar ;
    hesin:hasComponent """تذكرة بنار جهنم"""@ar ;
    hesin:hasComponent """متاع للمسافرين"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_35 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C406 a hesin:Concept ;
    rdfs:label """نظرة قارون (الإتيان على علم)"""@ar ;
    hesin:definition """نظرة الإنسان المغرورة التي تنسب النعم إلى ذكائه وخبرته وقدراته، متناسيًا أن الله هو المانح الحقيقي."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هو سبحانه وتعالى ذكَّر بأسلوب آخر أولئك الذين يرون أن كل ما في أيديهم، ينظرون إليه كنظرة قارون عندما قال: {إِنَّمَا أُوتِيتُهُ عَلَى عِلْمٍ عِنْدِي}"""@ar ;
    hesin:actions """نقد نظرة الاغترار بالذات."""@ar ;
    hesin:hasSynonym """الاغترار بالذات"""@ar ;
    hesin:hasSynonym """نسبة النعم للذات"""@ar ;
    hesin:hasComponent """نسبة النعم للذات"""@ar ;
    hesin:hasComponent """الاعتماد على الذكاء والخبرة"""@ar ;
    hesin:hasComponent """نسيان الله المنعم"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_36 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C407 a hesin:Concept ;
    rdfs:label """الموقفان الممكنان من النعم"""@ar ;
    hesin:definition """أن الإنسان بعد إقراره بأن الله هو المنعم، أمام خيارين: إما موقف الشكر (الانكسار، الحب، الطاعة) وإما موقف الكفران (الظلومية، الجحود، المعصية)."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أيُّ الموقفين هو الأليق بالإنسان من هذين؟ أليس هو الموقف الثاني؟. لأننا إذا وقفنا الموقف الأول، موقف الظلوم الكفار، بعد أن كنا قد شهدنا على أنفسنا وأقرينا في إجابتنا على هذا التساؤل الإلهي فقلنا: بل أنت يا الله، أنت الزارع، أليست هذه جريمة كبيرة؟"""@ar ;
    hesin:actions """التذكير بأن الإقرار بالمنعم يستلزم موقفًا عمليًا."""@ar ;
    hesin:hasSynonym """موقف الشكر مقابل موقف الكفران"""@ar ;
    hesin:hasComponent """موقف الشكر: انكسار، حب، طاعة"""@ar ;
    hesin:hasComponent """موقف الكفران: ظلومية، جحود، معصية"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_36 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C408 a hesin:Concept ;
    rdfs:label """القات كنعمة مؤقتة (كالمن والسلوى)"""@ar ;
    hesin:definition """نظرة إلى زراعة القات في اليمن باعتبارها نعمة مؤقتة من الله في فترة تيه الأمة، تشبه نعمة المن والسلوى على بني إسرائيل."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """القات بالنسبة لنا كأنه أشبه شيء بطائر السلوى الذي منحه الله بني إسرائيل أيام التيه، المن والسلوى"""@ar ;
    hesin:actions """تصحيح النظرة إلى القات كأزمة مؤقتة لا حل دائم."""@ar ;
    hesin:hasSynonym """نعمة مؤقتة"""@ar ;
    hesin:hasSynonym """جرعة إسعافية"""@ar ;
    hesin:hasComponent """نعمة في ظروف خاصة"""@ar ;
    hesin:hasComponent """فترة تيه"""@ar ;
    hesin:hasComponent """ليست بديلاً عن الاكتفاء الذاتي"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_37 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C409 a hesin:Concept ;
    rdfs:label """القات كعائق عن نصر الدين"""@ar ;
    hesin:definition """أن الاعتماد الكلي على زراعة القات (التي لا توفر الغذاء الأساسي) يؤدي إلى ضعف الأمة وعدم قدرتها على نصر الدين، لأن الغذاء أساس القوة."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """إذا كنت مصراً على زراعة القات باستمرار وأن تورثها للأجيال من بعدك فأنت مصر على قعودك عن نصر دين الله"""@ar ;
    hesin:actions """التوعية بضرورة التنويع الزراعي."""@ar ;
    hesin:hasSynonym """الاعتماد على القات وضعف الأمة"""@ar ;
    hesin:hasComponent """القات لا يوفر غذاءً أساسيًا"""@ar ;
    hesin:hasComponent """الاعتماد عليه يؤدي إلى شراء الغذاء من الخارج"""@ar ;
    hesin:hasComponent """يضعف الأمة عن مواجهة الأعداء"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_37 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C410 a hesin:Concept ;
    rdfs:label """الحاجة إلى الغذاء أشد من الحاجة إلى السلاح"""@ar ;
    hesin:definition """أن الأمن الغذائي (تأمين الغذاء الأساسي) هو أساس القوة والموقف في مواجهة الأعداء، وهو أولى من السلاح في بعض الأحوال."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أصبحت حاجتنا إلى الغذاء أشد من حاجة المسلمين إلى السلاح.. هل تفهمون هذا؟. حاجتنا إلى الغذاء أشد من حاجتنا إلى السلاح في ميدان وقفتنا ضد أعداء الله"""@ar ;
    hesin:actions """الاهتمام بالأمن الغذائي كأولوية."""@ar ;
    hesin:hasSynonym """أولوية الأمن الغذائي"""@ar ;
    hesin:hasComponent """الغذاء أساس القوة"""@ar ;
    hesin:hasComponent """الاعتماد على الأعداء في الغذاء يضعف الموقف"""@ar ;
    hesin:hasComponent """تأمين الغذاء من مقدمات النصر"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_37 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C411 a hesin:Concept ;
    rdfs:label """العودة إلى الله لحل الأزمات الاقتصادية"""@ar ;
    hesin:definition """أن الحل الحقيقي للأزمات الاقتصادية (كأزمة المياه والغذاء) هو العودة إلى الله والاستقامة على منهجه، وليس فقط الحلول المادية."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لا مجال إلا العودة إلى الله سبحانه وتعالى، فنشكر الله على هذه النعمة، نبتعد عن الأيمان الفاجرة، عن الكذب، عن الغش، عن الخيانة"""@ar ;
    hesin:actions """ربط الحلول الاقتصادية بالاستقامة الدينية."""@ar ;
    hesin:hasSynonym """الاستقامة كحل"""@ar ;
    hesin:hasSynonym """التوبة من الفساد"""@ar ;
    hesin:hasComponent """الإيمان والتقوى يفتحان البركات"""@ar ;
    hesin:hasComponent """الاستغفار يجلب الأمطار والأموال"""@ar ;
    hesin:hasComponent """الفساد سبب نزع البركات"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_37 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C412 a hesin:Concept ;
    rdfs:label """الماء أساس الحياة والقوة"""@ar ;
    hesin:definition """أن الماء هو أساس كل شيء: الحياة، الرزق، الحرية، نصر الدين. وهو بيد الله وحده."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """والحياة مرتبطة بالماء، الأرزاق مرتبطة بالماء، بل حريتنا مرتبطة بالماء، بل نصر ديننا مرتبط بالماء"""@ar ;
    hesin:actions """تقدير قيمة الماء وعدم التبذير فيه."""@ar ;
    hesin:hasSynonym """عمود الحياة"""@ar ;
    hesin:hasSynonym """مصدر البركات"""@ar ;
    hesin:hasComponent """أساس الحياة"""@ar ;
    hesin:hasComponent """أساس الرزق"""@ar ;
    hesin:hasComponent """أساس الحرية"""@ar ;
    hesin:hasComponent """أساس نصر الدين"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_38 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C413 a hesin:Concept ;
    rdfs:label """التبذير في الماء وإخوان الشياطين"""@ar ;
    hesin:definition """أن التبذير في الماء (وغيره) محرم شرعًا، والمبذرون هم إخوان الشياطين، لأنهم يضربون الأمة من أساسها."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """الحفاظ على الماء في استهلاكه قضية مهمة، والتبذير بالماء هو من التبذير الذي نهى الله عنه في كتابه الكريم، وشبه المبذرين بأنهم إخوان الشياطين {وَلا تُبَذِّرْ تَبْذِيراً إِنَّ الْمُبَذِّرِينَ كَانُوا إِخْوَانَ الشَّيَاطِينِ}"""@ar ;
    hesin:actions """التوعية بترشيد استهلاك الماء."""@ar ;
    hesin:hasSynonym """إسراف الماء"""@ar ;
    hesin:hasSynonym """عدم تقدير النعمة"""@ar ;
    hesin:hasComponent """التبذير محرم"""@ar ;
    hesin:hasComponent """المبذرون إخوان الشياطين"""@ar ;
    hesin:hasComponent """التبذير يضر بالأمة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_38 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C414 a hesin:Concept ;
    rdfs:label """وعد الله بالاستقامة والماء الغدق"""@ar ;
    hesin:definition """وعد إلهي بأن الاستقامة على منهج الله تجلب الماء الغزير (الغدق) من السماء والأرض."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَأَلَّوِ اسْتَقَامُوا عَلَى الطَّرِيقَةِ لَأَسْقَيْنَاهُمْ مَاءً غَدَقاً} (الجـن:16) والحياة مرتبطة بالماء، الأرزاق مرتبطة بالماء"""@ar ;
    hesin:actions """الدعوة إلى الاستقامة كحل للأزمات المائية."""@ar ;
    hesin:hasSynonym """الماء الغدق"""@ar ;
    hesin:hasSynonym """بركات السماء والأرض"""@ar ;
    hesin:hasComponent """الاستقامة شرط"""@ar ;
    hesin:hasComponent """الماء الغدق جزاء"""@ar ;
    hesin:hasComponent """ارتباط الإيمان بالبركات المادية"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_38 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C415 a hesin:Concept ;
    rdfs:label """النعم الثلاث الكبرى (الأساسية)"""@ar ;
    hesin:definition """أن النعم الأساسية التي يعتمد عليها كل شيء هي: نعمة التربة (الزراعة)، نعمة الماء، نعمة النار (الطاقة)."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لاحظوا هنا و الآيات تتحدث عن ثلاث نعم أساسية كبرى: نعمة التربة، ونعمة الماء، ونعمة النار، وهي نعم كبرى، وهي أساس تقريباً لكل النعم الأخرى في الحياة"""@ar ;
    hesin:actions """التركيز على هذه النعم الثلاث في التذكير."""@ar ;
    hesin:hasSynonym """أصول النعم"""@ar ;
    hesin:hasComponent """نعمة التربة (الزراعة)"""@ar ;
    hesin:hasComponent """نعمة الماء"""@ar ;
    hesin:hasComponent """نعمة النار (الطاقة)"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_39 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C416 a hesin:Concept ;
    rdfs:label """النار كتذكرة بجهنم"""@ar ;
    hesin:definition """أن النار في الدنيا هي تذكير للإنسان بنار جهنم في الآخرة، ليتذكر ويعمل."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{نَحْنُ جَعَلْنَاهَا تَذْكِرَةً} (الواقعة:73) هذه النار تذكر بالنار الكبرى بالآخر بنار جهنم"""@ar ;
    hesin:actions """استحضار نار جهنم عند رؤية النار."""@ar ;
    hesin:hasSynonym """التذكير بالآخرة"""@ar ;
    hesin:hasSynonym """النار الدنيوية تذكر بالنار الأخروية"""@ar ;
    hesin:hasComponent """النار الدنيوية تذكرة"""@ar ;
    hesin:hasComponent """التذكير بنار الآخرة"""@ar ;
    hesin:hasComponent """تحذير من النار الكبرى"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_39 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C417 a hesin:Concept ;
    rdfs:label """الجمال في النعم (جانب الزينة)"""@ar ;
    hesin:definition """أن الله لم يخلق النعم مفيدة فقط، بل جعل فيها جانبًا جماليًا (المنظر الجميل، الشكل الحسن، الرائحة الطيبة) لتسر النفوس."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """حتى الجانب الفني أو جانب الجمال، الجمال هو أيضاً مما هو ملحوظ داخل هذه النعم الإلهية. فتتمتع أعيننا، وأنفسنا ترتاح إلى هذه المناظر"""@ar ;
    hesin:actions """ملاحظة الجمال في الخلق كدليل على رحمة الله."""@ar ;
    hesin:hasSynonym """الفن في الخلق"""@ar ;
    hesin:hasSynonym """الإتقان الجمالي"""@ar ;
    hesin:hasComponent """منظر الحيوانات الجميل"""@ar ;
    hesin:hasComponent """شكل الثمار الحسن"""@ar ;
    hesin:hasComponent """رائحة الأطعمة الطيبة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_39 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C418 a hesin:Concept ;
    rdfs:label """الجبال كرواسي وأعلام ومساحات"""@ar ;
    hesin:definition """الجبال لها فوائد متعددة: تثبيت الأرض، وتكون أعلامًا للهداية، وتوفر مساحات صالحة للاستقرار والزراعة."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَأَلْقَى فِي الْأَرْضِ رَوَاسِيَ أَنْ تَمِيدَ بِكُمْ وَأَنْهَاراً وَسُبُلاً لَعَلَّكُمْ تَهْتَدُونَ} (النحل:15) الرواسي هي الجبال... هي نفسها تساعد على أن تبقى الأرض فلا تميد فوق البحر، وهي نفسها غير مقفلة، قابلة لتحرك الإنسان عليها، هي نفسها قابلة للإستقرار عليها"""@ar ;
    hesin:actions """التفكر في التصميم الإلهي للجبال."""@ar ;
    hesin:hasSynonym """فوائد الجبال المتعددة"""@ar ;
    hesin:hasComponent """رواسي (تثبيت الأرض)"""@ar ;
    hesin:hasComponent """أعلام (علامات للطريق)"""@ar ;
    hesin:hasComponent """مساحات صالحة للاستقرار"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_39 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C419 a hesin:Concept ;
    rdfs:label """عدم إضاعة المساحة في الخلق"""@ar ;
    hesin:definition """أن الله في خلقه لا يضيع شيئًا، بل كل شيء له فوائد متعددة، وهذا درس للإنسان في التصميم والصناعة."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """الله الذي صمم هذه الأرض، لاحظ كيف يعمل، لا يضيع شبراً واحداً من الأرض بدون فائدة، فالمساحات التي تشغلها الجبال في الأرض يعوضها، فتطلع مساحة الجبل أكثر من المساحة التي يشغلها"""@ar ;
    hesin:actions """الاستفادة من هذا المبدأ في التصميم المعماري والصناعي."""@ar ;
    hesin:hasSynonym """الإتقان في التصميم"""@ar ;
    hesin:hasSynonym """عدم التبذير في الخلق"""@ar ;
    hesin:hasComponent """كل شيء له فائدة"""@ar ;
    hesin:hasComponent """تعويض المساحات"""@ar ;
    hesin:hasComponent """درس في التصميم"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_39 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C420 a hesin:Concept ;
    rdfs:label """قصد السبيل على الله"""@ar ;
    hesin:definition """أن الله وحده هو المتكفل برسم الطريق القاصد (الصراط المستقيم) للناس، وليس للإنسان أن يشرع لنفسه."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَعَلَى اللَّهِ قَصْدُ السَّبِيلِ وَمِنْهَا جَائِرٌ وَلَوْ شَاءَ لَهَدَاكُمْ أَجْمَعِينَ} (النحل:9) يقول لأولئك الذين يعملون مجالس تشريعية... لا تنظروا إلى جانب الهداية كنظرتكم إلى جانب النعم"""@ar ;
    hesin:actions """الرجوع إلى الله في التشريع، ورفض مجالس التشريع البشرية."""@ar ;
    hesin:hasSynonym """هداية الله"""@ar ;
    hesin:hasSynonym """رسم الصراط المستقيم"""@ar ;
    hesin:hasComponent """الهداية من الله"""@ar ;
    hesin:hasComponent """التشريع من الله"""@ar ;
    hesin:hasComponent """لا اجتهاد بشري في التشريع الأساسي"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_40 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C421 a hesin:Concept ;
    rdfs:label """نقد مجالس التشريع البشرية"""@ar ;
    hesin:definition """نقد فكرة المجالس التشريعية التي تشرع قوانين من عند أنفسها، بدلاً من تطبيق شرع الله."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لماذا تسمون تلك المجالس مجالس تشريعية؟. لا يصح أن تسمى مجالس تشريعية بأي حال من الأحوال"""@ar ;
    hesin:actions """رفض التسمية (مجالس تشريعية) والعمل على تطبيق الشريعة."""@ar ;
    hesin:hasSynonym """رفض التشريع البشري"""@ar ;
    hesin:hasComponent """التشريع حق الله وحده"""@ar ;
    hesin:hasComponent """مجالس التشريع بدعة"""@ar ;
    hesin:hasComponent """الاعتماد على القوانين الوضعية شرك"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_40 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C422 a hesin:Concept ;
    rdfs:label """حاكمية الله (ولاية الله على عباده)"""@ar ;
    hesin:definition """أن الله وحده هو المالك الحقيقي والمتصرف في شؤون عباده، وهو وحده الذي له الحق في الحكم والتشريع والولاية."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """الله الذي خلقك، وخلق هذا العالم، وهو الذي دبر شئون هذا العالم على هذا النحو المفصل العجيب، هو وحده الذي له الحق أن يلي شئونك، أن يكون هو وليك"""@ar ;
    hesin:actions """رفض أي سلطة لا تستند إلى شرع الله."""@ar ;
    hesin:hasSynonym """سلطان الله"""@ar ;
    hesin:hasSynonym """ولاية الله"""@ar ;
    hesin:hasComponent """الله هو الولي"""@ar ;
    hesin:hasComponent """الحكم لله"""@ar ;
    hesin:hasComponent """التشريع لله"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_40 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C423 a hesin:Concept ;
    rdfs:label """الشرك بحاكمية غير الله"""@ar ;
    hesin:definition """أن جعل حاكمية غير الله (بإقرار أن البشر يشرعون من عند أنفسهم) هو نوع من الشرك بالله."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أذكر عند بعض العلماء من يعتقد هذا شركاً فعلاً، يعتبرها شركاً، أن تؤمن بحاكمية غير الله، أو حاكمية سلطان ليس على أساس من هدي الله"""@ar ;
    hesin:actions """رفض أي تشريع يخالف شرع الله."""@ar ;
    hesin:hasSynonym """الشرك في الحكم"""@ar ;
    hesin:hasSynonym """الشرك في التشريع"""@ar ;
    hesin:hasComponent """حاكمية غير الله شرك"""@ar ;
    hesin:hasComponent """التشريع البشري شرك"""@ar ;
    hesin:hasComponent """الخضوع لغير الله في التشريع"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_40 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C424 a hesin:Concept ;
    rdfs:label """الفساد في البر والبحر"""@ar ;
    hesin:definition """أن الفساد الذي يظهر في البيئة والاقتصاد والمجتمع هو نتيجة لمعاصي الناس، وسبب لنزع البركات."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{ظَهَرَ الْفَسَادُ فِي الْبَرِّ وَالْبَحْرِ بِمَا كَسَبَتْ أَيْدِي النَّاسِ} (الروم:41) فلم ير الناس أنفسهم متمكنين من زراعة الحبوب... السماء لم تعد تعطي بركاتها، الأرض لم تعد تعطي بركاتها"""@ar ;
    hesin:actions """ربط المشكلات البيئية والاقتصادية بالفساد الأخلاقي."""@ar ;
    hesin:hasSynonym """نزع البركات"""@ar ;
    hesin:hasSynonym """عقوبة المعاصي"""@ar ;
    hesin:hasComponent """الفساد نتيجة المعاصي"""@ar ;
    hesin:hasComponent """نزع البركات من السماء والأرض"""@ar ;
    hesin:hasComponent """الحل في العودة إلى الله"""@ar ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C425 a hesin:Concept ;
    rdfs:label """فساد السلطان وفساد الزمان"""@ar ;
    hesin:definition """أن فساد الحكام والسلاطين يؤدي إلى فساد المجتمع كله، وهو من أسباب نزع البركات."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """كما قال الإمام علي (عليه السلام) ((إذا فسد السلطان فسد الزمان)) أو لسنا نسمع من الدولة نفسها أنهم يشكون من الفساد المالي، والفساد الإداري، والفساد في القضاء"""@ar ;
    hesin:actions """مطالبة الحكام بالإصلاح."""@ar ;
    hesin:hasSynonym """تأثير الحاكم على المجتمع"""@ar ;
    hesin:hasComponent """فساد السلطان"""@ar ;
    hesin:hasComponent """فساد الزمان والمجتمع"""@ar ;
    hesin:hasComponent """شكوى الحكام من الفساد أنفسهم"""@ar ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C426 a hesin:Concept ;
    rdfs:label """التبعية الغذائية للأعداء"""@ar ;
    hesin:definition """حالة من التبعية الاقتصادية والغذائية للدول الأجنبية (وخصوصًا الأعداء)، مما يضعف الأمة ويجعلها غير قادرة على موقف مستقل."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """حتى البيضة تأتي من خارج، الدجاجة تأتي من خارج، كل ما بين أيدينا كل ما في مطابخنا، كل ما في أسواقنا كله من خارج، من عند أعدائنا، أليست هذه وضعية سيئة، وضعية خطيرة جداً"""@ar ;
    hesin:actions """العمل على تحقيق الاكتفاء الذاتي الغذائي."""@ar ;
    hesin:hasSynonym """الاعتماد على الأعداء"""@ar ;
    hesin:hasSynonym """ضعف الأمة"""@ar ;
    hesin:hasComponent """استيراد الغذاء من الأعداء"""@ar ;
    hesin:hasComponent """فقدان الأمن الغذائي"""@ar ;
    hesin:hasComponent """ضعف الموقف السياسي"""@ar ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C427 a hesin:Concept ;
    rdfs:label """تكفل الله بالهداية (بقاء هدايته)"""@ar ;
    hesin:definition """أن هداية الله (قصد السبيل) لا تزال قائمة كما النعم المادية، وهي أهم منها، ولا يمكن أن يرفعها الله ويبقي النعم المادية."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """نحن ما نزال نرى نعمه قائمة، ثم نقول: أما قصد السبيل فيبدو أنه قد غاب، كيف يرفع الله ما نحن في أمس الحاجة إليه، هدايته، ويترك لنا البقر والحمير، والإبل، والغنم، وهذه المواشي؟!"""@ar ;
    hesin:actions """التمسك بالثقلين: كتاب الله وعترة رسوله."""@ar ;
    hesin:hasSynonym """دوام الهداية"""@ar ;
    hesin:hasSynonym """استمرار هدي الله"""@ar ;
    hesin:hasComponent """هداية الله قائمة"""@ar ;
    hesin:hasComponent """الهداية أهم من النعم المادية"""@ar ;
    hesin:hasComponent """الاستمساك بالثقلين"""@ar ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C501 a hesin:Concept ;
    rdfs:label """تسبيح كل شيء لله"""@ar ;
    hesin:definition """أن كل المخلوقات في السماوات والأرض تسبح الله وتشهد بنزاهته عن كل عيب ونقص، سواء بالنطق أو بلسان الحال."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{سَبَّحَ لِلَّهِ مَا فِي السَّمَاوَاتِ وَالْأَرْضِ وَهُوَ الْعَزِيزُ الْحَكِيمُ} (الحديد1). سبح لله: نزهه, وشهد بنزاهته وقدسيته، نزاهته عن كل ما لا يليق به سبحانه وتعالى"""@ar ;
    hesin:actions """استشعار أن الكون كله يشهد بعظمة الله."""@ar ;
    hesin:hasSynonym """التسبيح الكوني"""@ar ;
    hesin:hasSynonym """شهادة المخلوقات"""@ar ;
    hesin:hasComponent """تنزيه الله عن العيوب"""@ar ;
    hesin:hasComponent """شهادة المخلوقات بكماله"""@ar ;
    hesin:hasComponent """التسبيح الكوني"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_41 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C502 a hesin:Concept ;
    rdfs:label """العزيز"""@ar ;
    hesin:definition """صفة إلهية تعني أن الله لا يُقهر ولا يُغلب، وهو وحده صاحب العزة المطلقة، ويمنح من عزته من يتولاه."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هُوَ الْعَزِيزُ: المَنِيع الذي لا يُقهر، لا يُغلَب ولا يُغالَب، هو غالب على أمره، هو العزيز الذي يَمنح مِن عزته من اعتزّ به"""@ar ;
    hesin:actions """استحضار عزة الله عند الخوف من أي مخلوق."""@ar ;
    hesin:hasSynonym """القوي المنيع"""@ar ;
    hesin:hasSynonym """الغالب"""@ar ;
    hesin:hasComponent """لا يقهر"""@ar ;
    hesin:hasComponent """لا يغلب"""@ar ;
    hesin:hasComponent """يمنح العزة لأوليائه"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_41 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C503 a hesin:Concept ;
    rdfs:label """الحكيم"""@ar ;
    hesin:definition """صفة إلهية تعني أن كل أفعال الله وتدبيره وتشريعه صادرة عن حكمة وإتقان."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """الحكيم في ما يصدر منه، الحكيم في تدبيره، الحكيم في هدايته، الحكيم في تشريعه، الحكيم في تدبيره لشئون خلقه"""@ar ;
    hesin:actions """الثقة بأن كل أمر من الله فيه حكمة."""@ar ;
    hesin:hasSynonym """المحكم في أفعاله"""@ar ;
    hesin:hasComponent """حكمة في التدبير"""@ar ;
    hesin:hasComponent """حكمة في التشريع"""@ar ;
    hesin:hasComponent """حكمة في الهداية"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_41 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C504 a hesin:Concept ;
    rdfs:label """ملك السماوات والأرض"""@ar ;
    hesin:definition """أن الله هو المالك الحقيقي للسماوات والأرض، وملكه دائم لا يزول، بخلاف ملوك الدنيا."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{لَهُ مُلْكُ السَّمَاوَاتِ وَالْأَرْضِ} (الحديد2) هو مَلِك السماوات والأرض، مَالِكُها"""@ar ;
    hesin:actions """استحضار أن كل شيء ملك لله."""@ar ;
    hesin:hasSynonym """الملك"""@ar ;
    hesin:hasSynonym """المالك"""@ar ;
    hesin:hasComponent """ملك دائم"""@ar ;
    hesin:hasComponent """لا ينزع منه الملك"""@ar ;
    hesin:hasComponent """لا يُغلب في ملكه"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_41 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C505 a hesin:Concept ;
    rdfs:label """الأول والآخر والظاهر والباطن"""@ar ;
    hesin:definition """أسماء الله الأربعة التي تعبر عن كماله المطلق: الأول (لا شيء قبله)، الآخر (يبقى بعد فناء كل شيء)، الظاهر (أظهر من كل مخلوق)، الباطن (لا تدركه الحواس)."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{هُوَ الْأَوَّلُ وَالْآخِرُ وَالظَّاهِرُ وَالْبَاطِنُ وَهُوَ بِكُلِّ شَيْءٍ عَلِيمٌ} (الحديد:3) هذا ثَناءٌ على الله، وبيان لكماله المطلق سبحانه وتعالى"""@ar ;
    hesin:actions """استحضار هذه الأسماء في التأمل."""@ar ;
    hesin:hasSynonym """أسماء الله الحسنى"""@ar ;
    hesin:hasComponent """الأول: لا شيء قبله"""@ar ;
    hesin:hasComponent """الآخر: الباقي بعد فناء كل شيء"""@ar ;
    hesin:hasComponent """الظاهر: أظهر من كل مخلوق"""@ar ;
    hesin:hasComponent """الباطن: لا تدركه الحواس"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_41 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C506 a hesin:Concept ;
    rdfs:label """خلق السماوات والأرض في ستة أيام"""@ar ;
    hesin:definition """أن الله خلق هذا الكون العظيم في ستة أيام (بالمقياس الأرضي)، وهو قادر على كل شيء، فكيف لا ينجز لأوليائه ما وعدهم به."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{هُوَ الَّذِي خَلَقَ السَّمَاوَاتِ وَالْأَرْضَ فِي سِتَّةِ أَيَّامٍ ثُمَّ اسْتَوَى عَلَى الْعَرْشِ} (الحديد:4) خلق السماوات والأرض، هذا العالم الكبير المترامي الأطراف... فيما يقدر بستة أيام من أيامنا وإلا فليس هناك زمن"""@ar ;
    hesin:actions """التفكر في عظمة الخلق."""@ar ;
    hesin:hasSynonym """خلق الكون"""@ar ;
    hesin:hasSynonym """قدرة الله"""@ar ;
    hesin:hasComponent """خلق الكون الواسع"""@ar ;
    hesin:hasComponent """في زمن محدود (ستة أيام)"""@ar ;
    hesin:hasComponent """دليل على القدرة المطلقة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_41 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C507 a hesin:Concept ;
    rdfs:label """العلم المحيط"""@ar ;
    hesin:definition """أن علم الله محيط بكل شيء: ما يدخل الأرض ويخرج منها، وما ينزل من السماء ويعرج فيها، وهو مع عباده أينما كانوا."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{يَعْلَمُ مَا يَلِجُ فِي الْأَرْضِ وَمَا يَخْرُجُ مِنْهَا وَمَا يَنزِلُ مِنَ السَّمَاء وَمَا يَعْرُجُ فِيهَا وَهُوَ مَعَكُمْ أَيْنَ مَا كُنتُمْ وَاللَّهُ بِمَا تَعْمَلُونَ بَصِيرٌ} (الحديد4)"""@ar ;
    hesin:actions """استحضار علم الله المحيط في كل عمل."""@ar ;
    hesin:hasSynonym """علم الغيب والشهادة"""@ar ;
    hesin:hasComponent """علم بما يلج في الأرض ويخرج منها"""@ar ;
    hesin:hasComponent """علم بما ينزل من السماء ويعرج فيها"""@ar ;
    hesin:hasComponent """معية الله لعباده"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_41 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C508 a hesin:Concept ;
    rdfs:label """معية الله"""@ar ;
    hesin:definition """أن الله مع عباده بعلمه وقدرته ورعايته، حاضر معهم أينما كانوا، لا يغيب عنهم."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَهُوَ مَعَكُمْ أَيْنَ مَا كُنتُمْ} (الحديد:4) هو معنا، عندما يحاول المتكلمون دائماً أن يعملوا التعريفات لكل شيء فلا يدعوا الموضوع للمعرفة الفطرية... هو معنا"""@ar ;
    hesin:actions """استشعار حضور الله في كل مكان."""@ar ;
    hesin:hasSynonym """حضور الله"""@ar ;
    hesin:hasSynonym """قربه من عباده"""@ar ;
    hesin:hasComponent """معية العلم"""@ar ;
    hesin:hasComponent """معية القدرة"""@ar ;
    hesin:hasComponent """معية الرعاية"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_41 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C509 a hesin:Concept ;
    rdfs:label """يولج الليل في النهار"""@ar ;
    hesin:definition """أن تعاقب الليل والنهار وتداخلهما هو بتدبير من الله، وهو دليل على قدرته وعلمه وكونه مالكًا لهذا العالم."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{يُولِجُ اللَّيْلَ فِي النَّهَارِ وَيُولِجُ النَّهَارَ فِي اللَّيْلِ وَهُوَ عَلِيمٌ بِذَاتِ الصُّدُورِ} (الحديد:6) هو من يدبر كل شيء، الليل والنهار هو الذي يدبره فيولج الليل في النهار ويولج النهار في الليل"""@ar ;
    hesin:actions """التفكر في تعاقب الليل والنهار."""@ar ;
    hesin:hasSynonym """تعاقب الليل والنهار"""@ar ;
    hesin:hasComponent """إيلاج الليل في النهار"""@ar ;
    hesin:hasComponent """إيلاج النهار في الليل"""@ar ;
    hesin:hasComponent """حركة مستمرة منظمة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_41 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C510 a hesin:Concept ;
    rdfs:label """نقد مفهوم "القديم""""@ar ;
    hesin:definition """نقد استخدام المتكلمين لصفة "القديم" لله، لأنها توهم العمق الزمني، بينما القرآن استخدم "الأول" التي لا توحي بذلك."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هذه العبارة أفضل بكثير من عبارة [المتكلمين] التي يرددونها:[القديم] فيسمون الله قديماً، وهذا - في ما أعتقد - لم تَرِد في القرآن الكريم ولا مرة واحدة: أن يصف نفسه, وأن يجعلها من أسمائه [القديم] ؛لأن كلمة:[قديم] ليست مما يصح أن يُمدَح الله بها سبحانه وتعالى لما فيها من إيهام وهو: أنها تُوهِم العمق الزمني"""@ar ;
    hesin:actions """استخدام الأسماء القرآنية فقط لله."""@ar ;
    hesin:hasSynonym """نقد صفة القدم"""@ar ;
    hesin:hasComponent """"القديم" توهم العمق الزمني"""@ar ;
    hesin:hasComponent """"الأول" أفضل تعبيرًا"""@ar ;
    hesin:hasComponent """الالتزام بالأسماء القرآنية"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_42 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C511 a hesin:Concept ;
    rdfs:label """نقد مفهوم "الغائب" وقياس الغائب على الشاهد"""@ar ;
    hesin:definition """نقد المنهج الكلامي الذي يصف الله بالغائب ثم يقيس عليه (قياس الغائب على الشاهد)، مما يرسخ في الأذهان غياب الله ويجعله بحاجة إلى الاستدلال."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """ليس غائباً كما يقول [المتكلمون]! فيقولون: [قياساً للغائب على الشاهد]، يعرف هذا من قرأ في كتب [علم الكلام] هذه العبارة القاصرة ترسخ غياب الله في ذهنية الإنسان"""@ar ;
    hesin:actions """إلغاء استخدام مصطلح "الغائب" في الحديث عن الله."""@ar ;
    hesin:hasSynonym """نقد أصول علم الكلام"""@ar ;
    hesin:hasComponent """وصف الله بالغائب"""@ar ;
    hesin:hasComponent """قياس الغائب على الشاهد"""@ar ;
    hesin:hasComponent """ترسيخ غياب الله في الذهنية"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_42 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C512 a hesin:Concept ;
    rdfs:label """نقد الاستدلال على وجود الله بالحدوث"""@ar ;
    hesin:definition """نقد المنهج الكلامي الذي يحاول إثبات وجود الله من خلال دليل الحدوث، بينما الله ظاهر لا يحتاج إلى إثبات."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لما جعلوا الله غائباً اتجهوا ليـبحثوا عن وجوده هو، عن هل هو موجود أم لا، فيأتون إلى ترتيب مقدمات معينة تبدأ بالحديث عن [أن هذه الأشياء وجدناها مُحدَثة لكونها ملازمة لعلامات الحدوث إذاً فهي مُحدَثة، إذاً هناك من هو مُحْدِثٌ لها، إذاً هناك مُحدِث]"""@ar ;
    hesin:actions """العودة إلى الفطرة في معرفة الله."""@ar ;
    hesin:hasSynonym """نقد دليل الحدوث"""@ar ;
    hesin:hasComponent """جعل الله غائبًا"""@ar ;
    hesin:hasComponent """الحاجة إلى الاستدلال"""@ar ;
    hesin:hasComponent """ترتيب مقدمات منطقية"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_42 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C513 a hesin:Concept ;
    rdfs:label """الفطرة على معرفة الله"""@ar ;
    hesin:definition """أن الله غرز معرفته في نفوس عباده بالفطرة، وليسوا بحاجة إلى مقدمات استدلالية لمعرفته."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """بل يقول [الإمام محمد بن القاسم بن إبراهيم] (صلوات الله عليهم) في كتاب [الهجرة والوصية]: ((أن الله غرَزَ معرفته في نفوس عباده من الملائكة والإنس والجن )) حتى قال أيضاً: (( بل والطير والحيوانات الأخرى كلها تعرف الله ))"""@ar ;
    hesin:actions """الاعتماد على الفطرة في معرفة الله."""@ar ;
    hesin:hasSynonym """المعرفة الفطرية"""@ar ;
    hesin:hasSynonym """غرز المعرفة"""@ar ;
    hesin:hasComponent """المعرفة فطرية"""@ar ;
    hesin:hasComponent """غرزها الله في النفوس"""@ar ;
    hesin:hasComponent """تشمل الملائكة والإنس والجن والحيوانات"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_42 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C514 a hesin:Concept ;
    rdfs:label """غياب الاستدلال على الوجود في القرآن"""@ar ;
    hesin:definition """أن القرآن لا يستخدم أسلوب الاستدلال على وجود الله (كأن يقول: هذا دليل على وجودي)، لأن الله ظاهر لا يحتاج إلى دليل."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لم أجد في القرآن الكريم آية واحدة - على الرغم مما ذكره الله سبحانه وتعالى من مظاهر قدرته ونعمته وحكمته و.. إلى آخره - أن ذكر شيئاً منها بعبارة الاستدلال بها على وجوده مثل: [أليس ذلك يدل على أنني كذا]، لا تجد هذه في القرآن الكريم"""@ar ;
    hesin:actions """عدم استخدام صيغ استدلالية (فدل على أن الله موجود)."""@ar ;
    hesin:hasSynonym """أسلوب القرآن في بيان وجود الله"""@ar ;
    hesin:hasComponent """عدم استخدام صيغ الاستدلال"""@ar ;
    hesin:hasComponent """الاكتفاء بذكر الآيات"""@ar ;
    hesin:hasComponent """التوجه إلى الفعل لا إلى الذات"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_42 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C515 a hesin:Concept ;
    rdfs:label """نقد تفسير "العرش" ككرسي"""@ar ;
    hesin:definition """نقد التفسير الحرفي لكلمة "العرش" الذي يفهمها ككرسي أو سرير يجلس عليه الله، لأن هذا الفهم لا يضيف قيمة معرفية ولا يليق بعظمة الله."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """ما قيمة أن يقول الله لنا الله سبحانه وتعالى بأن هناك عرشاً هو يستوي عليه؟. ما قيمته بالنسبة لنا في مقام الدلالة على قدرته سبحانه وتعالى على تدبيره، على حكمته، على عظمته وجلاله!"""@ar ;
    hesin:actions """فهم "العرش" في سياقه القرآني."""@ar ;
    hesin:hasSynonym """نقد الفهم الحرفي للعرش"""@ar ;
    hesin:hasComponent """العرش ليس كرسيًا"""@ar ;
    hesin:hasComponent """الفهم الحرفي يقلل من عظمة النص"""@ar ;
    hesin:hasComponent """يفتقر إلى القيمة المعرفية"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_43 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C516 a hesin:Concept ;
    rdfs:label """تفسير "العرش" بالملك والسلطان"""@ar ;
    hesin:definition """أن "العرش" في القرآن يعني السلطان والملك، والاستواء عليه يعني اتخاذ موقف التدبير والإدارة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هذا الكون الذي خلقه لم يخلقه ثم يرمي به هناك، خلقه ثم اتجه إلى تدبيره، اتجه إلى تدبير شئونه, تدبير شئون هذا العالم الفسيح، وهذا هو ما يعبر عنه [بالعرش] الذي يعني: السلطان والمملكة"""@ar ;
    hesin:actions """فهم "العرش" في ضوء السياق القرآني واللغة العربية."""@ar ;
    hesin:hasSynonym """العرش كناية عن الملك"""@ar ;
    hesin:hasComponent """العرش = الملك والسلطان"""@ar ;
    hesin:hasComponent """الاستواء = التدبير"""@ar ;
    hesin:hasComponent """السياق اللغوي العربي"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_43 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C517 a hesin:Concept ;
    rdfs:label """تفسير "الاستواء" بالتدبير"""@ar ;
    hesin:definition """أن "الاستواء على العرش" يعني التوجه لتدبير شؤون الملك، كما هو صريح في سورة يونس التي تربطه بـ "يدبر الأمر"."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """وجاء صريحاً هذا في أول [سورة يونس] ـ ومعظم ما تأتي عبارة استوى على العرش تأتي في مقام عرض لمظاهر قدرته سبحانه وتعالى ـ في أول [سورة يونس] يقول تعالى:{إِنَّ رَبَّكُمُ اللَّهُ الَّذِي خَلَقَ السَّمَاوَاتِ وَالْأَرْضَ فِي سِتَّةِ أَيَّامٍ ثُمَّ اسْتَوَى عَلَى الْعَرْشِ يُدَبِّرُ الْأَمْرَ} (يونس:3)"""@ar ;
    hesin:actions """تفسير القرآن بالقرآن."""@ar ;
    hesin:hasSynonym """الاستواء بمعنى التدبير"""@ar ;
    hesin:hasComponent """الاستواء = التوجه للتدبير"""@ar ;
    hesin:hasComponent """العرش = الملك"""@ar ;
    hesin:hasComponent """يفسر القرآن بعضه بعضًا"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_43 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C518 a hesin:Concept ;
    rdfs:label """حاكمية الله (من ملكه)"""@ar ;
    hesin:definition """أن ملكية الله للسماوات والأرض تستلزم أن الحكم والتدبير والتشريع حق له وحده، ولا شرعية لأي حكم لا يستند إلى شرع الله."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{لَهُ مُلْكُ السَّمَاوَاتِ وَالْأَرْضِ} له وحده ملكها، أليس هذا هو الدليل الكافي على أنه لا يجوز لأحد أن ينطلق نحو التحكم في شئون عباد الله دون أن يكون له شرعية من عند الله؟"""@ar ;
    hesin:actions """رفض أي حكم لا يستند إلى شرع الله."""@ar ;
    hesin:hasSynonym """ولاية الله"""@ar ;
    hesin:hasSynonym """سلطان الله"""@ar ;
    hesin:hasComponent """الله مالك السماوات والأرض"""@ar ;
    hesin:hasComponent """الحكم حق الله"""@ar ;
    hesin:hasComponent """لا شرعية لحكم بشري دون استناد إلى الله"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_44 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C519 a hesin:Concept ;
    rdfs:label """نقد مبدأ "السلطة ملك للشعب""""@ar ;
    hesin:definition """نقد المبدأ الديمقراطي الذي يجعل السلطة ملكًا للشعب، لأنه يتناقض مع مبدأ حاكمية الله وكونه مالك السماوات والأرض."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لا. السلطة ملك للشعب, هكذا نقول! هذه العبارة ليست سهلة، هذه عبارة خطيرة جداً على الأمة، أن تدين بها دولة، وأن يدين بها شعب عبارة خطيرة"""@ar ;
    hesin:actions """رفض مبدأ "السلطة ملك للشعب"."""@ar ;
    hesin:hasSynonym """نقد الديمقراطية"""@ar ;
    hesin:hasComponent """السلطة للشعب (ديمقراطية)"""@ar ;
    hesin:hasComponent """تناقض مع حاكمية الله"""@ar ;
    hesin:hasComponent """عبارة خطيرة على الأمة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_44 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C520 a hesin:Concept ;
    rdfs:label """نقد الحكم "الثيوقراطي" (مصطلح)"""@ar ;
    hesin:definition """نقد المصطلحات التي يطلقها الغرب على الحكم المستند إلى شرع الله (ثيوقراطي)، ورفض اعتبار هذا النظام "مرفوضًا" بينما هو المطلوب شرعًا."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """بل قُدِّمَ هذا المنطق بأنه منطق مرفوض، هو ما يسمى بالحكم [الثيوقراطي] ما يقابل [الديمقراطي]، هناك [الثيوقراطي] أي الحكم الإلهي، الله لا دخل له في العالم ومن ينادون بأن يكون الله هو من يحكم عباده... قالوا: ربط الحكم بالله ربط السلطة بالله، هذا هو نظام [ثيوقراطي] وهو نظام مرفوض!"""@ar ;
    hesin:actions """رفض وصم الحكم الإلهي بـ "الثيوقراطي" المرفوض."""@ar ;
    hesin:hasSynonym """الحكم الإلهي"""@ar ;
    hesin:hasComponent """الثيوقراطي = الحكم الإلهي"""@ar ;
    hesin:hasComponent """يُقدم كمقابل للديمقراطي"""@ar ;
    hesin:hasComponent """يُوصف بالمرفوض"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_44 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C521 a hesin:Concept ;
    rdfs:label """طاعة غير الله في التشريع شرك (قياسًا على الميتة)"""@ar ;
    hesin:definition """أن طاعة غير الله في التشريع ولو في مسألة جزئية (كحكم الميتة) تعتبر شركًا، فكيف بطاعة غير الله في شأن الأمة كله."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """وَإِنَّ الشَّيَاطِينَ لَيُوحُونَ إِلَى أَوْلِيَائِهِمْ لِيُجَادِلُوكُمْ وَإِنْ أَطَعْتُمُوهُمْ إِنَّكُمْ لَمُشْرِكُونَ} (الأنعام:121) أن تطيعوهم في شأن واحد من شئون مخلوقٍ واحد من مخلوقاته إنكم إذاً لمشركون"""@ar ;
    hesin:actions """رفض أي تشريع لا يستند إلى شرع الله."""@ar ;
    hesin:hasSynonym """شرك الطاعة"""@ar ;
    hesin:hasSynonym """شرك التشريع"""@ar ;
    hesin:hasComponent """طاعة غير الله شرك"""@ar ;
    hesin:hasComponent """الميتة نموذج جزئي"""@ar ;
    hesin:hasComponent """التشريع العام أولى بالتحريم"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_44 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C522 a hesin:Concept ;
    rdfs:label """حضور الله في قضاء داود وسليمان"""@ar ;
    hesin:definition """أن الله شاهد حاضر في قضاء الأنبياء، وهو الذي يفهمهم الأحكام، مما ينفي فكرة غياب الله بعد انقطاع الوحي."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَدَاوُدَ وَسُلَيْمَانَ إِذْ يَحْكُمَانِ فِي الْحَرْثِ إِذْ نَفَشَتْ فِيهِ غَنَمُ الْقَوْمِ وَكُنَّا لِحُكْمِهِمْ شَاهِدِينَ} (الانبياء:78) لا حظوا العبارة هذه:{وَكُنَّا لِحُكْمِهِمْ شَاهِدِينَ فَفَهَّمْنَاهَا سُلَيْمَانَ}"""@ar ;
    hesin:actions """الإيمان بأن الله شاهد على كل شيء."""@ar ;
    hesin:hasSynonym """شهادة الله"""@ar ;
    hesin:hasSynonym """تدخل الله"""@ar ;
    hesin:hasComponent """الله شاهد على الحكم"""@ar ;
    hesin:hasComponent """يفهم سليمان الحكم"""@ar ;
    hesin:hasComponent """تدخل إلهي في قضية جزئية"""@ar ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C523 a hesin:Concept ;
    rdfs:label """الاستخلاف في المال"""@ar ;
    hesin:definition """أن المال ليس ملكًا حقيقيًا للإنسان، بل هو مستخلف فيه، والله هو المالك الحقيقي."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَأَنْفِقُوا مِمَّا جَعَلَكُمْ مُسْتَخْلَفِينَ فِيهِ} (الحديد:7) بعد أن قرر لكم بأنه هو الذي خلق السماوات والأرض, وأن له ملك السماوات والأرض، إذاً فما أنتم إلا عبارة عن مستخلفين فيما بين أيديكم من أموال"""@ar ;
    hesin:actions """استحضار أن المال أمانة."""@ar ;
    hesin:hasSynonym """المال مستخلف"""@ar ;
    hesin:hasSynonym """أمانة المال"""@ar ;
    hesin:hasComponent """الله المالك الحقيقي"""@ar ;
    hesin:hasComponent """الإنسان مستخلف"""@ar ;
    hesin:hasComponent """الإنفاق واجب"""@ar ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C524 a hesin:Concept ;
    rdfs:label """إرجاع الأمور إلى الله"""@ar ;
    hesin:definition """أن الأمور كلها ترجع إلى الله في النهاية، وهو الذي يهيئ المتغيرات ويخلق الظروف، بخلاف ملوك الدنيا الذين تخرج الأمور عن أيديهم."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَإِلَى اللَّهِ تُرْجَعُ الْأُمُورُ} (الحديد:5) هو ملكها، ما أكثر الملوك في هذه الدنيا والرؤساء، لكن أليست الأمور تخرج عن أيديهم في كثير من أحوالهم... أما الله سبحانه وتعالى فهو وحده الذي إليه ترجع الأمور"""@ar ;
    hesin:actions """الثقة بأن الله هو المرجع النهائي."""@ar ;
    hesin:hasSynonym """المرجعية لله"""@ar ;
    hesin:hasComponent """الأمور ترجع إلى الله"""@ar ;
    hesin:hasComponent """الله يهيئ المتغيرات"""@ar ;
    hesin:hasComponent """لا تخرج الأمور عن إرادته"""@ar ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C601 a hesin:Concept ;
    rdfs:label """تكرار "هو الله" وأثره"""@ar ;
    hesin:definition """تكرار "هو الله" في الآيات يخلق التفاتة في النفس لتنقطع عن كل ما سوى الله وتتجه إليه وحده."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """عبارة (هو) هي تناجيك في كل لحظة وأنت تبحث عن أن تنصرف بذهنك إلى هذه الجهة أو إلى هذه الجهة، تقول لك: {هُوَ} وحده {اللَّهُ}"""@ar ;
    hesin:actions """استحضار معنى "هو" عند التوجه إلى أي شيء."""@ar ;
    hesin:hasSynonym """التفاتة قرآنية"""@ar ;
    hesin:hasSynonym """تأكيد التوحيد"""@ar ;
    hesin:hasComponent """التفاتة ذهنية"""@ar ;
    hesin:hasComponent """انقطاع عن غير الله"""@ar ;
    hesin:hasComponent """توجيه الانتباه إلى الله وحده"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_45 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C602 a hesin:Concept ;
    rdfs:label """عالم الغيب والشهادة"""@ar ;
    hesin:definition """صفة إلهية تعني أن علم الله شامل لكل ما هو غائب عن الحواس وما هو حاضر مشهود."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{هُوَ اللَّهُ الَّذِي لا إِلَهَ إِلَّا هُوَ عَالِمُ الْغَيْبِ وَالشَّهَادَةِ} (الحشر:22) أليس في هذا ما يدفعني إلى أن أثق به، وأطمئن إليه، وأتوكل عليه؟"""@ar ;
    hesin:actions """استحضار علم الله المحيط عند الخوف من المخلوقين."""@ar ;
    hesin:hasSynonym """علم الله المحيط"""@ar ;
    hesin:hasComponent """علم الغيب"""@ar ;
    hesin:hasComponent """علم الشهادة"""@ar ;
    hesin:hasComponent """لا يخفى عليه شيء"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_45 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C603 a hesin:Concept ;
    rdfs:label """الملك"""@ar ;
    hesin:definition """أن الله هو المالك الحقيقي المطلق لكل شيء، وملكه ليس ملك تسلط وجبروت، بل ملك رحمة وتكريم."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{الْمَلِكُ} يعني أنه هو وحده من له ملك السماوات والأرض وما فيهما، إذاً فهو هو وحده من له حق التصرف فينا، وهو وحده من يجب أن نرغب إليه، ونخاف منه"""@ar ;
    hesin:actions """استحضار أن الله هو المالك الحقيقي عند الخوف من حكام الأرض."""@ar ;
    hesin:hasSynonym """المالك الحقيقي"""@ar ;
    hesin:hasSynonym """صاحب الملك المطلق"""@ar ;
    hesin:hasComponent """ملك مطلق"""@ar ;
    hesin:hasComponent """حق التصرف"""@ar ;
    hesin:hasComponent """ملك رحمة وتكريم"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_45 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C604 a hesin:Concept ;
    rdfs:label """القدوس"""@ar ;
    hesin:definition """أن الله منزه عن كل عيب ونقص، وهذه الصفة تجعل الانتماء إليه فخرًا وشرفًا."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{الْقُدُّوسُ} المُنَزَّهُ المُعَظَّم، فأنت عندما تكون منقطعاً إليه ملتجئاً إليه تجهر بأنه ربك وأنه ملكك، فإنه من هو فخرٌ لك أن يكون إلهك؛ لأنه (قدُّوس)"""@ar ;
    hesin:actions """استشعار الفخر عند ذكر اسم الله القدوس."""@ar ;
    hesin:hasSynonym """المنزه"""@ar ;
    hesin:hasSynonym """المقدس"""@ar ;
    hesin:hasComponent """تنزيه عن العيوب"""@ar ;
    hesin:hasComponent """تعظيم"""@ar ;
    hesin:hasComponent """الفخر بالانتماء إليه"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_45 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C605 a hesin:Concept ;
    rdfs:label """السلام"""@ar ;
    hesin:definition """أن الله هو مصدر السلام والأمن، وهو الذي يمنح أولياءه السلامة والأمان في الدنيا والآخرة."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{السَّلامُ} سلام لأوليائه... فكن من أوليائه ليرعاك ويحيطك بالسلامة بالأمن من الضلال، من الذل في هذه الدنيا"""@ar ;
    hesin:actions """طلب السلام من الله وحده."""@ar ;
    hesin:hasSynonym """مصدر السلام"""@ar ;
    hesin:hasSynonym """واهب الأمن"""@ar ;
    hesin:hasComponent """سلام لأوليائه"""@ar ;
    hesin:hasComponent """أمن من الضلال والذل"""@ar ;
    hesin:hasComponent """دار السلام في الآخرة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_45 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C606 a hesin:Concept ;
    rdfs:label """المؤمن"""@ar ;
    hesin:definition """أن الله هو المؤمن لأوليائه، أي الموثوق به والمصدق لعباده الصالحين."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{الْمُؤْمِنُ} مؤمن لأوليائه، فكن من أوليائه ليرعاك ويحيطك بالسلامة"""@ar ;
    hesin:actions """الثقة بأن الله مؤمن لأوليائه."""@ar ;
    hesin:hasSynonym """المصدق"""@ar ;
    hesin:hasSynonym """الموثوق"""@ar ;
    hesin:hasComponent """إيمان لأوليائه"""@ar ;
    hesin:hasComponent """رعاية وحماية"""@ar ;
    hesin:hasComponent """أمن"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_45 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C607 a hesin:Concept ;
    rdfs:label """المهيمن"""@ar ;
    hesin:definition """أن الله هو المهيمن على كل شيء، فكل المخلوقات تحت هيمنته وقدرته، فلا ينبغي الخوف منهم."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{الْمُهَيْمِنُ} هو المهيمن على كل شيء، فكيف تخاف، وكيف ترهب ممن هم تحت هيمنته!!"""@ar ;
    hesin:actions """استحضار هيمنة الله عند الخوف من أي مخلوق."""@ar ;
    hesin:hasSynonym """المسيطر"""@ar ;
    hesin:hasSynonym """الرقيب"""@ar ;
    hesin:hasComponent """هيمنة على كل شيء"""@ar ;
    hesin:hasComponent """لا شيء يخرج عن هيمنته"""@ar ;
    hesin:hasComponent """الأمن من تحت الهيمنة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_45 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C608 a hesin:Concept ;
    rdfs:label """العزيز الجبار المتكبر"""@ar ;
    hesin:definition """أن الله عزيز لا يقهر، جبار يقهر أعداءه، متكبر عن صفات النقص، وهذه الصفات تجعل المؤمن قويًا في مواجهة أعدائه."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هو { الْعَزِيزُ الْجَبَّارُ الْمُتَكَبِّرُ} بما في هذه الأسماء من معاني العزة والجبروت والقهر للأعداء، فأنت عندما تلتجئ إليه لا يمكن أن تقول عنه: (الله هو طيب، لكن نفسه سمحة...)"""@ar ;
    hesin:actions """استحضار هذه الأسماء عند مواجهة الأعداء."""@ar ;
    hesin:hasSynonym """القاهر"""@ar ;
    hesin:hasSynonym """الغالب"""@ar ;
    hesin:hasComponent """عزيز: لا يقهر"""@ar ;
    hesin:hasComponent """جبار: قاهر للأعداء"""@ar ;
    hesin:hasComponent """متكبر: عن صفات النقص"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_45 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C609 a hesin:Concept ;
    rdfs:label """الخالق البارئ المصور"""@ar ;
    hesin:definition """أن الله هو الخالق المبدع الذي يخلق من لا شيء، ويصور المخلوقات على أحسن صورة، وهو القادر على إمداد أوليائه بالأموال والبنين."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{هُوَ اللَّهُ الْخَالِقُ الْبَارِئُ الْمُصَوِّرُ} هو من قال لبني إسرائيل: {ثُمَّ رَدَدْنَا لَكُمُ الْكَرَّةَ عَلَيْهِمْ وَأَمْدَدْنَاكُمْ بِأَمْوَالٍ وَبَنِينَ}... الله هو الخالق، هو الذي يستطيع أن يمدكم بأموال وبنين"""@ar ;
    hesin:actions """استحضار أن الله خالق كل شيء عند اليأس."""@ar ;
    hesin:hasSynonym """المبدع"""@ar ;
    hesin:hasSynonym """الموجد"""@ar ;
    hesin:hasComponent """خالق: موجد من العدم"""@ar ;
    hesin:hasComponent """بارئ: مبدع"""@ar ;
    hesin:hasComponent """مصور: مصور على أحسن تقويم"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_45 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C610 a hesin:Concept ;
    rdfs:label """الأسماء الحسنى"""@ar ;
    hesin:definition """أن أسماء الله الحسنى ليست مجرد ألفاظ، بل تعبر عن صفات كماله المطلق، وهي دعوة للإنسان للتوجه إلى الله والثقة به."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{لَهُ الْأَسْمَاءُ الْحُسْنَى} فهنا ذكر لنا مجموعة من أسمائه الحسنى، ماذا تعني؟ تعني كمالاً بالنسبة لله سبحانه وتعالى، ليس مجرد أسماء ألفاظ لا تعني شيئاً"""@ar ;
    hesin:actions """جمع أسماء الله الحسنى والتأمل في معانيها."""@ar ;
    hesin:hasSynonym """أسماء الله"""@ar ;
    hesin:hasSynonym """صفات الكمال"""@ar ;
    hesin:hasComponent """تعبر عن كمال الله"""@ar ;
    hesin:hasComponent """شهادة بصفاته العليا"""@ar ;
    hesin:hasComponent """دليل على استحقاقه للعبادة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_45 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C611 a hesin:Concept ;
    rdfs:label """الرحمن الرحيم (المبالغة في الرحمة)"""@ar ;
    hesin:definition """أن الله رحمن ورحيم، واجتماع الاسمين يفيد المبالغة في سعة الرحمة، وأن كل هداية وتشريع منه يقوم على أساس الرحمة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{هُوَ الرَّحْمَنُ الرَّحِيمُ} وكما قلنا في درس سابق أن مجموع اللفظتين تفيد المبالغة في أنه رحيم بعباده"""@ar ;
    hesin:actions """تذكر رحمة الله عند الشعور بالذنب."""@ar ;
    hesin:hasSynonym """واسع الرحمة"""@ar ;
    hesin:hasComponent """رحمة واسعة"""@ar ;
    hesin:hasComponent """التشريع من منطلق الرحمة"""@ar ;
    hesin:hasComponent """التدبير من منطلق الرحمة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_46 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C612 a hesin:Concept ;
    rdfs:label """رحمة الله في رعاية الصغار"""@ar ;
    hesin:definition """أن مظاهر الرحمة في رعاية الصغار (في البشر والحيوانات) هي من دلائل رحمة الله الواسعة بخلقه."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """رحمته بنا ونحن في أحضان أمهاتنا، يعطفن علينا بقلوب مليئة بالرأفة والشفقة... وهكذا تجد في مختلف الحيوانات الأخرى، حتى تلك الحيوانات الشرسة... أنثى التمساح التي ليس له حِجْر تحتضن صغارها فيه، أين تضع صغارها؟ في فمها"""@ar ;
    hesin:actions """التأمل في رعاية الأمهات لصغارهن."""@ar ;
    hesin:hasSynonym """رحمة الأمهات"""@ar ;
    hesin:hasSynonym """شفقة الخالق"""@ar ;
    hesin:hasComponent """رحمة الأمهات بالأطفال"""@ar ;
    hesin:hasComponent """رعاية الحيوانات لصغارها"""@ar ;
    hesin:hasComponent """حتى الحيوانات الشرسة ترحم صغارها"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_46 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C613 a hesin:Concept ;
    rdfs:label """مضاعفة الحسنات كرحمة"""@ar ;
    hesin:definition """أن مضاعفة الحسنات (الحسنة بعشر، إلى سبعمائة، وأكثر) هي من مظاهر رحمة الله الواسعة، التي لا يوجد مثلها في العلاقات البشرية."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """الرحمن الرحيم... يفتح لهم في الدنيا أبواباً كثيرة لمضاعفة الأجر: من أول وَهْلَه الحسنة بعشر حسنات... أي الناس من أقاربك من أرحم الناس بك يمكن أن يبادلك على هذا النحو؟"""@ar ;
    hesin:actions """استشعار عظمة رحمة الله عند فعل الحسنات."""@ar ;
    hesin:hasSynonym """التضعيف"""@ar ;
    hesin:hasSynonym """التكثير"""@ar ;
    hesin:hasComponent """الحسنة بعشر"""@ar ;
    hesin:hasComponent """إلى سبعمائة ضعف"""@ar ;
    hesin:hasComponent """مضاعفة في الأزمنة والأماكن والأحوال"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_46 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C614 a hesin:Concept ;
    rdfs:label """تبديل السيئات بحسنات"""@ar ;
    hesin:definition """أن الله يبدل سيئات التائبين إلى حسنات، وهي رحمة لا يجدها الإنسان في علاقاته مع البشر."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """عندما نتوب إليه - يبدل سيئاتنا بحسنات، الأمر الذي لا يكاد أن يفعله أي شخص ممن تعتذر نحوهم من زلة بدرت منك إليهم"""@ar ;
    hesin:actions """استحضار هذه الرحمة عند التوبة."""@ar ;
    hesin:hasSynonym """التوبة"""@ar ;
    hesin:hasSynonym """المحو"""@ar ;
    hesin:hasComponent """التوبة سبب"""@ar ;
    hesin:hasComponent """تبديل السيئات بحسنات"""@ar ;
    hesin:hasComponent """رحمة لا مثيل لها"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_46 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C615 a hesin:Concept ;
    rdfs:label """بسم الله الرحمن الرحيم (تأسيس السور)"""@ar ;
    hesin:definition """أن افتتاح معظم سور القرآن بالبسملة دليل على أن كل ما في القرآن من هداية وتشريع هو من منطلق رحمة الله بعباده."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """الله سبحانه وتعالى صدر سور كتابه الكريم بآية {بِسْمِ اللَّهِ الرَّحْمَنِ الرَّحِيمِ} وهي آية من أعظم الآيات وأهمها، لها دلالتها المهمة جداً جداً، على أن كل هداية منه تعالى، وكل تشريع منه، وكل توجيه داخل هذا القرآن الكريم هو من منطلق رحمته"""@ar ;
    hesin:actions """استحضار معنى البسملة عند قراءة القرآن."""@ar ;
    hesin:hasSynonym """بسملة"""@ar ;
    hesin:hasSynonym """افتتاحية الرحمة"""@ar ;
    hesin:hasComponent """افتتاحية السور"""@ar ;
    hesin:hasComponent """دليل على رحمة الله"""@ar ;
    hesin:hasComponent """كل تشريع من رحمة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_46 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C616 a hesin:Concept ;
    rdfs:label """التمجيد كأسلوب معرفي"""@ar ;
    hesin:definition """منهج قرآني في معرفة الله يعتمد على التمجيد والتعظيم من خلال عرض أسمائه الحسنى وصفاته الكاملة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """في مجال معرفة الله سبحانه وتعالى، وفي سبيل ترسيخ مفاهيم معرفته في أنفسنا لتعزيز الثقة به هناك وسيلة هي من أهم الوسائل، تلك الوسيلة هي: التمجيد والتعظيم لله سبحانه وتعالى من خلال عرض الثناء عليه بكماله"""@ar ;
    hesin:actions """تخصيص أوقات للتمجيد والتعظيم."""@ar ;
    hesin:hasSynonym """التعظيم"""@ar ;
    hesin:hasSynonym """الثناء"""@ar ;
    hesin:hasComponent """عرض الثناء"""@ar ;
    hesin:hasComponent """ذكر الأسماء الحسنى"""@ar ;
    hesin:hasComponent """شهادة بكمال الله"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_47 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C617 a hesin:Concept ;
    rdfs:label """التسبيح والتحميد والتهليل والتكبير"""@ar ;
    hesin:definition """أن التسبيح (تنزيه الله)، والتحميد (الثناء بالحمد)، والتهليل (توحيد الله)، والتكبير (تعظيم الله) هي أذكار شرعية لتمجيد الله وتقديسه."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هذا الأسلوب بالنسبة لنا يجب أن نرسخه في حياتنا أن تكون هناك أوقات كما نحن ندعو الله في أوقات معينة يكون هناك أوقات نمجِّد الله فيها، نعظم الله نقدس الله، من خلال ذكره الكثير الذي شرعه مثل (سُبْحَانَ اللَّهِ، وَالْحَمْدُ لِلَّهِ، ولا إِلَهَ إلا اللَّهُ، واللَّهُ أَكْبَرُ)"""@ar ;
    hesin:actions """ترديد هذه الأذكار بخشوع."""@ar ;
    hesin:hasSynonym """الأذكار الأربعة"""@ar ;
    hesin:hasComponent """تسبيح: تنزيه"""@ar ;
    hesin:hasComponent """تحميد: ثناء"""@ar ;
    hesin:hasComponent """تهليل: توحيد"""@ar ;
    hesin:hasComponent """تكبير: تعظيم"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_47 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C618 a hesin:Concept ;
    rdfs:label """تمجيد الله (عبادة وثناء)"""@ar ;
    hesin:definition """أن تمجيد الله والثناء عليه هو عبادة مستقلة لها أثرها في النفس، تختلف عن الدعاء بالحاجات."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هناك نوع آخر يسمى (تمجيد لله وثناء عليه)، هو عبادة مهمة ذات قيمة عظيمة، ولها أثرها فيما يتعلق بالنفس، في مقام معرفة الله سبحانه وتعالى واستشعار عظمته"""@ar ;
    hesin:actions """تخصيص أوقات للتمجيد بجانب الدعاء."""@ar ;
    hesin:hasSynonym """التقديس"""@ar ;
    hesin:hasSynonym """التكبير"""@ar ;
    hesin:hasComponent """عبادة مستقلة"""@ar ;
    hesin:hasComponent """تخلق شعورًا بعظمة الله"""@ar ;
    hesin:hasComponent """أثر في النفس"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_47 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C619 a hesin:Concept ;
    rdfs:label """دعاء الإمام زين العابدين في التمجيد"""@ar ;
    hesin:definition """أدعية أهل البيت (خاصة دعاء يوم عرفة للإمام زين العابدين) هي نموذج راقٍ في تمجيد الله والثناء عليه، ينبغي العودة إليها."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """فيما أثر عن الإمام زين العابدين (عليه السلام) في دعاء يوم عرفة قال (عليه السلام): (الحمد لله رب العالمين، اللهم لك الحمد بديع السموات والأرض ذا الجلال والإكرام...)"""@ar ;
    hesin:actions """قراءة أدعية أهل البيت بخشوع."""@ar ;
    hesin:hasSynonym """أدعية أهل البيت"""@ar ;
    hesin:hasComponent """تمجيد بأسلوب قرآني"""@ar ;
    hesin:hasComponent """شرح أسماء الله الحسنى"""@ar ;
    hesin:hasComponent """خلق شعور بعظمة الله"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_47 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C620 a hesin:Concept ;
    rdfs:label """الفخر بأن الله قدوس"""@ar ;
    hesin:definition """أن الانتماء إلى الله (كونه إلهًا وملكًا وقدوسًا) هو فخر وشرف، بخلاف الانتماء إلى بشر ناقصين."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:actions """استشعار الفخر عند قول "لا إله إلا الله"."""@ar ;
    hesin:hasSynonym """الشرف بالعبودية"""@ar ;
    hesin:hasComponent """الله قدوس منزه"""@ar ;
    hesin:hasComponent """الانتماء إليه شرف"""@ar ;
    hesin:hasComponent """لا تخجل من نسبك إليه"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_48 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C621 a hesin:Concept ;
    rdfs:label """الفخر بالانتماء إلى أهل البيت"""@ar ;
    hesin:definition """أن الانتماء إلى أهل البيت (كقدوات) هو فخر، لأنهم مطهرون كاملون، بخلاف من يحتاج أتباعهم إلى تبرير أخطائهم."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """من الفخر لنا، أن قدواتنا من أهل البيت، ليسوا من أولئك الملطخين بعار المخالفة للرسول (صلى الله عليه وعلى آله وسلم) الملطخين بالأخطاء والمساوئ... فأنت لا تخجل إذا ما قلت أن وليّك الإمام علي بن أبي طالب (عليه السلام)"""@ar ;
    hesin:actions """استشعار الفخر بالانتماء إلى أهل البيت."""@ar ;
    hesin:hasSynonym """القدوة الطاهرة"""@ar ;
    hesin:hasComponent """أهل البيت مطهرون"""@ar ;
    hesin:hasComponent """لا يحتاجون إلى تبرير"""@ar ;
    hesin:hasComponent """الفخر بالانتماء إليهم"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_48 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C622 a hesin:Concept ;
    rdfs:label """ضعف الثقة بالله (أزمة)"""@ar ;
    hesin:definition """حالة من ضعف الإيمان تجعل المسلم يخاف من المخلوقين أكثر من خوفه من الله، رغم ضعفهم وهيمنة الله عليهم."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هذه هي التي ضربت المسلمين كباراً وصغاراً (عدم الثقة بالله)، عدم الثقة بالله حتى فينا نحن الصغار نخاف من شخص هو مسكين بالنسبة للآخرين"""@ar ;
    hesin:actions """علاج ضعف الثقة بالتأمل في أسماء الله."""@ar ;
    hesin:hasSynonym """أزمة الثقة"""@ar ;
    hesin:hasComponent """الخوف من المخلوقين"""@ar ;
    hesin:hasComponent """نسيان هيمنة الله"""@ar ;
    hesin:hasComponent """ضعف اليقين"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_49 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C623 a hesin:Concept ;
    rdfs:label """سلسلة الهيمنة (من يهيمن على من)"""@ar ;
    hesin:definition """أن كل المخلوقات (بما فيها الطواغيت) تحت هيمنة الله، فمن يخاف منهم يخاف من مقهورين تحت قدرة الله."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """نخاف من شخص هناك وهو مهيمن عليه شخص آخر، وهذا الشخص الآخر هو مهيمن عليه شخص آخر، وهذا الكبير في الأخير هناك من هو مهيمن عليه وهو الله الواحد القهار"""@ar ;
    hesin:actions """تذكر أن كل من تخاف منهم تحت هيمنة الله."""@ar ;
    hesin:hasSynonym """التسلسل الهرمي للقوى"""@ar ;
    hesin:hasComponent """هيمنة الله على الجميع"""@ar ;
    hesin:hasComponent """كل الطواغيت مقهورون"""@ar ;
    hesin:hasComponent """الخوف منهم خوف من مقهورين"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_49 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C624 a hesin:Concept ;
    rdfs:label """السلام الحقيقي في العزة"""@ar ;
    hesin:definition """أن السلام الحقيقي يتحقق بالقوة والعزة المستمدة من الله، أما البحث عن السلام من موقف الضعف فهو استسلام."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """السلام لا يتحقق لك إلا إذا كنت في موقف عزة وقوة ومكانة، أما أن تبحث عن السلام وأنت تحت، - كما يصنع بعض الفلسطينيين، وكما يصنع العرب الآن - فإنما هو استسلام"""@ar ;
    hesin:actions """طلب العزة من الله، لا السلام بالاستسلام."""@ar ;
    hesin:hasSynonym """السلام مع القوة"""@ar ;
    hesin:hasComponent """السلام مع القوة"""@ar ;
    hesin:hasComponent """الاستسلام ليس سلامًا"""@ar ;
    hesin:hasComponent """العزة من الله"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_49 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C625 a hesin:Concept ;
    rdfs:label """نقد البحث عن السلام من غير الله"""@ar ;
    hesin:definition """نقد الحكومات العربية التي تبحث عن السلام من أمريكا وإسرائيل وروسيا، بدلاً من اللجوء إلى الله الذي هو السلام الحقيقي."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:actions """توجيه الدعوات والجهود نحو الله."""@ar ;
    hesin:hasSynonym """نقد الدبلوماسية الضعيفة"""@ar ;
    hesin:hasComponent """البحث عن السلام من الأعداء"""@ar ;
    hesin:hasComponent """إهمال اللجوء إلى الله"""@ar ;
    hesin:hasComponent """الاستسلام بدل السلام"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_49 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C626 a hesin:Concept ;
    rdfs:label """الإنسان ظلوم كفار"""@ar ;
    hesin:definition """أن الإنسان بطبيعته ظالم لنفسه جاحد لنعمة الله، إلا من رحم الله."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{إِنَّ الْأِنْسَانَ لَظَلُومٌ كَفَّارٌ} (ابراهيم:34) وفعلاً كل إنسان يستحق اللعنة إذا لم يرجع ليتفهم جيّداً معاني رحمة الله به"""@ar ;
    hesin:actions """استشعار هذه الصفة للتوبة."""@ar ;
    hesin:hasSynonym """جحود النعمة"""@ar ;
    hesin:hasComponent """ظلوم: يظلم نفسه"""@ar ;
    hesin:hasComponent """كفار: يجحد النعمة"""@ar ;
    hesin:hasComponent """الحاجة إلى التذكير"""@ar ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C627 a hesin:Concept ;
    rdfs:label """تكرار "لا إله إلا الله" كحجة"""@ar ;
    hesin:definition """أن تكرار "لا إله إلا الله" عبر القرون والأجيال هو دليل عملي على أنه لا إله إلا الله، فلو كان هناك إله آخر لظهر."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """نحن نرددها جيلاً بعد جيل مئات السنين، يرددها المسلمون في كل بقاع الدنيا، ولا أحد ظهر ليقول بأنه باقي واحد ثاني هو أنا. إذاً فحقيقة ليس هناك إله آخر"""@ar ;
    hesin:actions """استشعار حقيقة التوحيد عند التكرار."""@ar ;
    hesin:hasSynonym """الدليل العملي على التوحيد"""@ar ;
    hesin:hasComponent """التكرار عبر الأجيال"""@ar ;
    hesin:hasComponent """عدم ظهور مدّعٍ"""@ar ;
    hesin:hasComponent """إثبات عملي"""@ar ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C701 a hesin:Concept ;
    rdfs:label """كمال الله المطلق"""@ar ;
    hesin:definition """أن الله متصف بالكمال المطلق في ذاته وصفاته وأفعاله، بخلاف كل المخلوقات التي فيها نقص وحاجة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """إن من أعظم ما يؤكد عليه القرآن الكريم ويعمل على ترسيخه في النفوس هو: الشعور بكمال الله المطلق، أي هو من لا يحتاج أبداً إلى غيره، هو الكامل"""@ar ;
    hesin:actions """استحضار كمال الله عند مقارنته بأي مخلوق."""@ar ;
    hesin:hasSynonym """الكمال المطلق"""@ar ;
    hesin:hasSynonym """التنزيه"""@ar ;
    hesin:hasComponent """لا يحتاج إلى غيره"""@ar ;
    hesin:hasComponent """كامل في ذاته"""@ar ;
    hesin:hasComponent """كامل في صفاته"""@ar ;
    hesin:hasComponent """كامل في أفعاله"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_50 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C702 a hesin:Concept ;
    rdfs:label """التنزيه (تنزيه الله عما لا يليق)"""@ar ;
    hesin:definition """أن ينزه الإنسان الله في ذاته (عن الأعضاء والتشبيه)، وفي أفعاله (عن الظلم والعبث)، وفي تشريعه (عن الأمر بما يخالف حكمته)."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """التسبيح لله فيما يعنيه التسبيح من تنزيه لله سبحانه وتعالى وتقديس وإجلال وتعظيم له، فيما يعنيه أساساً من تنزيه لله عما لا يليق أن ينسب إليه لا باعتبار ذاته، ولا أفعاله، ولا في تشريعه"""@ar ;
    hesin:actions """تنزيه الله في كل ما ينسب إليه."""@ar ;
    hesin:hasSynonym """التسبيح"""@ar ;
    hesin:hasSynonym """التقديس"""@ar ;
    hesin:hasComponent """تنزيه الذات"""@ar ;
    hesin:hasComponent """تنزيه الأفعال"""@ar ;
    hesin:hasComponent """تنزيه التشريع"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_50 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C703 a hesin:Concept ;
    rdfs:label """الكمال المطلق يستلزم الوحدانية"""@ar ;
    hesin:definition """أن استحالة وجود إلهين كاملين هو نتيجة منطقية لمبدأ الكمال المطلق، لأن أي اثنين سيكون كل منهما ناقصًا بالنسبة للآخر."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """الكمال المطلق لا يمكن أن يكون إلا لواحد، لا يمكن أن تفترض أن هناك اثنين كاملين، كل واحد منهما سيظهر ناقصاً بالنسبة للآخر، الكمال المطلق لا يمكن أن يكون إلا لواحد، وهو الله سبحانه وتعالى"""@ar ;
    hesin:actions """استخدام مبدأ الكمال في الرد على الشرك."""@ar ;
    hesin:hasSynonym """لا إله إلا الله"""@ar ;
    hesin:hasComponent """الكمال المطلق خاص بواحد"""@ar ;
    hesin:hasComponent """الاثنان يناقض أحدهما الآخر"""@ar ;
    hesin:hasComponent """التوحيد نتيجة منطقية"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_50 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C704 a hesin:Concept ;
    rdfs:label """الفطرة على البحث عن الأكمل"""@ar ;
    hesin:definition """أن الإنسان مفطور على البحث عن الأكمل في كل شيء، وهذا السلم الفطري ينتهي بالله الكامل المطلق."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """مبدأ الكمال، والبحث عن الأكمل هو من الفطر التي فطر الله الناس عليها، وهو سلَّم ينتهي بالله سبحانه وتعالى الكامل الكمال المطلق"""@ar ;
    hesin:actions """استخدام هذا المبدأ في الدعوة إلى الله."""@ar ;
    hesin:hasSynonym """مبدأ الكمال الفطري"""@ar ;
    hesin:hasComponent """البحث عن الأكمل فطرة"""@ar ;
    hesin:hasComponent """سلم متدرج"""@ar ;
    hesin:hasComponent """نهايته الله"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_50 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C705 a hesin:Concept ;
    rdfs:label """نقد إثبات الوجه واليد لله"""@ar ;
    hesin:definition """نقد عقيدة إثبات الأعضاء (الوجه، اليد، الرجل) لله، لأن الأعضاء من خواص المخلوقات المحتاجة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """نحن نقول في عقائدنا: لا يجوز أن نقول: أن لله وجهاً, كما يقول الآخرون، وليس له يد, ليس له أعين كما يقول الآخرون، هذه آليات خلقها لنا نحن الناقصين، نحن القاصرين، نحن المحتاجين"""@ar ;
    hesin:actions """تنزيه الله عن صفات المخلوقات."""@ar ;
    hesin:hasSynonym """نقد التجسيم"""@ar ;
    hesin:hasSynonym """نقد التشبيه"""@ar ;
    hesin:hasComponent """الأعضاء من خواص المخلوقات"""@ar ;
    hesin:hasComponent """التركيب علامة الحدوث"""@ar ;
    hesin:hasComponent """إثبات الأعضاء يستلزم نقصًا"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_51 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C706 a hesin:Concept ;
    rdfs:label """التركيب علامة الحدوث"""@ar ;
    hesin:definition """أن أي موجود مركب من أجزاء لا بد أن يكون محدثًا (مخلوقًا)، لأن تركيبه يدل على وجود مركب له."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """التركيب علامة من علامات الحدوث. ماذا يعني الحدوث؟ أي أن هناك من منحه وجهه كما منحك وجهك، ومن منحه يده وجعلها في موضع في غير موضع وجهه... إذاً فهذه علامات الحدوث، إذاً هناك من منحه هذه الأشياء"""@ar ;
    hesin:actions """نفي التركيب عن الله."""@ar ;
    hesin:hasSynonym """الاستدلال على الحدوث بالتركيب"""@ar ;
    hesin:hasComponent """التركيب يدل على الحاجة إلى مركب"""@ar ;
    hesin:hasComponent """المركب محدث"""@ar ;
    hesin:hasComponent """الله ليس مركبًا"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_51 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C707 a hesin:Concept ;
    rdfs:label """نقد رؤية الله (الرؤية)"""@ar ;
    hesin:definition """نقد عقيدة رؤية الله في الآخرة، لأن الرؤية تستلزم شروطًا (مسافة، كيفية، تحديد) هي من خواص المحدثات، والله منزه عن ذلك."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{لا تُدْرِكُهُ الْأَبْصَارُ} (الأنعام:103) وتأتي العبارة مطلقة، وكلما هو تنزيه لذاته فهو تنزيه لذاته في الدنيا والآخرة... لماذا ننزه ذاته عن أن تدركه الأبصار؟ نفس الكلام الذي قلناه... متى ما قلنا بأنه يمكن أن يُرى فالرؤية لا تتحقق إلا من خلال شروط: أن يكون بينك وبين الطرف المرئي مسافة معقولة... ولا بد أن يكون على كيفية محددة، والتحديد والتكييف هو من خواص المحدثات"""@ar ;
    hesin:actions """رفض الدعوات التي تطلب رؤية الله."""@ar ;
    hesin:hasSynonym """استحالة رؤية الله"""@ar ;
    hesin:hasComponent """الرؤية تستلزم شروطًا"""@ar ;
    hesin:hasComponent """الشروط من خواص المحدثات"""@ar ;
    hesin:hasComponent """الله منزه عن ذلك"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_51 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C708 a hesin:Concept ;
    rdfs:label """نقد القول بأن الرؤية في الآخرة فقط"""@ar ;
    hesin:definition """نقد القول الذي يفرق بين الدنيا والآخرة في مسألة الرؤية، بدعوى أن الآية خاصة بالدنيا فقط، مع أن التنزيه مطلق."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """قالوا: يعني هذا في الدنيا أما في الآخرة فسنراه، ويدعون الله أيضاً أن يريهم وجهه الكريم... الباطل, النقص الذي نزه الله ذاته عنه يصبح عند بعض المسلمين عبادة يتعبدون الله بنسبتها إليه"""@ar ;
    hesin:actions """عدم التفريق بين الدنيا والآخرة في تنزيه الله."""@ar ;
    hesin:hasSynonym """تفريق الدنيا والآخرة"""@ar ;
    hesin:hasComponent """التفريق بين الدنيا والآخرة"""@ar ;
    hesin:hasComponent """نسبة النقص إلى الله"""@ar ;
    hesin:hasComponent """تحويل التنزيه إلى عبادة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_51 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C709 a hesin:Concept ;
    rdfs:label """نقد عقيدة خلق المعاصي"""@ar ;
    hesin:definition """نقد عقيدة الأشاعرة وغيرهم التي تزعم أن الله خالق أفعال العباد (بما فيها المعاصي)، لأن ذلك يتنافى مع كماله واستحقاقه للثناء."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هل سيَتَمَدّح بأنه الذي خلق المعاصي وخلق الظلم وخلق الفساد وخلق الكفر وخلق النفاق؟! هل هذا تمدُّح؟! لو كان هو من خلق الكفر والضلال والفساد والنفاق والمعاصي والباطل لما استحق أن نثني عليه"""@ar ;
    hesin:actions """تنزيه الله عن خلق القبائح."""@ar ;
    hesin:hasSynonym """نقد الجبر"""@ar ;
    hesin:hasSynonym """نقد خلق الأفعال"""@ar ;
    hesin:hasComponent """نسبة المعاصي إلى الله"""@ar ;
    hesin:hasComponent """تناقض مع الثناء"""@ar ;
    hesin:hasComponent """تناقض مع عدل الله"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_52 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C710 a hesin:Concept ;
    rdfs:label """الثناء على الله لا يتوافق مع خلق القبائح"""@ar ;
    hesin:definition """أن الثناء على الله (كالحمد والتسبيح) لا يتوافق مع الاعتقاد بأنه خالق المعاصي والشرور، لأن الثناء يكون على الكمال لا على النقص."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """فهل سيَتَمَدّح بأنه الذي خلق المعاصي... لو كان هو من خلق الكفر والضلال والفساد... لما استحق أن نثني عليه. نثني عليه مقابل ماذا؟ إذا كنا نقول: أنه مصدر القبيح ومصدر الفواحش، ومصدر الشرور, فلماذا نثني عليه؟"""@ar ;
    hesin:actions """تنزيه الله عن كل قبيح."""@ar ;
    hesin:hasSynonym """التناقض في الثناء"""@ar ;
    hesin:hasComponent """الثناء على الكمال"""@ar ;
    hesin:hasComponent """خلق القبائح نقص"""@ar ;
    hesin:hasComponent """التناقض في الاعتقاد"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_52 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C711 a hesin:Concept ;
    rdfs:label """نقد تأويل "وخلق كل شيء""""@ar ;
    hesin:definition """نقد التأويل الخاطئ لآية "وخلق كل شيء" التي وردت في مقام الثناء، بحملها على أن المعاصي داخلة تحت "كل شيء"."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هكذا, يقولون: [هذه عقيدة أهل السنة والجماعة، هذه عقيدتنا وهذا دليلها من القرآن{وَخَلَقَ كُلَّ شَيْءٍ } (الأنعام:101)، والمعاصي هي أشياء إذاً هو الذي خلقها!!]"""@ar ;
    hesin:actions """فهم الآيات في سياقها."""@ar ;
    hesin:hasSynonym """نقد الاستدلال بالآية"""@ar ;
    hesin:hasComponent """الاستدلال بالآية"""@ar ;
    hesin:hasComponent """إخراج الآية عن سياقها"""@ar ;
    hesin:hasComponent """تحميلها ما لا تحتمل"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_52 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C712 a hesin:Concept ;
    rdfs:label """السياق القرآني (القرائن المحيطة)"""@ar ;
    hesin:definition """أن فهم الآيات القرآنية لا يتم بمعزل عن السياق والقرائن (المقالية والحالية) التي تحدد المراد من العبارات المطلقة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """القرآن الكريم هو كتاب عربي, بلسان العرب, بأساليب العرب، ونحن نستخدم هذه العبارة, والقرائن المحيطة بها، والجو الذي تقدم فيه، الطرف الآخر الذي تتحدث معه هو من يعرف ماذا تعني"""@ar ;
    hesin:actions """فهم الآيات في ضوء سياقها."""@ar ;
    hesin:hasSynonym """تفسير القرآن بالقرآن"""@ar ;
    hesin:hasComponent """القرائن المقالية"""@ar ;
    hesin:hasComponent """القرائن الحالية"""@ar ;
    hesin:hasComponent """السياق العام"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_52 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C713 a hesin:Concept ;
    rdfs:label """الفطرة تعرف أن أفعال العبد منه"""@ar ;
    hesin:definition """أن الفطرة الإنسانية وحتى الحيوانية تشهد بأن أفعال العبد صادرة منه باختياره، وليست مخلوقة لله فيه قسرًا."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """كل إنسان بفطرته, بل الدواب بفطرتها تعرف أن أفعالها منها, أنها هي التي انطلقت فيها، ولهذا ترى القط, ترى الكلب عندما يعمل عملاً هو يعرف أنه عمل غير مسموح به"""@ar ;
    hesin:actions """الاستدلال بالفطرة على الاختيار."""@ar ;
    hesin:hasSynonym """الفطرة على الاختيار"""@ar ;
    hesin:hasComponent """الفطرة تشهد"""@ar ;
    hesin:hasComponent """الحيوانات تشهد"""@ar ;
    hesin:hasComponent """الشعور بالمسؤولية"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_52 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C714 a hesin:Concept ;
    rdfs:label """نقد تدجين الأمة للظالمين بالعقيدة"""@ar ;
    hesin:definition """أن عقيدة خلق الأفعال (الجبر) استخدمت لتبرير حكم الطغاة، بنسبة أفعالهم الظالمة إلى الله."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """الطواغيت وعلماء السوء هم من أجل خدمة السياسة الفاسدة, خدمة الطواغيت يحمِّلون الله كل سوء, وينسبون إلى الله كل قبيح فيشبهون على العوام من الناس، فمتى ما رأينا معاوية ووالياً بطغيانه وقبحه نقول: الله هو الذي ولاه، والأعمال التي تصدر من معاوية الله هو الذي خلقها!"""@ar ;
    hesin:actions """كشف الآثار السياسية للعقائد."""@ar ;
    hesin:hasSynonym """تسييس العقيدة"""@ar ;
    hesin:hasSynonym """خدمة الطواغيت"""@ar ;
    hesin:hasComponent """تبرير ظلم الحكام"""@ar ;
    hesin:hasComponent """نسبة الظلم إلى الله"""@ar ;
    hesin:hasComponent """تدجين الأمة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_52 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C715 a hesin:Concept ;
    rdfs:label """تنزيه تشريع الله عن طاعة الظالمين"""@ar ;
    hesin:definition """أن من تنزيه الله في تشريعه نفي أن يكون قد أمر بطاعة الظالمين والطواغيت، لأن ذلك يتنافى مع لعنه لهم في القرآن."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """تنزيه له سبحانه وتعالى أيضاً في تشريعه, وفي هدايته, أنزهه عن أن يشرع لي طاعة من يعصيه، أو يوجب علي أن أطيع الظالمين والجبارين والطواغيت والمتكبرين وهو من يلعنهم في كتابه"""@ar ;
    hesin:actions """رفض كل دعوى توجب طاعة الظالمين."""@ar ;
    hesin:hasSynonym """نقد طاعة الطواغيت"""@ar ;
    hesin:hasComponent """الله يلعن الظالمين"""@ar ;
    hesin:hasComponent """لا يمكن أن يأمر بطاعتهم"""@ar ;
    hesin:hasComponent """تنزيه التشريع"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_53 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C716 a hesin:Concept ;
    rdfs:label """إساءة نسبة التشريع الباطل إلى الله"""@ar ;
    hesin:definition """أن نسبة تشريعات باطلة (كطاعة الظالمين) إلى الله هي افتراء عظيم، ناتج عن الغفلة عن تنزيه الله."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """عندما نسينا هذا استسغنا عندما قالوا: هذا من دين الله، ورواه فلان عن فلان قال حدثني فلان أخبرني فلان أنه قال قال رسول الله كذا كذا .. إلى آخره صدق رسول الله. واعتقدناها ومشينا عليها، يُكذب على النبي (صلوات الله عليه وعلى آله) ويُفترى على الله سبحانه وتعالى"""@ar ;
    hesin:actions """تمييز الحق من الباطل في الروايات."""@ar ;
    hesin:hasSynonym """الافتراء على الله"""@ar ;
    hesin:hasComponent """الافتراء على الله"""@ar ;
    hesin:hasComponent """الكذب على النبي"""@ar ;
    hesin:hasComponent """استسغانة الناس بسبب الغفلة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_53 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C717 a hesin:Concept ;
    rdfs:label """الله لا يتغير (بخلاف البشر)"""@ar ;
    hesin:definition """أن الله لا يتغير ولا يتبدل، بخلاف البشر الذين قد يتغير مزاجهم وولاؤهم."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """وكونه مستحق للحمد هو لكماله, لقدسيته، فهو الكامل في الدنيا وفي الآخرة، فلا يمكن أن تخشى أن يتغير لديه مزاج كما يحصل للناس في هذه الدنيا"""@ar ;
    hesin:actions """الثقة بأن الله لا يتخلى عن أوليائه."""@ar ;
    hesin:hasSynonym """ثبات الكمال"""@ar ;
    hesin:hasComponent """لا يتغير مزاجه"""@ar ;
    hesin:hasComponent """لا يتبدل ولاؤه"""@ar ;
    hesin:hasComponent """ثبات الكمال"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_54 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C718 a hesin:Concept ;
    rdfs:label """الله خبير بعباده (بخلاف البشر)"""@ar ;
    hesin:definition """أن البشر (حتى أقوياءهم) يخطئون في تقدير الأمور، أما الله فهو الخبير الذي لا يخطئ."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """في هذه الدنيا نجد أمثلة كثيرة تبين أن كثيراً من أولئك الذين يعتمد عليهم الناس, فمتى ما انطلقوا ليفوا بوعودهم لهم كم تحصل من أخطاء .. أمريكا عندما دخلت أفغانستان... كم حصل من أخطاء من قِبَل الطائرات الأمريكية فضربت مدناً، وضربت مناطق هي تابعة لأحزاب المعارضة"""@ar ;
    hesin:actions """الثقة بأن الله لا يضيع جهود أوليائه."""@ar ;
    hesin:hasSynonym """الخبير"""@ar ;
    hesin:hasComponent """البشر يخطئون"""@ar ;
    hesin:hasComponent """أمريكا نموذج"""@ar ;
    hesin:hasComponent """الله لا يخطئ"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_54 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C719 a hesin:Concept ;
    rdfs:label """وعد الله لا يتخلف"""@ar ;
    hesin:definition """أن الله يفي بوعده لأوليائه، ولا يتخلى عنهم، بخلاف البشر الذين قد يتخلون عن حلفائهم."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """الله سبحانه وتعالى فهو من ينصر أولياءه, ومن يقف مع أوليائه، ومن لا يضيِّع جهود أوليائه، ومن يقرب أولياءه منه، ومن لا يفرط فيهم ولا يضيعهم ؛لأنه الحكيم الخبير"""@ar ;
    hesin:actions """الثقة بأن الله سينصر من نصره."""@ar ;
    hesin:hasSynonym """صدق الوعد"""@ar ;
    hesin:hasComponent """لا يضيع جهود أوليائه"""@ar ;
    hesin:hasComponent """لا يتخلى عنهم"""@ar ;
    hesin:hasComponent """الحكيم الخبير"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_54 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C720 a hesin:Concept ;
    rdfs:label """الإنسان خصيم مبين"""@ar ;
    hesin:definition """أن الإنسان بعد أن يرعاه الله من نطفة إلى رجل كامل، يتحول إلى خصيم لله معاند متمرد."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{خَلَقَ الإِنسَانَ مِن نُّطْفَةٍ فَإِذَا هُوَ خَصِيمٌ مُّبِينٌ}(النحل4) يلفت نظرك إلى أنك مخلوق من نطفة... ثم بعد أن يشتد عودك تتحول إلى خصيم لله"""@ar ;
    hesin:actions """استحضار بداية الإنسان للتذلل لله."""@ar ;
    hesin:hasSynonym """الجحود"""@ar ;
    hesin:hasSynonym """التمرد"""@ar ;
    hesin:hasComponent """بدء الإنسان من نطفة"""@ar ;
    hesin:hasComponent """رعاية الله له"""@ar ;
    hesin:hasComponent """التحول إلى خصيم"""@ar ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C721 a hesin:Concept ;
    rdfs:label """سعة علم الله"""@ar ;
    hesin:definition """أن علم الله محيط بكل شيء، من أكبر المخلوقات إلى أصغرها (كحبات القمح، الفيروسات)، ولا يعجزه حفظها."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لو تأتي إلى صنف واحد من مخلوقاته لبهرك سعة علمه سبحانه وتعالى به، كم في استراليا من مليارات حبات القمح وقت الزراعة؟ من الذي يستطيع أن يحصيها؟"""@ar ;
    hesin:actions """التأمل في سعة علم الله."""@ar ;
    hesin:hasSynonym """الإحصاء"""@ar ;
    hesin:hasSynonym """الإحاطة"""@ar ;
    hesin:hasComponent """علم بالمليارات"""@ar ;
    hesin:hasComponent """علم بالأصغر"""@ar ;
    hesin:hasComponent """لا يعجزه الحفظ"""@ar ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C722 a hesin:Concept ;
    rdfs:label """القاهر فوق عباده"""@ar ;
    hesin:definition """أن الله قاهر فوق جميع عباده، لا أحد يمكنه مغالبته أو الخروج عن قدرته."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَهُوَ الْقَاهِرُ فَوْقَ عِبَادِهِ} (الأنعام:18) من هو ذلك الذي يمكن أن نصفه بصفة كهذه من ملوك وزعماء الأرض؟ من هو ذلك الذي قد نقارن بينه وبين الله في جبروته وقهره؟ لا أحد"""@ar ;
    hesin:actions """استحضار قهر الله عند الخوف من الطواغيت."""@ar ;
    hesin:hasSynonym """القهر"""@ar ;
    hesin:hasSynonym """الجبروت"""@ar ;
    hesin:hasComponent """قهر على الجميع"""@ar ;
    hesin:hasComponent """لا أحد يغالبه"""@ar ;
    hesin:hasComponent """الملوك تحت قهره"""@ar ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C723 a hesin:Concept ;
    rdfs:label """التسبيح كعبادة واسعة"""@ar ;
    hesin:definition """أن التسبيح (تنزيه الله) هو عبادة عظيمة أخذت مساحة واسعة في شرع الله (في الصلاة، وفي الأذكار، وفي الملائكة)."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """والتسبيح هو الذي أخذ المساحة الواسعة في التعبد داخل الملائكة, وداخل المخلوقات كلها... في صلاتنا, تسبيح في الركوع في السجود في القيام ..أليس كذلك؟"""@ar ;
    hesin:actions """الالتزام بالتسبيح بخشوع."""@ar ;
    hesin:hasSynonym """التسبيح"""@ar ;
    hesin:hasSynonym """التنزيه"""@ar ;
    hesin:hasComponent """تسبيح الملائكة"""@ar ;
    hesin:hasComponent """تسبيح المخلوقات"""@ar ;
    hesin:hasComponent """التسبيح في الصلاة"""@ar ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C724 a hesin:Concept ;
    rdfs:label """الجهل بالله يؤدي إلى الرياء"""@ar ;
    hesin:definition """أن سبب الرياء هو صغر قدر الله في نفس العبد، واعتقاده أن ما عند الناس أعظم مما عند الله."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """الإنسان لا يرائي في أعماله إلا إذا لم يكن الله عظيماً في نفسه، الإنسان لا يرائي في أعماله إلا إذا كان ما يريده من الناس هو في نفسه أعظم مما يمكن أن يحصل عليه من قِبَل الله"""@ar ;
    hesin:actions """تعظيم الله في النفس لعلاج الرياء."""@ar ;
    hesin:hasSynonym """الرياء"""@ar ;
    hesin:hasSynonym """ضعف الإخلاص"""@ar ;
    hesin:hasComponent """صغر قدر الله في النفس"""@ar ;
    hesin:hasComponent """تقدير ما عند الناس أعظم"""@ar ;
    hesin:hasComponent """الرياء نتيجة"""@ar ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C801 a hesin:Concept ;
    rdfs:label """نقد اختزال الوعد والوعيد في الجنة والنار"""@ar ;
    hesin:definition """نقد المفهوم التقليدي الذي يختزل الوعد والوعيد في الجنة والنار فقط، متجاهلاً وعود الله ووعيده في الدنيا."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """قدم الوعد والوعيد بأنه يعني فقط: [الجنة والنار] ولم يأت حديث عن ما وعد الله به أولياءه في الدنيا... وقدم الوعيد بأنه النار فقط!! ولم يأت حديث عن ما توعد الله به المجرمين والفاسقين والضالين والمعرضين عن هديه هنا في الدنيا"""@ar ;
    hesin:actions """توسيع مفهوم الوعد والوعيد ليشمل الدنيا."""@ar ;
    hesin:hasSynonym """نقد علم الكلام"""@ar ;
    hesin:hasSynonym """نقد الفهم التقليدي"""@ar ;
    hesin:hasComponent """التركيز على الآخرة فقط"""@ar ;
    hesin:hasComponent """إغفال وعود الدنيا"""@ar ;
    hesin:hasComponent """إغفال وعيد الدنيا"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_55 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C802 a hesin:Concept ;
    rdfs:label """نقد اختزال موضوع الوعد والوعيد في الشفاعة"""@ar ;
    hesin:definition """نقد منهج علم الكلام الذي يختزل موضوع الوعد والوعيد في قضايا محدودة (الشفاعة، الخلود) بدلاً من استيعاب شموليته القرآنية."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """المؤسف هو أن هذا العنوان ـ الوعد والوعيد ـ هو من المباحث التي نقرأها في كتب [علم الكلام]... تقدم المسألة في أضيق نطاق، فتجد ما يبحث عنه في تلك الفصول تحت هذا العنوان، هو ما يتعلق بموضوع: [الشفاعة]، [الخلود من عدمه] أو [الشفاعة للمجرمين من عدمها]"""@ar ;
    hesin:actions """تجاوز القضايا المحدودة إلى الفهم الشامل."""@ar ;
    hesin:hasSynonym """نقد علم الكلام"""@ar ;
    hesin:hasComponent """التركيز على الشفاعة"""@ar ;
    hesin:hasComponent """التركيز على الخلود"""@ar ;
    hesin:hasComponent """إغفال الأبعاد الأخرى"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_55 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C803 a hesin:Concept ;
    rdfs:label """الجنة والنار كآلية للترغيب والترهيب"""@ar ;
    hesin:definition """أن الجنة والنار ليستا غاية في حد ذاتهما، بل هما وسيلة و"آلة" للترغيب والترهيب لدفع البشر إلى الاستقامة في الدنيا."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """نجد القرآن الكريم قدم قضية: الجنة والنار بكلها، باعتبارها آلة ترغيب وترهيب للبشر هنا في الدنيا ليستقيموا، لتستقيم الحياة، ليؤدي الإنسان المهمة التي استخلفه الله لأدائها"""@ar ;
    hesin:actions """استخدام الجنة والنار كأدوات للتربية لا كغاية."""@ar ;
    hesin:hasSynonym """الجنة والنار وسيلة"""@ar ;
    hesin:hasComponent """الجنة: ترغيب"""@ar ;
    hesin:hasComponent """النار: ترهيب"""@ar ;
    hesin:hasComponent """الهدف: الاستقامة في الدنيا"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_55 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C804 a hesin:Concept ;
    rdfs:label """نقد جعل الآخرة هي الغاية الوحيدة"""@ar ;
    hesin:definition """نقد الفهم الذي يجعل الآخرة هي الغاية الوحيدة من الوجود، متجاهلاً أن الاستخلاف في الدنيا هو الغاية الأساسية."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هذا المفهوم ناقص جداً، ومؤثر، وله سلبيات كثيرة فيما يتعلق بفهمنا للدين... مفهوم أدى إلى جهلنا بالغاية كلها من هذا الوجود... حصل تنصل عن هذه الحياة وفهم بأن الآخرة هي الغاية، هي الغاية من الوجود"""@ar ;
    hesin:actions """تصحيح الفهم ليكون الدنيا ميدان عمل والآخرة دار جزاء."""@ar ;
    hesin:hasSynonym """نقد التركيز على الآخرة"""@ar ;
    hesin:hasComponent """تنصل عن الحياة الدنيا"""@ar ;
    hesin:hasComponent """جهل بالغاية الحقيقية"""@ar ;
    hesin:hasComponent """فهم ناقص للدين"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_55 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C805 a hesin:Concept ;
    rdfs:label """الاستخلاف في الأرض (الغاية من الوجود)"""@ar ;
    hesin:definition """أن الغاية من خلق الإنسان هي أن يكون خليفة لله في الأرض، يعمرها ويطورها وفق هدي الله، وليس فقط أن يذهب إلى الجنة أو النار."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَإِذْ قَالَ رَبُّكَ لِلْمَلائِكَةِ إِنِّي جَاعِلٌ فِي الْأَرْضِ خَلِيفَةً} (البقرة:30) خليفة ماذا يعمل؟ خليفة تسخر له السموات والأرض وما فيهما وما بينهما، له دور كبير، له دور مهم"""@ar ;
    hesin:actions """فهم الدين كمنهج للحياة لا كطريق للجنة فقط."""@ar ;
    hesin:hasSynonym """خليفة الله"""@ar ;
    hesin:hasSynonym """مهمة الإنسان"""@ar ;
    hesin:hasComponent """خلافة الله في الأرض"""@ar ;
    hesin:hasComponent """تسخير الكون للإنسان"""@ar ;
    hesin:hasComponent """عمارة الأرض وتطويرها"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_56 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C806 a hesin:Concept ;
    rdfs:label """الدنيا ميدان العمل (لا مجرد مرور)"""@ar ;
    hesin:definition """أن الدنيا ليست مجرد مرحلة عبور لتمييز من يدخل الجنة ومن يدخل النار، بل هي ميدان عمل لتحقيق مهمة الاستخلاف."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """فقط مجرد مرور، هذا الوجود ليس له هناك غاية أكثر من أن يتميز هنا من الذي سيمشي إلى الجنة ومن الذي سيمشي إلى النار فقط.! هذا المفهوم ناقص جداً"""@ar ;
    hesin:actions """العمل في الدنيا كعبادة."""@ar ;
    hesin:hasSynonym """الحياة ميدان"""@ar ;
    hesin:hasSynonym """الدنيا ساحة عمل"""@ar ;
    hesin:hasComponent """الدنيا ميدان"""@ar ;
    hesin:hasComponent """ليست مجرد مرور"""@ar ;
    hesin:hasComponent """العمل فيها عبادة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_56 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C807 a hesin:Concept ;
    rdfs:label """الآخرة مرجع ومأوى لا غاية"""@ar ;
    hesin:definition """أن الآخرة هي المرجع والمأوى بعد انتهاء مهمة الدنيا، وليست الغاية التي خلق من أجلها الإنسان."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """الآخرة هي مرجع، هي مأوى، وليست هي الغاية من الوجود، ليست هي الغاية من وجود البشر هنا، لأنه كان بالإمكان أن يقال: لماذا لم تخلقنا في الجنة من أول يوم؟"""@ar ;
    hesin:actions """التركيز على أداء المهمة في الدنيا."""@ar ;
    hesin:hasSynonym """الآخرة دار جزاء"""@ar ;
    hesin:hasComponent """الآخرة مرجع"""@ar ;
    hesin:hasComponent """الآخرة مأوى"""@ar ;
    hesin:hasComponent """الدنيا ميدان العمل"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_56 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C808 a hesin:Concept ;
    rdfs:label """الإيمان في الآخرة لا ينفع"""@ar ;
    hesin:definition """أن الإيمان بالله والجنة والنار في الآخرة لا ينفع، لأن ساحة العمل والإيمان المطلوب هي الدنيا."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """في الحشر... أليس الناس سيكونون هناك كلهم مؤمنين... ولكن هل سينفعهم إيمانهم هناك؟ لا. لماذا؟... لأن ساحة العمل هي الدنيا التي كان المطلوب أن تؤمن هناك لتستقيم تلك الحياة"""@ar ;
    hesin:actions """عدم انتظار الآخرة للإيمان."""@ar ;
    hesin:hasSynonym """فوات وقت العمل"""@ar ;
    hesin:hasComponent """الآخرة: مشاهدة وإيمان اضطرار"""@ar ;
    hesin:hasComponent """الدنيا: ميدان الاختيار والإيمان الاختياري"""@ar ;
    hesin:hasComponent """فوات وقت العمل"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_56 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C809 a hesin:Concept ;
    rdfs:label """الإيمان الكامل بالله (الغفور الرحيم وشديد العقاب)"""@ar ;
    hesin:definition """أن الإيمان الكامل بالله يقتضي الإيمان بأنه غفور رحيم (للرجاء) وشديد العقاب (للخوف)، وليس الاقتصار على جانب واحد."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """الإيمان السائد بالله سبحانه وتعالى هو إيمان: [الله غفور رحيم] أليس كذلك؟!... أليس هو يريد أن نؤمن بالأمرين معاً؟: أنه غفور رحيم، وأن عذابه هو العذاب الأليم، أنه غفور رحيم، وأنه شديد العقاب"""@ar ;
    hesin:actions """الموازنة بين الخوف والرجاء."""@ar ;
    hesin:hasSynonym """الإيمان بالرغبة والرهبة"""@ar ;
    hesin:hasComponent """الغفور الرحيم: للرجاء"""@ar ;
    hesin:hasComponent """شديد العقاب: للخوف"""@ar ;
    hesin:hasComponent """الجمع بين الرجاء والخوف"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_57 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C810 a hesin:Concept ;
    rdfs:label """التقوى تستلزم الإيمان بشدة العقاب"""@ar ;
    hesin:definition """أن التقوى (اتقاء عذاب الله) لا تتحقق إلا بالإيمان بأن الله شديد العقاب، وليس فقط بأنه غفور رحيم."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أين يتجه الأمر بالتقوى؟ إلى غفور رحيم!؟ أو الإتقاء لأنه سبحانه وتعالى شديد العقاب؟! فلا تتحقق التقوى لدي إذا لم أؤمن بالله سبحانه وتعالى على هذا النحو"""@ar ;
    hesin:actions """تعزيز الخوف من الله مع الرجاء."""@ar ;
    hesin:hasSynonym """التقوى والخوف"""@ar ;
    hesin:hasComponent """التقوى: اتقاء العذاب"""@ar ;
    hesin:hasComponent """شدة العقاب سبب الاتقاء"""@ar ;
    hesin:hasComponent """الرحمة سبب الرجاء"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_57 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C811 a hesin:Concept ;
    rdfs:label """الإيمان باليوم الآخر جزء من الإيمان بالله"""@ar ;
    hesin:definition """أن الإيمان بالله لا ينفصل عن الإيمان باليوم الآخر، لأن صفات الله (كالجبار وشديد العقاب) تتجلى فيه."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أن تكون مؤمناً بالله ثم لا تكون مؤمناً باليوم الآخر، أو تكون غافلاً عن اليوم الآخر، أو ناسياً لليوم الآخر، سيبدو إيمانك بالله سبحانه وتعالى ذاته ناقصاً"""@ar ;
    hesin:actions """ربط الإيمان بالله بالإيمان باليوم الآخر."""@ar ;
    hesin:hasSynonym """الإيمان بالبعث والحساب"""@ar ;
    hesin:hasComponent """الإيمان بالله متصل بالإيمان باليوم الآخر"""@ar ;
    hesin:hasComponent """اليوم الآخر مظهر من مظاهر صفات الله"""@ar ;
    hesin:hasComponent """الإيمان الناقص باليوم الآخر إيمان ناقص بالله"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_57 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C812 a hesin:Concept ;
    rdfs:label """وعد الله في الدنيا"""@ar ;
    hesin:definition """أن الله وعد المؤمنين بنعم في الدنيا (كالماء الغدق، البركات، النصر، العزة) وليس فقط في الآخرة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """ألم يذكر الله في القرآن الكريم في آيات كثيرة الوعد والوعيد هنا في الدنيا؟{وَأن َلَّوِ اسْتَقَامُوا عَلَى الطَّرِيقَةِ لَأَسْقَيْنَاهُمْ مَاءً غَدَقاً} (الجـن:16) أليس هذا وعداً إلهياً؟{وَلَوْ أَنَّ أَهْلَ الْقُرَى آمَنُوا وَاتَّقَوْا لَفَتَحْنَا عَلَيْهِمْ بَرَكَاتٍ مِنَ السَّمَاءِ وَالْأَرْضِ}... {وَلَيَنْصُرَنَّ اللَّهُ مَنْ يَنْصُرُهُ}"""@ar ;
    hesin:actions """التذكير بوعود الله في الدنيا."""@ar ;
    hesin:hasSynonym """النصر"""@ar ;
    hesin:hasSynonym """العزة"""@ar ;
    hesin:hasSynonym """البركات"""@ar ;
    hesin:hasComponent """الماء الغدق"""@ar ;
    hesin:hasComponent """بركات السماء والأرض"""@ar ;
    hesin:hasComponent """النصر والعزة"""@ar ;
    hesin:hasComponent """التمكين في الأرض"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_58 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C813 a hesin:Concept ;
    rdfs:label """وعيد الله في الدنيا"""@ar ;
    hesin:definition """أن الله توعد العصاة والمجرمين بعقوبات في الدنيا (كالذلة والمسكنة والفساد) وليس فقط في الآخرة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{ضُرِبَتْ عَلَيْهِمُ الذِّلَّةُ أَيْنَ مَا ثُقِفُوا إِلَّا بِحَبْلٍ مِنَ اللَّهِ وَحَبْلٍ مِنَ النَّاسِ... أليست هذه عقوبة في الدنيا ووعيداً في الدنيا؟{ظَهَرَ الْفَسَادُ فِي الْبَرِّ وَالْبَحْرِ بِمَا كَسَبَتْ أَيْدِي النَّاسِ} أليس هذا وعيداً في الدنيا؟"""@ar ;
    hesin:actions """فهم واقع الأمة في ضوء وعيد الله."""@ar ;
    hesin:hasSynonym """العقوبات الدنيوية"""@ar ;
    hesin:hasSynonym """الذلة"""@ar ;
    hesin:hasComponent """الذلة والمسكنة"""@ar ;
    hesin:hasComponent """غضب الله"""@ar ;
    hesin:hasComponent """الفساد في البر والبحر"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_58 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C814 a hesin:Concept ;
    rdfs:label """معرفة موقعك (وعد أم وعيد)"""@ar ;
    hesin:definition """أن فهم وعد الله ووعيده في الدنيا يمكن الإنسان من تقييم وضعه: هل هو في نعمة (وعد) أم في عقوبة (وعيد)؟"""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """وأن تؤمن بأن الوعد والوعيد يبدأ من هنا من الدنيا؛ أنت ستستطيع أن تفهم واقعك، تستطيع أن تعرف وضعيتك التي أنت فيها، هل أنت في وعد أو وعيد؟"""@ar ;
    hesin:actions """تقييم واقع الأمة في ضوء القرآن."""@ar ;
    hesin:hasSynonym """تقييم الواقع"""@ar ;
    hesin:hasSynonym """الاستبصار"""@ar ;
    hesin:hasComponent """فهم واقع الأمة"""@ar ;
    hesin:hasComponent """معرفة موقعك من الله"""@ar ;
    hesin:hasComponent """الاستبصار"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_58 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C815 a hesin:Concept ;
    rdfs:label """لعن المضلين في الدنيا"""@ar ;
    hesin:definition """أن لعن المضلين والتبرؤ منهم يجب أن يكون في الدنيا، حيث ينفع، لا في الآخرة حيث لا ينفع."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هذه الآيات توحي لنا بأنه هنا في الدنيا، في الدنيا، إلعن أولئك الذين أضلونا... إن لعنتهم هنا في الدنيا هي التي ستجدي، أن تفضحهم هنا في الدنيا"""@ar ;
    hesin:actions """التبرؤ من المضلين في الدنيا."""@ar ;
    hesin:hasSynonym """التبرؤ من المضلين"""@ar ;
    hesin:hasComponent """لعن المضلين في الدنيا"""@ar ;
    hesin:hasComponent """فضحهم"""@ar ;
    hesin:hasComponent """التبرؤ منهم"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_59 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C816 a hesin:Concept ;
    rdfs:label """الأتباع والمضلون في النار"""@ar ;
    hesin:definition """أن الأتباع والمضلين جميعًا في النار، لكل منهم ضعف من العذاب (المضلون لإضلالهم، والأتباع لعدم استبصارهم)."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{قَالَ ادْخُلُوا فِي أُمَمٍ قَدْ خَلَتْ مِنْ قَبْلِكُمْ مِنَ الْجِنِّ وَالْأِنْسِ فِي النَّارِ كُلَّمَا دَخَلَتْ أُمَّةٌ لَعَنَتْ أُخْتَهَا}... {قَالَ لِكُلٍّ ضِعْفٌ} للأولين وللآخرين"""@ar ;
    hesin:actions """عدم الاعتماد على غيرك في الهداية."""@ar ;
    hesin:hasSynonym """مسؤولية الاتباع"""@ar ;
    hesin:hasComponent """المضلون في النار"""@ar ;
    hesin:hasComponent """الأتباع في النار"""@ar ;
    hesin:hasComponent """لكل ضعف من العذاب"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_59 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C817 a hesin:Concept ;
    rdfs:label """الأخلاء يتبرأ بعضهم من بعض في الآخرة"""@ar ;
    hesin:definition """أن الأصدقاء والأخلاء في الدنيا (غير المتقين) سيتحولون إلى أعداء في الآخرة، يتبرأ بعضهم من بعض."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{الْأَخِلَّاءُ يَوْمَئِذٍ بَعْضُهُمْ لِبَعْضٍ عَدُوٌّ إِلَّا الْمُتَّقِينَ} (الزخرف:67) أخلاؤك المتقون هنا... هم من سترى نفسك يوم القيامة أكثر حبا... لكن كل صداقتك ستتحول إلى عداء يوم القيامة"""@ar ;
    hesin:actions """اختيار الأصدقاء المتقين."""@ar ;
    hesin:hasSynonym """تحول الولاء إلى عداء"""@ar ;
    hesin:hasComponent """الأخلاء: أعداء يوم القيامة"""@ar ;
    hesin:hasComponent """المتقون: استثناء"""@ar ;
    hesin:hasComponent """التحسر على الصداقة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_59 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C818 a hesin:Concept ;
    rdfs:label """تمني البعد عن القرين في الآخرة"""@ar ;
    hesin:definition """أن الإنسان في الآخرة يتمنى لو كان بينه وبين قرينه السوء بعد المشرقين، وهذا التمني لا ينفع، لذا يجب الابتعاد عنهم في الدنيا."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَمَنْ يَعْشُ عَنْ ذِكْرِ الرَّحْمَنِ نُقَيِّضْ لَهُ شَيْطَاناً فَهُوَ لَهُ قَرِينٌ... حَتَّى إِذَا جَاءَنَا قَالَ يَا لَيْتَ بَيْنِي وَبَيْنَكَ بُعْدَ الْمَشْرِقَيْنِ فَبِئْسَ الْقَرِينُ} (الزخرف:36-38) قل هنا في الدنيا، لا تنتظر حتى تقول هذه يوم القيامة"""@ar ;
    hesin:actions """الابتعاد عن قرناء السوء."""@ar ;
    hesin:hasSynonym """الندم على الصحبة"""@ar ;
    hesin:hasComponent """تمني البعد"""@ar ;
    hesin:hasComponent """الندم على الصحبة"""@ar ;
    hesin:hasComponent """عدم النفع في الآخرة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_59 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C819 a hesin:Concept ;
    rdfs:label """المستضعفون يطلبون زيادة العذاب للمضلين"""@ar ;
    hesin:definition """أن الأتباع في النار يطلبون من الله زيادة العذاب على المضلين الذين أضلوهم، وهذا لا ينفعهم شيئًا."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{قَالَتْ أُخْرَاهُمْ لِأُولاهُمْ رَبَّنَا هَؤُلاءِ أَضَلُّونَا فَآتِهِمْ عَذَاباً ضِعْفاً مِنَ النَّارِ} (الأعراف:38)... لاحظوا في أكثر من آية، ليس أمامهم إلا أن يطلبوا: أن يزيد الله تلك الطائفة التي أضلتهم"""@ar ;
    hesin:actions """التبرؤ من المضلين في الدنيا."""@ar ;
    hesin:hasSynonym """الانتقام في الآخرة"""@ar ;
    hesin:hasComponent """طلب زيادة العذاب"""@ar ;
    hesin:hasComponent """حقد على المضلين"""@ar ;
    hesin:hasComponent """عدم النفع"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_59 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C820 a hesin:Concept ;
    rdfs:label """طاعة السادة والكبراء سبب الضلال"""@ar ;
    hesin:definition """أن طاعة السادة والكبراء (الزعماء والمشايخ) دون النظر إلى هدي الله هي سبب الضلال، وستكون سببًا للندم في الآخرة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{يَوْمَ تُقَلَّبُ وُجُوهُهُمْ فِي النَّارِ يَقُولُونَ يَا لَيْتَنَا أَطَعْنَا اللَّهَ وَأَطَعْنَا الرَّسُولا وَقَالُوا رَبَّنَا إِنَّا أَطَعْنَا سَادَتَنَا وَكُبَرَاءَنَا فَأَضَلُّونَا السَّبِيلا} (الأحزاب:66-67) هم سادتنا وكبراؤنا، هم أضلونا السبيلا"""@ar ;
    hesin:actions """عدم اتباع السادة والكبراء بغير حق."""@ar ;
    hesin:hasSynonym """اتباع الزعماء"""@ar ;
    hesin:hasComponent """طاعة السادة"""@ar ;
    hesin:hasComponent """طاعة الكبراء"""@ar ;
    hesin:hasComponent """الندم في الآخرة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_59 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C821 a hesin:Concept ;
    rdfs:label """عذاب جهنم (تبديل الجلود)"""@ar ;
    hesin:definition """أن عذاب جهنم مستمر لا ينقطع، حيث يبدل الله الجلود كلما احترقت ليبقى الألم."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{إِنَّ الَّذِينَ كَفَرُوا بِآيَاتِنَا سَوْفَ نُصْلِيهِمْ نَاراً كُلَّمَا نَضِجَتْ جُلُودُهُمْ بَدَّلْنَاهُمْ جُلُوداً غَيْرَهَا لِيَذُوقُوا الْعَذَابَ} (النساء:56) يقال: إن الجلد هو منطقة الإحساس فالجلد هو الذي يحترق، فكلما احترق يبدل ليبقى الألم مستمراً"""@ar ;
    hesin:actions """استحضار عذاب النار الدائم."""@ar ;
    hesin:hasSynonym """استمرار العذاب"""@ar ;
    hesin:hasComponent """تبديل الجلود"""@ar ;
    hesin:hasComponent """استمرار الألم"""@ar ;
    hesin:hasComponent """عدم فقدان الوعي"""@ar ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C822 a hesin:Concept ;
    rdfs:label """أمم في النار تتلاعن"""@ar ;
    hesin:definition """أن الأمم في النار تتلاعن وتلعن بعضها بعضًا، كل أمة تلعن الأخرى التي أضلتها."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{كُلَّمَا دَخَلَتْ أُمَّةٌ لَعَنَتْ أُخْتَهَا} (الأعراف:38) يتلاعنون [أنتم الذين أضليتمونا، أنتم الذين عملتم كذا، لعنة الله عليكم..!]"""@ar ;
    hesin:actions """الحذر من اتباع الأمم الضالة."""@ar ;
    hesin:hasSynonym """التلاعن في النار"""@ar ;
    hesin:hasComponent """التلاعن"""@ar ;
    hesin:hasComponent """إلقاء اللوم"""@ar ;
    hesin:hasComponent """الحقد المتبادل"""@ar ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C823 a hesin:Concept ;
    rdfs:label """التحاجج في النار"""@ar ;
    hesin:definition """أن أهل النار يتحاجون ويتجادلون، كل يحاول تبرئة نفسه وإلقاء اللوم على الآخر."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَإِذْ يَتَحَاجُّونَ فِي النَّارِ} (غافر:47) يتخاصمون ويتجادلون، وكل شخص يحاول أن يحج الآخر... {فَيَقُولُ الضُّعَفَاءُ لِلَّذِينَ اسْتَكْبَرُوا إِنَّا كُنَّا لَكُمْ تَبَعاً فَهَلْ أَنْتُمْ مُغْنُونَ عَنَّا نَصِيباً مِنَ النَّارِ}"""@ar ;
    hesin:actions """تحمل المسؤولية في الدنيا."""@ar ;
    hesin:hasSynonym """الجدال في النار"""@ar ;
    hesin:hasComponent """التحاجج والجدال"""@ar ;
    hesin:hasComponent """إلقاء اللوم"""@ar ;
    hesin:hasComponent """عدم النفع"""@ar ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C824 a hesin:Concept ;
    rdfs:label """الإيمان في الآخرة اضطرار لا اختيار"""@ar ;
    hesin:definition """أن الإيمان في الآخرة هو إيمان اضطرار (بالمشاهدة) لا اختيار، ولا ينفع صاحبه."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """هو يرى النار أمامه، أليس هذا اليقين والإيمان الواضح؟ ولكن هل سينفعهم إيمانهم هناك؟ لا. لماذا؟... لأن ساحة العمل هي الدنيا"""@ar ;
    hesin:actions """عدم تأجيل الإيمان إلى الآخرة."""@ar ;
    hesin:hasSynonym """الإيمان الاضطراري"""@ar ;
    hesin:hasComponent """إيمان بالمشاهدة"""@ar ;
    hesin:hasComponent """إيمان اضطرار"""@ar ;
    hesin:hasComponent """لا ينفع"""@ar ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C901 a hesin:Concept ;
    rdfs:label """الحسرة الأعظم على الأتباع"""@ar ;
    hesin:definition """أن الأتباع (التابعين للمضلين) هم الأكثر حسرة وندامة في الآخرة، لأنهم أضاعوا أعمارهم في اتباع من أضلهم، ثم تبرأ منهم أولئك المضلون."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """تلاحظ أن الحسرة تأتي بين هذه الأطراف التي كانت في الدنيا تسود ما بينها حالة من الود والتعاون والتأييد... لم يتحدث القرآن عن الحسرات بالنسبة للكبار، الكبار يكفيهم حسرة أنهم يحملون أوزارا كثيرة من أوزار الذين يضلونهم"""@ar ;
    hesin:actions """تحذير الأتباع من مغبة الاتباع الأعمى."""@ar ;
    hesin:hasSynonym """ندم الأتباع"""@ar ;
    hesin:hasSynonym """حسرات الأتباع"""@ar ;
    hesin:hasComponent """الأتباع أكثر ندمًا"""@ar ;
    hesin:hasComponent """الكبار يكفيهم حمل الأوزار"""@ar ;
    hesin:hasComponent """الأتباع هم من صعدوا الظالمين على أكتافهم"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_60 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C902 a hesin:Concept ;
    rdfs:label """الأخلاء يتحولون إلى أعداء في الآخرة"""@ar ;
    hesin:definition """أن الأصدقاء والأخلاء في الدنيا (غير المتقين) يتحولون إلى أعداء في الآخرة، يتبرأ بعضهم من بعض ويلعن بعضهم بعضًا."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{الْأَخِلَّاءُ يَوْمَئِذٍ بَعْضُهُمْ لِبَعْضٍ عَدُوٌّ إِلَّا الْمُتَّقِينَ} (الزخرف:67)... كل صداقتك ستتحول إلى عداء يوم القيامة، كل ولاء، كل تقديس في هذه الدنيا، وكل تصفيق، وكل تأييد سيتحول كله في الآخرة إلى عداء"""@ar ;
    hesin:actions """اختيار الأصدقاء المتقين."""@ar ;
    hesin:hasSynonym """عداوة الأخلاء"""@ar ;
    hesin:hasSynonym """انقلاب الصداقات"""@ar ;
    hesin:hasComponent """الأخلاء: أعداء يوم القيامة"""@ar ;
    hesin:hasComponent """المتقون: استثناء"""@ar ;
    hesin:hasComponent """التبرؤ واللعن المتبادل"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_60 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C903 a hesin:Concept ;
    rdfs:label """تمني الرجعة للتبرؤ من المضلين"""@ar ;
    hesin:definition """أن الأتباع في النار يتمنون لو يعودون إلى الدنيا ليتبرأوا من الذين أضلوهم، لكن هذا التمني لا ينفع."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَقَالَ الَّذِينَ اتَّبَعُوا لَوْ أَنَّ لَنَا كَرَّةً فَنَتَبَرَّأَ مِنْهُمْ كَمَا تَبَرَّأُوا مِنَّا} (البقرة:167) ليت لنا كرة: نرجع إلى الدنيا مرة ثانية نرجع فنتبرأ منهم كما تبرءوا منا. لا يوجد هناك رجعة نهائياً"""@ar ;
    hesin:actions """التبرؤ من المضلين في الدنيا."""@ar ;
    hesin:hasSynonym """تمني العودة"""@ar ;
    hesin:hasSynonym """الندم على الاتباع"""@ar ;
    hesin:hasComponent """تمني الرجعة"""@ar ;
    hesin:hasComponent """التبرؤ ممن أضل"""@ar ;
    hesin:hasComponent """عدم النفع"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_60 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C904 a hesin:Concept ;
    rdfs:label """طلب زيادة العذاب على المضلين"""@ar ;
    hesin:definition """أن الأتباع في النار يطلبون من الله زيادة العذاب على المضلين الذين أضلوهم، تعبيرًا عن شدة حقدهم وندمهم."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{قَالَتْ أُخْرَاهُمْ لِأُولاهُمْ رَبَّنَا هَؤُلاءِ أَضَلُّونَا فَآتِهِمْ عَذَاباً ضِعْفاً مِنَ النَّارِ} (الأعراف:38)... ليس أمامهم إلا أن يطلبوا: أن يزيد الله تلك الطائفة التي أضلتهم"""@ar ;
    hesin:actions """التبرؤ من المضلين في الدنيا."""@ar ;
    hesin:hasSynonym """الانتقام في الآخرة"""@ar ;
    hesin:hasSynonym """الحقد على المضلين"""@ar ;
    hesin:hasComponent """طلب العذاب المضاعف"""@ar ;
    hesin:hasComponent """الإقرار بأنهم أضلونا"""@ar ;
    hesin:hasComponent """عدم النفع"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_60 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C905 a hesin:Concept ;
    rdfs:label """تبرؤ المتبوعين من الأتباع في الآخرة"""@ar ;
    hesin:definition """أن المتبوعين (الكبار، الزعماء، المضلين) يتبرؤون من أتباعهم في الآخرة، ولا ينفعونهم بشيء."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{إِذْ تَبَرَّأَ الَّذِينَ اتُّبِعُوا مِنَ الَّذِينَ اتَّبَعُوا} (البقرة:166) الكبار تبرؤوا من الصغار، والصغار من كانوا في الدنيا يصفقون لهم، ويؤيدونهم، ويدعمونهم... يوم القيامة يتبرءون منهم"""@ar ;
    hesin:actions """عدم الاعتماد على الزعماء في الآخرة."""@ar ;
    hesin:hasSynonym """تخلي الكبار عن الصغار"""@ar ;
    hesin:hasComponent """تبرؤ المتبوعين"""@ar ;
    hesin:hasComponent """عدم النفع"""@ar ;
    hesin:hasComponent """إعلان التخلي"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_60 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C906 a hesin:Concept ;
    rdfs:label """طلب إراءة المضلين (ربنا أرنا الذين أضلانا)"""@ar ;
    hesin:definition """أن أهل النار يطلبون من الله أن يُريهم المضلين من الجن والإنس ليجعلوهم تحت أقدامهم، تعبيرًا عن شدة الحقد والندم."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَقَالَ الَّذِينَ كَفَرُوا رَبَّنَا أَرِنَا الَّذَيْنِ أَضَلَّانَا مِنَ الْجِنِّ وَالْأِنْسِ نَجْعَلْهُمَا تَحْتَ أَقْدَامِنَا لِيَكُونَا مِنَ الْأَسْفَلِينَ} (فصلت:29)... أين هم الذين أضلونا في الدنيا هنا هل كنت تبحث عن المضلين لتطاردهم؟"""@ar ;
    hesin:actions """البحث عن المضلين ومحاربتهم في الدنيا."""@ar ;
    hesin:hasSynonym """البحث عن المضلين في الآخرة"""@ar ;
    hesin:hasComponent """طلب إراءة المضلين"""@ar ;
    hesin:hasComponent """طلب جعلهم تحت الأقدام"""@ar ;
    hesin:hasComponent """الاهتمام حتى بالجن"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_60 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C907 a hesin:Concept ;
    rdfs:label """تظلم الأتباع لا يجاب"""@ar ;
    hesin:definition """أن تظلم الأتباع في الآخرة (بأنهم أضلهم غيرهم) لا يجاب، بل هو نوع من العذاب النفسي الإضافي لهم."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """تتظلم أليسوا هنا تظلموا {رَبَّنَا أَرِنَا الَّذَيْنِ أَضَلَّانَا}... أليس هذا تظلماً؟ لا يجابون إطلاقاً في تظلمهم، ولا يقدر لهم ذلك الموقف أنهم أصبحوا يبغضون ويكرهون ويباينون أعداء الله... لا . انتهى كل شيء، وما ذلك كله إلا نوع من العذاب النفسي لهم أيضاً"""@ar ;
    hesin:actions """تحمل المسؤولية في الدنيا."""@ar ;
    hesin:hasSynonym """عدم قبول العذر"""@ar ;
    hesin:hasComponent """التظلم لا ينفع"""@ar ;
    hesin:hasComponent """العذاب النفسي"""@ar ;
    hesin:hasComponent """انتهاء الفرصة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_60 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C908 a hesin:Concept ;
    rdfs:label """التبرؤ من المضلين في الدنيا"""@ar ;
    hesin:definition """أن الموقف الصحيح هو التبرؤ من المضلين ولعنهم في الدنيا، حيث ينفع، لا في الآخرة حيث لا ينفع."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """تبرأ هنا في الدنيا من الكبار المجرمين قبل أن يتبرءوا منك في الآخرة، إلعن المضلين وإن كان بينك وبينهم آلاف السنين، الذين هم سبب لإضلالك وإضلال الأمة التي أنت تعيش فيها، تبرأ منهم والعنهم، أظهر مباينتك لهم"""@ar ;
    hesin:actions """التبرؤ من المضلين في الدنيا."""@ar ;
    hesin:hasSynonym """لعن المضلين"""@ar ;
    hesin:hasSynonym """مباينة المضلين"""@ar ;
    hesin:hasComponent """التبرؤ في الدنيا"""@ar ;
    hesin:hasComponent """لعن المضلين"""@ar ;
    hesin:hasComponent """إظهار المباينة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_61 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C909 a hesin:Concept ;
    rdfs:label """جعل المضلين تحت الأقدام في الدنيا (مجازًا)"""@ar ;
    hesin:definition """أن جعل المضلين تحت الأقدام في الدنيا يعني: عدم الالتفات إليهم، وعدم التأثر بكلامهم، وجعل كلامهم لا قيمة له."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """إجعلهم هنا في الدنيا تحت أقدامك، اجعل المضلين تحت أقدامك هنا في الدنيا حيث سينفع... كلامهم، كلامهم يجب أن نجعله تحت أقدامنا لا نلتفت إليهم، لا نتأثر بهم، ولا بأوليائهم، ولا بالمروجين لهم"""@ar ;
    hesin:actions """عدم الالتفات إلى دعاة الضلال."""@ar ;
    hesin:hasSynonym """إهانة المضلين"""@ar ;
    hesin:hasSynonym """عدم الالتفات إليهم"""@ar ;
    hesin:hasComponent """عدم الالتفات"""@ar ;
    hesin:hasComponent """عدم التأثر"""@ar ;
    hesin:hasComponent """جعل كلامهم لا قيمة له"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_61 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C910 a hesin:Concept ;
    rdfs:label """الاهتمام بمعرفة المضلين في الدنيا"""@ar ;
    hesin:definition """أن الاهتمام بمعرفة المضلين والبحث عنهم يجب أن يكون في الدنيا، حيث يمكن اتخاذ موقف منهم، لا في الآخرة حيث لا ينفع."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """كن مهتما هنا في الدنيا أن تعرف منابع الفساد والإضلال، وتعرف رموز الباطل ورموز الضلال، لتعمل على أن تجعلهم تحت أقدامك هنا في الدنيا"""@ar ;
    hesin:actions """دراسة مصادر الضلال والتحذير منها."""@ar ;
    hesin:hasSynonym """البحث عن منابع الضلال"""@ar ;
    hesin:hasComponent """معرفة منابع الضلال"""@ar ;
    hesin:hasComponent """معرفة رموز الباطل"""@ar ;
    hesin:hasComponent """اتخاذ موقف منهم"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_61 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C911 a hesin:Concept ;
    rdfs:label """الابتعاد عن قرين السوء"""@ar ;
    hesin:definition """أنه لا يجوز مجالسة ومصادقة قرين السوء، حتى مع الثقة بالنفس، لأن ذلك قد يؤدي إلى الضلال."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """قرين السوء ابتعد عنه، ولا تقل: [أنا فاهم وعارف لكل شيء، ما باستطاعته أن يخدعني، وأنا عارف كيف هو وأنا واثق من نفسي...]. هذا غير صحيح. أنت من حيث المبدأ لا يصح لك أن تجالسه وتصادقه، وتكون على علاقة مستمرة معه"""@ar ;
    hesin:actions """الابتعاد عن قرناء السوء."""@ar ;
    hesin:hasSynonym """اجتناب جليس السوء"""@ar ;
    hesin:hasComponent """عدم مجالسة قرين السوء"""@ar ;
    hesin:hasComponent """عدم مصادقته"""@ar ;
    hesin:hasComponent """عدم الثقة بالنفس أمامه"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_61 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C912 a hesin:Concept ;
    rdfs:label """عدم مجاملة المضلين"""@ar ;
    hesin:definition """أن مجاملة المضلين والسكوت عن باطلهم من أجل الحفاظ على العلاقة هو تقديم للعلاقة على الدين، وهو ضلال في نفسه."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هل إذا كان سيبذل ماله في الصد عن سبيل الله هل أنت ستمنعه وتقول: لا لن أقف معك، وسأقطع علاقتي معك؟ لا بأس إن كنت من هذا النوع، لكن ما الذي سيحصل؟ مجاملات متبادلة، وسكوت عن باطل... إذاً أصبح الدين بكله لا يساوي علاقتك معه"""@ar ;
    hesin:actions """عدم السكوت عن الباطل."""@ar ;
    hesin:hasSynonym """عدم المداراة في الباطل"""@ar ;
    hesin:hasComponent """عدم السكوت عن الباطل"""@ar ;
    hesin:hasComponent """عدم مجاملة المضلين"""@ar ;
    hesin:hasComponent """تقديم الدين على العلاقات"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_61 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C913 a hesin:Concept ;
    rdfs:label """الفطرة على قبول الهدى"""@ar ;
    hesin:definition """أن الإنسان مفطور على قبول الحق والهدى، والضلال يأتي من تأثير المضلين من الجن والإنس."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لأن الناس بطبيعتهم، بفطرتهم مجبولون على قبول دين الله، على الإهتداء بهدي الله وإنما يأتي الضلال من قبل أطراف أخرى"""@ar ;
    hesin:actions """حماية الفطرة من تأثير المضلين."""@ar ;
    hesin:hasSynonym """الفطرة السليمة"""@ar ;
    hesin:hasComponent """الفطرة على الهدى"""@ar ;
    hesin:hasComponent """الضلال من الخارج"""@ar ;
    hesin:hasComponent """مسؤولية المضلين"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_61 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C914 a hesin:Concept ;
    rdfs:label """حرص النبي على هداية الآخرين"""@ar ;
    hesin:definition """أن النبي (صلى الله عليه وآله) كان شديد الحرص على هداية الآخرين، يتألم لضلالهم، وهو قدوة للمؤمنين."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{لَعَلَّكَ بَاخِعٌ نَفْسَكَ أَلَّا يَكُونُوا مُؤْمِنِينَ} (الشعراء:3) ... يتألم جدا، يتأسف جداً على الآخرين وهم يعبدون أصناماً... يكاد يقتل نفسه من شدة الألم أن يراهم هكذا على الضلال"""@ar ;
    hesin:actions """الاقتداء بالنبي في الحرص على هداية الناس."""@ar ;
    hesin:hasSynonym """روحية النبي"""@ar ;
    hesin:hasSynonym """الاهتمام بالآخرين"""@ar ;
    hesin:hasComponent """الحرص على الهداية"""@ar ;
    hesin:hasComponent """التألم لضلال الناس"""@ar ;
    hesin:hasComponent """الاجتهاد في إنقاذهم"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_62 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C915 a hesin:Concept ;
    rdfs:label """الاهتمام بإنقاذ الآخرين (روحية المؤمن)"""@ar ;
    hesin:definition """أن قوة الإيمان لا تقاس بمجرد الشعور الداخلي، بل بمدى انعكاسه على الاهتمام بالآخرين وهدايتهم."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """المؤمن يهتم بكل شيء، وميدان اهتمامك كلما قويت علاقتك بالله, ميدان اهتمامك هو يتوجه إلى الناس وإلى الحياة... كلما ترسخ الإيمان في قلبك كلما تعززت علاقتك بالله فإن الميدان الذي يعكس إيمانك القوي وعلاقتك القوية بالله هو الناس ميدان الحياة"""@ar ;
    hesin:actions """قياس الإيمان بمدى الاهتمام بالآخرين."""@ar ;
    hesin:hasSynonym """غيرية المؤمن"""@ar ;
    hesin:hasSynonym """نفع الآخرين"""@ar ;
    hesin:hasComponent """الإيمان ينعكس على الاهتمام بالآخرين"""@ar ;
    hesin:hasComponent """ميدان العمل هو الناس"""@ar ;
    hesin:hasComponent """لا انعزال"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_62 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C916 a hesin:Concept ;
    rdfs:label """الجهاد في سبيل الله هو هداية الناس"""@ar ;
    hesin:definition """أن الجهاد الحقيقي في سبيل الله هو العمل على هداية الناس وإنقاذهم من الضلال، وليس مجرد القتال المادي."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """الجهاد في سبيل الله أين ميدانه؟ هل أن هناك جبلا جعله الله وسماه سبيله يذهب الناس يطلقون الرصاص على هذا الجبل؟ أو ميدان العمل في سبيل الله؟ والجهاد في سبيل الله هو الناس أنفسهم أن تعمل لإنقاذهم لهدايتهم"""@ar ;
    hesin:actions """اعتبار هداية الناس من أعظم الجهاد."""@ar ;
    hesin:hasSynonym """ميدان الجهاد"""@ar ;
    hesin:hasComponent """هداية الناس"""@ar ;
    hesin:hasComponent """إنقاذهم من الضلال"""@ar ;
    hesin:hasComponent """العمل في سبيل الله"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_62 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C917 a hesin:Concept ;
    rdfs:label """عدم الانعزال بعد الهداية"""@ar ;
    hesin:definition """أن الشعور بقوة العلاقة بالله ليس غاية في ذاته، بل هو دافع للانطلاق لهداية الآخرين."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """إذا ما أحسست في نفسك بقوة علاقة بالله فلا تظن أن هذا هو كل شيء، وأن هذا هو المطلوب: أن أرى نفسي أكرر ذكر الله سبحانه وتعالى وأرى قلبي ممتلئاً بحب الله ثم أرتاح لهذه الحالة. إفهم هذه الحالة كل المطلوب من ورائها هو أن تنطلق في ميدان العمل لإنقاذ الآخرين وهداية الآخرين"""@ar ;
    hesin:actions """تحويل المشاعر الإيمانية إلى عمل."""@ar ;
    hesin:hasSynonym """رفض العزلة"""@ar ;
    hesin:hasSynonym """الانطلاق للآخرين"""@ar ;
    hesin:hasComponent """الشعور بالله دافع للعمل"""@ar ;
    hesin:hasComponent """الانطلاق للآخرين"""@ar ;
    hesin:hasComponent """عدم الاكتفاء بالشعور الداخلي"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_62 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C918 a hesin:Concept ;
    rdfs:label """التاجر البخيل (مثل لمن لا ينشر العلم)"""@ar ;
    hesin:definition """أن من تعلم الهدى ولم ينشره للآخرين يشبه التاجر البخيل الذي يجمع المال ولا ينفقه."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """الإنسان المؤمن الذي لا يحمل هذه الروحية فليس متأسياً بالنبي... هو كالتاجر البخيل. أن تتعلم أو تعرف هدى... ثم لا يكون لديك اهتمام أن توصل الهدى إلى أقصى دائرة ممكنة، فاعلم بأنك كالتاجر البخيل يجمع الأموال ثم لا يصرف شيئاً"""@ar ;
    hesin:actions """نشر العلم والهدى للآخرين."""@ar ;
    hesin:hasSynonym """البخل بالعلم"""@ar ;
    hesin:hasSynonym """حبس الخير"""@ar ;
    hesin:hasComponent """تعلم الهدى"""@ar ;
    hesin:hasComponent """عدم نشره"""@ar ;
    hesin:hasComponent """البخل بالعلم"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_62 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C919 a hesin:Concept ;
    rdfs:label """بذل المال في سبيل هداية الناس"""@ar ;
    hesin:definition """أن مواجهة المضلين تتطلب بذل المال (لشراء أشرطة، نشر الوعي) كما تتطلب بذل النفس والكلمة."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """نحن هنا يجب أن نبذل من أموالنا في مجال مواجهتهم، إنقاذ الناس منهم، إنقاذ أنفسنا أولا منهم وإنقاذ من أمكن من عباد الله منهم... فنحن في سبيل إنقاذ أنفسنا منهم وفي سبيل إنقاذ الآخرين منهم يجب أن نعمل بجدية بأنفسنا بأموالنا بالكلمة"""@ar ;
    hesin:actions """تخصيص جزء من المال لنشر الوعي."""@ar ;
    hesin:hasSynonym """الإنفاق في سبيل الله"""@ar ;
    hesin:hasComponent """بذل المال"""@ar ;
    hesin:hasComponent """بذل النفس"""@ar ;
    hesin:hasComponent """بذل الكلمة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_62 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C920 a hesin:Concept ;
    rdfs:label """نقد اللامبالاة تجاه المضلين"""@ar ;
    hesin:definition """نقد حالة اللامبالاة والبرود التي يعيشها كثير من الناس تجاه خطر المضلين (كالوهابيين، اليهود، النصارى)."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """كنا نلمس بأن هذا هو الموضوع الذي لا يحظى باهتمام كبير، ولا يستثير مشاعر الناس ولا يستثير غضبهم ولا يثير اهتمامهم... إذا قلنا الطائفة الفلانية قد تضلك، إذا قلنا اليهود والنصارى الله أخبرنا بأنهم يعملون على أن يردونا بعد إيماننا كافرين... لا تلمس اهتمام بالشكل المطلوب ولا اكتراث بالقضية بالشكل المطلوب"""@ar ;
    hesin:actions """إثارة الوعي بخطر المضلين."""@ar ;
    hesin:hasSynonym """عدم الاكتراث بالضلال"""@ar ;
    hesin:hasComponent """عدم الاهتمام"""@ar ;
    hesin:hasComponent """عدم الاستثارة"""@ar ;
    hesin:hasComponent """عدم الاكتراث"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_63 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C921 a hesin:Concept ;
    rdfs:label """نقد تقديم المصالح الدنيوية على الدين"""@ar ;
    hesin:definition """أن الناس يهتمون بمصالحهم الدنيوية الصغيرة أكثر من اهتمامهم بخطر الضلال على دينهم."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """ما هو حقه؟ سيقول لك: حقي قطعة من محجر، لا تساوي نصف ما يبذله من خسارة، أليس هذا يبدو الناس مهتمين به جداً، لا يهمه الوهابية, لكن هناك مضلون هناك دعاة ضلال... كله كلام بارد"""@ar ;
    hesin:actions """تذكير الناس بقيمة الدين."""@ar ;
    hesin:hasSynonym """إيثار الدنيا على الدين"""@ar ;
    hesin:hasComponent """الاهتمام بالدنيا"""@ar ;
    hesin:hasComponent """إهمال خطر الضلال"""@ar ;
    hesin:hasComponent """عدم تقدير قيمة الدين"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_63 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C922 a hesin:Concept ;
    rdfs:label """نقد تقديس السلف الصالح دون تمحيص"""@ar ;
    hesin:definition """نقد تقديس بعض الشخصيات (كبعض الصحابة) دون تمحيص، مما يؤدي إلى اتباع ضلالهم."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أولئك الذين نقدسهم تحت عناوين السلف الصالح صحابة ونحوها، إذا ما اكتشفت بأن ما صدر منهم هو مما أضل الأمة فتبرأ الآن تقدسهم تنزههم, تدافع عنهم، بمنطق باهت لا تملك حجة"""@ar ;
    hesin:actions """تمحيص الشخصيات المقدسة."""@ar ;
    hesin:hasSynonym """نقد التقديس الأعمى"""@ar ;
    hesin:hasComponent """تقديس بلا تمحيص"""@ar ;
    hesin:hasComponent """الدفاع بلا حجة"""@ar ;
    hesin:hasComponent """اتباع الضلال"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_63 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C923 a hesin:Concept ;
    rdfs:label """عدم الرد بالمثل على المعارضين"""@ar ;
    hesin:definition """أن الداعي إلى الحق لا يلتفت إلى المعارضين ولا يرد عليهم بنفس الأسلوب، بل يمضي في عمله."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """فكم قد حصل في الماضي وإلى الآن معارضة طويلة ومستمرة لم نكن نكترث بها. هذا شيء طبيعي قد يحصل لأي إنسان ينطلق في عمل أن يلقى من يعارضه... تلقى من يشوه عملك، من يعمل على الحط من مقدار عملك, بل قد تلقى من يكفرك أو يفسقك"""@ar ;
    hesin:actions """عدم الانشغال بالمعارضين."""@ar ;
    hesin:hasSynonym """عدم الاكتراث بالمعارضة"""@ar ;
    hesin:hasComponent """عدم الاكتراث بالمعارضة"""@ar ;
    hesin:hasComponent """عدم الرد بالمثل"""@ar ;
    hesin:hasComponent """الاستمرار في العمل"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_63 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1001 a hesin:Concept ;
    rdfs:label """عدم القنوط من رحمة الله"""@ar ;
    hesin:definition """أن الله يأمر عباده بعدم اليأس من رحمته مهما بلغت ذنوبهم، لأن الشيطان قد يدفع الإنسان إلى اليأس فيتوقف عن التوبة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{لا تَقْنَطُوا مِنْ رَحْمَةِ اللَّهِ} (الزمر:53) لا تيئسوا. والشيطان قد يعمل على أن يصل بالإنسان إلى اليأس... الله يقول:{لا تَقْنَطُوا مِنْ رَحْمَةِ اللَّهِ} من رجاء رحمته، من أن تحظوا برحمته"""@ar ;
    hesin:actions """تذكير النفس بعدم اليأس مهما عظمت الذنوب."""@ar ;
    hesin:hasSynonym """اليأس من رحمة الله"""@ar ;
    hesin:hasComponent """عدم اليأس"""@ar ;
    hesin:hasComponent """رجاء رحمة الله"""@ar ;
    hesin:hasComponent """التوبة ممكنة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_64 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1002 a hesin:Concept ;
    rdfs:label """غفران الذنوب جميعاً"""@ar ;
    hesin:definition """أن الله يغفر جميع الذنوب للتائبين، ولا يوجد ذنب لا يمكن التوبة منه."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{إِنَّ اللَّهَ يَغْفِرُ الذُّنُوبَ جَمِيعاً} (الزمر:53) أي ذنب أنت فيه، أي ذنب وقعت فيه بإمكانك أن تتخلص منه وتتوب إلى الله منه، ليس هناك ذنب لا تقبل منه توبة"""@ar ;
    hesin:actions """التوبة من جميع الذنوب."""@ar ;
    hesin:hasSynonym """مغفرة الله"""@ar ;
    hesin:hasSynonym """قبول التوبة"""@ar ;
    hesin:hasComponent """غفران جميع الذنوب"""@ar ;
    hesin:hasComponent """لا ذنب بلا توبة"""@ar ;
    hesin:hasComponent """الغفور الرحيم"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_64 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1003 a hesin:Concept ;
    rdfs:label """الإنابة والإسلام لله"""@ar ;
    hesin:definition """أن التوبة تتطلب الإنابة (الرجوع إلى الله بإخلاص) والإسلام (تسليم النفس لله والانقطاع إليه)."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَأَنِيبُوا إِلَى رَبِّكُمْ وَأَسْلِمُوا لَهُ} (الزمر:54) الإنابة: الرجوع إلى الله، الرجوع بإخلاص.{وَأَسْلِمُوا لَهُ} أسلموا أنفسكم له، أخلصوها له، سلموها له، عبِّدوها له"""@ar ;
    hesin:actions """تجديد النية والإنابة إلى الله."""@ar ;
    hesin:hasSynonym """الرجوع إلى الله"""@ar ;
    hesin:hasSynonym """التسليم لله"""@ar ;
    hesin:hasComponent """الإنابة: الرجوع بإخلاص"""@ar ;
    hesin:hasComponent """الإسلام: التسليم والانقطاع"""@ar ;
    hesin:hasComponent """الاستعداد للسير على هديه"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_64 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1004 a hesin:Concept ;
    rdfs:label """اتباع أحسن ما أنزل"""@ar ;
    hesin:definition """أن التوبة وحدها لا تكفي، بل يجب أن يتبعها العمل بكل ما أنزل الله (وليس بعضه)، وهذا هو الطريق إلى النجاة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَاتَّبِعُوا أَحْسَنَ مَا أُنْزِلَ إِلَيْكُمْ مِنْ رَبِّكُمْ} (الزمر:55) التوبة هي بداية رجوع، هي الخطوة الأولى على طريق العمل الذي يتمثل في إتباع أحسن ما أنزل الله إلى عباده"""@ar ;
    hesin:actions """العمل بجميع أوامر الله."""@ar ;
    hesin:hasSynonym """العمل بالقرآن كاملاً"""@ar ;
    hesin:hasComponent """العمل بالقرآن كاملاً"""@ar ;
    hesin:hasComponent """ليس بعض ما أنزل"""@ar ;
    hesin:hasComponent """الانطلاقة العملية بعد التوبة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_65 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1005 a hesin:Concept ;
    rdfs:label """عدم الاكتفاء بالتوبة الجزئية"""@ar ;
    hesin:definition """أن التوبة الصحيحة يجب أن تكون من جميع الذنوب (بما فيها التقصير في الواجبات الكبرى)، وليس من بعضها مع الإصرار على آخر."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """عندما يقال في أصولنا: بأن التوبة يجب أن تكون توبة من كل الذنوب... أن تتوب من ذنب واحد وأنت مصر على ذنوب أخرى... توبتك لا تقبل حتى من الأشياء التي نحن متفقون في عرفنا على أنها معاصي"""@ar ;
    hesin:actions """مراجعة شاملة للذنوب والتقصير."""@ar ;
    hesin:hasSynonym """شمولية التوبة"""@ar ;
    hesin:hasComponent """التوبة من كل الذنوب"""@ar ;
    hesin:hasComponent """عدم الإصرار على أي ذنب"""@ar ;
    hesin:hasComponent """شمولية التوبة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_65 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1006 a hesin:Concept ;
    rdfs:label """الدين الكامل لا يقبل المنقوص"""@ar ;
    hesin:definition """أن الله أنزل دينًا كاملاً، ولا يقبل منا تطبيقًا منقوصًا له، لأن رضاه مرتبط بالدين الكامل."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{الْيَوْمَ أَكْمَلْتُ لَكُمْ دِينَكُمْ} (المائدة:3) فلماذا هذا الدين الكامل ننطلق في مجال تطبيقه تطبيقا منقوصاً؟ وهو ربط رضاه بهذا الدين الكامل، ووعده بالجزاء الحسن مرتبط بهذا الدين الكامل"""@ar ;
    hesin:actions """العمل بجميع أحكام الدين."""@ar ;
    hesin:hasSynonym """شمولية الإسلام"""@ar ;
    hesin:hasComponent """الدين كامل"""@ar ;
    hesin:hasComponent """لا يقبل المنقوص"""@ar ;
    hesin:hasComponent """الجزاء مرتبط بالكمال"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_65 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1007 a hesin:Concept ;
    rdfs:label """التقصير من الذنوب الكبيرة"""@ar ;
    hesin:definition """أن التقصير في الواجبات الكبرى (كالجهاد، الإنفاق، الاعتصام) يعتبر من الذنوب الكبيرة التي تتوعد عليها النار."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """التقصير من الذنوب الكبيرة، القعود عن العمل في سبيل الله، عن الإنفاق في سبيله، عن الجهاد في سبيله، عن الاعتصام بحبله، التقصير فيها من الذنوب الكبيرة"""@ar ;
    hesin:actions """الالتزام بالواجبات الكبرى."""@ar ;
    hesin:hasSynonym """ذنوب التقصير"""@ar ;
    hesin:hasComponent """القعود عن الجهاد"""@ar ;
    hesin:hasComponent """عدم الإنفاق في سبيل الله"""@ar ;
    hesin:hasComponent """التفرق والاختلاف"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_65 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1008 a hesin:Concept ;
    rdfs:label """العذاب البغتة (المفاجئ)"""@ar ;
    hesin:definition """أن العذاب قد يأتي الناس فجأة وهم لا يشعرون بأنهم على خطأ، لأنهم اعتادوا على التقصير واعتبروه ليس بذنب."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{مِنْ قَبْلِ أَنْ يَأْتِيَكُمُ الْعَذَابُ بَغْتَةً وَأَنْتُمْ لا تَشْعُرُونَ} (الزمر:55) الحالة التي نحن فيها... قد يأتينا العذاب يوم القيامة بغتة ونحن لا نشعر [ثم نتعجب ألم نكن مؤمنين فما بالنا]!!"""@ar ;
    hesin:actions """عدم الاغترار بالعادات."""@ar ;
    hesin:hasSynonym """العذاب المفاجئ"""@ar ;
    hesin:hasComponent """العذاب بغتة"""@ar ;
    hesin:hasComponent """عدم الشعور بالذنب"""@ar ;
    hesin:hasComponent """المفاجأة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_65 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1009 a hesin:Concept ;
    rdfs:label """التحسر على التفريط في جنب الله"""@ar ;
    hesin:definition """أن أهل النار يتحسرون على تقصيرهم في طاعة الله، ويتمنون لو كانوا عملوا كل ما يمكن عمله في جنب الله."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{أَنْ تَقُولَ نَفْسٌ يَا حَسْرَتَى عَلَى مَا فَرَّطْتُ فِي جَنْبِ اللَّهِ} (الزمر:56) أليس هذا تعبيراً عن التحسر عندما يرى نفسه إلى أين وصل به الحال أصبح من أهل جهنم"""@ar ;
    hesin:actions """استحضار هذا التحسر لتحفيز العمل."""@ar ;
    hesin:hasSynonym """الندم على التقصير"""@ar ;
    hesin:hasComponent """التحسر"""@ar ;
    hesin:hasComponent """التفريط في جنب الله"""@ar ;
    hesin:hasComponent """رؤية العذاب"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_66 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1010 a hesin:Concept ;
    rdfs:label """تمني الهداية (لو أن الله هداني)"""@ar ;
    hesin:definition """أن بعض أهل النار يتمنون لو أن الله هدانهم في الدنيا، لكن الله يرد بأنه جاءتهم آياته فكذبوا بها."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{أَوْ تَقُولَ لَوْ أَنَّ اللَّهَ هَدَانِي لَكُنْتُ مِنَ الْمُتَّقِينَ} (الزمر:57) ليت أن الله هداني... فأجاب الله عليه هناك:{بَلَى قَدْ جَاءَتْكَ آيَاتِي فَكَذَّبْتَ بِهَا}"""@ar ;
    hesin:actions """قبول الهداية في الدنيا."""@ar ;
    hesin:hasSynonym """تمني الهداية"""@ar ;
    hesin:hasComponent """تمني الهداية"""@ar ;
    hesin:hasComponent """عدم النفع"""@ar ;
    hesin:hasComponent """مجيء الآيات"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_66 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1011 a hesin:Concept ;
    rdfs:label """تمني الرجعة للإحسان (لو أن لي كرة)"""@ar ;
    hesin:definition """أن أهل النار يتمنون العودة إلى الدنيا ليكونوا من المحسنين (لا مجرد المؤمنين)، لكن هذا التمني لا ينفع."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{أَوْ تَقُولَ حِينَ تَرَى الْعَذَابَ لَوْ أَنَّ لِي كَرَّةً فَأَكُونَ مِنَ الْمُحْسِنِينَ} (الزمر:58) أي: ليت لي كرة: رجعة إلى الدنيا{فَأَكُونَ مِنَ الْمُحْسِنِينَ}"""@ar ;
    hesin:actions """الإحسان في الدنيا قبل فوات الأوان."""@ar ;
    hesin:hasSynonym """تمني العودة للدنيا"""@ar ;
    hesin:hasComponent """تمني الرجعة"""@ar ;
    hesin:hasComponent """الإحسان المطلوب"""@ar ;
    hesin:hasComponent """عدم النفع"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_66 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1012 a hesin:Concept ;
    rdfs:label """التكذيب العملي للآيات"""@ar ;
    hesin:definition """أن التكذيب لا يقتصر على الإنكار اللفظي، بل يشمل ترك العمل بالآيات والصد عنها."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{بَلَى قَدْ جَاءَتْكَ آيَاتِي فَكَذَّبْتَ بِهَا} (الزمر:59) هذا التكذيب لا يلزم فيها أن تقول: كذب. هل نحن نقول في القرآن: كذب؟ لا أحد منا يقول: كذب أبداً، لكن في واقعنا كالمكذبين"""@ar ;
    hesin:actions """العمل بالآيات لا مجرد الإقرار بها."""@ar ;
    hesin:hasSynonym """الكفر العملي"""@ar ;
    hesin:hasComponent """ترك العمل"""@ar ;
    hesin:hasComponent """الصد عن الآيات"""@ar ;
    hesin:hasComponent """الاستكبار"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_66 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1013 a hesin:Concept ;
    rdfs:label """الاستكبار (المانع من الهداية)"""@ar ;
    hesin:definition """أن الاستكبار (التكبر والأنفة) هو مانع كبير من قبول الهداية والعمل بها."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَاسْتَكْبَرْتَ} (الزمر:59) الإنسان يقف أمام آيات الله موقف الرافض لاعتبارات أخرى، وموقف المستكبر الذي يأنف من أن يلتزم بها في واقعه"""@ar ;
    hesin:actions """التواضع للحق."""@ar ;
    hesin:hasSynonym """الكبر"""@ar ;
    hesin:hasSynonym """الأنفة"""@ar ;
    hesin:hasComponent """الأنفة من الالتزام"""@ar ;
    hesin:hasComponent """رفض الآيات"""@ar ;
    hesin:hasComponent """عدم التواضع للحق"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_66 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1014 a hesin:Concept ;
    rdfs:label """التقوى تنجي (لا مجرد الإيمان)"""@ar ;
    hesin:definition """أن النجاة في الآخرة تكون بالتقوى (الوقاية من العذاب بالعمل)، وليس بمجرد الإيمان النظري."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَيُنَجِّي اللَّهُ الَّذِينَ اتَّقَوْا بِمَفَازَتِهِمْ} (الزمر:61) التقوى هي التي تنجي الإنسان... أنت آمنت فانطلق لتقي نفسك من عذاب الله"""@ar ;
    hesin:actions """الانتقال من الإيمان إلى التقوى."""@ar ;
    hesin:hasSynonym """التقوى أساس النجاة"""@ar ;
    hesin:hasComponent """التقوى: الوقاية"""@ar ;
    hesin:hasComponent """العمل الصالح"""@ar ;
    hesin:hasComponent """لا مجرد الإيمان"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_67 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1015 a hesin:Concept ;
    rdfs:label """الإحسان (الجهاد والإنفاق)"""@ar ;
    hesin:definition """أن الإحسان في القرآن يشمل أعمالاً عملية كالجهاد والإنفاق، وهي من أعظم ما يقي من النار."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَالَّذِينَ جَاهَدُوا فِينَا لَنَهْدِيَنَّهُمْ سُبُلَنَا وَإِنَّ اللَّهَ لَمَعَ الْمُحْسِنِينَ} (العنكبوت:69) ألم يسم المجاهدين محسنين؟"""@ar ;
    hesin:actions """الالتزام بأعمال الإحسان."""@ar ;
    hesin:hasSynonym """أعمال الإحسان"""@ar ;
    hesin:hasComponent """الجهاد في سبيل الله"""@ar ;
    hesin:hasComponent """الإنفاق في السراء والضراء"""@ar ;
    hesin:hasComponent """كظم الغيظ والعفو"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_67 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1016 a hesin:Concept ;
    rdfs:label """صفات المتقين (الإنفاق، كظم الغيظ، العفو)"""@ar ;
    hesin:definition """أن من صفات المتقين الذين أعدت لهم الجنة: الإنفاق في كل الأحوال، وكظم الغيظ، والعفو عن الناس."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{الَّذِينَ يُنْفِقُونَ فِي السَّرَّاءِ وَالضَّرَّاءِ وَالْكَاظِمِينَ الْغَيْظَ وَالْعَافِينَ عَنِ النَّاسِ} (آل عمران:134) ألم يعرض صفات المحسنين؟ إنفاق في حالات السراء والضراء، وكظم الغيظ، وعفو عن الناس"""@ar ;
    hesin:actions """التحلي بهذه الصفات."""@ar ;
    hesin:hasSynonym """أخلاق المتقين"""@ar ;
    hesin:hasComponent """الإنفاق في السراء والضراء"""@ar ;
    hesin:hasComponent """كظم الغيظ"""@ar ;
    hesin:hasComponent """العفو عن الناس"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_67 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1017 a hesin:Concept ;
    rdfs:label """السخرية (المانع من الاهتداء)"""@ar ;
    hesin:definition """أن السخرية من الدين أو من أهل الحق أو من الأعمال الصالحة هي مانع من الهداية وسبب للندم في الآخرة."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَإِنْ كُنْتُ لَمِنَ السَّاخِرِينَ} (الزمر:56) كنت في الدنيا من الساخرين... الساخر لا يهتدي، الساخر يحول بين نفسه وبين مصادر الهداية"""@ar ;
    hesin:actions """عدم السخرية من الدين."""@ar ;
    hesin:hasSynonym """الاستهزاء بالدين"""@ar ;
    hesin:hasComponent """الاستهزاء"""@ar ;
    hesin:hasComponent """الصد عن الهداية"""@ar ;
    hesin:hasComponent """الندم"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_67 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1018 a hesin:Concept ;
    rdfs:label """نقد مفهوم الإيمان المجرد عن العمل"""@ar ;
    hesin:definition """أن الإيمان الحقيقي في الإسلام هو إيمان عملي، ومجرد التصديق النظري دون عمل لا ينفع صاحبه."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هل التصديق بالله سبحانه وتعالى والإيمان بالله بمجرد كلام ينفع؟... الإيمان كله عملي في الإسلام كله، في القرآن كله، الاعتقادات عملية، الإيمان عملي، أما مجرد إيمان لا يتبعه عمل تعتبر كمن ليس بمؤمن"""@ar ;
    hesin:actions """ترجمة الإيمان إلى عمل."""@ar ;
    hesin:hasSynonym """الإيمان النظري"""@ar ;
    hesin:hasComponent """الإيمان العملي"""@ar ;
    hesin:hasComponent """رفض الإيمان النظري"""@ar ;
    hesin:hasComponent """العمل شرط"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_68 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1019 a hesin:Concept ;
    rdfs:label """نقد المقاصاة في الطاعات"""@ar ;
    hesin:definition """أن البحث عن الحد الأدنى من الواجبات والمقاصاة مع الله في الطاعات هو موقف خاطئ، والصحيح هو السؤال: "هل في هذا العمل رضى الله؟""""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """الذي ينطلق يفرق بين الأحكام فيقول: [هذا ما قد وجب، وهذا ما قد يلزم] قد يكون ممن ليس لديه اهتمام بقضايا كبيرة... لكن متى ما انطلقت ستكون من أولئك المتقين"""@ar ;
    hesin:actions """السؤال: هل هذا العمل فيه رضى الله؟"""@ar ;
    hesin:hasSynonym """الحساب مع الله"""@ar ;
    hesin:hasComponent """البحث عن الحد الأدنى"""@ar ;
    hesin:hasComponent """المقاصاة مع الله"""@ar ;
    hesin:hasComponent """ضعف الاهتمام"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_68 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1020 a hesin:Concept ;
    rdfs:label """نقد مقولة "منسوخ بآية الزكاة""""@ar ;
    hesin:definition """نقد القول بأن آيات الإنفاق في سبيل الله منسوخة بآية الزكاة، مما أدى إلى إهمال واجب مهم."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """اذهب اسأل عنها كل هذه في قائمة المندوبات في قائمة المندوبات كلها. الإنفاق في سبيل الله قالوا: منسوخ بآية الزكاة. وانتهى الموضوع.! فالذين ينفقون في السراء والضراء عبارة عن تطوعات فقط"""@ar ;
    hesin:actions """العمل بآيات الإنفاق."""@ar ;
    hesin:hasSynonym """نقد نفي وجوب الإنفاق"""@ar ;
    hesin:hasComponent """نقد النسخ المزعوم"""@ar ;
    hesin:hasComponent """إعادة الاعتبار للإنفاق"""@ar ;
    hesin:hasComponent """رفض تبسيط الدين"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_68 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1021 a hesin:Concept ;
    rdfs:label """نقد الكذب على الله (باسم الدين)"""@ar ;
    hesin:definition """أن الكذب على الله (بنسبة أقوال أو أحكام له لم يقلها) هو من أعظم الذنوب، ويؤدي إلى اسوداد الوجوه يوم القيامة."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَيَوْمَ الْقِيَامَةِ تَرَى الَّذِينَ كَذَبُوا عَلَى اللَّهِ وُجُوهُهُمْ مُسْوَدَّةٌ} (الزمر:60) فقد يكون مما يحمل الإنسان على الكذب على الله حالة ترفع من التزام بما هدى إليه الله... الكذب على الله سبحانه وتعالى في الاعتقادات، وفي الحديث عن الدين"""@ar ;
    hesin:actions """التثبت قبل نسبة شيء لله."""@ar ;
    hesin:hasSynonym """الافتراء على الله"""@ar ;
    hesin:hasComponent """نسبة الباطل لله"""@ar ;
    hesin:hasComponent """الصد عن الحق"""@ar ;
    hesin:hasComponent """اسوداد الوجوه"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_68 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1022 a hesin:Concept ;
    rdfs:label """نقد القعود خوفًا على العلماء"""@ar ;
    hesin:definition """نقد فكرة أن حفظ العالم من القتل أولى من الجهاد في سبيل الله، مع أن العلماء قدوة في التضحية."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أن يأتي عالم فيظن أن الحفاظ على شخصه هو يمثل الحفاظ على الإسلام فهذه نظرة مغلوطة، أن يقول لك أو يقول لي: لا تتحرك لأنك ستؤدي بهذا العالم، أو ذلك العالم إلى أن يقتل"""@ar ;
    hesin:actions """القدوة بمواقف العلماء المجاهدين."""@ar ;
    hesin:hasSynonym """نقد التقية المبالغ فيها"""@ar ;
    hesin:hasComponent """عدم التحرك خوفًا على العلماء"""@ar ;
    hesin:hasComponent """نظرة مغلوطة"""@ar ;
    hesin:hasComponent """تأثير سلبي على الأمة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_68 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1101 a hesin:Concept ;
    rdfs:label """القرآن كتدبير إلهي للإنسان"""@ar ;
    hesin:definition """أن إنزال القرآن وإرسال الرسل ليس أمرًا منفصلاً عن تدبير الله للكون، بل هو جزء أساسي من تدبير شؤون الإنسان، وهو الجانب الأكبر من تدبير الله لخلقه."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """إذا كان خلق السماوات والأرض يستتبعه تدبير ممن خلقه كذلك أنت أيها الإنسان الذي خلقك وبدأ خلقك من طين لا بد أن يدبر شئونك... تدبير شئونك في جانب منه هو الجانب الأكبر يتمثل في: هداية من الله، إنذار، تشريع، تعليم، توجيه، عن طريق كتب الله، وعن طريق رسله"""@ar ;
    hesin:actions """فهم القرآن كمنهج متكامل للحياة لا كمجرد عبادات فردية."""@ar ;
    hesin:hasSynonym """الهداية"""@ar ;
    hesin:hasSynonym """الإنذار"""@ar ;
    hesin:hasSynonym """التشريع"""@ar ;
    hesin:hasComponent """القرآن مصدر هداية"""@ar ;
    hesin:hasComponent """الإنذار والتشريع"""@ar ;
    hesin:hasComponent """امتداد لتدبير الكون"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_69 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1102 a hesin:Concept ;
    rdfs:label """ازدواجية الإنسان في قبول تدبير الله"""@ar ;
    hesin:definition """موقف الإنسان المتناقض الذي يطلب من الله التدبير في الجانب المادي (المطر، الزرع، الرزق) لكنه يرفض تدبيره في الجانب التشريعي والهدائي."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """نريد منه فقط أن يدبر شئون المخلوقات من حولنا، أما شأننا نحن وهو الشأن الواسع، شأن جانب الهداية، رسم المنهجية في الحياة، الخطة التي نسير عليها في حياتنا، فنحن نتهرب من الله ولا نتركه هو أن يكون هو الذي يختص بوضعها لنا"""@ar ;
    hesin:actions """نقد موقف من يقبلون الدين في العبادات ويرفضونه في التشريع."""@ar ;
    hesin:hasSynonym """التناقض"""@ar ;
    hesin:hasSynonym """الانتقائية"""@ar ;
    hesin:hasComponent """قبول التدبير المادي"""@ar ;
    hesin:hasComponent """رفض التدبير التشريعي"""@ar ;
    hesin:hasComponent """التناقض"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_69 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1103 a hesin:Concept ;
    rdfs:label """حاجة الإنسان للتشريع (شهادة الإنسان على نفسه)"""@ar ;
    hesin:definition """أن اعتراف البشر بحاجتهم إلى القوانين والدساتير هو شهادة منهم على ضرورة التشريع الإلهي، فلماذا يرفضونه إذا جاء من الله؟"""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """كلنا بنو البشر مجمعون على أننا بحاجة إلى تشريعات، ودساتير، ولوائح، وأنظمة على مستوى الشعب الواحد... ألسنا نشهد على أنفسنا أننا بحاجة إلى هذا الجانب، وأن هذا الجانب، هو الجانب المهم الذي تستقيم به الحياة في كل مجالاتها؟"""@ar ;
    hesin:actions """استخدام هذا المنطق في الدعوة إلى تطبيق الشريعة."""@ar ;
    hesin:hasSynonym """ضرورة القانون"""@ar ;
    hesin:hasComponent """البشر يضعون قوانين"""@ar ;
    hesin:hasComponent """هذا يعترف بالحاجة للتشريع"""@ar ;
    hesin:hasComponent """التشريع الإلهي أولى"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_69 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1104 a hesin:Concept ;
    rdfs:label """نقد مفهوم "لا علاقة للدين بالحياة""""@ar ;
    hesin:definition """نقد المفهوم العلماني الذي يفصل الدين عن شؤون الحياة والدولة، معتبرًا أن الدين مجرد عبادة فردية."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أليسوا هم من أبعد أنفسهم عن الله فيما يتعلق بالجانب المهم، جانب الهداية، جانب التشريع، جانب الإرشاد، جانب الإنذار، ثم هم من نزلوا قاعدة: [لا علاقة للدين بالحياة] [لا علاقة للدين بالدولة]"""@ar ;
    hesin:actions """رفض هذا المبدأ وتأكيد شمولية الدين."""@ar ;
    hesin:hasSynonym """العلمانية"""@ar ;
    hesin:hasSynonym """فصل الدين عن الدولة"""@ar ;
    hesin:hasComponent """فصل الدين عن الحياة"""@ar ;
    hesin:hasComponent """إبعاد التشريع الإلهي"""@ar ;
    hesin:hasComponent """تدجين الأمة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_69 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1105 a hesin:Concept ;
    rdfs:label """نقد ترويض الأمة على البدائل (كالقانون والدستور)"""@ar ;
    hesin:definition """أن استخدام مصطلحات مثل "قانون" و"دستور" بدلاً من "شريعة" و"دين" هو عملية ترويض تدريجي للأمة لقبول البدائل عن شرع الله."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """يجب أن يكون حديث الناس كله بالشكل الذي يوحي بالارتباط بشرع الله وهديه ودينه، كلمة: قانون وقوانين ودستور هي توحي للإنسان بمنهجية أخرى وبمصدر آخر لتنظيم شئون الحياة بغير الشريعة"""@ar ;
    hesin:actions """استخدام المصطلحات الشرعية في الخطاب."""@ar ;
    hesin:hasSynonym """الاستبدال التدريجي"""@ar ;
    hesin:hasComponent """ترويض لغوي"""@ar ;
    hesin:hasComponent """إبعاد المصطلحات الشرعية"""@ar ;
    hesin:hasComponent """تمهيد لقبول التشريع البشري"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_69 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1106 a hesin:Concept ;
    rdfs:label """نقد التخويف بالموت والقبر"""@ar ;
    hesin:definition """نقد المنهج الوعظي الذي يركز على تخويف الناس من الموت والقبر، بدلاً من التركيز على اليوم الآخر كما يفعل القرآن."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """ليعرف أولئك الذين يتحدثون مع الناس ويرشدون الناس أنهم كم يغلطون، كم يرتكبون من خطأ جسيم عندما يتحدثون مع الناس عن تخويفهم بالموت نفسه ثم يذكرون لهم أهوال القبر وعذاب القبر وكلاما في النعش وكلاما طويلا عريضا كله يحول الموت إلى شبح مخيف. أن هذا أسلوب يترك أثرا سيئا جداً جداً يتخالف مع منهجية القرآن"""@ar ;
    hesin:actions """الوعظ بالتركيز على اليوم الآخر والجنة والنار."""@ar ;
    hesin:hasSynonym """خطأ منهج الوعظ"""@ar ;
    hesin:hasComponent """التركيز على الموت"""@ar ;
    hesin:hasComponent """تخويف الناس"""@ar ;
    hesin:hasComponent """إضعاف روح الجهاد"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_70 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1107 a hesin:Concept ;
    rdfs:label """الموت كخطوة أولى (لا كشبح مخيف)"""@ar ;
    hesin:definition """أن الموت في القرآن ليس وسيلة تخويف، بل هو مجرد خطوة أولى في الرجوع إلى الله، والخوف الحقيقي يجب أن يكون من اليوم الآخر."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """الموت نفسه إنما هو الخطوة الأولى، وهو قضية عادية، قضية عادية، هو بداية الرجوع إلى الله. ليس هو في حد ذاته ما يجب أن يخيف باعتباره حدثا، ليكن خوفك هو من الرجوع إلى الله إلى اليوم الآخر"""@ar ;
    hesin:actions """عدم التركيز على الموت في الوعظ."""@ar ;
    hesin:hasSynonym """الموت بداية الرجوع"""@ar ;
    hesin:hasComponent """الموت عادي"""@ar ;
    hesin:hasComponent """بداية الرجوع"""@ar ;
    hesin:hasComponent """الخوف من اليوم الآخر"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_70 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1108 a hesin:Concept ;
    rdfs:label """تربية القرآن على الاستبسال (لا على الجبن)"""@ar ;
    hesin:definition """أن القرآن يربي على الاستبسال وعدم الخوف من الموت، وليس على الجبن الناتج عن التخويف من الموت."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """إنه الذي يربي هذه الأمة تربية جهادية، الذي يربيك لتكون مجاهدا، هل ينطلق ليخوفك من الموت نفسه، وهو يريد منك أن تستبسل وأن تبذل نفسك في سبيل الله.. لا يمكن هذا حتى ولا لقائد عسكري أن يعمله"""@ar ;
    hesin:actions """التركيز على فضل الشهادة والجنة."""@ar ;
    hesin:hasSynonym """التربية الجهادية"""@ar ;
    hesin:hasComponent """تربية جهادية"""@ar ;
    hesin:hasComponent """الاستبسال"""@ar ;
    hesin:hasComponent """عدم الخوف من الموت"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_70 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1109 a hesin:Concept ;
    rdfs:label """إلغاء الموت للمجاهدين (أحياء عند ربهم)"""@ar ;
    hesin:definition """أن القرآن ألغى مفهوم الموت بالنسبة للمجاهدين، ووصفهم بأنهم أحياء، ليدفعهم إلى التضحية دون تردد."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """ألغي الموت بكله من قائمة المجاهدين.. بكله لماذا؟ لأنه حتى أن يبقى اسم الموت، أو شبح الموت ماثلا أمامهم قد يكون غير منطقي وغير أسلوب بل سيلغي الموت بكله أمام المجاهدين"""@ar ;
    hesin:actions """تعليم الناس أن الشهادة حياة."""@ar ;
    hesin:hasSynonym """الشهادة حياة"""@ar ;
    hesin:hasComponent """إلغاء اسم الموت"""@ar ;
    hesin:hasComponent """وصف الشهداء بالأحياء"""@ar ;
    hesin:hasComponent """دفع للاستبسال"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_70 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1110 a hesin:Concept ;
    rdfs:label """الهداية الإلهية تكريم لا إذلال"""@ar ;
    hesin:definition """أن الهداية الإلهية تُقدم بطريقة تحترم كرامة الإنسان وعقله، وليس بالإكراه والإجبار (كالسجن والتعذيب)، لأن ذلك إذلال."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَلَوْ شِئْنَا لَآتَيْنَا كُلَّ نَفْسٍ هُدَاهَا}... هل تريد أن ترى هدى من هذا النوع الذي كنت تقترحه على الله سبحانه وتعالى.. وهو الشيء الذي لا يمكن أن يعمله.. انظر إلى السجون إلى التعذيب هناك هدى بوسائل التعذيب"""@ar ;
    hesin:actions """تقديم الهداية بأسلوب يحترم عقل الإنسان."""@ar ;
    hesin:hasSynonym """كرامة الإنسان"""@ar ;
    hesin:hasComponent """الهداية بالعقل والاختيار"""@ar ;
    hesin:hasComponent """احترام الكرامة"""@ar ;
    hesin:hasComponent """رفض الإكراه"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_71 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1111 a hesin:Concept ;
    rdfs:label """تفسير "ولو شئنا لآتينا كل نفس هداها""""@ar ;
    hesin:definition """تفسير الآية بأن الله لو شاء لهدى الناس بالإكراه والجبر، لكنه اختار أن يهديهم بطريقة تحترم إنسانيتهم وكرامتهم."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """ما هو الهدى الذي كانوا ينتظرونه؟ أن يساقوا سوقا رغما عنهم وقسراً إلى كل قضية... أن يمسك الإنسان بمقدمة رأسه فيساق غصبا عنه إلى الصلاة... لكن هذا ليس هدى أنت حينئذ لست إنسانا. إنك إنسان لك درجتك ولك كرامتك"""@ar ;
    hesin:actions """فهم الآية في سياق كرامة الإنسان."""@ar ;
    hesin:hasSynonym """عدم الإكراه"""@ar ;
    hesin:hasComponent """الإكراه ليس هدى"""@ar ;
    hesin:hasComponent """الهداية بالاختيار"""@ar ;
    hesin:hasComponent """تكريم الإنسان"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_71 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1112 a hesin:Concept ;
    rdfs:label """العبودية لله عزة وكرامة"""@ar ;
    hesin:definition """أن العبودية لله ليست ذلاً، بل هي مصدر العزة والكرامة، بينما الذل الحقيقي هو في الخضوع لغير الله."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """تذليل أنفسنا له هي الكرامة، هي العزة. ونذلل أنفسنا لمن هم أضل من الأنعام ولا نذلل أنفسنا لله سبحانه وتعالى"""@ar ;
    hesin:actions """تعليم الناس أن العبودية لله هي العزة."""@ar ;
    hesin:hasSynonym """حرية العبودية"""@ar ;
    hesin:hasComponent """العبودية لله عزة"""@ar ;
    hesin:hasComponent """الخضوع لغير الله ذل"""@ar ;
    hesin:hasComponent """إعادة تعريف العبودية"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_71 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1113 a hesin:Concept ;
    rdfs:label """الاستفهام الاستبعادي (أإذا ضللنا في الأرض)"""@ar ;
    hesin:definition """أن صيغة الاستفهام في القرآن أحيانًا تعبر عن الاستبعاد والجحود، وليس عن التساؤل الحقيقي."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أليس قولهم: {وَقَالُوا أَإِذَا ضَلَلْنَا فِي الْأَرْضِ أَإِنَّا لَفِي خَلْقٍ جَدِيدٍ} أليس كفرا؟ لأنه استبعاد هنا، ليس استفهام، ليس سؤالاً... هم لا يريدون أن يؤمنوا لا أن القضية هذه لا براهين عليها كافية"""@ar ;
    hesin:actions """التمييز بين الاستفهام الصادق والاستبعادي."""@ar ;
    hesin:hasSynonym """الجحود"""@ar ;
    hesin:hasSynonym """الإنكار"""@ar ;
    hesin:hasComponent """الاستفهام الاستبعادي"""@ar ;
    hesin:hasComponent """الجحود"""@ar ;
    hesin:hasComponent """عدم الرغبة في الإيمان"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_72 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1114 a hesin:Concept ;
    rdfs:label """ندم المجرمين في الآخرة (ربنا أبصرنا وسمعنا)"""@ar ;
    hesin:definition """مشهد من مشاهد الآخرة حيث يندم المجرمون ويطلبون العودة إلى الدنيا ليعملوا صالحًا، بعد أن رأوا العذاب وأيقنوا."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَلَوْ تَرَى إِذِ الْمُجْرِمُونَ نَاكِسُو رُؤُوسِهِمْ عِنْدَ رَبِّهِمْ رَبَّنَا أَبْصَرْنَا وَسَمِعْنَا فَارْجِعْنَا نَعْمَلْ صَالِحاً إِنَّا مُوقِنُونَ} (السجدة:12) أليست هذه العبارة عبارة الخاضع؟ عبارة الخاشع؟ عبارة المتأدب؟ عبارة من عرف أن الله ربه؟"""@ar ;
    hesin:actions """استحضار هذا المشهد لتحفيز العمل في الدنيا."""@ar ;
    hesin:hasSynonym """الندم"""@ar ;
    hesin:hasSynonym """التوبة المتأخرة"""@ar ;
    hesin:hasComponent """الخضوع والذل"""@ar ;
    hesin:hasComponent """طلب الرجعة"""@ar ;
    hesin:hasComponent """اليقين المتأخر"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_72 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1115 a hesin:Concept ;
    rdfs:label """العمى في الدنيا يؤدي إلى العمى في الآخرة"""@ar ;
    hesin:definition """أن عدم البصيرة في الدنيا (بالتفكر في آيات الله واتباع هديه) يؤدي إلى العمى والضلال في الآخرة."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَمَنْ كَانَ فِي هَذِهِ أَعْمَى فَهُوَ فِي الْآخِرَةِ أَعْمَى وَأَضَلُّ سَبِيلاً} (الاسراء:72) لاحظوا كيف يأتي القرآن الكريم يربط بين الشقاء في الدنيا والشقاء في الآخرة، بين العمى في الدنيا والعمى في الآخرة"""@ar ;
    hesin:actions """الحث على البصيرة في الدنيا."""@ar ;
    hesin:hasSynonym """العاقبة السيئة"""@ar ;
    hesin:hasComponent """العمى في الدنيا"""@ar ;
    hesin:hasComponent """العمى في الآخرة"""@ar ;
    hesin:hasComponent """الربط بين الدنيا والآخرة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_72 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1116 a hesin:Concept ;
    rdfs:label """نسيان لقاء اليوم الآخر سبب العذاب"""@ar ;
    hesin:definition """أن سبب العذاب هو نسيان لقاء الله واليوم الآخر، وعدم الاستعداد له."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{فَذُوقُوا بِمَا نَسِيتُمْ لِقَاءَ يَوْمِكُمْ هَذَا إِنَّا نَسِينَاكُمْ} (السجدة:14) أنتم من نسيتم أنفسكم"""@ar ;
    hesin:actions """تذكير الناس باليوم الآخر."""@ar ;
    hesin:hasSynonym """الغفلة"""@ar ;
    hesin:hasSynonym """النسيان"""@ar ;
    hesin:hasComponent """نسيان اليوم الآخر"""@ar ;
    hesin:hasComponent """عدم الاستعداد"""@ar ;
    hesin:hasComponent """النسيان الإلهي جزاء"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_72 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1117 a hesin:Concept ;
    rdfs:label """نقد تقييد الحج (كنموذج للترويض)"""@ar ;
    hesin:definition """نقد تقييد أعداد الحجاج تحت ذرائع تنظيمية، واعتبار ذلك ترويضًا للأمة لقبول المزيد من التقييدات المستقبلية."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """جاء تنظيم الحج: اليمن يحج منه أربعة عشرة ألفا إلى عشرين ألفا... قالوا المشاعر ضيقة... وكل بلد يحدد له عددا معينا!.. أليس ذلك ما هو حاصل الآن؟. هذه أول خطوة من خطوات احتلال اليهود للحج"""@ar ;
    hesin:actions """المطالبة بحرية الحج وفق الشريعة."""@ar ;
    hesin:hasSynonym """تحجيم الشعائر"""@ar ;
    hesin:hasComponent """تقييد الأعداد"""@ar ;
    hesin:hasComponent """ترويض الأمة"""@ar ;
    hesin:hasComponent """مخطط لتقليل الحج"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_73 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1118 a hesin:Concept ;
    rdfs:label """نقد روايات منكر ونكير"""@ar ;
    hesin:definition """نقد روايات عذاب القبر ومنكر ونكير، واعتبارها غير ثابتة أو مستبعدة عقلاً."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """وبعض العلماء استنكر فعلا واستعبد وأنكر قضية [منكر ونكير]، إنه حتى ليس في أسماء الملائكة هذه الأسماء المزعجة الغير طبيعية [منكر ونكير]... هذا مما استبعده علماء ـ وهو فعلا مستبعد جدا"""@ar ;
    hesin:actions """الاعتماد على القرآن في التخويف."""@ar ;
    hesin:hasSynonym """نقد الأحاديث الضعيفة"""@ar ;
    hesin:hasComponent """استبعاد الروايات"""@ar ;
    hesin:hasComponent """نقد الأسماء"""@ar ;
    hesin:hasComponent """عدم ورودها في القرآن"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_73 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1119 a hesin:Concept ;
    rdfs:label """العمل الصالح مرتبط بالوجهة لا بالشكل"""@ar ;
    hesin:definition """أن العمل لا يكون صالحًا بمجرد شكله، بل باتجاهه وموافقته لهدي الله."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """قد يكون إنفاقك مائة ريال يسمى عمل صالح.. أليس كذلك؟ وإنفاق خمسة آلاف في مجال آخر يسمى عمل باطل.. ما الفارق؟ هل مجرد العطاء هو الذي يسمى: صالحاً؟ إذاً فلتكن الخمسة الآلاف هي الصالحة والمائة الريال هي العمل الباطل. المجالات التي تتجه في أعمالك نحوها"""@ar ;
    hesin:actions """توجيه الأعمال نحو ما يرضي الله."""@ar ;
    hesin:hasSynonym """نية العمل"""@ar ;
    hesin:hasComponent """الشكل لا يكفي"""@ar ;
    hesin:hasComponent """الوجهة تحدد الصلاح"""@ar ;
    hesin:hasComponent """الاتباع لهدي الله"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_73 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1201 a hesin:Concept ;
    rdfs:label """الخرور سجدا عند التذكير بآيات الله"""@ar ;
    hesin:definition """أن المؤمن الحقيقي يتأثر بآيات الله بشكل عميق يدفعه إلى الخضوع والطاعة فور تذكره بها، دون تردد أو استكبار."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{إِنَّمَا يُؤْمِنُ بِآياتِنَا الَّذِينَ إِذَا ذُكِّرُوا بِهَا خَرُّوا سُجَّداً} (السجدة:15) ... الإنسان المؤمن قد يعتريه ـ أحيانا ـ ذهول عن أهمية بعض الأشياء... هو مؤمن من هذه النوعية موطن نفسه على أن يعمل وينطلق في كل عمل فيه لله رضى؛ لأنه ساجد لله، خاضع لله، وخاشع لله"""@ar ;
    hesin:actions """قياس الإيمان بمدى التأثر بآيات الله."""@ar ;
    hesin:hasSynonym """الخشوع"""@ar ;
    hesin:hasSynonym """التفاعل مع الذكر"""@ar ;
    hesin:hasComponent """التأثر بآيات الله"""@ar ;
    hesin:hasComponent """الخضوع الفوري"""@ar ;
    hesin:hasComponent """التفاعل العملي"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_74 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1202 a hesin:Concept ;
    rdfs:label """التسبيح بحمد الله وعدم الاستكبار"""@ar ;
    hesin:definition """أن المؤمنين يسبحون الله ويثنون عليه، ولا يستكبرون عن أداء أي عمل صالح مهما كان شاقًا أو خطيرًا."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَسَبَّحُوا بِحَمْدِ رَبِّهِمْ وَهُمْ لا يَسْتَكْبِرُونَ} (السجدة:15) ... ليسوا من أولئك ـ وهم الكثير فينا ـ الذي يرى نفسه أنه قد تورط وهو في عمل صالح، لكن هذا العمل هو من النوع الشاق الشائك، الخطير نوعا ما، فيرى نفسه أنه في مشكلة"""@ar ;
    hesin:actions """تنمية روح التواضع وعدم الاستكبار."""@ar ;
    hesin:hasSynonym """التنزيه"""@ar ;
    hesin:hasSynonym """الثناء"""@ar ;
    hesin:hasComponent """التسبيح والثناء"""@ar ;
    hesin:hasComponent """عدم الاستكبار"""@ar ;
    hesin:hasComponent """تجاوز مشاعر التثاقل"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_74 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1203 a hesin:Concept ;
    rdfs:label """تجافي الجنب عن المضاجع (التهجد)"""@ar ;
    hesin:definition """أن المؤمنين يتخلون عن راحة النوم للعبادة والدعاء، وهذا ليس مجرد صلاة الفريضة بل أعمال إضافية."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{تَتَجَافَى جُنُوبُهُمْ عَنِ الْمَضَاجِعِ يَدْعُونَ رَبَّهُمْ خَوْفاً وَطَمَعاً} (السجدة:16) ... ليسوا مسارعين إلى النوم تبتعد جنوبهم، وعندما تبتعد جنوبهم عن النوم ليس في مجال متابعة حلقات التلفزيون المفسدة، ولا في مجال متابعة القنوات الفضائية"""@ar ;
    hesin:actions """تشجيع قيام الليل والدعاء."""@ar ;
    hesin:hasSynonym """قيام الليل"""@ar ;
    hesin:hasSynonym """السهر في الطاعة"""@ar ;
    hesin:hasComponent """ترك النوم للعبادة"""@ar ;
    hesin:hasComponent """الدعاء خوفًا وطمعًا"""@ar ;
    hesin:hasComponent """عدم الانشغال باللهو"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_74 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1204 a hesin:Concept ;
    rdfs:label """الإنفاق من الرزق (عبادة مستمرة)"""@ar ;
    hesin:definition """أن الإنفاق في سبيل الله صفة ملازمة للمؤمنين، يفعلونه باستمرار وبحثًا عن مواطن البر، دون انتظار تذكير متكرر."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَمِمَّا رَزَقْنَاهُمْ يُنْفِقُونَ} (السجدة:16) ... هم من يبحثون عن المجالات التي تنصر دين الله لينفقوا فيها... ليسوا من أولئك الذين يحتاجون إلى كلام خاص حول موضوع الإنفاق يتكرر دائما دائما على مسامعهم"""@ar ;
    hesin:actions """تنمية روح البذل والإنفاق."""@ar ;
    hesin:hasSynonym """البذل في سبيل الله"""@ar ;
    hesin:hasComponent """البحث عن مجالات الإنفاق"""@ar ;
    hesin:hasComponent """الاستمرارية"""@ar ;
    hesin:hasComponent """عدم انتظار التذكير"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_74 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1205 a hesin:Concept ;
    rdfs:label """الدعاء خوفًا وطمعًا"""@ar ;
    hesin:definition """أن المؤمنين يجمعون في دعائهم بين الخوف من عقاب الله والطمع في رحمته ورضوانه."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{يَدْعُونَ رَبَّهُمْ خَوْفاً وَطَمَعاً} (السجدة:16) خوفا من الله، خوفا من أنفسنا أن تكون عاقبتنا بالشكل الذي توعد الله به العاصين له... والمؤمنون أيضا يطمعون في رضوان الله"""@ar ;
    hesin:actions """الموازنة بين الخوف والرجاء."""@ar ;
    hesin:hasSynonym """الخوف والرجاء"""@ar ;
    hesin:hasComponent """الخوف من العذاب"""@ar ;
    hesin:hasComponent """الطمع في الرحمة"""@ar ;
    hesin:hasComponent """الموازنة بين الرجاء والخوف"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_74 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1206 a hesin:Concept ;
    rdfs:label """نقد عقيدة شفاعة النبي لأهل الكبائر"""@ar ;
    hesin:definition """نقد عقيدة شفاعة النبي لأهل الكبائر التي تزعم أن الفاسقين والمجرمين يدخلون الجنة بشفاعة النبي، مخالفة لنصوص القرآن التي تنفي التسوية بين المؤمن والفاسق."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """وهذه آية تصرخ في وجوه أولئك الذين يقدمون عقيدة ينسبونها إلى الرسول (صلوات الله عليه وعلى آله) تقضي بالتسوية بين المجرمين أهل الكبائر، وبين المؤمنين، فيحضون جميعا بالجنة... أين حديث: شفاعتي لأهل الكبائر من أمتي من هذه الآية، وأمثالها؟ يتبخر مثل هذا الكلام"""@ar ;
    hesin:actions """رفض الأحاديث المخالفة للقرآن."""@ar ;
    hesin:hasSynonym """نقد التسوية بين المؤمن والفاسق"""@ar ;
    hesin:hasComponent """رفض التسوية بين المؤمن والفاسق"""@ar ;
    hesin:hasComponent """إنكار شفاعة أهل الكبائر"""@ar ;
    hesin:hasComponent """التمسك بنصوص القرآن"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_75 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1207 a hesin:Concept ;
    rdfs:label """لا يستوي أصحاب النار وأصحاب الجنة"""@ar ;
    hesin:definition """أن المؤمنين والفاسقين ليسوا سواء في الآخرة، بل لكل جزاء بحسب عمله."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{أَفَمَنْ كَانَ مُؤْمِناً كَمَنْ كَانَ فَاسِقاً لا يَسْتَوُونَ} (السجدة:18) {لا يَسْتَوِي أَصْحَابُ النَّارِ وَأَصْحَابُ الْجَنَّةِ} (الحشر:20) أكثر من ثلاث أو أربع آيات في ذهني حول هذا الموضوع مصرحة بأنه لن يكون جزاؤهم سويا"""@ar ;
    hesin:actions """التحذير من التسوية الخاطئة."""@ar ;
    hesin:hasSynonym """عدم المساواة"""@ar ;
    hesin:hasComponent """المؤمن له الجنة"""@ar ;
    hesin:hasComponent """الفاسق له النار"""@ar ;
    hesin:hasComponent """لا مساواة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_75 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1208 a hesin:Concept ;
    rdfs:label """المؤمنون هم الذين آمنوا وعملوا الصالحات"""@ar ;
    hesin:definition """أن الإيمان الحقيقي لا ينفصل عن العمل الصالح، والأعمال الصالحة هي ما حددها القرآن والسنة، وليس ما يراه الناس من مصالح."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{أَمَّا الَّذِينَ آمَنُوا وَعَمِلُوا الصَّالِحَاتِ فَلَهُمْ جَنَّاتُ الْمَأْوَى نُزُلاً بِمَا كَانُوا يَعْمَلُونَ} (السجدة:19) ... العمل الصالح هو أن تسكت لتحافظ على مصالح فلان أو فلان... الأعمال الصالحة هي التي تضمنها القرآن الكريم دعانا إليها، ودعانا إليها الرسول"""@ar ;
    hesin:actions """التمسك بالأعمال الصالحة الشرعية."""@ar ;
    hesin:hasSynonym """الإيمان المقترن بالعمل"""@ar ;
    hesin:hasComponent """الإيمان مرتبط بالعمل"""@ar ;
    hesin:hasComponent """الأعمال الصالحة يحددها الشرع"""@ar ;
    hesin:hasComponent """رفض الأعمال المبتدعة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_75 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1209 a hesin:Concept ;
    rdfs:label """جزاء المؤمنين (قرّة أعين)"""@ar ;
    hesin:definition """أن ما أعده الله للمؤمنين من النعيم يفوق تصور البشر، ولا يعلم كنهه أحد."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{فَلا تَعْلَمُ نَفْسٌ مَا أُخْفِيَ لَهُمْ مِنْ قُرَّةِ أَعْيُنٍ جَزَاءً بِمَا كَانُوا يَعْمَلُونَ} (السجدة:17) ... لا نفس ملك من ملائكة الله ولا نفس نبي من أنبياء الله عظم ما وعدوا به من الثواب العظيم والمكان الرفيع عند الله"""@ar ;
    hesin:actions """استحضار هذا الثواب لتحفيز العمل."""@ar ;
    hesin:hasSynonym """الثواب العظيم"""@ar ;
    hesin:hasComponent """نعيم لا يعلمه أحد"""@ar ;
    hesin:hasComponent """قرّة أعين (ما يسر النفوس)"""@ar ;
    hesin:hasComponent """جزاء على الأعمال"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_76 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1210 a hesin:Concept ;
    rdfs:label """الفاسقون يعادون إلى النار"""@ar ;
    hesin:definition """أن الفاسقين في النار، وكلما حاولوا الخروج أعيدوا إليها، كما كانوا في الدنيا كلما أراد الحق أن يخرجهم من الظلمات أصرّوا على البقاء فيها."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَأَمَّا الَّذِينَ فَسَقُوا فَمَأْوَاهُمُ النَّارُ كُلَّمَا أَرَادُوا أَنْ يَخْرُجُوا مِنْهَا أُعِيدُوا فِيهَا} (السجدة:20) ... كلما حاول أولئك وهم يتحركون لمحاولة الخروج من جهنم ضربوا أيضا بمقامع من حديد"""@ar ;
    hesin:actions """التحذير من الإصرار على الفسق."""@ar ;
    hesin:hasSynonym """عذاب الخلود"""@ar ;
    hesin:hasComponent """المأوى النار"""@ar ;
    hesin:hasComponent """كل محاولة خروج تعاد"""@ar ;
    hesin:hasComponent """مقارعة بمقامع الحديد"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_76 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1211 a hesin:Concept ;
    rdfs:label """العذاب الأدنى (في الدنيا) قبل العذاب الأكبر"""@ar ;
    hesin:definition """أن الله يذيق الناس عذابًا في الدنيا (كالمصائب والهزائم) قبل عذاب الآخرة، رحمة بهم لعلهم يرجعون."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَلَنُذِيقَنَّهُمْ مِنَ الْعَذَابِ الْأَدْنَى دُونَ الْعَذَابِ الْأَكْبَرِ لَعَلَّهُمْ يَرْجِعُونَ} (السجدة:21) ... أن الأعمال السيئة في هذه الدنيا يحصل من ورائها الإنسان على نوع من العذاب... لأنه رحيم سبحانه وتعالى... عسى أن يرجعوا"""@ar ;
    hesin:actions """فهم المصائب كفرصة للعودة."""@ar ;
    hesin:hasSynonym """العقوبات الدنيوية"""@ar ;
    hesin:hasComponent """عذاب أدنى في الدنيا"""@ar ;
    hesin:hasComponent """العذاب الأكبر في الآخرة"""@ar ;
    hesin:hasComponent """الرحمة في الإنذار"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_76 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1212 a hesin:Concept ;
    rdfs:label """الإعراض عن آيات الله ظلم للنفس"""@ar ;
    hesin:definition """أن الإعراض عن آيات الله بعد تذكير الإنسان بها هو أشد أنواع الظلم، وهو ظلم للنفس قبل كل شيء."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَمَنْ أَظْلَمُ مِمَّنْ ذُكِّرَ بِآياتِ رَبِّهِ فَأَعْرَضَ عَنْهَا وَنَسِيَ مَا قَدَّمَتْ يَدَاهُ} (الكهف:57) من أظلم من هذا؟! من أظلم منه لنفسه؟! من أظلم منه في موقفه السيء أمام ربه المنعم عليه، الرحيم به"""@ar ;
    hesin:actions """الحذر من الإعراض عن التذكير."""@ar ;
    hesin:hasSynonym """الظلم الذاتي"""@ar ;
    hesin:hasComponent """الإعراض بعد التذكير"""@ar ;
    hesin:hasComponent """نسيان ما قدمت اليدان"""@ar ;
    hesin:hasComponent """الظلم للنفس"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_76 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1213 a hesin:Concept ;
    rdfs:label """ربط العمل بالضعفاء (نموذج سورة عبس)"""@ar ;
    hesin:definition """أن العمل الدعوي يجب أن يركز على الفقراء والمستضعفين الذين لا يستكبرون، وليس على الكبار الذين قد يفرضون شروطًا ويشوهون الدين."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لم يسمح الله أبدا لأنبيائه أن يطردوا أحدا... [سورة عبس] من تأملها سيدرك الخطورة البالغة... المهم هو: أن تجد الرجل الذي تنفعه الذكرى، هذا هو المهم"""@ar ;
    hesin:actions """الاهتمام بالضعفاء والعامة."""@ar ;
    hesin:hasSynonym """الاهتمام بالمستضعفين"""@ar ;
    hesin:hasComponent """التركيز على من تنفعه الذكرى"""@ar ;
    hesin:hasComponent """عدم التودد للكبراء"""@ar ;
    hesin:hasComponent """القدوة بقصة سورة عبس"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_77 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1214 a hesin:Concept ;
    rdfs:label """عدم التودد للكبراء بشروط"""@ar ;
    hesin:definition """أن الكبار الذين يشترطون لدخولهم في العمل الديني أن يراعى مصالحهم ومشاعرهم هم عقبة في طريق العمل الصالح."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لا تربط نفسك بكبار من هؤلاء ولا تربط عملك الثقافي بكبار من هؤلاء... لأن من دخل بإملاءات وشروط هو ذلك الذي يريد أن تكون حركة الناس على وفق ما يريد وبالشكل الذي يراعي مشاعره ومصالحه"""@ar ;
    hesin:actions """عدم تقديم تنازلات للكبراء على حساب الدين."""@ar ;
    hesin:hasSynonym """عدم استرضاء الكبار"""@ar ;
    hesin:hasComponent """رفض الإملاءات"""@ar ;
    hesin:hasComponent """عدم استرضاء الكبار"""@ar ;
    hesin:hasComponent """التركيز على من لا يشترطون"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_77 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1215 a hesin:Concept ;
    rdfs:label """الاستكبار مانع من الاستجابة"""@ar ;
    hesin:definition """أن الاستكبار (الكبر والعجب) هو مانع رئيسي من الاستجابة للحق وقبول التذكير."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أولئك الكبار هم من لديهم اعتبارات معينة يحافظون عليها، ممن ينظر إليك وأنت تذكره أنك تحت أنك دونه فلا يكاد يسمع منك... لأنه في واقعه مستكبر"""@ar ;
    hesin:actions """التحرر من الكبر والاستكبار."""@ar ;
    hesin:hasSynonym """الكبر"""@ar ;
    hesin:hasSynonym """العجب"""@ar ;
    hesin:hasComponent """عدم القبول من الأدنى"""@ar ;
    hesin:hasComponent """الحرص على المكانة"""@ar ;
    hesin:hasComponent """الرفض المبدئي"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_77 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1216 a hesin:Concept ;
    rdfs:label """السنة الإلهية في الانتقام من المجرمين"""@ar ;
    hesin:definition """أن الله سنّ سنة الانتقام من المجرمين الذين أعرضوا عن آياته بعد تذكيرهم."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{إِنَّا مِنَ الْمُجْرِمِينَ مُنْتَقِمُونَ} (السجدة:22) هو مجرم ولأنه ليس هناك وسيلة أخرى أبلغ وأعظم وأكثر تأثيراً في نفسه من هذه الآيات التي أعرض عنها فواقعه إذاً مجرم هو مجرم والمجرم هو ذلك الذي لا يستحق إلا الانتقام منه"""@ar ;
    hesin:actions """التحذير من عاقبة الإجرام."""@ar ;
    hesin:hasSynonym """عدل الله"""@ar ;
    hesin:hasComponent """الانتقام من المجرمين"""@ar ;
    hesin:hasComponent """الإعراض سبب الانتقام"""@ar ;
    hesin:hasComponent """سنة إلهية ثابتة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_77 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1217 a hesin:Concept ;
    rdfs:label """استراتيجية الأعداء في محاربة الأسماء والأعلام"""@ar ;
    hesin:definition """أن الأعداء (اليهود والنصارى) يعملون على محو الأسماء والمصطلحات الإسلامية (كجهاد، الإمام علي، أهل البيت) لأنها تحمل في طياتها خطرًا عليهم."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """تغيير الاسم، تغير المصطلحات مهما أمكن كما وجدنا من تغيير كلمة: [جهاد] ونحوها... كيف غيب الحديث عن الإمام علي (عليه السلام) وأهل البيت (عليهم السلام) في المناهج الدراسية"""@ar ;
    hesin:actions """الحفاظ على المصطلحات والأسماء الإسلامية."""@ar ;
    hesin:hasSynonym """محو الهوية"""@ar ;
    hesin:hasComponent """تغيير المصطلحات"""@ar ;
    hesin:hasComponent """إقصاء الأعلام"""@ar ;
    hesin:hasComponent """إضعاف الهوية"""@ar ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1218 a hesin:Concept ;
    rdfs:label """السكوت عن الباطل خطورة"""@ar ;
    hesin:definition """أن السكوت عن الباطل هو خطورة بالغة على الأمة، والقرآن كله حركة وكلام ضد الباطل."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لو كان السكوت هو من ذهب ـ كما يقولون ـ لما تحدث القرآن الكريم عن الجهاد ، عن التضحية، عن الاستبسال، عن إنفاق الأموال، عن التواصي بالحق. أليس القرآن كله حركة وكلام؟ أم أنه صمت وجمود؟ كله حركة.. كله كلام"""@ar ;
    hesin:actions """رفع الصوت ضد الباطل."""@ar ;
    hesin:hasSynonym """التخاذل"""@ar ;
    hesin:hasComponent """السكوت خطورة"""@ar ;
    hesin:hasComponent """الجهاد والكلام ضد الباطل"""@ar ;
    hesin:hasComponent """القرآن كله حركة"""@ar ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1219 a hesin:Concept ;
    rdfs:label """أهمية التذكير من أي طرف كان"""@ar ;
    hesin:definition """أن التذكير بآيات الله يجب أن يُقبل من أي شخص، بغض النظر عن مكانته الاجتماعية، والمؤمن لا يستكبر عن قبول التذكير من الأدنى."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """القرآن الكريم يعتبر للتذكير أهميته من أي طرف كان ولو من صغير {قَالَ رَجُلانِ مِنَ الَّذِينَ يَخَافُونَ أَنْعَمَ اللَّهُ عَلَيهِمَا} (المائدة:23)... المؤمن لا يستكبر إذا ما ذكر من صغير أو من طرف آخر يراه وضيعا"""@ar ;
    hesin:actions """تقبل التذكير من الجميع."""@ar ;
    hesin:hasSynonym """قبول النصيحة"""@ar ;
    hesin:hasComponent """قبول التذكير من أي طرف"""@ar ;
    hesin:hasComponent """عدم الاستكبار"""@ar ;
    hesin:hasComponent """قيمة التذكير ذاتها"""@ar ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1301 a hesin:Concept ;
    rdfs:label """الوعيد يبدأ من الدنيا"""@ar ;
    hesin:definition """أن الإنسان ينال جزاء أعماله وعقوباتها في الدنيا قبل الآخرة، وهذا سنة إلهية ثابتة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """قضية مهمة جداً: أن نعرف أن هناك وعداً ووعيداً في الدنيا، إضافة إلى الوعد والوعيد في الآخرة... تقصيرنا في فهمنا لهذه القضية هو ما جعلنا نجهل وضعيتنا التي نحن فيها"""@ar ;
    hesin:actions """تقييم واقع الأمة في ضوء وعيد الله."""@ar ;
    hesin:hasSynonym """العقوبات الدنيوية"""@ar ;
    hesin:hasSynonym """جزاء الأعمال في الدنيا"""@ar ;
    hesin:hasComponent """العقوبات الدنيوية"""@ar ;
    hesin:hasComponent """الجزاء العاجل"""@ar ;
    hesin:hasComponent """فهم الواقع في ضوء العقوبات"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_78 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1302 a hesin:Concept ;
    rdfs:label """عقوبة المعصية تبدأ فورًا (نموذج آدم)"""@ar ;
    hesin:definition """أن عقوبة المعصية تبدأ فورًا في الدنيا، كما حدث مع آدم عندما أكل من الشجرة فشقي ونزعت عنه ملابسه."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أوليس أول معصية كانت في التاريخ حدثت من أبينا آدم؟ ألم يشق؟ شقي فعلا... أليست هذه أول معصية؟ تحدث نتيجتها في الدنيا على من اقترفها أن يشقى، وأن تنزع عنه حتى ملابسه"""@ar ;
    hesin:actions """عدم الاستهانة بآثار المعاصي."""@ar ;
    hesin:hasSynonym """السرعة في العقوبة"""@ar ;
    hesin:hasComponent """السرعة في العقوبة"""@ar ;
    hesin:hasComponent """الشقاء في الدنيا"""@ar ;
    hesin:hasComponent """نزع الملابس (الجزاء العاجل)"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_78 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1303 a hesin:Concept ;
    rdfs:label """عقوبة الربا (حرب من الله)"""@ar ;
    hesin:definition """أن الربا من أعظم الذنوب التي توعد الله عليها بحرب في الدنيا، وآثار هذه الحرب ظاهرة في تدهور الاقتصاد والمعيشة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{فَإِنْ لَمْ تَفْعَلُوا فَأْذَنُوا بِحَرْبٍ مِنَ اللَّهِ وَرَسُولِهِ} (البقرة:279) ماذا يعني هذا؟ عقوبة في الدنيا أليس كذلك؟ بل حرب الله سبحانه وتعالى سيتجه إلى طرف يحارب عباده إذا لم يدعوا الربا"""@ar ;
    hesin:actions """تحذير الناس من الربا وبيان آثاره."""@ar ;
    hesin:hasSynonym """حرب الله على المرابين"""@ar ;
    hesin:hasComponent """حرب من الله"""@ar ;
    hesin:hasComponent """آثار اقتصادية"""@ar ;
    hesin:hasComponent """تدهور المعيشة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_78 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1304 a hesin:Concept ;
    rdfs:label """الإيمان ببعض الكتاب وكفر ببعض (خزي في الدنيا)"""@ar ;
    hesin:definition """أن الأمة التي تؤمن ببعض ما أنزل الله وتكفر (ترفض) بالبعض الآخر تستحق الخزي في الدنيا، وهذا ما يفسر واقع الأمة الإسلامية اليوم."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{أَفَتُؤْمِنُونَ بِبَعْضِ الْكِتَابِ وَتَكْفُرُونَ بِبَعْضٍ فَمَا جَزَاءُ مَنْ يَفْعَلُ ذَلِكَ مِنْكُمْ إِلَّا خِزْيٌ فِي الْحَيَاةِ الدُّنْيَا} (البقرة:85) ... الذي كفروا به أو أصبحت الأمة في واقعها كافرة به هو الجزء المهم والأكثر أهمية"""@ar ;
    hesin:actions """تطبيق كل ما أنزل الله."""@ar ;
    hesin:hasSynonym """الانتقائية في الدين"""@ar ;
    hesin:hasComponent """إيمان ببعض الكتاب"""@ar ;
    hesin:hasComponent """كفر (رفض) ببعضه"""@ar ;
    hesin:hasComponent """الخزي في الدنيا"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_78 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1305 a hesin:Concept ;
    rdfs:label """الخزي في الدنيا ينذر بعذاب الآخرة"""@ar ;
    hesin:definition """أن الخزي والذلة في الدنيا ليس علامة على أن صاحبها على حق، بل هو إنذار بعذاب أشد في الآخرة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """إذا كنت شقيا في الدنيا فاحذر أنك قد تكون شقيا فعلا في الآخرة... القرآن في أكثر من آية يربط على هذا النحو: {لَهُمْ فِي الدُّنْيَا خِزْيٌ وَلَهُمْ فِي الْآخِرَةِ عَذَابٌ عَظِيمٌ}"""@ar ;
    hesin:actions """عدم الاغترار بالخزي والذلة."""@ar ;
    hesin:hasSynonym """الربط بين الدنيا والآخرة"""@ar ;
    hesin:hasComponent """الخزي في الدنيا إنذار"""@ar ;
    hesin:hasComponent """العذاب في الآخرة"""@ar ;
    hesin:hasComponent """الربط بين الحالتين"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_78 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1306 a hesin:Concept ;
    rdfs:label """نقد فكرة أن الدنيا طبعت على الخزي والذلة"""@ar ;
    hesin:definition """نقد الفهم الخاطئ الذي يجعل الخزي والذلة في الدنيا علامة على أن صاحبه على الحق، ويربطه بالصبر الذي يثاب عليه في الآخرة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """نحن نرى أنفسنا تحت أقدام اليهود والنصارى: أن الصبر على ذلك هو نفسه الوسيلة لأن نحظى بالعزة والرفعة في الآخرة؟.. لا. بل أقرب ما يمكن أن يكون الأمر هو: أن الله ربط بين الشقاء في الدنيا والشقاء في الآخرة"""@ar ;
    hesin:actions """تصحيح الفهم الخاطئ للصبر."""@ar ;
    hesin:hasSynonym """نقد التبرير الخاطئ"""@ar ;
    hesin:hasComponent """رفض التبرير"""@ar ;
    hesin:hasComponent """الربط القرآني بين الشقاءين"""@ar ;
    hesin:hasComponent """الخزي ليس علامة حق"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_79 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1307 a hesin:Concept ;
    rdfs:label """نقد فكرة أن المعيشة الضنكا تكليف لا عقوبة"""@ar ;
    hesin:definition """نقد الفهم الذي يجعل المعيشة الضنكا والذلة في الدنيا مجرد ابتلاء أو تكليف، بينما القرآن يربطها بالعقوبة في الآخرة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَمَنْ أَعْرَضَ عَنْ ذِكْرِي فَإِنَّ لَهُ مَعِيشَةً ضَنْكاً} (طه:124) لاحظوا الربط:{فَإِنَّ لَهُ مَعِيشَةً ضَنْكاً وَنَحْشُرُهُ يَوْمَ الْقِيَامَةِ أَعْمَى} ... من أين جاء هذا الفهم لكثير من المرشدين؟ أن ننتظر بعد الخزي في الدنيا رفعة في الآخرة"""@ar ;
    hesin:actions """تفسير الأزمات في ضوء القرآن."""@ar ;
    hesin:hasSynonym """نقد تبرير الأزمات"""@ar ;
    hesin:hasComponent """المعيشة الضنكا عقوبة"""@ar ;
    hesin:hasComponent """ربطها بالعمى في الآخرة"""@ar ;
    hesin:hasComponent """نقد التبرير"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_79 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1308 a hesin:Concept ;
    rdfs:label """نقد التصور بأن الخزي علامة على الحق"""@ar ;
    hesin:definition """نقد الفكر الذي جعل الخزي والذلة مقياسًا للحق، بينما القرآن جعل الخزي عقوبة على التقصير."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أصبح الخزي علامة أنك محق.. أليس كذلك؟ كلما كنت في خزي أكبر كلما كان ذلك يعني: أنك على الحق أكثر وأكثر، لكنا هنا القرآن الكريم يقول:{أَفَتُؤْمِنُونَ بِبَعْضِ الْكِتَابِ وَتَكْفُرُونَ بِبَعْضٍ فَمَا جَزَاءُ مَنْ يَفْعَلُ ذَلِكَ مِنْكُمْ إِلَّا خِزْيٌ فِي الْحَيَاةِ الدُّنْيَا}"""@ar ;
    hesin:actions """تصحيح المقاييس."""@ar ;
    hesin:hasSynonym """نقد الانقلاب في المقاييس"""@ar ;
    hesin:hasComponent """الخزي عقوبة لا مقياس"""@ar ;
    hesin:hasComponent """الانقلاب في المقاييس"""@ar ;
    hesin:hasComponent """نقد الفكر المنحرف"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_79 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1309 a hesin:Concept ;
    rdfs:label """عقوبة التيه (نموذج بني إسرائيل)"""@ar ;
    hesin:definition """أن رفض طاعة الله وامتناع الأمة عن أداء واجباتها يؤدي إلى التيه والضياع في الدنيا، كما حدث لبني إسرائيل."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{قَالَ فَإِنَّهَا مُحَرَّمَةٌ عَلَيْهِمْ أَرْبَعِينَ سَنَةً يَتِيهُونَ فِي الْأَرْضِ} (المائدة:26) أليس هذا وعيدا في الدنيا حصل لبني إسرائيل؟ تاهوا أربعين سنة... نحن الآن في حالة تيه، لكن تيهنا تيه فكري، تيه ثقافي"""@ar ;
    hesin:actions """فهم واقع الأمة كتيه يحتاج إلى خروج."""@ar ;
    hesin:hasSynonym """التيه"""@ar ;
    hesin:hasSynonym """الضياع"""@ar ;
    hesin:hasComponent """التيه في الأرض"""@ar ;
    hesin:hasComponent """ضياع الرؤية"""@ar ;
    hesin:hasComponent """التشابه مع واقع الأمة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_80 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1310 a hesin:Concept ;
    rdfs:label """لعنة الله على الأمم العاصية"""@ar ;
    hesin:definition """أن الله قد يلعن الأمم العاصية بطرده إياهم من رحمته وتوفيقه، وهذا أخطر أنواع العقوبات الدنيوية."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{لُعِنَ الَّذِينَ كَفَرُوا مِنْ بَنِي إِسْرائيلَ عَلَى لِسَانِ دَاوُدَ وَعِيسَى ابْنِ مَرْيَمَ} (المائدة:78) ألم يلعنهم في الدنيا؟ اللعنة في الدنيا ماذا تعني؟ طردا من رحمة الله"""@ar ;
    hesin:actions """الحذر من أسباب اللعنة."""@ar ;
    hesin:hasSynonym """الطرد من الرحمة"""@ar ;
    hesin:hasComponent """اللعنة طرد من الرحمة"""@ar ;
    hesin:hasComponent """فقدان التوفيق"""@ar ;
    hesin:hasComponent """الاستحقاق بالعصيان"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_80 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1311 a hesin:Concept ;
    rdfs:label """الذلة والمسكنة نتيجة العصيان"""@ar ;
    hesin:definition """أن الذلة والمسكنة في الدنيا هما نتيجة للكفر بآيات الله والعصيان، وهما عبرة للأمم الأخرى."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَضُرِبَتْ عَلَيْهِمُ الذِّلَّةُ وَالْمَسْكَنَةُ وَبَاءُوا بِغَضَبٍ مِنَ اللَّهِ ذَلِكَ بِأَنَّهُمْ كَانُوا يَكْفُرُونَ بِآيَاتِ اللَّهِ} (البقرة:61) ... هذا يعني: أن الحديث عن بني إسرائيل قدم لنا عبرة"""@ar ;
    hesin:actions """استخلاص العبر من تاريخ بني إسرائيل."""@ar ;
    hesin:hasSynonym """الخزي"""@ar ;
    hesin:hasSynonym """الإهانة"""@ar ;
    hesin:hasComponent """الذلة والمسكنة"""@ar ;
    hesin:hasComponent """غضب الله"""@ar ;
    hesin:hasComponent """عبرة للأمم"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_80 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1312 a hesin:Concept ;
    rdfs:label """تبديل الكلمة (حطة إلى حنطة) واستحقاق الرجز"""@ar ;
    hesin:definition """أن تبديل كلمة (حطة) إلى (حنطة) - أي تحريف بسيط - أدى إلى نزول الرجز من السماء، مما يدل على خطورة التحريف حتى في الأمور البسيطة."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{فَبَدَّلَ الَّذِينَ ظَلَمُوا قَوْلاً غَيْرَ الَّذِي قِيلَ لَهُمْ فَأَنْزَلْنَا عَلَى الَّذِينَ ظَلَمُوا رِجْزاً مِنَ السَّمَاءِ} (البقرة:59) ... زيادة نون جعلت اللفظة التي أمروا بها أصبحوا بها مبدلين... استحقوا أن ينالوا عقوبة إضافة نون إلى حطة"""@ar ;
    hesin:actions """الحذر من تحريف كلمات الله."""@ar ;
    hesin:hasSynonym """تحريف الكلم"""@ar ;
    hesin:hasSynonym """استحقاق العقوبة"""@ar ;
    hesin:hasComponent """التحريف ولو بسيطًا"""@ar ;
    hesin:hasComponent """استحقاق العقوبة"""@ar ;
    hesin:hasComponent """سرعة النزول (الفاء)"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_80 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1313 a hesin:Concept ;
    rdfs:label """قسوة القلب عقوبة على نقض الميثاق"""@ar ;
    hesin:definition """أن قسوة القلب هي عقوبة إلهية على نقض الميثاق وعدم الوفاء بالعهود، وهي بداية لكل شر."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{فَبِمَا نَقْضِهِمْ مِيثَاقَهُمْ لَعَنَّاهُمْ وَجَعَلْنَا قُلُوبَهُمْ قَاسِيَةً} (المائدة:13) ... لأنهم لم يفوا بالميثاق الذي بينهم وبين الله، لأنهم لم يفوا بالمواثيق التي بينهم وبين الآخرين، فنقض الميثاق معصية تأتي بعده هذه العقوبة: أن يقسو القلب"""@ar ;
    hesin:actions """الوفاء بالعهود."""@ar ;
    hesin:hasSynonym """طمس القلوب"""@ar ;
    hesin:hasComponent """نقض الميثاق سبب"""@ar ;
    hesin:hasComponent """قسوة القلب عقوبة"""@ar ;
    hesin:hasComponent """الانطلاق في المعاصي"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_81 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1314 a hesin:Concept ;
    rdfs:label """قيمة الرجلين (الاثنان) عند الله"""@ar ;
    hesin:definition """أن الله يعتد بكلام رجلين أو رجل واحد إذا كان كلامه حقًا، ولا ينتظر إجماع الأغلبية أو العلماء."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{قَالَ رَجُلانِ مِنَ الَّذِينَ يَخَافُونَ أَنْعَمَ اللَّهُ عَلَيهِمَا} (المائدة:23) ... رجلين فقط الأغلبية كلهم ليسوا حول هذا الموضوع، لكن ألم يكن كلام أولئك الرجلين كلاما كان مهما عند الله سبحانه وتعالى فسطره في كتابه وخلد ذكره"""@ar ;
    hesin:actions """عدم انتظار العلماء للتحرك."""@ar ;
    hesin:hasSynonym """أهمية القلة المؤمنة"""@ar ;
    hesin:hasComponent """قيمة الرجلين"""@ar ;
    hesin:hasComponent """لا انتظار للإجماع"""@ar ;
    hesin:hasComponent """خلد الله ذكرهما"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_82 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1315 a hesin:Concept ;
    rdfs:label """السكوت عن الباطل يجعلك شريكًا فيه"""@ar ;
    hesin:definition """أن السكوت عن الباطل والصمت أمام الكلمة السيئة يجعل الساكت شريكًا فيها، ويعبر عن موقف المجتمع كله."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """إذا ما جاءت كلمة سيئة من أطراف الناس وسكت أولئك الذين يجب عليهم أن يقفوا ضدها فكأنها هي كلمة تعبر عن موقف المجتمع كله لأنه هاهنا قال يحكي عن بني إسرائيل {قالوا} وكم تحت [الواو] في كلمة {قالوا} تفهم وكأنه ما عدا الرجلين"""@ar ;
    hesin:actions """الإنكار على الباطل."""@ar ;
    hesin:hasSynonym """التخاذل"""@ar ;
    hesin:hasSynonym """المشاركة بالصمت"""@ar ;
    hesin:hasComponent """السكوت مشاركة"""@ar ;
    hesin:hasComponent """التعبير عن المجتمع"""@ar ;
    hesin:hasComponent """المسؤولية الجماعية"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_82 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1316 a hesin:Concept ;
    rdfs:label """لا تنتظر العلماء كلهم ليتحركوا"""@ar ;
    hesin:definition """أن الانتظار حتى يتحرك العلماء كلهم أو الزعماء كلهم هو تبرير خاطئ للقعود، فالله مع المبادرين ولو كانوا قلة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لنعرف أنه في كل زمان هل سيكون الله مع أولئك الذين يسكتون من علماء وعباد ووجهاء وزعماء؟. أو أنه سيكون مع رجل أو رجلين من هنا، أو هناك ينطلقون ليضعوا خططا عملية للأمة تسير عليها"""@ar ;
    hesin:actions """المبادرة دون انتظار الكل."""@ar ;
    hesin:hasSynonym """نقد انتظار الإجماع"""@ar ;
    hesin:hasComponent """عدم انتظار الإجماع"""@ar ;
    hesin:hasComponent """المبادرون مع الله"""@ar ;
    hesin:hasComponent """نقد التبرير"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_82 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1317 a hesin:Concept ;
    rdfs:label """واقع الأمة أسوأ من واقع بني إسرائيل"""@ar ;
    hesin:definition """أن تخلي الأمة الإسلامية عن مسئوليتها في نشر الدين وقيادة الأمم جعل وضعها أسوأ من وضع بني إسرائيل الذين لعنوا."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """جريمتنا أعظم من جريمة بني إسرائيل، أن تخلينا عن هذه المسئولية هي نفسها الذي أتاح الفرصة لبني إسرائيل أن يسعوا في الأرض فسادا وأن يشمل فسادهم الدنيا بكلها"""@ar ;
    hesin:actions """العودة إلى المسؤولية."""@ar ;
    hesin:hasSynonym """تدهور الأمة"""@ar ;
    hesin:hasComponent """التخلي عن المسؤولية"""@ar ;
    hesin:hasComponent """الجريمة أعظم"""@ar ;
    hesin:hasComponent """التمكين لأعداء الله"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_83 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1318 a hesin:Concept ;
    rdfs:label """نقد التصور بأن العمل الخطير يجب تركه"""@ar ;
    hesin:definition """أن القول بأن العمل "خطير" ليس مبررًا لتركه، بل هو دليل على تأثيره، والخطر الحقيقي هو في السكوت."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """إذا قيل لك بأن عملك هذا خطير، فاعرف أن عملك هذا مؤثر ضد أعداء الله... قارن بين سكوتك وعملك أيهما سيكون أخطر عليك من جانب من؟... ستجد أن السكوت هو الذي يشكل خطر عظيما عليك"""@ar ;
    hesin:actions """موازنة الخطرين قبل القرار."""@ar ;
    hesin:hasSynonym """نقد الخوف من المخاطرة"""@ar ;
    hesin:hasComponent """الخطورة دليل التأثير"""@ar ;
    hesin:hasComponent """مقارنة الخطرين"""@ar ;
    hesin:hasComponent """السكوت أخطر"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_83 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1401 a hesin:Concept ;
    rdfs:label """نار جهنم أعظم من كل عذاب دنيوي"""@ar ;
    hesin:definition """أن عذاب جهنم أعظم وأشد بلا مقارنة من أي عذاب في الدنيا، مهما بلغت قوة البشر وأسلحتهم."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لو صب الأمريكيون كل ما لديهم من قوة عليك وحدك أنت لما ساوى ذلك كله يوماً واحداً في نار جهنم... كل ما لديهم لا يساوي يوماً واحداً في جهنم"""@ar ;
    hesin:actions """مقارنة عذاب الدنيا بعذاب الآخرة لتصغير شأن الأول."""@ar ;
    hesin:hasSynonym """عذاب الآخرة"""@ar ;
    hesin:hasSynonym """نار جهنم"""@ar ;
    hesin:hasComponent """عذاب جهنم لا يُقاس"""@ar ;
    hesin:hasComponent """أسلحة الدنيا لا تساوي شيئًا"""@ar ;
    hesin:hasComponent """يوم واحد في جهنم يفوق كل عذاب الدنيا"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_84 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1402 a hesin:Concept ;
    rdfs:label """ثياب أهل النار (نار وقطران)"""@ar ;
    hesin:definition """أن أهل النار يلبسون ثيابًا من نار وقطران، وهذه التفاصيل تهدف إلى تخويف الناس من مغبة المعصية."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{قُطِّعَتْ لَهُمْ ثِيَابٌ مِنْ نَارٍ} (الحج:19) ... {سَرَابِيلُهُمْ مِنْ قَطِرَانٍ وَتَغْشَى وُجُوهَهُمُ النَّارُ} (ابراهيم:50) لم ينس القرآن الكريم أن يتحدث حتى ثياب أهل النار"""@ar ;
    hesin:actions """استحضار ثياب النار عند الإغراء بثياب الدنيا."""@ar ;
    hesin:hasSynonym """سرابيل من قطران"""@ar ;
    hesin:hasSynonym """ثياب من نار"""@ar ;
    hesin:hasComponent """ثياب من نار"""@ar ;
    hesin:hasComponent """سرابيل من قطران"""@ar ;
    hesin:hasComponent """تغشى وجوههم النار"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_84 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1403 a hesin:Concept ;
    rdfs:label """شجرة الزقوم (طعام أهل النار)"""@ar ;
    hesin:definition """شجرة في جهنم ثمارها كرؤوس الشياطين، وهي طعام أهل النار، شديدة المرارة، تغلي في البطون."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{إِنَّهَا شَجَرَةٌ تَخْرُجُ فِي أَصْلِ الْجَحِيمِ طَلْعُهَا كَأَنَّهُ رُؤُوسُ الشَّيَاطِينِ} (الصافات:64-65) ... هي شجرة حقيقية، والله بقدرته سبحانه وتعالى هو القادر على أن يجعل في النار أشجارا تتغذى على النار"""@ar ;
    hesin:actions """مقارنة طعام الدنيا بطعم الزقوم."""@ar ;
    hesin:hasSynonym """شجرة الزقوم"""@ar ;
    hesin:hasSynonym """طعام الأثيم"""@ar ;
    hesin:hasComponent """شجرة تخرج في أصل الجحيم"""@ar ;
    hesin:hasComponent """طلعها كرؤوس الشياطين"""@ar ;
    hesin:hasComponent """طعام الأثيم"""@ar ;
    hesin:hasComponent """كالمهل يغلي في البطون"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_84 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1404 a hesin:Concept ;
    rdfs:label """شراب أهل النار (حميم وصديد)"""@ar ;
    hesin:definition """أن شراب أهل النار هو الحميم (الماء الحار جدًا) والصديد (عصارة أهل النار)، وهو يذيب ما في بطونهم وجلودهم."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{يُصَبُّ مِنْ فَوْقِ رُؤُوسِهِمُ الْحَمِيمُ يُصْهَرُ بِهِ مَا فِي بُطُونِهِمْ وَالْجُلُودُ} (الحج:19-20) ... شراب جهنم ثم أيضا يصب من فوق رؤوسهم الحميم"""@ar ;
    hesin:actions """استحضار شراب النار عند الإغراء بشراب الدنيا."""@ar ;
    hesin:hasSynonym """الحميم"""@ar ;
    hesin:hasSynonym """الصديد"""@ar ;
    hesin:hasComponent """حميم يصب من فوق الرؤوس"""@ar ;
    hesin:hasComponent """يذيب ما في البطون والجلود"""@ar ;
    hesin:hasComponent """صديد (عصارة أهل النار)"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_84 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1405 a hesin:Concept ;
    rdfs:label """أبواب جهنم وزبانيتها"""@ar ;
    hesin:definition """لجهنم سبعة أبواب لكل باب جزء من أهلها، وخزنتها ملائكة غلاظ شداد بأيديهم مقامع من حديد."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{لَهَا سَبْعَةُ أَبْوَابٍ لِكُلِّ بَابٍ مِنْهُمْ جُزْءٌ مَقْسُومٌ} (الحجر:44) ... وهناك بجانب الأبواب من زبانيتها الغلاظ الشداد من يضربونهم بمقامع من حديد"""@ar ;
    hesin:actions """استحضار أبواب جهنم عند التفكير في المعصية."""@ar ;
    hesin:hasSynonym """أبواب جهنم"""@ar ;
    hesin:hasSynonym """خزنة جهنم"""@ar ;
    hesin:hasComponent """سبعة أبواب"""@ar ;
    hesin:hasComponent """خزنة غلاظ شداد"""@ar ;
    hesin:hasComponent """مقامع من حديد"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_84 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1406 a hesin:Concept ;
    rdfs:label """خلود أهل النار في جهنم"""@ar ;
    hesin:definition """أن خلود أهل النار في جهنم هو أشد أنواع العذاب، فهم لا يموتون ولا يخرجون أبدًا."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """روي أنه لو قيل لأهل جهنم أنكم ستبقون فيها وما بين السماوات والأرض مليء بحبات الخردل، وفي كل سنة يأتي طائر يأخذ حبة واحدة منها لفرحوا... الخلود في جهنم في حد ذاته هو الشيء الذي يجب أن يزعج كل إنسان مسلم"""@ar ;
    hesin:actions """استحضار الخلود في النار عند التهاون."""@ar ;
    hesin:hasSynonym """الخلود"""@ar ;
    hesin:hasSynonym """البقاء الأبدي"""@ar ;
    hesin:hasComponent """خلود أبدي"""@ar ;
    hesin:hasComponent """لا موت"""@ar ;
    hesin:hasComponent """لا خروج"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_84 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1407 a hesin:Concept ;
    rdfs:label """تمني أهل النار الموت"""@ar ;
    hesin:definition """أن أهل النار يتمنون الموت راحة من العذاب، وهو ما كانوا يخافونه في الدنيا."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{يَوْمَ يَنْظُرُ الْمَرْءُ مَا قَدَّمَتْ يَدَاهُ وَيَقُولُ الْكَافِرُ يَا لَيْتَنِي كُنْتُ تُرَاباً} (النبأ:40) يتمنى أهل جهنم أن يموتوا... الموت الذي يخاف منه الناس هنا في الدنيا سيصبح نعمة كبرى يتمنونها"""@ar ;
    hesin:actions """استحضار تمني الموت في النار."""@ar ;
    hesin:hasSynonym """الموت كراحة"""@ar ;
    hesin:hasComponent """تمني الموت"""@ar ;
    hesin:hasComponent """الموت راحة"""@ar ;
    hesin:hasComponent """انقلاب الموازين"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_84 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1408 a hesin:Concept ;
    rdfs:label """مقارعة أهل النار بمقامع من حديد"""@ar ;
    hesin:definition """أن أهل النار كلما حاولوا الخروج منها ضربتهم الملائكة بمقامع من حديد فأعيدوا إليها."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَلَهُمْ مَقَامِعُ مِنْ حَدِيدٍ كُلَّمَا أَرَادُوا أَنْ يَخْرُجُوا مِنْهَا مِنْ غَمٍّ أُعِيدُوا فِيهَا} (الحج:22) ... إذا كنت في سجن في الدنيا لا ترى أنك في كل ساعة تسعى إلى باب السجن لتحاول أن تخرج منه"""@ar ;
    hesin:actions """استحضار هذا المشهد."""@ar ;
    hesin:hasSynonym """ضرب أهل النار"""@ar ;
    hesin:hasComponent """مقامع من حديد"""@ar ;
    hesin:hasComponent """محاولة الخروج"""@ar ;
    hesin:hasComponent """الإعادة إلى النار"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_84 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1409 a hesin:Concept ;
    rdfs:label """عقيدة الشفاعة لأهل الكبائر مشجعة على الجريمة"""@ar ;
    hesin:definition """أن عقيدة شفاعة النبي لأهل الكبائر تشجع المجرمين على الاستمرار في إجرامهم، لأنهم يؤمنون بأنهم سيشفع لهم."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """ألم يصبح الإسلام عبارة عن رخصة؟ ألم يصبح دينا بدلا من أن يكافح الجريمة يشجع عليها؟... فبدلا من أن تبقى مستحقا للعذاب الشديد، أسلم. والإسلام مجرد قول، ثم ابقَ على أعمالك! وحينئذ لا جهنم، وحينئذ ستدخل الجنة مع المؤمنين"""@ar ;
    hesin:actions """نقد هذه العقيدة وبيان بطلانها."""@ar ;
    hesin:hasSynonym """نقد الشفاعة للمجرمين"""@ar ;
    hesin:hasComponent """تشجيع على الجريمة"""@ar ;
    hesin:hasComponent """إضعاف الردع"""@ar ;
    hesin:hasComponent """استسهال المعصية"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_85 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1410 a hesin:Concept ;
    rdfs:label """التسوية بين المؤمن والفاسق باطلة"""@ar ;
    hesin:definition """أن مجرد حمل اسم الإسلام لا يعفي من العقاب، والمساواة بين المؤمن العامل والفاسق المجرم باطلة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هل من المعقول أن يكون الصد عن دين الله مسموح للإنسان الذي يحمل اسم إسلام؟... ستصبح كلمة: [لا إله إلا الله محمد رسول الله] عبارة عن بطاقة تضعها في جيبك، ثم تنطلق إلى أسوأ مما كان عليه المشركون والكافرون"""@ar ;
    hesin:actions """التأكيد على أن العمل هو المعيار."""@ar ;
    hesin:hasSynonym """رفض التسوية"""@ar ;
    hesin:hasComponent """الإسلام ليس بطاقة أمان"""@ar ;
    hesin:hasComponent """المساواة باطلة"""@ar ;
    hesin:hasComponent """العمل هو المعيار"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_85 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1411 a hesin:Concept ;
    rdfs:label """تشبيه عقيدة الشفاعة بعقيدة اليهود"""@ar ;
    hesin:definition """أن عقيدة شفاعة النبي لأهل الكبائر هي أسوأ من عقيدة اليهود الذين قالوا إن النار لن تمسهم إلا أيامًا معدودة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """اليهود قالوا:{لَنْ تَمَسَّنَا النَّارُ إِلَّا أَيَّاماً مَعْدُودَاتٍ} أما نحن المسلمون فقد فقناهم بهذا القول, فقلنا: ولا أياما معدودة، ولا لحظة واحدة... أليست عقيدة أسوأ من عقيدة اليهود؟"""@ar ;
    hesin:actions """بيان خطورة هذه العقيدة."""@ar ;
    hesin:hasSynonym """التشابه مع اليهود"""@ar ;
    hesin:hasComponent """اليهود قالوا أيامًا معدودة"""@ar ;
    hesin:hasComponent """المسلمون قالوا لا لحظة واحدة"""@ar ;
    hesin:hasComponent """العقيدة أسوأ"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_85 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1412 a hesin:Concept ;
    rdfs:label """العمل في سبيل الله لا خسارة فيه"""@ar ;
    hesin:definition """أن كل ما يبذله المؤمن في سبيل الله ليس خسارة، بل هو ربح في الدنيا والآخرة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """إن من يعمل لدينه وفي سبيله، وينطلق في رضاه، ليس هناك أمامه أي خسارة على الإطلاق، لا خسارة مادية، ولا خسارة معنوية أبدا"""@ar ;
    hesin:actions """تغيير النظرة إلى التضحية في سبيل الله."""@ar ;
    hesin:hasSynonym """الربح في الدنيا والآخرة"""@ar ;
    hesin:hasComponent """لا خسارة مادية"""@ar ;
    hesin:hasComponent """لا خسارة معنوية"""@ar ;
    hesin:hasComponent """ربح في الدنيا والآخرة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_86 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1413 a hesin:Concept ;
    rdfs:label """الخسارة الحقيقية خسارة الآخرة"""@ar ;
    hesin:definition """أن الخسارة الحقيقية هي خسارة النفس والأهل في الآخرة، وليس ما يلحق المؤمن في الدنيا من أذى في سبيل الله."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَقَالَ الَّذِينَ آمَنُوا إِنَّ الْخَاسِرِينَ الَّذِينَ خَسِرُوا أَنْفُسَهُمْ وَأَهْلِيهِمْ يَوْمَ الْقِيَامَةِ} (الشورى:45) الخسارة الحقيقية التي سيلقونها هم... أما المؤمن المجاهد الصابر الذي يعمل في سبيل الله فلو خسر نفسه, ولو خسر أهله وبيته وماله فإنه ليس خاسراً"""@ar ;
    hesin:actions """إعادة تعريف الخسارة والربح."""@ar ;
    hesin:hasSynonym """الخسران المبين"""@ar ;
    hesin:hasComponent """خسارة الآخرة هي الحقيقية"""@ar ;
    hesin:hasComponent """خسارة الدنيا في سبيل الله ليست خسارة"""@ar ;
    hesin:hasComponent """الشهداء أحياء"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_86 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1414 a hesin:Concept ;
    rdfs:label """الشهيد حي لا ميت"""@ar ;
    hesin:definition """أن الشهداء أحياء عند ربهم يرزقون، وقد ألغى القرآن اسم الموت عنهم ليدفع المؤمنين إلى الاستبسال."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَلا تَقُولُوا لِمَنْ يُقْتَلُ فِي سَبِيلِ اللَّهِ أَمْوَاتٌ بَلْ أَحْيَاءٌ وَلَكِنْ لا تَشْعُرُونَ} (البقرة:154) {وَلا تَحْسَبَنَّ الَّذِينَ قُتِلُوا فِي سَبِيلِ اللَّهِ أَمْوَاتاً بَلْ أَحْيَاءٌ عِنْدَ رَبِّهِمْ يُرْزَقُونَ} (آل عمران:169)"""@ar ;
    hesin:actions """تعليم الناس أن الشهادة حياة."""@ar ;
    hesin:hasSynonym """حياة الشهداء"""@ar ;
    hesin:hasComponent """الشهيد حي"""@ar ;
    hesin:hasComponent """عند ربه يرزق"""@ar ;
    hesin:hasComponent """إلغاء الموت"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_86 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1415 a hesin:Concept ;
    rdfs:label """العلم الحقيقي يتحقق بالجهاد"""@ar ;
    hesin:definition """أن العلم الحقيقي لا يتحقق بالانعزال والانكباب على الكتب فقط، بل بالجهاد في سبيل الله والعمل الصالح."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَالَّذِينَ جَاهَدُوا فِينَا لَنَهْدِيَنَّهُمْ سُبُلَنَا وَإِنَّ اللَّهَ لَمَعَ الْمُحْسِنِينَ} (العنكبوت:69) ... طالب العلم الذي يرى نفسه بأنه في طاعة الله... يرى مجاميع كهذه يضيعون أوقاتهم... هم من سيحصلون على العلم الحقيقي فعلا"""@ar ;
    hesin:actions """ربط العلم بالعمل والجهاد."""@ar ;
    hesin:hasSynonym """علم الجهاد"""@ar ;
    hesin:hasComponent """الجهاد سبب الهداية"""@ar ;
    hesin:hasComponent """الإحسان سبب الإيتاء"""@ar ;
    hesin:hasComponent """العلم من الله"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_87 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1416 a hesin:Concept ;
    rdfs:label """الحكمة من الله (نموذج يوسف وموسى)"""@ar ;
    hesin:definition """أن الحكمة والعلم هبة من الله لمن أحسن العمل، وليست مجرد تحصيل كتبي."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَلَمَّا بَلَغَ أَشُدَّهُ وَاسْتَوَى آتَيْنَاهُ حُكْماً وَعِلْماً وَكَذَلِكَ نَجْزِي الْمُحْسِنِينَ} (يوسف:22) ... يوسف (عليه السلام) نشأ في مصر... من الذي علم يوسف؟... موسى (عليه السلام) من الذي علمه في مجتمع الفراعنة؟ هو الله سبحانه وتعالى"""@ar ;
    hesin:actions """طلب العلم من الله مع العمل."""@ar ;
    hesin:hasSynonym """إيتاء الحكمة"""@ar ;
    hesin:hasComponent """الحكمة من الله"""@ar ;
    hesin:hasComponent """جزاء الإحسان"""@ar ;
    hesin:hasComponent """أمثلة يوسف وموسى"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_87 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1417 a hesin:Concept ;
    rdfs:label """نقد الانشغال بالكتب عن الجهاد"""@ar ;
    hesin:definition """نقد الانشغال المفرط بكتب الفقه وأصوله على حساب العمل والجهاد في سبيل الله."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """ثم وجدنا أنفسنا في الأخير وإذا بنا كنا نقطع أيامنا مع كتب وإذا هي ضلال كلها من أولها إلى آخرها ككتب [أصول الفقه] بقواعده، وإذا هي وراء كل ضلال نحن عليه، وراء قعود الزيدية"""@ar ;
    hesin:actions """الموازنة بين العلم والعمل."""@ar ;
    hesin:hasSynonym """نقد الانعزال"""@ar ;
    hesin:hasComponent """الانشغال بالكتب"""@ar ;
    hesin:hasComponent """القعود عن الجهاد"""@ar ;
    hesin:hasComponent """آثار سلبية على الأمة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_87 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C1418 a hesin:Concept ;
    rdfs:label """العلم بلا حكمة يتحول إلى إضلال"""@ar ;
    hesin:definition """أن العلم المجرد عن الحكمة قد يتحول إلى أداة للإضلال والصد عن سبيل الله."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """ثم كم وجدنا ممن حملوا علما وليس لديهم حكمة، ومتى كان للإنسان علم دون حكمة يتحول علمه إلى ماذا؟ إلى صد عن سبيل الله في أغلب الحالات، يتحول علمه إلى إضلال"""@ar ;
    hesin:actions """طلب الحكمة مع العلم."""@ar ;
    hesin:hasSynonym """العلم الضار"""@ar ;
    hesin:hasComponent """علم بلا حكمة"""@ar ;
    hesin:hasComponent """يتحول إلى إضلال"""@ar ;
    hesin:hasComponent """أخطاء في العقيدة"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_87 ;
    hesin:belongsToLesson hesin:F5_Lesson .
