    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C027 a hesin:Concept ;
    rdfs:label """الجنة"""@ar ;
    hesin:definition """دار النعيم الأبدي للمؤمنين، وقد وصفها القرآن بالتفصيل."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """اعرض في قائمة أخرى ما ذكره الله عن الجنة... عندما ترى الجنة وما ذكر الله عن أوصافها، وما وعد المؤمنين فيها من النعيم العظيم والدرجات العالية"""@ar ;
    hesin:actions """جمع الآيات التي تصف الجنة لتكوين صورة جذابة تدفع إلى العمل."""@ar ;
