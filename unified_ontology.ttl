    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C028 a hesin:Concept ;
    rdfs:label """الخلود في النار"""@ar ;
    hesin:definition """البقاء الدائم في النار دون انقطاع، وهو أعظم ما يخوف به القرآن."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """الخلود في جهنم هو الشيء الذي يخيف جداً. لو أن البقاء في جهنم ألف سنة، خمسة آلاف سنة، وهناك أمل في الخروج منها لكانت المسألة ما تزال هينة، لكن الخلود ـ نعوذ بالله من الخلود في قعر جهنم"""@ar ;
    hesin:actions """استحضار الخلود في النار لتعظيم الخوف."""@ar ;
    hesin:hasSynonym """البقاء الأبدي في جهنم"""@ar ;
    hesin:hasComponent """لا خروج"""@ar ;
    hesin:hasComponent """لا موت"""@ar ;
    hesin:hasComponent """لا نهاية"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_7 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C029 a hesin:Concept ;
    rdfs:label """الغفلة"""@ar ;
    hesin:definition """حالة من عدم التذكر والانشغال عن الله والآخرة، مما يؤدي إلى التقصير في العمل."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """متى ما قسي قلبك سيطرت عليك الغفلة والنسيان لله سبحانه وتعالى"""@ar ;
    hesin:actions """رصد مدى تذكر الله والآخرة في السلوك اليومي."""@ar ;
