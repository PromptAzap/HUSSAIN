    hesin:belongsToGroup hesin:F6_Group_6 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C025 a hesin:Concept ;
    rdfs:label """الغلبة"""@ar ;
    hesin:definition """النصر الإلهي المحتوم لحزب الله على اليهود والنصارى وأعداء الإسلام."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """الْغَالِبُونَ... ما هي الغلبة؟ أليست هي القهر للأعداء الذين تتحدث الآيات عنهم، اليهود والنصارى؟"""@ar ;
    hesin:actions """متغير توقع: غياب الغلبة رغم الإمكانات مؤشر على عدم استحقاق الفئة."""@ar ;
    hesin:hasSynonym """النصر"""@ar ;
    hesin:hasSynonym """القهر"""@ar ;
    hesin:hasComponent """قهر الأعداء"""@ar ;
    hesin:hasComponent """تحقيق الأهداف الإسلامية"""@ar ;
    hesin:hasComponent """نصر إلهي"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_6 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C026 a hesin:Concept ;
    rdfs:label """التقية (المشروعة)"""@ar ;
    hesin:definition """ترخيص شرعي مؤقت لإظهار خلاف الباطن تحت الإكراه، لكنه ليس مبررًا للمسارعة فيهم المستمرة."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """قد تأتي أحكام شرعية تسوغ مؤقتاً تصرف معين تحت وطأة الخوف ما يقال عنها: [التقية] {إِلَّا أَنْ تَتَّقُوا مِنْهُمْ تُقَاةً}"""@ar ;
    hesin:actions """يُستخدم لتمييز الخوف المبرر من مرض القلب."""@ar ;
    hesin:hasSynonym """الخوف المبرر"""@ar ;
    hesin:hasComponent """إكراه حقيقي"""@ar ;
    hesin:hasComponent """مؤقتية"""@ar ;
    hesin:hasComponent """عدم تحول إلى منهج"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_6 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C027 a hesin:Concept ;
    rdfs:label """النوعية المتميزة"""@ar ;
    hesin:definition """الفئة التي تستحق محبة الله بتميزها في الإيمان والوعي والعمل."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """والله لا يحب إلا نوعية متميزة... ليسوا كمثلكم، بل بقوم يحبهم ويحبونه"""@ar ;
    hesin:actions """مفهوم تصنيف للفئة المستهدفة بالتمكين."""@ar ;
    hesin:hasSynonym """الصفوة"""@ar ;
    hesin:hasSynonym """القوم المحبوبون"""@ar ;
    hesin:hasComponent """تميز إيماني"""@ar ;
    hesin:hasComponent """وعي وفهم"""@ar ;
    hesin:hasComponent """عمل بلا تردد"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_6 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C028 a hesin:Concept ;
    rdfs:label """العمل من منطلق الحب"""@ar ;
    hesin:definition """تجاوز منطق "يلزم أو لا يلزم" إلى منطق الحب والرغبة في رضا الله."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """ينطلقون من واقع المحبة لله سواء قالوا واجب أو مندوب المهم أن فيه لله رضى"""@ar ;
    hesin:actions """يُستخدم لقياس درجة الإخلاص."""@ar ;
    hesin:hasSynonym """العبادة عن شوق"""@ar ;
    hesin:hasSynonym """الإخلاص"""@ar ;
    hesin:hasComponent """محبة الله"""@ar ;
    hesin:hasComponent """البحث عن مرضاته"""@ar ;
    hesin:hasComponent """عدم الانشغال بالتفريعات الفقهية الضيقة"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_6 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C029 a hesin:Concept ;
    rdfs:label """التعامل مع المفسرين"""@ar ;
    hesin:definition """منهج في نقد التفاسير التي تحاول صرف الآيات عن معانيها الأصلية (خصوصًا آية الولاية) بدافع الولاء لأبي بكر وعمر."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هذا من محاولة مسخ معاني كتاب الله الكريم... يدفعهم إلى أن يجعلوا كتاب الله... كلام الناس العاديين"""@ar ;
    hesin:actions """عند تحليل النص، يُستخدم هذا المفهوم لفهم دوافع المفسرين."""@ar ;
    hesin:hasSynonym """نقد التفاسير"""@ar ;
    hesin:hasSynonym """كشف التحريف"""@ar ;
    hesin:hasComponent """كشف الدوافع (الدفاع عن أبي بكر وعمر)"""@ar ;
    hesin:hasComponent """نقد التعميم غير المنطقي"""@ar ;
    hesin:hasComponent """التمسك بالنص الحرفي والسياق"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_6 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C030 a hesin:Concept ;
    rdfs:label """الربط بين المفاهيم"""@ar ;
    hesin:definition """منهجية النص في ربط المفاهيم المختلفة (الولاء، الجهاد، النصر) في نسق واحد متماسك."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """لاحظ الربط المهم، الربط الشديد بين قضية ولاية الإمام علي في مقام، وبين التأهيل للأمة في مواجهة اليهود والنصارى"""@ar ;
    hesin:actions """يستخدم في بناء النظام الآلي لضمان الترابط بين المفاهيم."""@ar ;
    hesin:hasSynonym """التكامل المنهجي"""@ar ;
    hesin:hasComponent """ربط العقيدة بالسياسة"""@ar ;
    hesin:hasComponent """ربط التاريخ بالواقع"""@ar ;
    hesin:hasComponent """ربط النص القرآني بالسلوك"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_6 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C031 a hesin:Concept ;
    rdfs:label """الانطلاق من القرآن"""@ar ;
    hesin:definition """منهجية الاعتماد على القرآن كمصدر وحيد للحقائق والهداية في تحليل الواقع."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """نأخذ الحقائق من كتاب الله ربنا الرحيم بنا، الذي يعلم السر في السموات والأرض"""@ar ;
    hesin:actions """كل تحليل يبدأ ويرجع إلى النص القرآني."""@ar ;
    hesin:hasSynonym """المرجعية القرآنية"""@ar ;
    hesin:hasComponent """القرآن مصدر المعرفة"""@ar ;
    hesin:hasComponent """الاعتماد على وعود الله"""@ar ;
    hesin:hasComponent """الثقة بالنص القرآني"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_6 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C032 a hesin:Concept ;
    rdfs:label """الوعي والانتباه"""@ar ;
    hesin:definition """حالة من اليقظة الفكرية والروحية تمكن المؤمن من تمييز مبررات المتولين والمرتدين."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """يجب أن نكون واعين، نحن أمام من تنطلق من أفواههم هذه العبارات من كبير أو من صغير"""@ar ;
    hesin:actions """الهدف من عملية تحليل النصوص: إنتاج وعي."""@ar ;
    hesin:hasSynonym """الفهم"""@ar ;
    hesin:hasSynonym """اليقظة"""@ar ;
    hesin:hasComponent """تمييز الحقيقة من الزيف"""@ar ;
    hesin:hasComponent """عدم الانخداع بالعبارات"""@ar ;
    hesin:hasComponent """القدرة على التحليل"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_6 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C033 a hesin:Concept ;
    rdfs:label """التعامل مع التثبيط"""@ar ;
    hesin:definition """فهم أن المعارضة والتشويه ظاهرة طبيعية تصاحب كل عمل عظيم، وأن الوعي بهذه الظاهرة يحصن النفس من تأثيرها."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أي شيء مهما كان مهماً، مهما كان عظيماً لا بد أن يسمع الإنسان حوله كلاماً معاكساً، كلاماً مثبطاً، كلاماً مشوهاً... لأن معرفة هذا نفسه يمثل جانباً مهماً من وعي القضية وفهمها"""@ar ;
    hesin:actions """في النظام: أي تحليل لنص أو فكرة يجب أن يتضمن توقعًا للمعارضة كمؤشر على الأهمية."""@ar ;
    hesin:hasSynonym """مواجهة المثبطين"""@ar ;
    hesin:hasSynonym """عدم التأثر بالكلام المعاكس"""@ar ;
    hesin:hasComponent """توقع المعارضة مسبقًا"""@ar ;
    hesin:hasComponent """عدم الاستغراب من وجود المثبطين"""@ar ;
    hesin:hasComponent """تحصين النفس بالوعي المسبق"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_7 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C034 a hesin:Concept ;
    rdfs:label """قاعدة الخوف من الله لا من غيره"""@ar ;
    hesin:definition """قاعدة ثابتة في مواجهة التخويف: لا شيء يستحق الخوف إلا الله، لأن عذابه (جهنم) لا يُقارن بأي خطر دنيوي."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """عندما يخوفونك فلتعلم أن الله هو الذي يجب أن تخافه، الله هو الذي يجب أن تخشاه لأنه هو القادر على أن يضر بك ولا يحول أحد دون إرادته فيك"""@ar ;
    hesin:actions """في النظام: أي تهديد أو تخويف يُقيَّم بمقارنة الخطر المذكور مع خطر جهنم."""@ar ;
    hesin:hasSynonym """التوحيد في الخوف"""@ar ;
    hesin:hasSynonym """عدم الخوف مما دون الله"""@ar ;
    hesin:hasComponent """إدراك عظمة عذاب الله (جهنم)"""@ar ;
    hesin:hasComponent """المقارنة بين الخوف من الله والخوف من الناس"""@ar ;
    hesin:hasComponent """عدم الاكتراث بالتهديدات الدنيوية"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_7 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C035 a hesin:Concept ;
    rdfs:label """قاعدة الثقة برحمة الله ونصحه"""@ar ;
    hesin:definition """عندما يأتي من يثبطك بحجة "النصح" و"الحرص"، فالثقة بالله (الرحيم، الناصح، الخبير) أولى، لأنه وحده يعلم ما يصلح عباده حقًا."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """إن الله هو أرحم بي منك، الله هو أنصح لي منك حتى وإن كنت رحيماً وإن كنت ناصحاً فقد توقعني في الهلكة من حيث لا تشعر"""@ar ;
    hesin:actions """في النظام: أي كلام يثبط عن عمل إسلامي ويُقدَّم بنبرة "النصح" يُصنف كمحاولة تثبيط، ويُقيَّم بناءً على المرجعية القرآنية."""@ar ;
    hesin:hasSynonym """الثقة بالله"""@ar ;
    hesin:hasSynonym """رفض "النصح" المثبط"""@ar ;
    hesin:hasComponent """إدراك أن الله أرحم من أي إنسان"""@ar ;
    hesin:hasComponent """إدراك أن الله أعلم بالمصلحة"""@ar ;
    hesin:hasComponent """رفض النصح الذي يأتي بثوب الحرص لكنه يثبط عن العمل الإسلامي"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_7 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C036 a hesin:Concept ;
    rdfs:label """التخويف بما دون الله"""@ar ;
    hesin:definition """أسلوب يستخدمه المثبطون لصرف الناس عن الحق، بتضخيم مخاطر دنيوية لا تُقارن بعذاب الله."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """يخوفونك بلا شيء بما ليس مخيفاً مقارنة بما يجب أن نخافه مما هو بيد الله"""@ar ;
    hesin:actions """رصد العبارات التي تُكثر من ذكر المخاطر الدنيوية وتُقلل من ذكر عذاب الله."""@ar ;
    hesin:hasSynonym """الترهيب الباطل"""@ar ;
    hesin:hasSynonym """تضخيم المخاوف الدنيوية"""@ar ;
    hesin:hasComponent """تضخيم المخاطر الدنيوية"""@ar ;
    hesin:hasComponent """تجاهل الخطر الحقيقي (عذاب الله)"""@ar ;
    hesin:hasComponent """استخدام الخوف كأداة للسيطرة"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_7 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C037 a hesin:Concept ;
    rdfs:label """مبدأ الكمال الإلهي"""@ar ;
    hesin:definition """ترسيخ فهم أن الله كامل بكل صفاته، وأن إدراك هذا الكمال هو الأساس لنسف الشرك والانحراف."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """القرآن الكريم يتجه إلى ترسيخ مبدأ الكمال، الله سبحانه وتعالى بدءاً منه ملأ كتابه الكريم بالحديث الذي يرسخ في أذهاننا كماله هو"""@ar ;
    hesin:actions """أي تحليل لأي شخصية أو فكرة يجب أن يُقيَّم بمدى قربها من معايير الكمال الإلهي."""@ar ;
    hesin:hasSynonym """ترسيخ كمال الله"""@ar ;
    hesin:hasSynonym """عظمة الله"""@ar ;
    hesin:hasComponent """الإيمان بصفات الله الكاملة"""@ar ;
    hesin:hasComponent """مقارنة أي معبود مزعوم بالله لبيان نقصه"""@ar ;
    hesin:hasComponent """تأثير هذا المبدأ في تزكية النفوس"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_8 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C038 a hesin:Concept ;
    rdfs:label """مبدأ الكمال في الأنبياء (تكريمهم بصفاتهم لا بأسمائهم)"""@ar ;
    hesin:definition """منهج قرآني في تقديم النبي (ص) ليس باسمه الشخصي فقط، بل بصفاته التي تعبر عن كماله (رسول، نبي)، لترسيخ عظمته في النفوس."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """رسول الله (صلوات الله عليه وعلى آله) يُقدم في القرآن الكريم باسم [رسوله، رسول الله، رسول، رسولنا]... أليست كلمة: [رسول] في حد ذاتها هي صفة عظيمة لمحمد (صلوات الله عليه وعلى آله)؟"""@ar ;
    hesin:actions """في النظام: عند التعامل مع النصوص، يُصنف ذكر الصفات الكاملة على أنه أسلوب لترسيخ العظمة."""@ar ;
    hesin:hasSynonym """تقديم النبي بصفاته الكاملة"""@ar ;
    hesin:hasComponent """التركيز على الصفات الكاملة"""@ar ;
    hesin:hasComponent """إغفال الاسم الشخصي في المقامات التعظيمية"""@ar ;
    hesin:hasComponent """ترسيخ الشعور بالعظمة"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_8 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C039 a hesin:Concept ;
    rdfs:label """مبدأ الكمال في الأئمة (تقديمهم بصفاتهم)"""@ar ;
    hesin:definition """منهج قرآني في تقديم الإمام علي (ع) ليس باسمه فقط، بل بصفاته الكاملة (إقامة الصلاة، إيتاء الزكاة في الركوع)، لترسيخ كماله في النفوس."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """نأتي إلى علي (عليه السلام) ونأتي إلى هذه الآية نفسها هل قال: ومن يتول الله ومحمد وعلي؟. قال {وَرَسُولَهُ} ألم يقدم محمداً بصفته رسولاً قدم علياً بنفس الأسلوب قدمه باسم الإيمان ويتحدث عن صفتين مهمتين فيه"""@ar ;
    hesin:actions """عند تحليل الآيات، يجب البحث عن صفات الكمال لا الاكتفاء بالأسماء."""@ar ;
    hesin:hasSynonym """تقديم الإمام علي بصفاته الكاملة"""@ar ;
    hesin:hasComponent """تقديم صفات الكمال بدل الاسم"""@ar ;
    hesin:hasComponent """تركيز القرآن على الأعماق النفسية"""@ar ;
    hesin:hasComponent """الربط بين الصفة والدلالة على الاهتمام بالأمة"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_8 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C040 a hesin:Concept ;
    rdfs:label """الكمال كمعيار للقيادة"""@ar ;
    hesin:definition """ضرورة اشتراط معايير الكمال (العلم، التقوى، الشجاعة، الرحمة، العدالة) فيمن يتولى قيادة الأمة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """حتى مقاييس الكمال هي دقيقة جداً جداً... الزيدية في كتبها عن شروط الإمامة أليسوا يضعوا شروط كمال؟. فيقولون: أن يكون عالماً وأن يكون مدبراً وأن يكون سليماً وأن يكون شجاعاً يكون تقياً ورعاً زاهداً رحيماً بالأمة وعادلاً"""@ar ;
    hesin:actions """في النظام: أي تقييم لشخصية قيادية يجب أن يُقيَّم بمعايير الكمال."""@ar ;
    hesin:hasSynonym """شروط الإمامة"""@ar ;
    hesin:hasSynonym """أهلية القيادة"""@ar ;
    hesin:hasComponent """العلم بالدين"""@ar ;
    hesin:hasComponent """التقوى والورع"""@ar ;
    hesin:hasComponent """الشجاعة"""@ar ;
    hesin:hasComponent """الرحمة بالأمة"""@ar ;
    hesin:hasComponent """العدالة"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_8 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C041 a hesin:Concept ;
    rdfs:label """نسف الكمال"""@ar ;
    hesin:definition """عملية متعمدة لإسقاط معايير الكمال من شروط القيادة، لفتح المجال أمام أي شخص للحكم دون مؤهلات دينية."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أولئك الذين يحاربون الإمامة باعتبار إمامة أهل البيت... هم مشغولون بأن يحاربوا مسألة أهل البيت وهم في نفس الوقت يؤمنون ببقية الشروط فلماذا لا تقدم الشروط الأخرى... لأنها معايير إلهية، لا تتوفر إلا على يد الله سبحانه وتعالى ونحن لا نريد أن نربط المسألة بهذا"""@ar ;
    hesin:actions """رصد الدساتير والأنظمة التي تخلو من معايير الكمال."""@ar ;
    hesin:hasSynonym """إسقاط المعايير"""@ar ;
    hesin:hasSynonym """العلمنة السياسية"""@ar ;
    hesin:hasComponent """محاربة شرط النسب (أهل البيت)"""@ar ;
    hesin:hasComponent """إسقاط الشروط الأخرى (العلم، التقوى)"""@ar ;
    hesin:hasComponent """استبدالها بشروط شكلية (العمر، الجنسية)"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_8 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C042 a hesin:Concept ;
    rdfs:label """الشكليات مقابل الأعماق"""@ar ;
    hesin:definition """التمييز بين الأعمال السطحية (كثرة الصلاة، الصيام) وبين الأعماق النفسية (الرحمة، الاهتمام بالأمة) التي تكشف عن حقيقة الإنسان."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هذه شكليات سطحية يمكن أن أنمق شخصاً آخر هو خبيث فأقول هو كان كذا وكان كذا في الشكليات هذه... الذي يعرف أعماق النفوس؟ أليس هو الله سبحانه وتعالى؟ هنا كشف لنا نفسية علي عليه السلام التي الأمة بحاجة إليها"""@ar ;
    hesin:actions """في النظام: أي تحليل لشخصية يجب أن يركز على ما كشفه النص عن أعماقها، لا على المظاهر السطحية."""@ar ;
    hesin:hasSynonym """المظاهر السطحية"""@ar ;
    hesin:hasSynonym """الجوهر مقابل الشكل"""@ar ;
    hesin:hasComponent """الشكليات: أعمال ظاهرية يمكن تزييفها"""@ar ;
    hesin:hasComponent """الأعماق: ما كشفه الله عن النفس البشرية"""@ar ;
    hesin:hasComponent """التركيز القرآني على الأعماق"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_8 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C043 a hesin:Concept ;
    rdfs:label """النص الصريح مقابل النص الهادي"""@ar ;
    hesin:definition """القرآن ليس كتاب نصوص صريحة فقط، بل هو كتاب هداية يتجه إلى القلوب من زوايا متعددة، ويحتاج إلى استبطان واستنباط."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """قد يقول البعض: لماذا لم يقل في الآية [علي] حتى تكون واضحة كالشمس؟. قلنا هذا أسلوب القرآن الكريم متى ما تناول قضية ليس لها فقط اتجاه واحد في مقام الهداية، تهدي من هنا ومن هنا ومن هنا"""@ar ;
    hesin:actions """عند تحليل الآية، لا يُكتفى بمعناها الظاهر، بل تُبحث مستويات هدايتها المختلفة."""@ar ;
    hesin:hasSynonym """الظاهر الحرفي"""@ar ;
    hesin:hasSynonym """مقاصد القرآن"""@ar ;
    hesin:hasComponent """النص الصريح: ما ورد بنص لفظي لا يحتمل التأويل"""@ar ;
    hesin:hasComponent """النص الهادي: ما يهدي من خلال سياقه وترتيبه وعلاقاته"""@ar ;
    hesin:hasComponent """تعدد مستويات الهداية في الآية الواحدة"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_9 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C044 a hesin:Concept ;
    rdfs:label """كشف الأعماق النفسية في القرآن"""@ar ;
    hesin:definition """منهج قرآني في كشف حقائق النفوس وأعماق الشخصيات، لتمييز الحق من الباطل، والولي من العدو."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هنا كشف لنا نفسية علي عليه السلام التي الأمة بحاجة إليها... ألم يكشف لنا نفسية عمر... ألم يكشف الرسول هذا كما كشف القرآن نفسية علي عليه السلام؟"""@ar ;
    hesin:actions """رصد المواقف التي يكشف فيها القرآن عن أعماق الشخصيات."""@ar ;
    hesin:hasSynonym """التحليل النفسي القرآني"""@ar ;
    hesin:hasComponent """كشف نفسية علي: الاهتمام بالفقير أثناء الصلاة"""@ar ;
    hesin:hasComponent """كشف نفسية عمر: منع كتابة الوصية"""@ar ;
    hesin:hasComponent """كشف نفسية الآخرين من خلال مواقفهم"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_9 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C045 a hesin:Concept ;
    rdfs:label """ربط الآيات لفهم المقاصد"""@ar ;
    hesin:definition """منهجية فهم القرآن من خلال ربط الآيات ببعضها، واستنتاج المقاصد الكلية من خلال العلاقات بينها."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لاحظوا الربط المهم، الربط الشديد بين قضية ولاية الإمام علي في مقام، وبين التأهيل للأمة في مواجهة اليهود والنصارى"""@ar ;
    hesin:actions """في النظام: لا تُفهم آية بمفردها، بل تُربط بالآيات الأخرى في السياق ذاته."""@ar ;
    hesin:hasSynonym """التفسير الموضوعي"""@ar ;
    hesin:hasSynonym """الربط المنهجي"""@ar ;
    hesin:hasComponent """ربط آية الولاية (55) بآية الغلبة (56)"""@ar ;
    hesin:hasComponent """ربط آية ولاية علي بآيات مواجهة اليهود"""@ar ;
    hesin:hasComponent """استنتاج أن ولاية علي شرط للغلبة"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_9 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C046 a hesin:Concept ;
    rdfs:label """الأعلام الإلهية"""@ar ;
    hesin:definition """شخصيات اختارها الله لتكون قدوة وأعلام هداية للأمة، ويجب التمسك بهم والولاء لهم."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """الأمة تحتاج إلى أعلام ترتبط بهم... ولا بد أن يكون الله سبحانه وتعالى هو من يحدد، هو من يبين لنا من هم الأعلام من بعد نبيه (صلوات الله عليه وعلى آله) لنرتبط بهم"""@ar ;
    hesin:actions """تحديد الأعلام الإلهية من خلال النص القرآني."""@ar ;
    hesin:hasSynonym """أعلام الهدى"""@ar ;
    hesin:hasSynonym """القدوات"""@ar ;
    hesin:hasComponent """اصطفاء إلهي"""@ar ;
    hesin:hasComponent """كمال في الصفات"""@ar ;
    hesin:hasComponent """دور في هداية الأمة"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_10 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C047 a hesin:Concept ;
    rdfs:label """الأعلام الوهمية"""@ar ;
    hesin:definition """شخصيات يصنعها أهل الباطل لتكون قدوة، بهدف صرف الناس عن الأعلام الإلهية وتضليلهم."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """إذا لم نلتزم نحن بأن نسبق الآخرين إلى قلوبنا... فإنهم هم سيأتون ليضعون لنا أعلاماً آخرين يصلون بهم إلى أعماق نفوسنا فتكون أعلاماً للباطل"""@ar ;
    hesin:actions """رصد الشخصيات التي يُضخمها الإعلام الغربي أو الإقليمي."""@ar ;
    hesin:hasSynonym """الأعلام المصطنعة"""@ar ;
    hesin:hasSynonym """رموز الباطل"""@ar ;
    hesin:hasComponent """صناعة إعلامية (إعلام، تمويل، تضخيم)"""@ar ;
    hesin:hasComponent """شخصيات غير مؤهلة حقيقة"""@ar ;
    hesin:hasComponent """هدفها صرف الناس عن الحق"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_10 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C048 a hesin:Concept ;
    rdfs:label """لا حياد في الأعلام"""@ar ;
    hesin:definition """لا يمكن للإنسان أن يعيش بلا أعلام وقدوات؛ فإذا لم يرتبط بالأعلام الإلهية فسيَرتبط بالأعلام الوهمية، ولا حياد ممكن."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لا بد للإنسان من أعلام ومتى ما حاولت أن تنصرف عن علي عليه السلام فإنك ستنصرف إلى عَلَمٍ آخر لا محالة... إذا تهربت من الكل فتقول: [لا أريد لا أبا بكر ولا عمر ولا عثمان ولا علي]، ألست هنا رفضت علياً عليه السلام رفضت حقاً فماذا بعد الحق إلا الضلال"""@ar ;
    hesin:actions """أي ادعاء بالحياد أو رفض جميع الأعلام يُعتبر في الواقع ارتباطًا بأعلام الباطل."""@ar ;
    hesin:hasSynonym """الضرورة الملزمة للارتباط بأعلام"""@ar ;
    hesin:hasComponent """حاجة الإنسان الفطرية للقدوة"""@ar ;
    hesin:hasComponent """استحالة الحياد المطلق"""@ar ;
    hesin:hasComponent """رفض علي يؤدي إلى الانحراف"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_10 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C049 a hesin:Concept ;
    rdfs:label """الاصطفاء الإلهي"""@ar ;
    hesin:definition """مبدأ إلهي مفاده أن الله وحده هو الذي يختار من يكون أعلام هداية للأمة، وليس للبشر حق الاختيار في ذلك."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """اللَّهُ يَصْطَفِي مِنَ الْمَلائِكَةِ رُسُلاً وَمِنَ النَّاسِ... فهو الذي يحدد من هم الأعلام الذين نتولاهم ونسير على هديهم"""@ar ;
    hesin:actions """في النظام: تحديد الأعلام الإلهية من خلال النص القرآني فقط."""@ar ;
    hesin:hasSynonym """الاختيار الإلهي"""@ar ;
    hesin:hasSynonym """التفضيل"""@ar ;
    hesin:hasComponent """اصطفاء الله للرسل"""@ar ;
    hesin:hasComponent """اصطفاء الله للأئمة من بعدهم"""@ar ;
    hesin:hasComponent """رفض اختيار البشر (الانتخاب) في تحديد الأعلام الدينيين"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_10 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C050 a hesin:Concept ;
    rdfs:label """الهداية من خلال الأعلام"""@ar ;
    hesin:definition """لا يمكن للإنسان أن يهتدي مباشرة دون وساطة أعلام الهدى الذين اختارهم الله؛ فالهداية تأتي من خلال التولي لهم والارتباط بهم."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """فمن خلالهم نهتدي، وعلى أيديهم نهتدي... أنهم بحاجة إلى أن يكونوا حزب الله ويكونوا غالبين لا بد أن يرتبطوا بأعلام"""@ar ;
    hesin:actions """أي منهج تعليمي أو تربوي يجب أن يمر عبر الأعلام الإلهية."""@ar ;
    hesin:hasSynonym """التوسط في الهداية"""@ar ;
    hesin:hasSynonym """باب مدينة العلم"""@ar ;
    hesin:hasComponent """الهداية تحتاج إلى وسائط"""@ar ;
    hesin:hasComponent """الوسائط هم الأعلام الإلهية"""@ar ;
    hesin:hasComponent """التولي لهم شرط للهداية"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_10 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C051 a hesin:Concept ;
    rdfs:label """معارضة كتابة الوصية"""@ar ;
    hesin:definition """حادثة تاريخية تعكس نفسية عمر وعدم اهتمامه الحقيقي بمصلحة الأمة، حيث حال دون كتابة وصية النبي (ص)."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """يقول عمر: لا، حسبنا كتاب الله ويثير ضجة... دعوا الرجل فقد غلبه الوجع، دعوا الرجل فإنه يهجر"""@ar ;
    hesin:actions """في النظام: هذه الحادثة تُستخدم كمؤشر تاريخي لكشف حقيقة الشخصيات."""@ar ;
    hesin:hasSynonym """حادثة الخميس"""@ar ;
    hesin:hasSynonym """منع كتابة الكتاب"""@ar ;
    hesin:hasComponent """طلب النبي (ص) الكتابة لضمان عدم ضلال الأمة"""@ar ;
    hesin:hasComponent """معارضة عمر ومنعه"""@ar ;
    hesin:hasComponent """تبرير المعارضة بـ"حسبنا كتاب الله""""@ar ;
    hesin:hasComponent """اتهام النبي (ص) بالهجر (عياذًا بالله)"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_11 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C052 a hesin:Concept ;
    rdfs:label """دور عمر في رفع بني أمية"""@ar ;
    hesin:definition """مفهوم تاريخي يشير إلى دور عمر في إعادة تمكين بني أمية بعد أن وضعهم الإسلام، مما مهد لانحراف الخلافة لاحقًا."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هو الذي رفع بني أمية بعد أن وضعهم الإسلام، وأصبحوا مجتمعاً منحطاً في نظر الأمة، هو الذي رفعهم من جديد فأصبحوا يمتلكون الأموال الهائلة"""@ar ;
    hesin:actions """يُستخدم كأداة لتحليل أسباب الانحراف التاريخي."""@ar ;
    hesin:hasSynonym """تمكين بني أمية"""@ar ;
    hesin:hasSynonym """تأسيس الانحراف"""@ar ;
    hesin:hasComponent """إضعاف مكانة بني أمية في بداية الإسلام"""@ar ;
    hesin:hasComponent """سياسات عمر في تمكينهم ماليًا وسياسيًا"""@ar ;
    hesin:hasComponent """تأسيس معاوية في الشام"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_11 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C053 a hesin:Concept ;
    rdfs:label """المهندس للعملية"""@ar ;
    hesin:definition """تصور لعمر بن الخطاب بصفته المخطط الرئيسي لانحراف الخلافة عن مسارها الإلهي، من خلال تدبيره لبيعة أبي بكر، ووصول عثمان، وتمكين معاوية."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """عمر هو مهندس كل تلك المتغيرات من الصعود بأبي بكر... هو الذي هندس للخلافة أن تصل إلى عثمان... هو الذي هندس ورتب أوضاع معاوية"""@ar ;
    hesin:actions """يُستخدم في التحليل التاريخي لتفسير أسباب الانحراف."""@ar ;
    hesin:hasSynonym """المخطط الرئيسي"""@ar ;
    hesin:hasComponent """التخطيط لبيعة أبي بكر"""@ar ;
    hesin:hasComponent """ترتيب خلافة عثمان"""@ar ;
    hesin:hasComponent """تأسيس معاوية في الشام"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_11 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C054 a hesin:Concept ;
    rdfs:label """قيادة المهتمين بالفقراء"""@ar ;
    hesin:definition """معيار لصلاحية القيادة: أن يكون القائد مهتمًا بأحوال الفقراء والمستضعفين، حتى في أثناء أهم العبادات."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أن يتصدّق علي عليه السلام بخاتمه وهو يصلي تدلنا نحن على جدارته العظيمة بأن يقود الأمة؛ لأنه هو من يهتم بها، من يؤلمه فقير واحد منها"""@ar ;
    hesin:actions """أي تقييم للقيادة يجب أن يركز على مدى اهتمامها بالفقراء والمستضعفين."""@ar ;
    hesin:hasSynonym """القيادة الرحيمة"""@ar ;
    hesin:hasSynonym """القيادة الخادمة"""@ar ;
    hesin:hasComponent """الاهتمام بالفقراء"""@ar ;
    hesin:hasComponent """عدم الانشغال بالعبادة عن خدمة الناس"""@ar ;
    hesin:hasComponent """الشعور بألم الأمة"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_12 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C055 a hesin:Concept ;
    rdfs:label """بناء الأمة على يد القادة الكاملين"""@ar ;
    hesin:definition """أن النهضة والتنمية الحقيقية لا تتحقق إلا على أيدي قادة يتحلون بالمعايير الإلهية (الاهتمام بالفقراء، الرحمة، العدالة)."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """صاحب تلك الصفات والمعايير الإلهية هو الشخص الذي يمكن أن تُبنى على يديه الأمة بناء عظيماً... الإمام الخميني الذي كان لا يملك إلا ممتلكات قليلة جداً كوّن جيشاً بأكمله سماه جيش [جهاد البناء]"""@ar ;
    hesin:actions """يُستخدم النموذج الإيراني (الخميني) كمثال تطبيقي لهذا المفهوم."""@ar ;
    hesin:hasSynonym """البناء الحضاري"""@ar ;
    hesin:hasSynonym """التنمية"""@ar ;
    hesin:hasComponent """الاهتمام بالبنية التحتية"""@ar ;
    hesin:hasComponent """الاهتمام بالأرياف والمناطق المحرومة"""@ar ;
    hesin:hasComponent """تأسيس مؤسسات خدمية (جيش البناء)"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_12 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C056 a hesin:Concept ;
    rdfs:label """المعايير الإلهية في اختيار القيادة"""@ar ;
    hesin:definition """ضرورة اعتماد معايير إلهية (وليس مادية أو شكلية) في اختيار القادة والمسؤولين."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """الإمام الخميني جاء بكلمة مهمة قال: ( يجب علينا أن تكون معاييرنا إلهية) هي هذه المعايير الإلهية التي قُدِّمَت هنا في هذه الآية {والَّذِينَ آمَنُوا الَّذِينَ يُقِيمُونَ الصَّلَاةَ وَيُؤْتُونَ الزَّكَاةَ وَهُمْ رَاكِعُونَ}"""@ar ;
    hesin:actions """في النظام: أي عملية انتخاب أو تعيين يجب أن تُقيَّم بمدى تطبيقها للمعايير الإلهية."""@ar ;
    hesin:hasSynonym """المعايير الدينية"""@ar ;
    hesin:hasSynonym """شروط الولاية"""@ar ;
    hesin:hasComponent """إقامة الصلاة (العلاقة بالله)"""@ar ;
    hesin:hasComponent """إيتاء الزكاة (الاهتمام بالفقراء)"""@ar ;
    hesin:hasComponent """الصدق والرحمة"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_12 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C057 a hesin:Concept ;
    rdfs:label """خطة اليهود في تدمير الأرياف"""@ar ;
    hesin:definition """نظرية مؤامرة ترى أن تدمير الأرياف وهجرة السكان إلى المدن هي خطة صهيونية غربية لتفكيك المجتمعات وتدمير الزراعة ونشر الفساد."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هذه خطة مقصودة من خطط اليهود الغربيين من أجل أن يزدحم الناس في المدن، وازدحام الناس في المدن سيعطل الأرياف، وهي المساحات الكبرى في الشعوب فتتعطل الزراعة ويتعطل كل شيء"""@ar ;
    hesin:actions """يُستخدم في تحليل سياسات التخطيط العمراني."""@ar ;
    hesin:hasSynonym """التهجير القسري"""@ar ;
    hesin:hasSynonym """التمدن الزائف"""@ar ;
    hesin:hasComponent """تعطيل الأرياف (الزراعة، الإنتاج)"""@ar ;
    hesin:hasComponent """ازدحام المدن"""@ar ;
    hesin:hasComponent """تفكك العلاقات الاجتماعية"""@ar ;
    hesin:hasComponent """انتشار الفساد"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_12 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C058 a hesin:Concept ;
    rdfs:label """الوساطة كدليل على فساد النظام"""@ar ;
    hesin:definition """أن انتشار ثقافة الوساطة والمحسوبية دليل على فساد النظام، بينما القيادة الصالحة تهتم بمن لا يعرفونها ولا تعرفهم."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """ألسنا نقول دائماً: أبحث لك عن وساطة؟. ما هي الوساطة؟ الوساطة هذه تعني شخص يعرف فلاناً وفلان يعرفه... الإمام الخميني اهتم بمن لا يعرفهم، وبمن لا يعرفون ربما إلا صوره بعدما صعد"""@ar ;
    hesin:actions """رصد مدى انتشار المحسوبية والوساطة كمؤشر على فساد النظام."""@ar ;
    hesin:hasSynonym """المحسوبية"""@ar ;
    hesin:hasSynonym """التوسط"""@ar ;
    hesin:hasComponent """الوساطة: حاجة الناس لمعرفة المسؤول للحصول على الخدمات"""@ar ;
    hesin:hasComponent """النظام الفاسد: لا يخدم إلا من يعرفه"""@ar ;
    hesin:hasComponent """النظام الصالح: يخدم من لا يعرفه"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_12 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C059 a hesin:Concept ;
    rdfs:label """الحاجة إلى أعلام"""@ar ;
    hesin:definition """حاجة فطرية للإنسان لارتباطه بأعلام وقدوات، وهذه الحاجة تستغل إما لهدايته أو لإضلاله."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لا بد للإنسان من أعلام ومتى ما حاولت أن تنصرف عن علي عليه السلام فإنك ستنصرف إلى عَلَمٍ آخر لا محالة"""@ar ;
    hesin:actions """أي منهج تربوي يجب أن يوفر أعلامًا صالحين للاقتداء."""@ar ;
    hesin:hasSynonym """الحاجة إلى قدوات"""@ar ;
    hesin:hasSynonym """الضرورة الفطرية"""@ar ;
    hesin:hasComponent """الحاجة الفطرية للقدوة"""@ar ;
    hesin:hasComponent """استحالة العيش بدون أعلام"""@ar ;
    hesin:hasComponent """ضرورة الاختيار الواعي للأعلام"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_13 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C060 a hesin:Concept ;
    rdfs:label """الفارق بين الزيدية والإمامية"""@ar ;
    hesin:definition """تمييز بين الزيدية (التي انحرفت عن معايير الإمام الهادي) والإمامية (التي حافظت على المعايير الإلهية في القيادة)."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """بل تأثرت الزيدية نفسها عندما غابت عن المعايير التي وضعها الإمام الهادي عليه السلام باعتبارها معايير إلهية في بداية كتاب ( الأحكام ) فظهر لنا أئمة حتى داخل الزيدية ليسوا جديرين بأن يحكموا الأمة"""@ar ;
    hesin:actions """يُستخدم في التحليل التاريخي للفرق الإسلامية."""@ar ;
    hesin:hasSynonym """الزيدية"""@ar ;
    hesin:hasSynonym """الإمامية"""@ar ;
    hesin:hasComponent """الزيدية الأصلية: تتبع معايير الإمام الهادي (الكمال)"""@ar ;
    hesin:hasComponent """انحراف الزيدية: تحول المعايير إلى شكليات"""@ar ;
    hesin:hasComponent """الإمامية: الحفاظ على المعايير الإلهية"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_13 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C061 a hesin:Concept ;
    rdfs:label """جهاد البناء"""@ar ;
    hesin:definition """مفهوم يجمع بين الجهاد العسكري والجهاد التنموي، حيث يكون بناء الأمة وتطويرها جزءًا من الجهاد في سبيل الله."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """كوّن جيشاً بأكمله سماه جيش [جهاد البناء] هناك جيش مجاهدين يحملون البنادق والبوازيك... وكوّن جيشاً يحمل المطارق والفِرَس والكُرَيْكات ومفاتيح الهندسة ويقود الحراثات"""@ar ;
    hesin:actions """يُستخدم كنموذج للمؤسسات التنموية في الأنظمة الإسلامية."""@ar ;
    hesin:hasSynonym """التنمية"""@ar ;
    hesin:hasSynonym """البناء الحضاري"""@ar ;
    hesin:hasComponent """الجهاد العسكري: الدفاع عن الأمة"""@ar ;
    hesin:hasComponent """جهاد البناء: التنمية والخدمات"""@ar ;
    hesin:hasComponent """التكامل بينهما"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_13 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C062 a hesin:Concept ;
    rdfs:label """إطعام المسكين والأسير"""@ar ;
    hesin:definition """نموذج قرآني يظهر فيه الاهتمام بفرد واحد (مسكين، يتيم، أسير) كدلالة على عمق الرحمة والإيثار، بغض النظر عن الكم."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَيُطْعِمُونَ الطَّعَامَ عَلَى حُبِّهِ مِسْكِيناً وَيَتِيماً وَأَسِيراً}... لاحظوا حتى التقليل في العبارة هنا مسكيناً واحداً أول ليلة ويتيماً واحداً ثاني ليلة أسيراً واحداً ثالث ليلة"""@ar ;
    hesin:actions """يُستخدم كمثال لقياس مدى الاهتمام الحقيقي بالمحرومين."""@ar ;
    hesin:hasSynonym """الإيثار"""@ar ;
    hesin:hasSynonym """الاهتمام بالمحرومين"""@ar ;
    hesin:hasComponent """الإيثار على النفس"""@ar ;
    hesin:hasComponent """الاهتمام بالفرد الواحد"""@ar ;
    hesin:hasComponent """عدم انتظار الجزاء أو الشكر"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_13 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C063 a hesin:Concept ;
    rdfs:label """زمن الفتن"""@ar ;
    hesin:definition """عصر يتميز بانتشار الضلال والتضليل على نطاق واسع وسريع، بحيث يمسي المرء مؤمناً ويصبح كافراً."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هذا الزمن، هذا العصر لا نعلم بأنه مر في هذه الدنيا عصر أزهى منه، ولا أكثر تضليلاً وضلالاً مما يحدث فيه، ضلال بشكل رهيب، وبشكل دقيق، وبانتشار كثير على نطاق واسع"""@ar ;
    hesin:actions """في النظام: أي نص من هذا العصر يُحلل بافتراض وجود مستويات عالية من التضليل."""@ar ;
    hesin:hasSynonym """الفتن كقطع الليل المظلم"""@ar ;
    hesin:hasSynonym """عصر التضليل"""@ar ;
    hesin:hasComponent """سرعة انتشار الضلال (لحظة واحدة، ساعة واحدة)"""@ar ;
    hesin:hasComponent """انتشار الضلال إلى كل بيت ومسجد"""@ar ;
    hesin:hasComponent """دقة وسائل التضليل"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_14 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C064 a hesin:Concept ;
    rdfs:label """ضعف الزيدية في زمن الفتن"""@ar ;
    hesin:definition """وصف لواقع الزيدية في العصر الحديث، حيث تفتقر إلى المؤسسات الثقافية والإعلامية والتربوية التي تحميها من التضليل."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """نحن الزيدية هذا الشيء الذي يزعجنا جداً ربما نحن الطائفة الوحيدة في هذه الدنيا، وفي هذا العصر الرهيب، الطائفة المعرضة للتضليل بشكل رهيب جداً أكثر من غيرها"""@ar ;
    hesin:actions """يُستخدم في تحليل وضع الطوائف المهمشة ثقافيًا."""@ar ;
    hesin:hasSynonym """واقع الزيدية"""@ar ;
    hesin:hasSynonym """التهميش الثقافي"""@ar ;
    hesin:hasComponent """غياب المدارس الزيدية"""@ar ;
    hesin:hasComponent """غياب وسائل الإعلام الزيدية"""@ar ;
    hesin:hasComponent """غياب المراجع والأعلام الواضحة"""@ar ;
    hesin:hasComponent """المكتبات المملوءة بكتب الآخرين (99%)"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_14 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C065 a hesin:Concept ;
    rdfs:label """وسائل التضليل العصرية"""@ar ;
    hesin:definition """وسائل التأثير التي تتعرض لها الأمة من خارجها (إعلام، صحافة، ثقافة، مناهج) دون أن يكون لها منافذ خاصة بها."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """الصوت الذي نسمعه ليس منا، الصوت أو الموقف الذي نراه أيضاً ليس من داخلنا، الصحيفة التي نقرأها ليست من داخلنا، ليس لنا أعلام واضحة، ليس لنا هداة نلتزم بهم"""@ar ;
    hesin:actions """رصد مصادر المعلومات التي يتعرض لها الفرد دون اختيار."""@ar ;
    hesin:hasSynonym """الإعلام المضل"""@ar ;
    hesin:hasSynonym """الثقافة المستوردة"""@ar ;
    hesin:hasComponent """وسائل مسموعة (إذاعات، أشرطة)"""@ar ;
    hesin:hasComponent """وسائل مرئية (تلفزيون، لافتات)"""@ar ;
    hesin:hasComponent """وسائل مقروءة (صحف، كتب)"""@ar ;
    hesin:hasComponent """مناهج دراسية"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_14 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C066 a hesin:Concept ;
    rdfs:label """التضليل الإجباري"""@ar ;
    hesin:definition """حالة يتعرض فيها الإنسان للمعلومات المضللة دون إرادته أو اختياره، مما يجعله عرضة للضلال دون أن يشعر."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """تسمع حتى على غير إرادة منك وتشاهد رغماً عنك، تسمع رغماً عنك، وتشاهد رغماً عنك... حتى يصبح الإنسان يتعرض لبعض الأشياء رغماً عنه فيضل رغماً عنه"""@ar ;
    hesin:actions """في النظام: يُعتبر التعرض للمعلومة دون اختيار مؤشرًا لخطر التضليل."""@ar ;
    hesin:hasSynonym """التعرض للضلال رغماً عن الإنسان"""@ar ;
    hesin:hasComponent """التعرض للميكرفونات في المساجد والأسواق"""@ar ;
    hesin:hasComponent """سماع الأشرطة من السيارات المارة"""@ar ;
    hesin:hasComponent """رؤية اللوحات والصحف الملقاة"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_14 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C067 a hesin:Concept ;
    rdfs:label """القرآن كقناة وحيدة للهداية في زمن الفتن"""@ar ;
    hesin:definition """في زمن الفتن الشديدة، لا مخرج إلا بالتمسك بالقرآن كمصدر وحيد للهداية والمعرفة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أثناء الفتن وعند تراكم الفتن هذه التي كقطع الليل المظلم... قال رسول الله (صلوات الله عليه وعلى آله): ((كتاب الله فيه نبأ ما قبلكم، وخبر ما بعدكم))"""@ar ;
    hesin:actions """في النظام: أي تحليل للواقع في زمن الفتن يجب أن ينطلق من القرآن."""@ar ;
    hesin:hasSynonym """المخرج من الفتن"""@ar ;
    hesin:hasSynonym """الحبل المتين"""@ar ;
    hesin:hasComponent """فيه نبأ ما قبلكم (عبرة)"""@ar ;
    hesin:hasComponent """فيه خبر ما بعدكم (بصيرة)"""@ar ;
    hesin:hasComponent """فيه حكم ما بينكم (فصل)"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_15 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C068 a hesin:Concept ;
    rdfs:label """خصائص القرآن"""@ar ;
    hesin:definition """مجموعة الصفات التي تجعل القرآن المرجعية المطلقة في الهداية، منها ثباته رغم اختلاف الألسن، وعجائبه التي لا تنقضي، وكونه حبل الله المتين."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """((وهو حبل الله المتين، وهو الذكر الحكيم، وهو الصراط المستقيم، هو الذي لا تزيغ به الأهواء، ولا تلتبس به الألسن ولا يشبع منه العلماء... لا يخلق على كثرة الرد، ولا تنقضي عجائبه))"""@ar ;
    hesin:actions """في النظام: أي تحليل يعتمد على غير القرآن في زمن الفتن يُعتبر منحرفًا."""@ar ;
    hesin:hasSynonym """صفات القرآن"""@ar ;
    hesin:hasSynonym """كمال القرآن"""@ar ;
    hesin:hasComponent """حبل الله المتين"""@ar ;
    hesin:hasComponent """الذكر الحكيم"""@ar ;
    hesin:hasComponent """الصراط المستقيم"""@ar ;
    hesin:hasComponent """لا تزيغ به الأهواء"""@ar ;
    hesin:hasComponent """لا يشبع منه العلماء"""@ar ;
    hesin:hasComponent """لا يخلق على كثرة الرد"""@ar ;
    hesin:hasComponent """لا تنقضي عجائبه"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_15 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C069 a hesin:Concept ;
    rdfs:label """التثقف عبر قناة واحدة أولاً"""@ar ;
    hesin:definition """منهجية في التعامل مع كثرة المعلومات في العصر الحديث: أن يبدأ الإنسان بتثبيت معارفه من قناة واحدة (القرآن) قبل الانفتاح على مصادر أخرى."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """سيكون هذا مفيداً متى ما بدأت تمشي في طريق واحدة وتثقف نفسك أولاً من قناة واحدة فتصبح لديك ثوابت صحيحة، يصبح لديك رؤية صحيحة مقاييس صحيحة، معايير صحيحة"""@ar ;
    hesin:actions """في النظام: أي عملية تعلم يجب أن تبدأ بتأسيس معايير ثابتة قبل الانفتاح على التنوع."""@ar ;
    hesin:hasSynonym """ترسيخ الثوابت"""@ar ;
    hesin:hasSynonym """التحصين المسبق"""@ar ;
    hesin:hasComponent """البدء بقناة واحدة (القرآن)"""@ar ;
    hesin:hasComponent """ترسيخ الثوابت والمعايير"""@ar ;
    hesin:hasComponent """ثم الانفتاح على المصادر الأخرى لاكتساب الخبرة"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_15 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C070 a hesin:Concept ;
    rdfs:label """التحذير من طلب الهدى من غير القرآن"""@ar ;
    hesin:definition """تحذير إلهي ونبوي من أن البحث عن الهداية في مصادر غير القرآن (حتى مع حسن النية) يؤدي إلى الضلال."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """((ومن ابتغى الهدى من غيره أضله الله))... حتى من يشعر بحاجة إلى الهدى متى ما انطلق ليهتدي من هنا أو من هناك سيضل"""@ar ;
    hesin:actions """في النظام: أي مصدر يُقدم كبديل للقرآن في الهداية يُصنف كمصدر مضل."""@ar ;
    hesin:hasSynonym """ابتغاء الهدى من غيره"""@ar ;
    hesin:hasSynonym """الضلال بالبحث"""@ar ;
    hesin:hasComponent """طلب الهدى (حتى مع وجود حاجة)"""@ar ;
    hesin:hasComponent """المصادر البديلة (كتب، أشخاص، مدارس)"""@ar ;
    hesin:hasComponent """النتيجة: يضله الله"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_15 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C071 a hesin:Concept ;
    rdfs:label """الولاية كعلاقة هداية وتربية"""@ar ;
    hesin:definition """العلاقة مع ولي الأمر (الله، الرسول، الإمام) هي علاقة هداية وتربية وبناء للنفس، وليست مجرد علاقة سلطة وأوامر."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """يجب أن نفهم كيف يجب أن تكون العلاقة، وكيف هي العلاقة فعلاً من وجهة نظر القرآن... ليست العلاقة بيننا وبين الله... ولا بيننا وبين رسوله... على نمط العلاقة بيننا وبين الرئيس أو الملك أو الزعيم الفلاني"""@ar ;
    hesin:actions """في النظام: أي تحليل للولاية يجب أن يركز على دورها التربوي قبل السياسي."""@ar ;
    hesin:hasSynonym """ولي الأمر"""@ar ;
    hesin:hasSynonym """ولاية الهداية"""@ar ;
    hesin:hasComponent """تسليم النفس للتربية والبناء"""@ar ;
    hesin:hasComponent """التلقي المستمر للتوجيهات"""@ar ;
    hesin:hasComponent """الاهتمام بشؤون النفس وزكاتها"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_16 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C072 a hesin:Concept ;
    rdfs:label """النبي أولى بالمؤمنين من أنفسهم"""@ar ;
    hesin:definition """مفهوم مفاده أن النبي (ص) له الأولوية في تربية المؤمنين وبناء نفوسهم، لأن الإنسان لا يستطيع بمفرده أن يجعل من نفسه الإنسان الصالح."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{النَّبِيُّ أَوْلَى بِالْمُؤْمِنِينَ مِنْ أَنْفُسِهِمْ}... ماذا تعني؟... أنه هو الذي يتولى بنائها... يبني نفسك يثقفها ينورها"""@ar ;
    hesin:actions """في النظام: أي منهج تربوي يجب أن يمر عبر تعاليم النبي."""@ar ;
    hesin:hasSynonym """ولاية النبي التربوية"""@ar ;
    hesin:hasComponent """تعليم الكتاب والحكمة"""@ar ;
    hesin:hasComponent """تزكية النفوس"""@ar ;
    hesin:hasComponent """إخراج من الظلمات إلى النور"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_16 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C073 a hesin:Concept ;
    rdfs:label """ولاية الإمام علي كولاية هداية"""@ar ;
    hesin:definition """ولاية الإمام علي (ع) لا تقتصر على الجانب السياسي، بل تشمل تربية النفوس وتزكيتها وبناء الأمة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """الإمام علي عليه السلام ولايتنا لـه ننظر إليه كولي أمرنا.. ما هو أمرنا؟ مهامنا في الحياة، مهامنا ونحن نربي أنفسنا ونرشدها لنزكيها"""@ar ;
    hesin:actions """في النظام: يُعتبر الإمام علي نموذجًا للقائد المربي."""@ar ;
    hesin:hasSynonym """ولاية علي التربوية"""@ar ;
    hesin:hasComponent """ولاية هدى واقتداء"""@ar ;
    hesin:hasComponent """ولاية طاعة وأمر"""@ar ;
    hesin:hasComponent """تسليم النفس للتربية"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_16 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C074 a hesin:Concept ;
    rdfs:label """القيادة الموحدة"""@ar ;
    hesin:definition """مبدأ ضرورة وحدة القيادة في الأمة، وعدم تعدد ولاة الأمر، كما أقر به عمر نفسه في سياق مختلف."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """عمر نفسه رفض عندما قال الأنصار: [منا أمير ومنكم أمير]. قال: لا. وأنت تريد أن تضيف عمر وهو يرفض من حيث المبدأ ما تريد أن تعمله له"""@ar ;
    hesin:actions """يُستخدم في تحليل النظم السياسية وتعدد المرجعيات."""@ar ;
    hesin:hasSynonym """لا يجتمع سيفان في غمد"""@ar ;
    hesin:hasComponent """قائد واحد للأمة"""@ar ;
    hesin:hasComponent """رفض تعدد المرجعيات"""@ar ;
    hesin:hasComponent """الحاجة إلى سلطة موحدة"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_16 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C075 a hesin:Concept ;
    rdfs:label """التفريق بين ولاية المؤمنين العامة وولاية الهداية"""@ar ;
    hesin:definition """التمييز بين نوعين من الولاية: (1) ولاية المؤمنين العامة (تآخٍ، تعاون، موقف واحد)، و(2) ولاية الهداية الخاصة (تلقّي التوجيهات من قائد)."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هذه تختلف عن الولاية فيما بين المؤمنين أنفسهم {وَالْمُؤْمِنُونَ وَالْمُؤْمِنَاتُ بَعْضُهُمْ أَوْلِيَاءُ بَعْضٍ}... لكن هنا يرشد إلى جانب الجهة التي تتولاها لتتلقى منها الهداية"""@ar ;
    hesin:actions """في النظام: يُصنف مفهوم الولاية حسب السياق."""@ar ;
    hesin:hasSynonym """ولاية التآخي مقابل ولاية القيادة"""@ar ;
    hesin:hasComponent """الولاية العامة: أخوة، تعاون، تكافل"""@ar ;
    hesin:hasComponent """ولاية الهداية: قيادة، طاعة، تلقّي"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_16 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C076 a hesin:Concept ;
    rdfs:label """العلاقة مع الله ليست كعلاقة مع الرئيس"""@ar ;
    hesin:definition """نقد لفهم العلاقة مع الله والرسول والأئمة على نمط العلاقة مع الزعماء البشريين، وهو فهم أدى إلى إضعاف المسؤولية."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """انحططنا بشكل رهيب، أضعنا مسئوليتنا فلم نعد نعرف ما هي العلاقة بيننا وبين الله فنرى كم هي متشعبة، ثم نرى كم هي واسعة"""@ar ;
    hesin:actions """في النظام: يُقيّم أي فهم للعلاقة مع الله ورسوله بمستوى هذه المعايير."""@ar ;
    hesin:hasSynonym """رفع مستوى العلاقة"""@ar ;
    hesin:hasComponent """العلاقة مع الله: أسمى وأرفع"""@ar ;
    hesin:hasComponent """العلاقة مع النبي: هداية وتربية"""@ar ;
    hesin:hasComponent """العلاقة مع الإمام: ولاية أمر واسعة"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_16 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C077 a hesin:Concept ;
    rdfs:label """نقد التسامح مع أبي بكر وعمر"""@ar ;
    hesin:definition """نقد لمحاولات التوفيق بين ولاية علي وولاية من خالفوه، مع التأكيد على أن ذلك ليس تسامحًا بل تضليل."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """يبدو بعض الناس يتساءل [أنه لماذا ولاية علي عليه السلام بالذات ممكن أن نتولى علياً و أبا بكر وعمر وعثمان والكل ونرضى عليهم جميعاً]"""@ar ;
    hesin:actions """في النظام: أي محاولة للتوفيق بين الحق والباطل تُصنف كتضليل."""@ar ;
    hesin:hasSynonym """رفض المجاملة"""@ar ;
    hesin:hasSynonym """كشف الحقائق"""@ar ;
    hesin:hasComponent """رفض الجمع بين المتضادين"""@ar ;
    hesin:hasComponent """التأكيد على أن هذا ليس من منطق القرآن"""@ar ;
    hesin:hasComponent """الحاجة إلى كشف الحقائق ولو جرحت المشاعر"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_17 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C078 a hesin:Concept ;
    rdfs:label """عدم التسامح مع من حرفوا الدين"""@ar ;
    hesin:definition """موقف يرفض التسامح مع من تسببوا في انحراف الأمة بحجة الوحدة أو مراعاة المشاعر، ويؤكد على ضرورة كشف الحقائق."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """ليس عصر مجاملة، ليس عصر مداهنة، ليس زمن تغطية وتلبيس، زمن يجب أن تكشف فيه الحقائق على أرقى مستوى"""@ar ;
    hesin:actions """في النظام: يُقيّم أي نص من خلال مدى صراحته في كشف الحقائق."""@ar ;
    hesin:hasSynonym """شدة القرآن"""@ar ;
    hesin:hasSynonym """رفض المداهنة"""@ar ;
    hesin:hasComponent """رفض التغطية والتلبيس"""@ar ;
    hesin:hasComponent """كشف الحقائق مهما كانت قاسية"""@ar ;
    hesin:hasComponent """تحديد المسؤول عن جراح الأمة"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_17 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C079 a hesin:Concept ;
    rdfs:label """رفع الصوت فوق صوت النبي"""@ar ;
    hesin:definition """تحذير قرآني شديد من رفع الصوت فوق صوت النبي، مع بيان أن ذلك قد يؤدي إلى حبوط الأعمال دون شعور."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{يَا أَيُّهَا الَّذِينَ آمَنُوا لا تَرْفَعُوا أَصْوَاتَكُمْ فَوْقَ صَوْتِ النَّبِيِّ}... {أَنْ تَحْبَطَ أَعْمَالُكُمْ وَأَنْتُمْ لا تَشْعُرُونَ}"""@ar ;
    hesin:actions """يُستخدم كمؤشر لقياس مدى احترام النبي."""@ar ;
    hesin:hasSynonym """سوء الأدب مع النبي"""@ar ;
    hesin:hasComponent """عدم إجلال النبي بالشكل الكافي"""@ar ;
    hesin:hasComponent """سهولة مخالفته بعد ذلك"""@ar ;
    hesin:hasComponent """حبوط الأعمال"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_17 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C080 a hesin:Concept ;
    rdfs:label """معارضة كتابة الوصية كدليل على عدم الاهتمام بالأمة"""@ar ;
    hesin:definition """تحليل لحادثة منع عمر كتابة الوصية، واستخلاص أنها تكشف عن عدم اهتمامه الحقيقي بمصلحة الأمة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """ألم يسمع أن الرسول (صلوات الله عليه وعلى آله) يقول عن الكتاب (لا تضلوا من بعده)؟... يحول بين الرسول (صلوات الله عليه وعلى آله) وبين كتابة هذا الكتاب... يكشف لنا هنا نفسية عمر أنه إنسان لا يهمه أمر الأمة"""@ar ;
    hesin:actions """يُستخدم كدليل تاريخي في تحليل الشخصيات."""@ar ;
    hesin:hasSynonym """موقف عمر في مرض النبي"""@ar ;
    hesin:hasComponent """الرسول يريد كتابة كتاب يمنع الضلال"""@ar ;
    hesin:hasComponent """عمر يعارض ويثير الضجة"""@ar ;
    hesin:hasComponent """التبرير: حسبنا كتاب الله"""@ar ;
    hesin:hasComponent """الدلالة: عدم الاهتمام بالأمة"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_17 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C081 a hesin:Concept ;
    rdfs:label """حبوط الأعمال بسبب مخالفة النبي"""@ar ;
    hesin:definition """عقوبة إلهية على من يخالف أدب التعامل مع النبي، حيث تُحبط أعمالهم الصالحة دون أن يشعروا."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{أَنْ تَحْبَطَ أَعْمَالُكُمْ} سنحبط أعمالكم. ماذا وراء إحباط الأعمال ماذا؟ أليس وراءها جهنم"""@ar ;
    hesin:actions """يُستخدم كتحذير من الفصل بين الظاهر والباطن."""@ar ;
    hesin:hasSynonym """إحباط الأعمال"""@ar ;
    hesin:hasSynonym """خسارة الأعمال الصالحة"""@ar ;
    hesin:hasComponent """أعمال صالحة ظاهريًا"""@ar ;
    hesin:hasComponent """مخالفة لأدب النبي"""@ar ;
    hesin:hasComponent """حبوط دون شعور"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_17 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C082 a hesin:Concept ;
    rdfs:label """من سبق بالإيمان vs من سبق بالمخالفة"""@ar ;
    hesin:definition """تمييز بين الصحابة الذين سبقوا بالإيمان (فعليًا) والذين سبقوا بالمخالفة، وتحديد أن آية الاستغفار (الحشر:10) تشمل الأولين فقط."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """من سبقونا إلى مخالفة النبي والضرب بجهوده عرض الحائط وضرب أمته، هل هذا هو الذي نستغفر له؟ هل سبقنا بإيمان أم سبقنا بمخالفة؟"""@ar ;
    hesin:actions """في النظام: يُصنف الصحابة وفق معايير الإيمان الحقيقي."""@ar ;
    hesin:hasSynonym """التفريق بين الصحابة"""@ar ;
    hesin:hasComponent """السبق بالإيمان: يستحق الاستغفار"""@ar ;
    hesin:hasComponent """السبق بالمخالفة: لا يستحق"""@ar ;
    hesin:hasComponent """الإيمان الحقيقي: ولاية علي"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_17 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C083 a hesin:Concept ;
    rdfs:label """مسؤولية الزيدية"""@ar ;
    hesin:definition """مسؤولية خاصة تقع على عاتق الزيدية لأنهم يدّعون أنهم يحملون الحق الصافي، مما يوجب عليهم العمل لإعلائه ونشره."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """المسئولية على الزيدية تبدوا أكبر من المسئولية على أي طائفة أخرى؛ لأننا - في نفس الوقت - نقول: نحن أهل الحق، ونحن من بين أيدينا مبادئ الإسلام وقيمه بشكل صافٍ ونقي"""@ar ;
    hesin:actions """في النظام: أي طائفة تدعي الحق تُقيّم بمدى تحملها للمسؤولية."""@ar ;
    hesin:hasSynonym """حمل راية الحق"""@ar ;
    hesin:hasComponent """ادعاء حمل الحق"""@ar ;
    hesin:hasComponent """نقاء المبادئ"""@ar ;
    hesin:hasComponent """وجوب إعلاء كلمة الحق"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_18 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C084 a hesin:Concept ;
    rdfs:label """الملل وضيق الأفق"""@ar ;
    hesin:definition """حالة من الضجر وعدم الرغبة في الاستمرار في تلقي المعرفة، خاصة في ما يتعلق بأساسيات الدين والإمامة."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """متى ما تحدث أحدنا عن الإمام علي بن أبي طالب (عليه السلام) مرتين أو ثلاث قلنا [يكفي، يكفي]... ملل وضيق أفق"""@ar ;
    hesin:actions """رصد حالات "يكفي" كمؤشر على ضعف الوعي."""@ar ;
    hesin:hasSynonym """عدم الرغبة في التعلم"""@ar ;
    hesin:hasSynonym """التوقف عن التلقي"""@ar ;
    hesin:hasComponent """التوقف عن التعلم بعد مرات قليلة"""@ar ;
    hesin:hasComponent """قول "يكفي" للمتحدث"""@ar ;
    hesin:hasComponent """ضيق الأفق عن استيعاب المزيد"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_18 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C085 a hesin:Concept ;
    rdfs:label """ضرورة الوعي والفهم"""@ar ;
    hesin:definition """دعوة إلى الوعي والفهم المتزايد كوسيلة للنجاة من عقوبة الله في الدنيا والآخرة."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """إذاً فلنعي ولنفهم ولنحاول أن نسمع أكثر... حتى لا نبوأ بغضب من الله، حتى لا نتعرض لعقوبة الله في الدنيا قبل الآخرة"""@ar ;
    hesin:actions """في النظام: أي عملية تعلم يجب أن تستمر دون توقف."""@ar ;
    hesin:hasSynonym """الانتباه"""@ar ;
    hesin:hasSynonym """الفهم"""@ar ;
    hesin:hasComponent """الاستماع أكثر"""@ar ;
    hesin:hasComponent """عدم الملل"""@ar ;
    hesin:hasComponent """تحمل المسؤولية"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_18 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C086 a hesin:Concept ;
    rdfs:label """التسامح مع الله"""@ar ;
    hesin:definition """رفض فكرة أن يكون الإنسان "أكثر تسامحًا من الله" في التعامل مع من خالفوا أمره وظلموا الأمة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """كيف تريد أن تتسامح مع أشخاص هم ضربوا هذه الأمة؟. بل لا مخرج لهذه الأمة إلا عندما تصحح وقفتها معهم ونظرتها إليهم من جديد"""@ar ;
    hesin:actions """أي موقف يتسامح مع الظالمين يُقيَّم بمدى مطابقته لموقف الله."""@ar ;
    hesin:hasSynonym """رفض المجاملة الإلهية"""@ar ;
    hesin:hasComponent """الله هو أرحم الراحمين"""@ar ;
    hesin:hasComponent """الله يلعن الكافرين والظالمين"""@ar ;
    hesin:hasComponent """التسامح الزائد هو تجنٍّ على حكمة الله"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_19 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C087 a hesin:Concept ;
    rdfs:label """لا مجال للمجاملة في الدين"""@ar ;
    hesin:definition """في القضايا المصيرية للأمة، لا مجال للمجاملة أو المداهنة، بل يجب كشف الحقائق بكل وضوح."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """ليس عصر مجاملة، ليس عصر مداهنة، ليس زمن تغطية وتلبيس، زمن يجب أن تكشف فيه الحقائق على أرقى مستوى"""@ar ;
    hesin:actions """في النظام: أي نص يتجنب كشف الحقائق بسبب المشاعر يُصنف كمداهنة."""@ar ;
    hesin:hasSynonym """الشدة في مواقف الدين"""@ar ;
    hesin:hasComponent """كشف الحقائق مهما كانت قاسية"""@ar ;
    hesin:hasComponent """تحديد المسؤول عن الجراح"""@ar ;
    hesin:hasComponent """عدم التغطية والتلبيس"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_19 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C088 a hesin:Concept ;
    rdfs:label """أسلوب القرآن في معالجة المخالفين"""@ar ;
    hesin:definition """المنهج القرآني في التعامل مع المخالفين: شدة في مواقف الحق، لعن للظالمين، تحذير من حبوط الأعمال."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """الله الذي يسمي نفسه بأنه أرحم الراحمين، رحيم بعباده يلعن هذا، وسيحبط عمل هذا، ويضرب هذا"""@ar ;
    hesin:actions """في النظام: أي تحليل لموقف ديني يجب أن يُقيَّم بمدى مطابقته لأسلوب القرآن."""@ar ;
    hesin:hasSynonym """منطق القرآن"""@ar ;
    hesin:hasSynonym """شدة القرآن"""@ar ;
    hesin:hasComponent """لعن الكافرين والفاسقين والظالمين"""@ar ;
    hesin:hasComponent """حبوط أعمال المخالفين"""@ar ;
    hesin:hasComponent """تحذيرات شديدة اللهجة"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_19 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C089 a hesin:Concept ;
    rdfs:label """موقف فاطمة الزهراء من أبي بكر وعمر"""@ar ;
    hesin:definition """موقف تاريخي لفاطمة الزهراء (ع) يعكس رفضها لأبي بكر وعمر، وهو دليل على أن التشدد في موقفهم ليس بدعة بل هو من نهج أهل البيت."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """هو منطق فاطمة الزهراء عليها السلام التي أوصت أن لا يحضر جنازتها ولا الصلاة عليها أبو بكر ولا عمر، حتى خرج الإمام علي عليه السلام مع عمار ومجموعة خاصة من أوليائه ليدفنوها في الليل"""@ar ;
    hesin:actions """يُستخدم كدليل تاريخي على موقف أهل البيت."""@ar ;
    hesin:hasSynonym """وصية فاطمة"""@ar ;
    hesin:hasSynonym """دفنها ليلاً"""@ar ;
    hesin:hasComponent """وصية بعدم حضورهم جنازتها"""@ar ;
    hesin:hasComponent """دفنها ليلاً مع خاصة أوليائها"""@ar ;
    hesin:hasComponent """عمل عدة قبور لإخفاء قبرها"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_19 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C090 a hesin:Concept ;
    rdfs:label """مسؤولية أبي بكر وعمر عن انحراف الأمة"""@ar ;
    hesin:definition """نظرية تاريخية ترى أن أبا بكر وعمر هما المسؤولان الأولان عن ظلم أهل البيت وانحراف الأمة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """يُظلم أول من يُظلم أهل بيته: علي وفاطمة والإمام الحسن والإمام الحسين أول من ظلم في هذه الأمة، على يد من حصل هذا؟ على يد أبي بكر وعمر"""@ar ;
    hesin:actions """يُستخدم في التحليل التاريخي لانحراف الأمة."""@ar ;
    hesin:hasSynonym """سبب الانحراف"""@ar ;
    hesin:hasSynonym """الجذور التاريخية"""@ar ;
    hesin:hasComponent """ظلم أهل البيت (علي، فاطمة، الحسن، الحسين)"""@ar ;
    hesin:hasComponent """وصول معاوية ويزيد إلى الحكم"""@ar ;
    hesin:hasComponent """انحراف الخلافة عن المسار الإلهي"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_20 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C091 a hesin:Concept ;
    rdfs:label """صعود معاوية إلى الحكم"""@ar ;
    hesin:definition """تحليل لوصول معاوية ويزيد إلى الحكم كنتيجة طبيعية لانحراف الخلافة عن مسارها الإلهي بفعل أبي بكر وعمر."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """يصل معاوية إلى حكم الأمة، ويصل يزيد إلى حكم الأمة، ويصل من كانوا يسبحون في أحواض الخمر فيشرب حتى الثمَالة وهو أمير المؤمنين، على يد من حصل هذا؟ وبسبب من حصل هذا؟"""@ar ;
    hesin:actions """يُستخدم في تحليل أسباب الانحراف التاريخي."""@ar ;
    hesin:hasSynonym """تمكين معاوية"""@ar ;
    hesin:hasSynonym """نتيجة الانحراف"""@ar ;
    hesin:hasComponent """معاوية في الشام"""@ar ;
    hesin:hasComponent """يزيد الخليفة"""@ar ;
    hesin:hasComponent """شرب الخمر في الخلافة"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_20 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C092 a hesin:Concept ;
    rdfs:label """التمييز بين ولاية علي وولاية غيره"""@ar ;
    hesin:definition """التأكيد على أن ولاية الإمام علي تختلف عن ولاية أي شخص آخر، حتى عن عمار بن ياسر الذي هو من كبار الصحابة."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أليس عمار بن ياسر... يتولى الإمام علي عليه السلام كما نتولاه نحن؟ بل أعظم مما نتولاه نحن... إذاً فكيف تريد مني أن أمنح هذه الولاية التي لم أمنحها لعمار أن أمنحها لمن خالف الرسول فيها"""@ar ;
    hesin:actions """في النظام: يُصنف الصحابة حسب موقعهم من ولاية علي."""@ar ;
    hesin:hasSynonym """ولاية الهداية الخاصة"""@ar ;
    hesin:hasComponent """عمار يتولى عليًا (لا العكس)"""@ar ;
    hesin:hasComponent """ولاية علي هي ولاية هداية خاصة"""@ar ;
    hesin:hasComponent """غيره من الصحابة ليسوا في هذا المقام"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_21 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C093 a hesin:Concept ;
    rdfs:label """عمار بن ياسر كنموذج للصحابي المخلص"""@ar ;
    hesin:definition """تقديم عمار بن ياسر كنموذج للصحابي المخلص الذي يتولى الإمام علي ويعد نفسه جنديًا من جنوده."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """عمار من السابقين في الإسلام، وهو من قال فيه الرسول (صلوات الله عليه وعلى آله) ((أنه ملأ إيماناً من قمة رأسه إلى أخمص قدميه))"""@ar ;
    hesin:actions """يُستخدم كنموذج لقياس ولاء الصحابة."""@ar ;
    hesin:hasSynonym """ملء إيمانًا"""@ar ;
    hesin:hasComponent """السبق في الإسلام"""@ar ;
    hesin:hasComponent """ملء الإيمان"""@ar ;
    hesin:hasComponent """ولاية الإمام علي"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_21 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C094 a hesin:Concept ;
    rdfs:label """اتخاذ الدين هزؤاً ولعباً"""@ar ;
    hesin:definition """تحذير من اتخاذ أولياء من الذين يسخرون من الدين ويتخذونه هزؤًا ولعبًا، وهم من أهل الكتاب والكفار."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{يَا أَيُّهَا الَّذِينَ آمَنُوا لا تَتَّخِذُوا الَّذِينَ اتَّخَذُوا دِينَكُمْ هُزُواً وَلَعِباً مِنَ الَّذِينَ أُوتُوا الْكِتَابَ مِنْ قَبْلِكُمْ وَالْكُفَّارَ أَوْلِيَاءَ}"""@ar ;
    hesin:actions """رصد وسائل الإعلام التي تسخر من الإسلام."""@ar ;
    hesin:hasSynonym """الاستهزاء بالدين"""@ar ;
    hesin:hasSynonym """السخرية"""@ar ;
    hesin:hasComponent """الاستهزاء بالدين"""@ar ;
    hesin:hasComponent """السخرية من الشعائر (كالأذان)"""@ar ;
    hesin:hasComponent """خطورة موالاتهم"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_22 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C095 a hesin:Concept ;
    rdfs:label """الغضب للدين"""@ar ;
    hesin:definition """صفة المؤمن الحقيقي أن يغضب لله ولدينه ولأعلام الدين عندما يُستهان بها أو يُسخر منها."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """من الذي يغضب لدين الله؟ هم القليل، من الذي يؤلمه أن يجد من يسخر من دين الله من يسخر من أعلام دين الله؟"""@ar ;
    hesin:actions """يُستخدم لقياس درجة الإيمان."""@ar ;
    hesin:hasSynonym """الغيرة على الدين"""@ar ;
    hesin:hasComponent """الغضب لله"""@ar ;
    hesin:hasComponent """الغضب لأعلام الدين"""@ar ;
    hesin:hasComponent """الألم من السخرية بالدين"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_22 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C096 a hesin:Concept ;
    rdfs:label """الاستهزاء بالصلاة"""@ar ;
    hesin:definition """وصف قرآني لأهل الكتاب والكفار بأنهم يسخرون من نداء الصلاة، مما يدل على عدم عقلهم."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{وَإِذَا نَادَيْتُمْ إِلَى الصَّلاةِ اتَّخَذُوهَا هُزُواً وَلَعِباً ذَلِكَ بِأَنَّهُمْ قَوْمٌ لا يَعْقِلُونَ}"""@ar ;
    hesin:actions """رصد السلوكيات التي تسخر من الصلاة."""@ar ;
    hesin:hasSynonym """السخرية من الشعائر"""@ar ;
    hesin:hasComponent """السخرية من الأذان"""@ar ;
    hesin:hasComponent """الاستهزاء بالمصلين"""@ar ;
    hesin:hasComponent """دلالة على عدم العقل"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_22 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C097 a hesin:Concept ;
    rdfs:label """خطورة الكفر الخفي"""@ar ;
    hesin:definition """أن الخطر الحقيقي ليس هو الكفر الصريح، بل الكفر الخفي الذي يحدث في أعماق النفس دون تصريح."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لو كانت على هذا النحو أنه فقط الخطورة هي أن تصل إلى درجة التصريح... لما كان هناك ما يوجب أن يأتي بمعشار ما أتى من آيات عن بني إسرائيل"""@ar ;
    hesin:actions """في النظام: يُعتبر التحول الباطني أخطر من التصريح."""@ar ;
    hesin:hasSynonym """الكفر بدون تصريح"""@ar ;
    hesin:hasComponent """عدم التصريح بالكفر"""@ar ;
    hesin:hasComponent """تحول الباطن مع بقاء الظاهر"""@ar ;
    hesin:hasComponent """خطورة عدم الشعور به"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_23 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C098 a hesin:Concept ;
    rdfs:label """عبودية الشيطان بدون شعور"""@ar ;
    hesin:definition """أن كثيرًا من الناس يعبدون الشيطان دون أن يشعروا، لأن العبادة ليست مجرد سجود بل هي طاعة واتباع."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{أَلَمْ أَعْهَدْ إِلَيْكُمْ يَا بَنِي آدَمَ أَنْ لا تَعْبُدُوا الشَّيْطَانَ}... عبدوه عبادة"""@ar ;
    hesin:actions """أي تحليل للسلوك يجب أن يبحث عن الطاعة للشيطان وإن لم تكن ظاهرة."""@ar ;
    hesin:hasSynonym """عبودية خفية"""@ar ;
    hesin:hasComponent """العبادة = طاعة واتباع"""@ar ;
    hesin:hasComponent """الشيطان يُطاع دون شعور"""@ar ;
    hesin:hasComponent """غالبية الناس (95%) يعبدونه"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_23 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C099 a hesin:Concept ;
    rdfs:label """عدم الشعور بالحبوط"""@ar ;
    hesin:definition """أن الإنسان قد تُحبط أعماله الصالحة دون أن يشعر بذلك، فيظن أنه على خير وهو في الواقع خاسر."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """{أَنْ تَحْبَطَ أَعْمَالُكُمْ وَأَنْتُمْ لا تَشْعُرُونَ}... يضرب هذا ويحبط أعماله وهو لا يشعر"""@ar ;
    hesin:actions """يُستخدم كتحذير من الثقة الزائدة بالأعمال الظاهرية."""@ar ;
    hesin:hasSynonym """حبوط الأعمال الخفي"""@ar ;
    hesin:hasComponent """أعمال صالحة ظاهرية"""@ar ;
    hesin:hasComponent """حبوط دون شعور"""@ar ;
    hesin:hasComponent """استمرار الظن بالخير"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_23 ;
    hesin:belongsToLesson hesin:F6_Lesson .
hesin:F6_C100 a hesin:Concept ;
    rdfs:label """التأمين مما لم يأمن منه النبي"""@ar ;
    hesin:definition """نقد لمن يتسامح مع مخالفي النبي، وكأنه يمنحهم أمانًا مما لم يؤمن منه النبي نفسه (عذاب الله)."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """تريد أن تمنحه ما لم يمُنح لمحمد من قِبَل الله (صلوات الله عليه وعلى آله)؟ فتؤمّنه مما لم يأمن منه محمد (صلوات الله عليه وعلى آله) إن عصى ربه؟!!"""@ar ;
    hesin:actions """أي تسامح مع مخالفي أمر الله يُقيَّم بمدى مطابقته لموقف النبي."""@ar ;
    hesin:hasSynonym """جرأة على الله"""@ar ;
    hesin:hasSynonym """تجنٍّ على حكمة الله"""@ar ;
    hesin:hasComponent """النبي يخاف عذاب الله إن عصى"""@ar ;
    hesin:hasComponent """المتسامح يؤمن غيره من العذاب"""@ar ;
    hesin:hasComponent """هذا تجنٍّ على حكمة الله"""@ar ;
    hesin:belongsToGroup hesin:F6_Group_23 ;
    hesin:belongsToLesson hesin:F6_Lesson .
