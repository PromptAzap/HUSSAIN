    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C128 a hesin:Concept ;
    rdfs:label """حكام جاهلون"""@ar ;
    hesin:definition """حكام استغلوا الدين لتبرير سلطتهم، واتخذوا من العلماء المهادنين وسيلة لتدجين المجتمع."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """عندما ساد الناس أيضاً حكام جاهلون، همه أن يبحث عن العالم الذي يدجِّن المجتمع له دينياً، فيتوارث خليفة بعد خليفة، وملك بعد ملك، ورئيس بعد رئيس، على أكتاف هذه الأمة وهي تعيش في ضلام الجهل والتخلف"""@ar ;
    hesin:actions """نقد الاستغلال السياسي للدين."""@ar ;
    hesin:hasSynonym """السلاطين"""@ar ;
    hesin:hasSynonym """الطواغيت"""@ar ;
