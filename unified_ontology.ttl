hesin:F5_C021 a hesin:Concept ;
    rdfs:label """الولاء لله"""@ar ;
    hesin:definition """جعل الله وليًا للأمر، والاهتداء به، والاسترشاد به، والثقة به، والتوكل عليه."""@ar ;
    hesin:importance """رئيسي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """متى ما أصبحت من أوليائه أنك جعلته وليا لأمرك، لكل أمورك، تهتدي به، تسترشد به، تثق به، تتوكل عليه"""@ar ;
    hesin:actions """تحديد من هو المتولى (هل هو الله أم غيره) من خلال تحليل السلوك."""@ar ;
