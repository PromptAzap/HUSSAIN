hesin:F5_C030 a hesin:Concept ;
    rdfs:label """الخبث"""@ar ;
    hesin:definition """تراكم آثار المعاصي في النفس حتى تصبح صفة ملازمة، تجعل العودة إلى الطاعة صعبة."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """كل معصية ترسخ نسبة من الخبث في نفسك، وهكذا واحدة بعد واحدة حتى تحيط بك خطيئاتك، فتصبح خبيثا، تصبح خبيثا فعلا"""@ar ;
    hesin:actions """تحليل مسار تطور السلوك الخاطئ."""@ar ;
