hesin:F5_C023 a hesin:Concept ;
    rdfs:label """عدم الخوف من غير الله"""@ar ;
    hesin:definition """حالة من الطمأنينة والأمن تجعل المؤمن لا يخاف من أي مخلوق مهما بلغت قوته، لأنه يعلم أن النفع والضر بيد الله."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لو وثقنا بالله كما ينبغي لانطلق الناس لا يخشون أحداً إلا الله"""@ar ;
    hesin:actions """قياس مدى تأثر السلوك بالتهديدات البشرية."""@ar ;
