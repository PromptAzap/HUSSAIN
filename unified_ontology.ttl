    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C133 a hesin:Concept ;
    rdfs:label """العلمانيون"""@ar ;
    hesin:definition """تيار فكري ينكر دور الدين في الحياة، وينظر إلى التمسك بالدين كتخلف، وهو نتيجة للأخطاء الثقافية في تقديم الإسلام."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """أصبح في المجتمع الإسلامي علمانيون كثيرون، علمانيون يتنكرون للدين، ويسخرون حتى من المرأة عندما تلبس الحجاب الإسلامي ويرون فيه مظهراً للتخلف"""@ar ;
    hesin:actions """نقد العلمانية وبيان أسبابها."""@ar ;
