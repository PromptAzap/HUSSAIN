    hesin:definition """حالة الأمة الإسلامية الحالية من تفرق وضعف، نتيجة الانحراف عن المنهج القرآني."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """نرى أنفسنا أمة متفرقة ممزقة ونرى ما بين أيدينا من ركام الأقوال لا يقدم ولا يؤخر"""@ar ;
    hesin:actions """دراسة أسباب التفرق للعلاج."""@ar ;
