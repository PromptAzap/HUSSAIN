hesin:F5_C137 a hesin:Concept ;
    rdfs:label """التخلق بأخلاق الله"""@ar ;
    hesin:definition """أن يتصف المؤمن بصفات الله في حدود الطاقة البشرية، كالرحمة والحكمة والعدل، مما ينعكس على سلوكه في الحياة."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """ضمني"""@ar ;
    hesin:foundational_quote """لأن المؤمنين حينها سينطلقون ليتخلقوا بأخلاق الله سبحانه وتعالى سيكونون حريصين على أن يحافظوا على البيئة"""@ar ;
    hesin:actions """ربط المعرفة بالله بالسلوك الأخلاقي."""@ar ;
