hesin:F5_C015 a hesin:Concept ;
    rdfs:label """حكمة الله"""@ar ;
    hesin:definition """صفة إلهية تعني أن أفعال الله وأوامره صادرة عن علم وإتقان، وكلها خير وصلاح للعباد."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """كل توجيه من توجيهاته، كل إرشاد من إرشاداته، كل أمر من أوامره، كل نهي من نواهيه هو ينطلق بحكمة، ينطلق من الحكيم سبحانه وتعالى. والحكمة ما هي؟ وضع الشيء في موضعه"""@ar ;
    hesin:actions """استحضار حكمة الله عند مواجهة أوامر تبدو شاقة أو غير مفهومة."""@ar ;
