hesin:F7_Collection a hesin:Collection ;
    rdfs:label """سلسلة ملازم المدرسة"""@ar ;
    hesin:description """مجموعة من الدروس القرآنية في المنهج والوعي والمسؤولية والهوية الإيمانية، مستخلصة من سبعة دروس."""@ar .
hesin:F7_Lesson a hesin:Lesson ;
    rdfs:label ""@ar ;
    hesin:belongsToCollection hesin:F7_Collection .
hesin:F7_Group_1 a hesin:ConceptGroup ;
    rdfs:label """مجموعة الوعي والمسؤولية"""@ar ;
    hesin:belongsToLesson hesin:F7_Lesson .
hesin:F7_Group_2 a hesin:ConceptGroup ;
    rdfs:label """مجموعة تحليل المؤامرة والعدو"""@ar ;
    hesin:belongsToLesson hesin:F7_Lesson .
hesin:F7_Group_3 a hesin:ConceptGroup ;
    rdfs:label """مجموعة نقد التراث والمواقف"""@ar ;
    hesin:belongsToLesson hesin:F7_Lesson .
hesin:F7_Group_4 a hesin:ConceptGroup ;
    rdfs:label """مجموعة الأدوات والأفعال"""@ar ;
    hesin:belongsToLesson hesin:F7_Lesson .
hesin:F7_Group_5 a hesin:ConceptGroup ;
    rdfs:label """مجموعة المفاهيم التأسيسية والضدية"""@ar ;
    hesin:belongsToLesson hesin:F7_Lesson .
hesin:F7_Group_6 a hesin:ConceptGroup ;
    rdfs:label """مجموعة الهوية الإيمانية (بطاقة المؤمن)"""@ar ;
    hesin:belongsToLesson hesin:F7_Lesson .
hesin:F7_Group_7 a hesin:ConceptGroup ;
