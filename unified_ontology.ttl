    rdfs:label """الحسرات"""@ar ;
    hesin:definition """الندم الشديد الذي يصيب الإنسان يوم القيامة عندما يرى أعماله السيئة، ويتبرأ منه من كان يتبعهم."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
