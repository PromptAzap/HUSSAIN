    rdfs:label """المروءة والمعروف"""@ar ;
    hesin:definition """فطرة إنسانية تقتضي رد الجميل والوفاء لمن أحسن، وهي من المداخل لمعرفة الله واستشعار نعمه."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """لو لم يعطي حسنة واحدة لكان الإنسان يحكم من باب المروءة والمعروف بأنه يجب عليه أن يعطي أكثر مما سأله إلهه"""@ar ;
    hesin:actions """استخدام المروءة كمدخل لتربية الشكر."""@ar ;
    hesin:hasSynonym """الشهامة"""@ar ;
    hesin:hasSynonym """الوفاء بالجميل"""@ar ;
