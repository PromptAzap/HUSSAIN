hesin:F2_Collection a hesin:Collection ;
    rdfs:label """دروس آيات من آل عمران"""@ar ;
    hesin:description """تفسير موضوعي ومنهجي لآيات من سورة آل عمران (100-115) مع التركيز على تحليل خطر اتباع أهل الكتاب، وأهمية الاعتصام بالله، وضرورة وجود أعلام هدى (أهل البيت) بعد النبي، ونقد المفاهيم الخاطئة عن الدين، وتأسيس مفهوم الأمة للأمر بالمعروف والنهي عن المنكر، وسنة الاستبدال الإلهي."""@ar .
hesin:F2_Lesson a hesin:Lesson ;
    rdfs:label """سورة آل عمران (دروس من هدي القرآن الكريم)"""@ar ;
    hesin:belongsToCollection hesin:F2_Collection .
