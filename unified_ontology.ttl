    hesin:hasComponent """تدجين المجتمع"""@ar ;
    hesin:hasComponent """إبقاء الأمة في الجهل"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_21 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C129 a hesin:Concept ;
    rdfs:label """اليهود والنصارى (كأمم سبقت في الإنتاج)"""@ar ;
    hesin:definition """الأمم التي سبقت المسلمين في التفكر والإبداع الحضاري، واستغلت ذلك للهيمنة على العالم."""@ar ;
    hesin:importance """هامشي"""@ar ;
    hesin:confidence """واضح"""@ar ;
    hesin:foundational_quote """من هم سادة البحار الآن؟ اليهود والنصارى.. أليس كذلك؟ متى ما أردنا أن نشتري غواصة منهم بكم تكلف؟ ملايين"""@ar ;
    hesin:actions """الاستفادة من تقدمهم مع نقد استغلالهم."""@ar ;
    hesin:hasSynonym """الغربيون"""@ar ;
    hesin:hasSynonym """الأمم المتقدمة"""@ar ;
