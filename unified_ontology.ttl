    hesin:definition """المواجهة الفكرية والعملية مع أعداء الله (الطواغيت، المستكبرين، أعداء الدين) من خلال الجهاد باللسان واليد والمال."""@ar ;
    hesin:importance """فرعي"""@ar ;
    hesin:confidence """واضح"""@ar ;
