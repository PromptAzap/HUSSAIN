    hesin:hasComponent """وضع الأشياء في مواضعها"""@ar ;
    hesin:hasComponent """لا عبث في خلقه وتشريعه"""@ar ;
    hesin:hasComponent """كل ما يأمر به فيه صلاح العبد"""@ar ;
    hesin:belongsToGroup hesin:F5_Group_4 ;
    hesin:belongsToLesson hesin:F5_Lesson .
hesin:F5_C016 a hesin:Concept ;
    rdfs:label """علم الله المحيط"""@ar ;
    hesin:definition """إحاطة علم الله بكل شيء: الماضي والحاضر والمستقبل، الظاهر والخفي."""@ar ;
